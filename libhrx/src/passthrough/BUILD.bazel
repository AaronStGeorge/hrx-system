load("//libhrx/build_tools/bazel:cc.bzl", "hrx_cc_shared_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

PASSTHROUGH_INCLUDES = [
    "..",
]

hrx_cc_shared_library(
    name = "hip_intercept",
    srcs = ["hip_intercept.c"],
    hdrs = ["hip_function_table.h"],
    includes = PASSTHROUGH_INCLUDES,
    deps = [
        "//build_tools:dl",
        "//build_tools:pthreads",
    ],
)

hrx_cc_shared_library(
    name = "hip_logging",
    srcs = ["hip_logging.c"],
    hdrs = ["hip_function_table.h"],
    includes = PASSTHROUGH_INCLUDES,
    deps = ["//build_tools:pthreads"],
)

hrx_cc_shared_library(
    name = "hip_noop",
    srcs = ["interceptors/passthrough_interceptor.c"],
    hdrs = ["hip_function_table.h"],
    includes = PASSTHROUGH_INCLUDES,
)

hrx_cc_shared_library(
    name = "hip_buffer_tracer",
    srcs = ["hip_buffer_tracer.c"],
    hdrs = ["hip_function_table.h"],
    includes = PASSTHROUGH_INCLUDES,
    deps = ["//build_tools:pthreads"],
)
