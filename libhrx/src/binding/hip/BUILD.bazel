load("//libhrx/build_tools/bazel:cc.bzl", "hrx_cc_shared_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

hrx_cc_shared_library(
    name = "amdhip64",
    srcs = ["api.c"],
    hdrs = ["api.h"],
    copts = [
        "-DIREE_HAL_STREAMING_HIP_EXPORTS",
        "-Wno-attributes",
        "-Wno-unused-variable",
    ],
    includes = [
        "../..",
        "../../../include",
        "../../libhrx",
    ],
    deps = [
        "//libhrx/src/streaming",
        "//runtime/src/iree/base",
        "//runtime/src/iree/hal",
    ],
)
