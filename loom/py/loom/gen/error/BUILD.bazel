load("//build_tools/bazel:python.bzl", "iree_py_binary", "iree_py_test")

package(
    default_visibility = ["//loom/py/loom/gen:__subpackages__"],
    licenses = ["notice"],  # Apache 2.0
)

GENERATOR_VISIBILITY = [
    "//loom/py/loom/gen:__subpackages__",
    "//loom/src/loom/error:__pkg__",
    "//loom/src/loom/target/arch/amdgpu:__pkg__",
    "//loom/src/loom/target/arch/spirv:__pkg__",
    "//loom/src/loom/target/emit/wasm:__pkg__",
]

iree_py_binary(
    name = "c_errors",
    srcs = [
        "__init__.py",
        "c_errors.py",
    ],
    main = "c_errors.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom/error",
        "//loom/py/loom/gen/support",
    ],
)

iree_py_test(
    name = "c_errors_test",
    srcs = [
        "c_errors_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.error.c_errors_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":c_errors",
    ],
)
