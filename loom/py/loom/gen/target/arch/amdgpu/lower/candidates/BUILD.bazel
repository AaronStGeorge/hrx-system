load("//build_tools/bazel:python.bzl", "iree_py_binary", "iree_py_test")

package(
    default_visibility = ["//loom/py/loom/gen:__subpackages__"],
    licenses = ["notice"],  # Apache 2.0
)

GENERATOR_VISIBILITY = [
    "//loom/py/loom/gen:__subpackages__",
    "//loom/src/loom/target/arch/amdgpu:__pkg__",
    "//loom/src/loom/target/arch/amdgpu:__subpackages__",
]

iree_py_binary(
    name = "atomic_candidates",
    srcs = [
        "__init__.py",
        "amdgpu_atomic_candidates.py",
        "validation.py",
    ],
    main = "amdgpu_atomic_candidates.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/amdgpu:descriptors",
    ],
)

iree_py_binary(
    name = "compare_candidates",
    srcs = [
        "__init__.py",
        "amdgpu_compare_candidates.py",
        "validation.py",
    ],
    main = "amdgpu_compare_candidates.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/dialect/scalar",
        "//loom/py/loom/dialect/vector",
        "//loom/py/loom/gen/support",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/amdgpu:descriptors",
    ],
)

iree_py_binary(
    name = "memory_candidates",
    srcs = [
        "__init__.py",
        "amdgpu_memory_candidates.py",
        "validation.py",
    ],
    main = "amdgpu_memory_candidates.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/amdgpu:descriptors",
    ],
)

iree_py_test(
    name = "candidates_test",
    srcs = [
        "amdgpu_candidates_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.target.arch.amdgpu.lower.candidates.amdgpu_candidates_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":atomic_candidates",
        ":compare_candidates",
        ":memory_candidates",
    ],
)
