load("//build_tools/bazel:python.bzl", "iree_py_binary", "iree_py_test")

package(
    default_visibility = ["//loom/py/loom/gen:__subpackages__"],
    licenses = ["notice"],  # Apache 2.0
)

GENERATOR_VISIBILITY = [
    "//loom/py/loom/gen:__subpackages__",
    "//loom/src/loom/target/arch/spirv:__pkg__",
]

iree_py_binary(
    name = "features",
    srcs = [
        "__init__.py",
        "spirv_features.py",
    ],
    main = "spirv_features.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support:c",
        "//loom/py/loom/gen/support:files",
        "//loom/py/loom/gen/support:generated_file",
        "//loom/py/loom/target/arch/spirv:features",
    ],
)

iree_py_test(
    name = "features_test",
    srcs = [
        "spirv_features_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.target.arch.spirv.spirv_features_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":features",
        "//loom/py/loom/target/arch/spirv:features",
    ],
)

iree_py_binary(
    name = "packet_rows",
    srcs = [
        "__init__.py",
        "spirv_packet_rows.py",
    ],
    main = "spirv_packet_rows.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support:c",
        "//loom/py/loom/gen/support:generated_file",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/spirv:builtins",
        "//loom/py/loom/target/arch/spirv:cooperative_matrix",
        "//loom/py/loom/target/arch/spirv:descriptors",
        "//loom/py/loom/target/arch/spirv:scalar_alu",
        "//loom/py/loom/target/arch/spirv:scalar_conversion",
        "//loom/py/loom/target/arch/spirv:scalar_memory",
    ],
)

iree_py_test(
    name = "packet_rows_test",
    srcs = [
        "spirv_packet_rows_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.target.arch.spirv.spirv_packet_rows_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":packet_rows",
    ],
)

iree_py_binary(
    name = "cooperative_properties",
    srcs = [
        "__init__.py",
        "spirv_cooperative_properties.py",
    ],
    main = "spirv_cooperative_properties.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support:c",
        "//loom/py/loom/gen/support:generated_file",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/spirv:cooperative_matrix",
        "//loom/py/loom/target/arch/spirv:cooperative_vector",
        "//loom/py/loom/target/arch/spirv:descriptors",
    ],
)

iree_py_test(
    name = "cooperative_properties_test",
    srcs = [
        "spirv_cooperative_properties_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.target.arch.spirv.spirv_cooperative_properties_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":cooperative_properties",
    ],
)
