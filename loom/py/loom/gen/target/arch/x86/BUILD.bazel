load("//build_tools/bazel:python.bzl", "iree_py_binary", "iree_py_test")

package(
    default_visibility = ["//loom/py/loom/gen:__subpackages__"],
    licenses = ["notice"],  # Apache 2.0
)

GENERATOR_VISIBILITY = [
    "//loom/py/loom/gen:__subpackages__",
    "//loom/src/loom/target/arch/x86:__pkg__",
    "//loom/src/loom/target/arch/x86/descriptors:__pkg__",
    "//loom/src/loom/target/arch/x86/records:__pkg__",
    "//loom/src/loom/target/emit/llvmir/x86:__pkg__",
]

iree_py_binary(
    name = "low_descriptor_shard",
    srcs = [
        "__init__.py",
        "x86_descriptors.py",
    ],
    main = "x86_descriptors.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/target/low:low_descriptors",
        "//loom/py/loom/target:descriptor_sets",
        "//loom/py/loom/target/arch/x86:descriptors",
        "//loom/py/loom/target/arch/x86:target_info",
    ],
)

iree_py_test(
    name = "low_descriptor_shard_test",
    srcs = [
        "x86_descriptors_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.gen.target.arch.x86.x86_descriptors_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":low_descriptor_shard",
    ],
)

iree_py_binary(
    name = "target_profiles",
    srcs = [
        "__init__.py",
        "x86_target_profiles.py",
    ],
    main = "x86_target_profiles.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support:c",
        "//loom/py/loom/gen/support:files",
        "//loom/py/loom/gen/support:generated_file",
        "//loom/py/loom/target/arch/x86:target_info",
        "//loom/py/loom/target/emit/llvmir/x86:target_info",
    ],
)

iree_py_binary(
    name = "packed_dot_contract",
    srcs = [
        "__init__.py",
        "x86_packed_dot_contract.py",
    ],
    main = "x86_packed_dot_contract.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        "//loom/py/loom/gen/support:c",
        "//loom/py/loom/gen/support:generated_file",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch/x86:target_info",
    ],
)
