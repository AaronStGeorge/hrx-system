load("//build_tools/bazel:python.bzl", "iree_py_binary", "iree_py_library", "iree_py_test")

package(
    default_visibility = ["//loom/py/loom/gen:__subpackages__"],
    licenses = ["notice"],  # Apache 2.0
)

GENERATOR_VISIBILITY = [
    "//loom/py/loom/gen:__subpackages__",
    "//loom/src/loom/target/arch/ireevm/descriptors:__pkg__",
    "//loom/src/loom/target/arch/spirv/descriptors:__pkg__",
    "//loom/src/loom/target/arch/wasm/descriptors:__pkg__",
    "//loom/src/loom/target/test:__pkg__",
]

LOW_DESCRIPTOR_DEPS = [
    "//loom/py/loom/gen:bootstrap",
    "//loom/py/loom/gen/support:c",
    "//loom/py/loom/gen/support:generated_file",
    "//loom/py/loom/gen/support:string_pool",
    "//loom/py/loom/gen/target:package",
    "//loom/py/loom/target:low_descriptors",
]

iree_py_library(
    name = "low_descriptors",
    srcs = [
        "__init__.py",
        "low_descriptors.py",
    ],
    deps = LOW_DESCRIPTOR_DEPS,
)

LOW_DESCRIPTOR_SHARD_DEPS = [
    ":low_descriptors",
    "//loom/py/loom/target:descriptor_sets",
]

iree_py_library(
    name = "low_descriptor_shard",
    srcs = [
        "__init__.py",
        "low_descriptor_shard.py",
    ],
    deps = LOW_DESCRIPTOR_SHARD_DEPS,
)

iree_py_binary(
    name = "ireevm_low_descriptor_shard",
    srcs = [
        "__init__.py",
        "low_descriptor_shard.py",
    ],
    main = "low_descriptor_shard.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        ":low_descriptor_shard",
        "//loom/py/loom/target/arch/ireevm:descriptors",
    ],
)

iree_py_binary(
    name = "spirv_low_descriptor_shard",
    srcs = [
        "__init__.py",
        "low_descriptor_shard.py",
    ],
    main = "low_descriptor_shard.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        ":low_descriptor_shard",
        "//loom/py/loom/target/arch/spirv:descriptors",
    ],
)

iree_py_binary(
    name = "wasm_low_descriptor_shard",
    srcs = [
        "__init__.py",
        "low_descriptor_shard.py",
    ],
    main = "low_descriptor_shard.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        ":low_descriptor_shard",
        "//loom/py/loom/target/arch/wasm:descriptors",
    ],
)

iree_py_binary(
    name = "test_low_descriptor_shard",
    srcs = [
        "__init__.py",
        "low_descriptor_shard.py",
    ],
    main = "low_descriptor_shard.py",
    visibility = GENERATOR_VISIBILITY,
    deps = [
        ":low_descriptor_shard",
        "//loom/py/loom/target/test:descriptors",
    ],
)

iree_py_test(
    name = "low_descriptors_test",
    srcs = [
        "low_descriptor_shard_test.py",
        "low_descriptors_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.gen.target.low.low_descriptor_shard_test",
        "loom.gen.target.low.low_descriptors_test",
    ],
    main = "pytest_style_runner.py",
    deps = [
        ":low_descriptor_shard",
        ":low_descriptors",
        "//loom/py/loom:core",
        "//loom/py/loom/target:descriptor_sets",
        "//loom/py/loom/target/test:descriptors",
    ],
)
