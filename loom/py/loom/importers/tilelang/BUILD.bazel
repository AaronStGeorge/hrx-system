py_library(
    name = "core",
    srcs = [
        "abi.py",
        "buffers.py",
        "context.py",
        "converter.py",
        "coverage.py",
        "model.py",
        "nodes.py",
        "types.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom:package",
        "//loom/py/loom/importers/core",
    ],
)

py_library(
    name = "tilelang",
    srcs = [
        "__init__.py",
        "defaults.py",
        "importer.py",
    ],
    deps = [
        ":core",
        "//loom/py/loom/importers/tilelang/ops",
    ],
)

py_library(
    name = "tilelang_packages",
    data = iree_select({
        "//loom/py/loom/importers:tilelang_enabled": _TILELANG_PACKAGE_DATA,
        "//conditions:default": [],
    }),
    deps = iree_select({
        "//loom/py/loom/importers:tilelang_enabled": [
            "@importer_pip//apache_tvm_ffi",
            "@importer_pip//cloudpickle",
