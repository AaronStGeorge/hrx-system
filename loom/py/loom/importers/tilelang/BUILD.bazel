load("@rules_python//python:defs.bzl", "py_library", "py_test")
load("//loom/build_tools/bazel:build_defs.bzl", "iree_cmake_extra_content", "iree_select")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

_TILELANG_IMPORTER_COMPATIBLE = iree_select({
    "//loom/py/loom/importers:tilelang_enabled": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

_TILELANG_PACKAGE_DATA = [
    "@importer_pip//apache_tvm_ffi:data",
    "@importer_pip//cuda_bindings:data",
    "@importer_pip//nvidia_cublas:data",
    "@importer_pip//nvidia_cuda_cupti:data",
    "@importer_pip//nvidia_cuda_nvrtc:data",
    "@importer_pip//nvidia_cuda_runtime:data",
    "@importer_pip//nvidia_cudnn_cu13:data",
    "@importer_pip//nvidia_cufft:data",
    "@importer_pip//nvidia_cufile:data",
    "@importer_pip//nvidia_curand:data",
    "@importer_pip//nvidia_cusolver:data",
    "@importer_pip//nvidia_cusparse:data",
    "@importer_pip//nvidia_cusparselt_cu13:data",
    "@importer_pip//nvidia_nccl_cu13:data",
    "@importer_pip//nvidia_nvjitlink:data",
    "@importer_pip//nvidia_nvshmem_cu13:data",
