            "@importer_pip//torch_c_dlpack_ext",
            "@importer_pip//tqdm",
            "@importer_pip//triton",
            "@importer_pip//typing_extensions",
            "@importer_pip//z3_solver",
        ],
        "//conditions:default": [],
    }),
