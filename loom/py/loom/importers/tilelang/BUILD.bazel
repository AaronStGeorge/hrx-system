load("@rules_python//python:defs.bzl", "py_library", "py_test")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

py_library(
    name = "core",
    srcs = [
        "abi.py",
        "context.py",
        "converter.py",
        "coverage.py",
        "model.py",
        "nodes.py",
        "types.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom:package",
        "//loom/py/loom/importers/core",
    ],
)

py_library(
    name = "tilelang",
    srcs = [
        "__init__.py",
        "defaults.py",
        "importer.py",
    ],
    deps = [
        ":core",
        "//loom/py/loom/importers/tilelang/ops",
    ],
)

py_test(
    name = "tilelang_test",
    srcs = [
        "context_test.py",
        "coverage_test.py",
        "importer_test.py",
        "types_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.importers.tilelang.context_test",
        "loom.importers.tilelang.coverage_test",
        "loom.importers.tilelang.importer_test",
        "loom.importers.tilelang.types_test",
    ],
    main = "pytest_style_runner.py",
    deps = [
        ":tilelang",
        "//loom/py/loom/importers/check/tilelang",
    ],
)
