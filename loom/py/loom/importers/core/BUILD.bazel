load("@rules_python//python:defs.bzl", "py_library", "py_test")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

py_library(
    name = "core",
    srcs = [
        "__init__.py",
        "kernel.py",
        "names.py",
        "options.py",
        "printing.py",
        "session.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom:package",
        "//loom/py/loom/format/text",
    ],
)

py_test(
    name = "core_test",
    srcs = [
        "names_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.importers.core.names_test",
    ],
    main = "pytest_style_runner.py",
    deps = [":core"],
)
