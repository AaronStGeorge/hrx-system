load("@rules_python//python:defs.bzl", "py_library", "py_test")
load("//loom/build_tools/bazel:build_defs.bzl", "iree_cmake_extra_content", "iree_select")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

_TILELANG_IMPORTER_COMPATIBLE = iree_select({
    "//loom/py/loom/importers:tilelang_enabled": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

py_library(
    name = "tilelang",
    srcs = [
        "__init__.py",
        "backend.py",
        "cases.py",
        "harness.py",
        "runner.py",
    ],
    deps = [
        "//loom/py/loom/importers/check",
        "//loom/py/loom/importers/core",
        "//loom/py/loom/importers/tilelang",
    ],
)

iree_cmake_extra_content(
    content = """
if(LOOM_IMPORTER_TILELANG)
""",
    inline = True,
)

py_test(
    name = "tilelang_test",
    srcs = [
        "cases_test.py",
        "harness_test.py",
        "runner_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.importers.check.tilelang.cases_test",
        "loom.importers.check.tilelang.harness_test",
        "loom.importers.check.tilelang.runner_test",
    ],
    legacy_create_init = False,
    main = "pytest_style_runner.py",
    target_compatible_with = _TILELANG_IMPORTER_COMPATIBLE,
    deps = [
        ":tilelang",
        "//loom/py/loom/importers/tilelang:tilelang_packages",
    ],
)

iree_cmake_extra_content(
    content = """
endif()
""",
    inline = True,
)
