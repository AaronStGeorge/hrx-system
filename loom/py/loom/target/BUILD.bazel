load("@rules_python//python:defs.bzl", "py_library")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

py_library(
    name = "package",
    srcs = ["__init__.py"],
    deps = ["//loom/py/loom:package"],
)

py_library(
    name = "low_descriptors",
    srcs = ["low_descriptors.py"],
    deps = [
        ":package",
        "//loom/py/loom:core",
    ],
)

py_library(
    name = "descriptor_sets",
    srcs = ["descriptor_sets.py"],
    deps = [
        ":low_descriptors",
    ],
)

py_library(
    name = "contract_fragments",
    srcs = ["contract_fragments.py"],
    deps = [
        ":package",
        "//loom/py/loom:core",
        "//loom/py/loom/target/contracts",
    ],
)
