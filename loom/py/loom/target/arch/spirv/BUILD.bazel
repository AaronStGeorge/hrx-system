load("@rules_python//python:defs.bzl", "py_library")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

py_library(
    name = "dialect",
    srcs = [
        "__init__.py",
        "dialect.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom/dialect/target",
    ],
)

py_library(
    name = "descriptors",
    srcs = [
        "__init__.py",
        "descriptors.py",
    ],
    deps = [
        ":features",
        ":scalar_memory",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch:package",
    ],
)

py_library(
    name = "features",
    srcs = [
        "__init__.py",
        "features.py",
    ],
    deps = [
        "//loom/py/loom/target/arch:package",
    ],
)

py_library(
    name = "scalar_memory",
    srcs = [
        "__init__.py",
        "scalar_memory.py",
    ],
    deps = [
        ":features",
    ],
)
