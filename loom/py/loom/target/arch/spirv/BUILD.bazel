load("//build_tools/bazel:python.bzl", "iree_py_library")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

iree_py_library(
    name = "dialect",
    srcs = [
        "__init__.py",
        "dialect.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom/dialect/target",
    ],
)

iree_py_library(
    name = "builtins",
    srcs = [
        "__init__.py",
        "builtins.py",
    ],
)

iree_py_library(
    name = "descriptors",
    srcs = [
        "__init__.py",
        "descriptors.py",
    ],
    deps = [
        ":builtins",
        ":cooperative_matrix",
        ":features",
        ":scalar_alu",
        ":scalar_conversion",
        ":scalar_memory",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch:package",
    ],
)

iree_py_library(
    name = "cooperative_matrix",
    srcs = [
        "__init__.py",
        "cooperative_matrix.py",
    ],
    deps = [
        ":features",
        ":scalar_memory",
    ],
)

iree_py_library(
    name = "cooperative_vector",
    srcs = [
        "__init__.py",
        "cooperative_vector.py",
    ],
    deps = [
        ":features",
    ],
)

iree_py_library(
    name = "features",
    srcs = [
        "__init__.py",
        "features.py",
    ],
    deps = [
        "//loom/py/loom/target/arch:package",
    ],
)

iree_py_library(
    name = "scalar_memory",
    srcs = [
        "__init__.py",
        "scalar_memory.py",
    ],
    deps = [
        ":features",
    ],
)

iree_py_library(
    name = "scalar_alu",
    srcs = [
        "__init__.py",
        "scalar_alu.py",
    ],
    deps = [
        ":features",
    ],
)

iree_py_library(
    name = "scalar_conversion",
    srcs = [
        "__init__.py",
        "scalar_conversion.py",
    ],
    deps = [
        ":scalar_alu",
    ],
)
