load("//build_tools/bazel:python.bzl", "iree_py_library", "iree_py_test")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

iree_py_library(
    name = "target_info",
    srcs = [
        "__init__.py",
        "target_info.py",
    ],
    deps = [
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch:package",
    ],
)

iree_py_library(
    name = "isa_xml",
    srcs = ["isa_xml.py"],
)

iree_py_library(
    name = "dialect",
    srcs = [
        "__init__.py",
        "dialect.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom/dialect/target",
        "//loom/py/loom/target/arch/amdgpu:target_info",
    ],
)

iree_py_library(
    name = "matrix_contracts",
    srcs = ["matrix_contracts.py"],
)

iree_py_library(
    name = "descriptors",
    srcs = [
        "__init__.py",
        "descriptor_overlay.py",
        "descriptors/__init__.py",
        "descriptors/alu.py",
        "descriptors/api.py",
        "descriptors/atomic.py",
        "descriptors/candidates.py",
        "descriptors/categories.py",
        "descriptors/common.py",
        "descriptors/contracts.py",
        "descriptors/control.py",
        "descriptors/matrix.py",
        "descriptors/memory.py",
        "descriptors/sets.py",
        "descriptors/workgroup.py",
        "encoding.py",
        "target_info.py",
    ],
    deps = [
        ":isa_xml",
        ":target_info",
        "//loom/py/loom/target:low_descriptors",
        "//loom/py/loom/target/arch:package",
    ],
)

iree_py_test(
    name = "target_info_test",
    srcs = [
        "isa_xml_test.py",
        "target_info_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.target.arch.amdgpu.isa_xml_test",
        "loom.target.arch.amdgpu.target_info_test",
    ],
    main = "pytest_style_runner.py",
    deps = [
        ":isa_xml",
        ":target_info",
    ],
)

iree_py_test(
    name = "descriptors_test",
    srcs = [
        "descriptor_overlay_test.py",
        "descriptors_test.py",
        "isa_xml_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = [
        "loom.target.arch.amdgpu.descriptor_overlay_test",
        "loom.target.arch.amdgpu.descriptors_test",
    ],
    main = "pytest_style_runner.py",
    deps = [
        ":descriptors",
        ":isa_xml",
        "//loom/py/loom/target:low_descriptors",
    ],
)
