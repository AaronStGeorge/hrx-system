load("//build_tools/bazel:python.bzl", "iree_py_library", "iree_py_test")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

iree_py_library(
    name = "target_info",
    srcs = [
        "__init__.py",
        "target_info.py",
    ],
    deps = [
        "//loom/py/loom/target/arch/x86:target_info",
        "//loom/py/loom/target/emit/llvmir:package",
