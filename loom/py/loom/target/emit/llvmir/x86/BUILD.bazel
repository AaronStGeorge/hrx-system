)

iree_py_test(
    name = "target_info_test",
    srcs = [
        "target_info_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.target.emit.llvmir.x86.target_info_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":target_info",
    ],
)
