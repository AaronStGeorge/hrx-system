load("//build_tools/bazel:python.bzl", "iree_py_library", "iree_py_test")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

iree_py_library(
    name = "vector",
    srcs = [
        "__init__.py",
        "defs.py",
    ],
    deps = [
        "//loom/py/loom:core",
        "//loom/py/loom/dialect:shared",
        "//loom/py/loom/dialect/scalar",
        "//loom/py/loom/error",
    ],
)

iree_py_test(
    name = "vector_ops_test",
    srcs = [
        "vector_ops_test.py",
        "//loom/py/loom/tools:pytest_style_runner.py",
    ],
    args = ["loom.dialect.vector.vector_ops_test"],
    main = "pytest_style_runner.py",
    deps = [
        ":vector",
        "//loom/py/loom/dialect/scalar",
    ],
)
