load("@bazel_skylib//lib:selects.bzl", "selects")
load("@bazel_skylib//rules:common_settings.bzl", "string_list_flag")

package(default_visibility = ["//visibility:public"])

# Advanced target-architecture slices. Public //loom/config/target values imply
# these effective settings; this flag is only for source embedders that want
# target metadata/providers without the corresponding production emitters.
DEFAULT_ENABLED = []

SUPPORTED_VALUES = [
    "amdgpu",
    "ireevm",
    "spirv",
    "wasm",
    "x86",
]

string_list_flag(
    name = "enable",
    build_setting_default = DEFAULT_ENABLED,
)

[
    config_setting(
        name = "explicit_" + value,
        flag_values = {
            ":enable": value,
        },
    )
    for value in SUPPORTED_VALUES
]

[
    selects.config_setting_group(
        name = value,
        match_any = [
            "//loom/config/target:" + value,
            ":explicit_" + value,
        ],
    )
    for value in SUPPORTED_VALUES
]
