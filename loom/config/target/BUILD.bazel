load("@bazel_skylib//rules:common_settings.bzl", "string_list_flag")

package(default_visibility = ["//visibility:public"])

DEFAULT_ENABLED = [
    "ireevm",
]

SUPPORTED_VALUES = [
    "amdgpu",
    "ireevm",
    "spirv",
    "wasm",
    "x86",
]

string_list_flag(
    name = "enable",
    build_setting_default = DEFAULT_ENABLED,
)

[
    config_setting(
        name = value,
        flag_values = {
            ":enable": value,
        },
    )
    for value in SUPPORTED_VALUES
]
