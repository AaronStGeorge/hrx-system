package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # AMD GPUOpen machine-readable ISA specifications.
)

exports_files([
    "amdgpu_isa_cdna3.xml",
    "amdgpu_isa_cdna4.xml",
    "amdgpu_isa_rdna3.xml",
    "amdgpu_isa_rdna4.xml",
])

filegroup(
    name = "all_xml",
    srcs = glob(["*.xml"]),
)
