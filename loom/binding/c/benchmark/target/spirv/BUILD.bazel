load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_benchmark")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_benchmark(
    name = "compile_throughput_benchmark",
    srcs = ["compile_throughput_benchmark.cc"],
    args = [
        "--benchmark_filter=Smoke",
    ],
    deps = [
        "//loom/binding/c:loomc",
        "//loom/binding/c:loomc_target_spirv",
        "//loom/binding/c/benchmark:compile_throughput_benchmark_harness",
        "//runtime/src/iree/base",
        "//runtime/src/iree/testing:benchmark_main",
    ],
)
