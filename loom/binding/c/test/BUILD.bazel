load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
    "loom_config_compatible_with",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

LOOMC_TARGET_SPIRV_COMPATIBLE_WITH = loom_config_compatible_with([
    "//loom/config/target/arch:spirv",
    "//loom/config/emit:spirv",
])

LOOMC_TARGET_SPIRV_VULKAN_COMPATIBLE_WITH = loom_config_compatible_with([
    "//loom/config/execute:spirv_vulkan_hal",
])

loom_cc_library(
    name = "test_util",
    testonly = True,
    hdrs = ["util.h"],
    includes = [".."],
    deps = [
        "//loom/binding/c:loomc",
        "//runtime/src/iree/testing:gtest",
    ],
)

loom_cc_test(
    name = "full_package_test",
    srcs = ["full_package_test.cc"],
    target_compatible_with = LOOMC_TARGET_SPIRV_VULKAN_COMPATIBLE_WITH,
    deps = [
        ":test_util",
        "//loom/binding/c:loomc_full",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
