{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loom",
  "scopeName": "source.loom",
  "fileTypes": [
    "loom"
  ],
  "comment": "GENERATED by loom.gen.textmate. Do not edit by hand. Regenerate with: python3 loom/py/loom/gen/run.py textmate",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#op-names"
    },
    {
      "include": "#references"
    },
    {
      "include": "#attribute-names"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loom",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.loom",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.loom"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.loom"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.loom",
              "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9A-Fa-f]{4})"
            },
            {
              "name": "invalid.illegal.escape.loom",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "op-names": {
      "patterns": [
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(buffer)\\.(assume\\.memory_space|alloca|view)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(encoding)\\.(layout\\.assume\\.strided|layout\\.assume\\.dense|layout\\.strided|layout\\.dense|assume\\.spec|define|isa)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(func)\\.(template|ukernel|return|apply|call|decl|def)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(global)\\.(constant|variable|store|load)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(index)\\.(constant|assume|cast|madd|add|cmp|div|mul|rem|sub)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(kernel)\\.(async\\.tensor\\.store\\.from\\.lds|async\\.cluster\\.gather\\.mask|async\\.tensor\\.load\\.to\\.lds|tensor\\.lds\\.descriptor|async\\.cluster\\.gather|async\\.gather\\.mask|async\\.copy\\.mask|async\\.gather|async\\.group|workitem\\.id|async\\.copy|async\\.wait|barrier)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(llvmir)\\.(inline_asm|intrinsic)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(pool)\\.(buffer|store|unpin|load|pin)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(scalar)\\.(floordivsi|roundevenf|ceildivsi|ceildivui|copysignf|isfinitef|constant|maximumf|minimumf|bitcast|fptrunc|maxnumf|minnumf|acoshf|asinhf|assume|atan2f|atanhf|ctpopi|expm1f|floorf|fptosi|fptoui|isinff|isnanf|log10f|log1pf|poison|roundf|rsqrtf|sitofp|truncf|trunci|uitofp|acosf|asinf|atanf|cbrtf|ceilf|coshf|ctlzi|cttzi|divsi|divui|erfcf|exp2f|extsi|extui|log2f|maxsi|maxui|minsi|minui|remsi|remui|rotli|rotri|shrsi|shrui|signf|signi|sinhf|sqrtf|tanhf|absf|absi|addf|addi|andi|cmpf|cmpi|cosf|divf|erff|expf|extf|fmaf|fmai|logf|mulf|muli|negf|negi|powf|remf|shli|sinf|subf|subi|tanf|xori|ori)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(scf)\\.(condition|lookup|select|switch|while|yield|for|if)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(test)\\.(fact_encoding_layout_stride_hi|fact_view_root_min_alignment|fact_encoding_matrix_field|fact_is_vector_prefix_mask|fact_buffer_min_alignment|fact_encoding_layout_kind|fact_buffer_memory_space|fact_is_buffer_reference|fact_view_byte_length_hi|fact_view_byte_length_lo|fact_view_byte_offset_hi|fact_view_byte_offset_lo|fact_view_element_bytes|fact_view_min_alignment|fact_is_view_reference|fact_view_memory_space|fact_view_root_matches|fact_is_vector_iota|fact_non_negative|fact_power_of_two|isolated_region|mutate_resource|implicit_yield|low_asm_region|write_resource|fact_non_zero|fact_positive|fact_range_hi|fact_range_lo|read_resource|region_syntax|fact_divisor|operand_dict|region_table|attr_table|block_args|constant|convert|counter|deflate|assume|branch|invoke|record|reduce|update|alloc|attrs|slice|yield|addi|cast|decl|func|loop|cmp|dim|map|neg|use|br)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(vector)\\.(atomic\\.reduce\\.mask|bitfield\\.extracts|bitfield\\.extractu|atomic\\.rmw\\.mask|bitfield\\.insert|store\\.compress|table\\.quantize|atomic\\.reduce|from_elements|deinterleave|scatter\\.mask|table\\.lookup|gather\\.mask|load\\.expand|atomic\\.rmw|bitunpacks|bitunpacku|floordivsi|interleave|mask\\.range|roundevenf|store\\.mask|broadcast|ceildivsi|ceildivui|copysignf|isfinitef|load\\.mask|transform|transpose|constant|maximumf|minimumf|bitcast|bitpack|extract|fptrunc|maxnumf|minnumf|scatter|shuffle|acoshf|asinhf|atan2f|atanhf|concat|ctpopi|dot4f8|dot8i4|expm1f|floorf|fptosi|fptoui|gather|insert|isinff|isnanf|log10f|log1pf|poison|reduce|roundf|rsqrtf|select|sitofp|truncf|trunci|uitofp|acosf|asinf|atanf|cbrtf|ceilf|coshf|ctlzi|cttzi|divsi|divui|dot2f|dot4i|empty|erfcf|exp2f|extsi|extui|log2f|maxsi|maxui|minsi|minui|remsi|remui|rotli|rotri|shrsi|shrui|signf|signi|sinhf|slice|splat|sqrtf|store|tanhf|absf|absi|addf|addi|andi|cmpf|cmpi|cosf|divf|dotf|erff|expf|extf|fmaf|fmai|iota|load|logf|mulf|muli|negf|negi|powf|remf|shli|sinf|subf|subi|tanf|xori|ori)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(view)\\.(atomic\\.reduce|atomic\\.rmw|prefetch|subview|refine|store|load)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "name": "variable.other.ssa.loom",
          "match": "(%)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.ssa.loom"
            },
            "2": {
              "name": "variable.other.ssa.name.loom"
            }
          }
        },
        {
          "name": "entity.name.label.block.loom",
          "match": "(\\^)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.label.block.loom"
            },
            "2": {
              "name": "entity.name.label.block.name.loom"
            }
          }
        },
        {
          "name": "variable.other.symbol.loom",
          "match": "(@)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.symbol.loom"
            },
            "2": {
              "name": "variable.other.symbol.name.loom"
            }
          }
        },
        {
          "name": "variable.other.attribute.hash.loom",
          "match": "(#)([A-Za-z_$][A-Za-z0-9_$]*)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.attribute.hash.loom"
            },
            "2": {
              "name": "variable.other.attribute.hash.name.loom"
            }
          }
        }
      ]
    },
    "attribute-names": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.loom",
          "match": "(?<![A-Za-z0-9_$])[A-Za-z_$][A-Za-z0-9_$]*(?=\\s*=)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.loom",
          "match": "\\b(?:kernel\\.tensor\\.lds\\.descriptor|kernel\\.async\\.group|kernel\\.async\\.token|hal\\.buffer|buffer|f8E4M3|f8E5M2|offset|tensor|vector|group|index|bf16|pool|tile|view|f16|f32|f64|i16|i32|i64|i1|i8)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.loom",
          "match": "\\b(?:allocation|iter_args|priority|schedule|default|dgroups|device|import|layout|public|source|target|using|where|case|else|host|into|step|as|do|to|x)\\b"
        },
        {
          "name": "constant.language.boolean.loom",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.loom",
          "match": "(?<![A-Za-z0-9_$])-?(?:[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?|[0-9]+[eE][+-]?[0-9]+)(?![A-Za-z0-9_$])"
        },
        {
          "name": "constant.numeric.integer.hex.loom",
          "match": "(?<![A-Za-z0-9_$])-?0x[0-9A-Fa-f]+(?![A-Za-z0-9_$])"
        },
        {
          "name": "constant.numeric.integer.decimal.loom",
          "match": "(?<![A-Za-z0-9_$])-?[0-9]+(?![A-Za-z0-9_$])"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.loom",
          "match": "->"
        },
        {
          "name": "punctuation.separator.loom",
          "match": "[,|:]"
        },
        {
          "name": "punctuation.definition.group.loom",
          "match": "[(){}\\[\\]<>]"
        },
        {
          "name": "keyword.operator.assignment.loom",
          "match": "="
        }
      ]
    }
  }
}
