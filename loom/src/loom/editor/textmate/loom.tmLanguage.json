{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loom",
  "scopeName": "source.loom",
  "fileTypes": [
    "loom"
  ],
  "comment": "GENERATED by loom.gen.textmate. Do not edit by hand. Regenerate with: python3 loom/py/loom/gen/run.py textmate",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#op-names"
    },
    {
      "include": "#references"
    },
    {
      "include": "#attribute-names"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loom",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.loom",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.loom"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.loom"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.loom",
              "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9A-Fa-f]{4})"
            },
            {
              "name": "invalid.illegal.escape.loom",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "op-names": {
      "patterns": [
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(buffer)\\.(view)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(encoding)\\.(layout\\.strided|layout\\.dense|define|isa)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(func)\\.(template|ukernel|return|apply|call|decl|def)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(global)\\.(constant|variable|store|load)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(pool)\\.(buffer|store|unpin|load|pin)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(scalar)\\.(floordivsi|index_cast|roundevenf|ceildivsi|ceildivui|copysignf|isfinitef|constant|maximumf|minimumf|bitcast|fptrunc|maxnumf|minnumf|acoshf|asinhf|assume|atan2f|atanhf|ctpopi|expm1f|floorf|fptosi|fptoui|isinff|isnanf|log10f|log1pf|roundf|rsqrtf|select|sitofp|truncf|trunci|uitofp|acosf|asinf|atanf|cbrtf|ceilf|coshf|ctlzi|cttzi|divsi|divui|erfcf|exp2f|extsi|extui|log2f|maxsi|maxui|minsi|minui|remsi|remui|rotli|rotri|shrsi|shrui|signf|signi|sinhf|sqrtf|tanhf|absf|absi|addf|addi|andi|cmpf|cmpi|cosf|divf|erff|expf|extf|fmaf|fmai|logf|mulf|muli|negf|negi|powf|remf|shli|sinf|subf|subi|tanf|xori|ori)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(scf)\\.(yield|for|if)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(test)\\.(fact_non_negative|fact_power_of_two|isolated_region|mutate_resource|implicit_yield|write_resource|fact_non_zero|fact_positive|fact_range_hi|fact_range_lo|read_resource|fact_divisor|operand_dict|constant|convert|counter|deflate|assume|branch|invoke|reduce|update|alloc|attrs|slice|yield|addi|cast|decl|func|loop|cmp|dim|map|neg|use)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(vector)\\.(atomic\\.reduce\\.mask|bitfield\\.extracts|bitfield\\.extractu|atomic\\.rmw\\.mask|bitfield\\.insert|store\\.compress|atomic\\.reduce|from_elements|deinterleave|scatter\\.mask|table\\.lookup|gather\\.mask|load\\.expand|atomic\\.rmw|interleave|store\\.mask|broadcast|load\\.mask|transpose|constant|bitcast|extract|fptrunc|scatter|shuffle|concat|fptosi|fptoui|gather|insert|reduce|select|sitofp|trunci|uitofp|extsi|extui|slice|splat|sqrtf|store|addf|addi|cmpf|cmpi|extf|fmaf|load|mulf|muli)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        },
        {
          "name": "meta.operation-name.loom",
          "match": "\\b(view)\\.(subview)\\b",
          "captures": {
            "1": {
              "name": "support.namespace.dialect.loom"
            },
            "2": {
              "name": "entity.name.function.operation.loom"
            }
          }
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "name": "variable.other.ssa.loom",
          "match": "(%)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.ssa.loom"
            },
            "2": {
              "name": "variable.other.ssa.name.loom"
            }
          }
        },
        {
          "name": "entity.name.label.block.loom",
          "match": "(\\^)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.label.block.loom"
            },
            "2": {
              "name": "entity.name.label.block.name.loom"
            }
          }
        },
        {
          "name": "variable.other.symbol.loom",
          "match": "(@)([A-Za-z0-9_$]+)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.symbol.loom"
            },
            "2": {
              "name": "variable.other.symbol.name.loom"
            }
          }
        },
        {
          "name": "variable.other.attribute.hash.loom",
          "match": "(#)([A-Za-z_$][A-Za-z0-9_$]*)(?![A-Za-z0-9_$])",
          "captures": {
            "1": {
              "name": "punctuation.definition.attribute.hash.loom"
            },
            "2": {
              "name": "variable.other.attribute.hash.name.loom"
            }
          }
        }
      ]
    },
    "attribute-names": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.loom",
          "match": "(?<![A-Za-z0-9_$])[A-Za-z_$][A-Za-z0-9_$]*(?=\\s*=)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.loom",
          "match": "\\b(?:hal\\.buffer|buffer|f8E4M3|f8E5M2|offset|tensor|vector|group|index|bf16|pool|tile|view|f16|f32|f64|i16|i32|i64|i1|i8)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.loom",
          "match": "\\b(?:iter_args|priority|device|import|layout|public|where|else|host|into|step|as|to|x)\\b"
        },
        {
          "name": "constant.language.boolean.loom",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.loom",
          "match": "(?<![A-Za-z0-9_$])-?(?:[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?|[0-9]+[eE][+-]?[0-9]+)(?![A-Za-z0-9_$])"
        },
        {
          "name": "constant.numeric.integer.hex.loom",
          "match": "(?<![A-Za-z0-9_$])-?0x[0-9A-Fa-f]+(?![A-Za-z0-9_$])"
        },
        {
          "name": "constant.numeric.integer.decimal.loom",
          "match": "(?<![A-Za-z0-9_$])-?[0-9]+(?![A-Za-z0-9_$])"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.loom",
          "match": "->"
        },
        {
          "name": "punctuation.separator.loom",
          "match": "[,|:]"
        },
        {
          "name": "punctuation.definition.group.loom",
          "match": "[(){}\\[\\]<>]"
        },
        {
          "name": "keyword.operator.assignment.loom",
          "match": "="
        }
      ]
    }
  }
}
