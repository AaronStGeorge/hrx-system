load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_benchmark", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "parser_impl",
    srcs = [
        "accumulator.c",
        "attrs.c",
        "diagnostics.c",
        "format.c",
        "format_signatures.c",
        "format_tables.c",
        "locations.c",
        "low_asm.c",
        "low_asm_structural.c",
        "parser.c",
        "pipeline.c",
        "scope.c",
        "types.c",
    ],
    hdrs = [
        "accumulator.h",
        "aliases.h",
        "attrs.h",
        "context.h",
        "diagnostics.h",
        "format.h",
        "format_signatures.h",
        "format_tables.h",
        "locations.h",
        "low_asm.h",
        "parser.h",
        "pipeline.h",
        "regions.h",
        "scope.h",
        "types.h",
    ],
    deps = [
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/error:renderer",
        "//loom/src/loom/format/text:low_asm",
        "//loom/src/loom/format/text:tokenizer",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:symbol_map",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops:type_registry",
        "//loom/src/loom/util:stable_id",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_test(
    name = "parser_test",
    srcs = ["parser_test.cc"],
    deps = [
        ":parser_impl",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/format/text/printer:printer_impl",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "low_asm_test",
    srcs = ["low_asm_test.cc"],
    deps = [
        ":parser_impl",
        "//loom/src/loom/codegen/low:text_asm",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/target:registers",
        "//loom/src/loom/target/test:alt_descriptors",
        "//loom/src/loom/target/test:descriptors",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_benchmark(
    name = "scope_benchmark",
    srcs = ["scope_benchmark.cc"],
    deps = [
        ":parser_impl",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/test",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:benchmark_main",
        "@com_google_benchmark//:benchmark",
    ],
)
