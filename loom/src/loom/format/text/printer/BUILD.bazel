load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "printer_impl",
    srcs = [
        "atoms.c",
        "context.c",
        "format.c",
        "format_regions.c",
        "format_signatures.c",
        "format_tables.c",
        "low_asm.c",
        "pipeline.c",
        "printer.c",
        "regions.c",
    ],
    hdrs = [
        "atoms.h",
        "context.h",
        "format.h",
        "format_regions.h",
        "format_signatures.h",
        "format_tables.h",
        "low_asm.h",
        "pipeline.h",
        "printer.h",
        "regions.h",
    ],
    deps = [
        "//loom/src/loom/format/text:low_asm",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/base/internal:unicode",
    ],
)

loom_cc_test(
    name = "printer_test",
    srcs = ["printer_test.cc"],
    deps = [
        ":printer_impl",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "low_asm_test",
    srcs = ["low_asm_test.cc"],
    deps = [
        ":printer_impl",
        "//loom/src/loom/codegen/low:text_asm",
        "//loom/src/loom/format/text/parser:parser_impl",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/target/test:alt_descriptors",
        "//loom/src/loom/target/test:descriptors",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
