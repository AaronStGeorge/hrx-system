// RUN: pass vector-to-scalar,canonicalize

// A specialized zero vector extent erases the scalarized load/store loops. This
// is the optional-feature shape we want to be boring: valid dynamic IR enters
// lowering and disappears when facts say there are no lanes.
func.def @zero_extent_vector_memory_erases(%features: index, %buffer: buffer, %byte_offset: offset, %origin: index) {
  %disabled = index.assume %features [range(%features, 0, 0)] : index
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<[%disabled]xf32, %layout>
  %loaded = vector.load %view[%origin] : view<[%disabled]xf32, %layout> -> vector<[%disabled]xf32>
  vector.store %loaded, %view[%origin] : vector<[%disabled]xf32>, view<[%disabled]xf32, %layout>
  func.return
}

// ----
func.def @zero_extent_vector_memory_erases(%features: index, %buffer: buffer, %byte_offset: offset, %origin: index) {
  func.return
}

// ====

func.def @scalarizes_dense_f16_f32_mma(%lhs_data: vector<4xf16>, %rhs_data: vector<4xf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xf16>, vector<4xf16>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
func.def @scalarizes_dense_f16_f32_mma(%lhs_data: vector<4xf16>, %rhs_data: vector<4xf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %11 = vector.extract %init_data[0] : vector<4xf32> -> f32
  %12 = vector.extract %lhs_data[0] : vector<4xf16> -> f16
  %13 = vector.extract %rhs_data[0] : vector<4xf16> -> f16
  %14 = scalar.extf %12 : f16 to f32
  %15 = scalar.extf %13 : f16 to f32
  %16 = scalar.fmaf %14, %15, %11 : f32
  %17 = vector.extract %lhs_data[1] : vector<4xf16> -> f16
  %18 = vector.extract %rhs_data[2] : vector<4xf16> -> f16
  %19 = scalar.extf %17 : f16 to f32
  %20 = scalar.extf %18 : f16 to f32
  %21 = scalar.fmaf %19, %20, %16 : f32
  %22 = vector.extract %init_data[1] : vector<4xf32> -> f32
  %23 = vector.extract %lhs_data[0] : vector<4xf16> -> f16
  %24 = vector.extract %rhs_data[1] : vector<4xf16> -> f16
  %25 = scalar.extf %23 : f16 to f32
  %26 = scalar.extf %24 : f16 to f32
  %27 = scalar.fmaf %25, %26, %22 : f32
  %28 = vector.extract %lhs_data[1] : vector<4xf16> -> f16
  %29 = vector.extract %rhs_data[3] : vector<4xf16> -> f16
  %30 = scalar.extf %28 : f16 to f32
  %31 = scalar.extf %29 : f16 to f32
  %32 = scalar.fmaf %30, %31, %27 : f32
  %33 = vector.extract %init_data[2] : vector<4xf32> -> f32
  %34 = vector.extract %lhs_data[2] : vector<4xf16> -> f16
  %35 = vector.extract %rhs_data[0] : vector<4xf16> -> f16
  %36 = scalar.extf %34 : f16 to f32
  %37 = scalar.extf %35 : f16 to f32
  %38 = scalar.fmaf %36, %37, %33 : f32
  %39 = vector.extract %lhs_data[3] : vector<4xf16> -> f16
  %40 = vector.extract %rhs_data[2] : vector<4xf16> -> f16
  %41 = scalar.extf %39 : f16 to f32
  %42 = scalar.extf %40 : f16 to f32
  %43 = scalar.fmaf %41, %42, %38 : f32
  %44 = vector.extract %init_data[3] : vector<4xf32> -> f32
  %45 = vector.extract %lhs_data[2] : vector<4xf16> -> f16
  %46 = vector.extract %rhs_data[1] : vector<4xf16> -> f16
  %47 = scalar.extf %45 : f16 to f32
  %48 = scalar.extf %46 : f16 to f32
  %49 = scalar.fmaf %47, %48, %44 : f32
  %50 = vector.extract %lhs_data[3] : vector<4xf16> -> f16
  %51 = vector.extract %rhs_data[3] : vector<4xf16> -> f16
  %52 = scalar.extf %50 : f16 to f32
  %53 = scalar.extf %51 : f16 to f32
  %54 = scalar.fmaf %52, %53, %49 : f32
  %55 = vector.from_elements %21, %32, %43, %54 : vector<4xf32>
  %result = vector.fragment<result> %55 shape [%m, %n] : vector<4xf32>
  func.return %result : vector<4xf32>
}

