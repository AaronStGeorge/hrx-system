load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "memory_footprint",
    srcs = ["memory_footprint.c"],
    hdrs = ["memory_footprint.h"],
    deps = [
        "//loom/src/loom/analysis:vector_memory_footprint",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "to_scalar",
    srcs = [
        "to_scalar.c",
        "to_scalar_aggregates.c",
        "to_scalar_aggregates.h",
        "to_scalar_core.h",
        "to_scalar_descriptors.c",
        "to_scalar_descriptors.h",
        "to_scalar_lanes.c",
        "to_scalar_lanes.h",
        "to_scalar_memory.c",
        "to_scalar_memory.h",
        "to_scalar_quantized.c",
        "to_scalar_quantized.h",
        "to_scalar_reductions.c",
        "to_scalar_reductions.h",
        "to_scalar_structural.c",
        "to_scalar_structural.h",
        "to_scalar_tables.c",
        "to_scalar_tables.h",
        "to_scalar_terms.c",
        "to_scalar_terms.h",
        "to_scalar_transforms.c",
        "to_scalar_transforms.h",
