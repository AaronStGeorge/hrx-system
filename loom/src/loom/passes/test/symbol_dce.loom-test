// RUN: pass cfg-simplify,dce,symbol-dce

test.target<low_core> @test_target

func.decl @add_i32(%lhs: i32, %rhs: i32) -> (i32)

func.def public @entry(%lhs: i32, %rhs: i32) -> (i32) {
  %is_vm = scalar.constant 1 : i1
  cfg.cond_br %is_vm, ^vm, ^fallback
^vm:
  %vm_sum = low.invoke @vm_add(%lhs, %rhs) : (i32, i32) -> (i32)
  cfg.br ^join(%vm_sum: i32)
^fallback:
  %fallback_sum = low.invoke @fallback_add(%lhs, %rhs) : (i32, i32) -> (i32)
  cfg.br ^join(%fallback_sum: i32)
^join(%sum: i32):
  func.return %sum : i32
}

low.func.def target(@test_target) @vm_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

low.func.def target(@test_target) @fallback_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ----
test.target<low_core> @test_target

func.def public @entry(%lhs: i32, %rhs: i32) -> (i32) {
  %vm_sum = low.invoke @vm_add(%lhs, %rhs) : (i32, i32) -> (i32)
  func.return %vm_sum : i32
}

low.func.def target(@test_target) @vm_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ====

// RUN: pass symbol-dce

test.target<low_core> @test_target

func.decl @add_i32(%lhs: i32, %rhs: i32) -> (i32)

func.def public @entry(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = low.invoke @live_add(%lhs, %rhs) : (i32, i32) -> (i32)
  func.return %sum : i32
}

func.def @dead_wrapper(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = low.invoke @dead_add(%lhs, %rhs) : (i32, i32) -> (i32)
  func.return %sum : i32
}

low.func.def target(@test_target) @live_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

low.func.def target(@test_target) @dead_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ----
test.target<low_core> @test_target

func.def public @entry(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = low.invoke @live_add(%lhs, %rhs) : (i32, i32) -> (i32)
  func.return %sum : i32
}

low.func.def target(@test_target) @live_add(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ====

// RUN: pass symbol-dce

test.target<low_core> @test_target

low.func.def target(@test_target) @dead_add(%lhs: reg<test.i32>) -> (reg<test.i32>) {
  low.return %lhs : reg<test.i32>
}

func.def public @entry(%lhs: i32) -> (i32) {
  // ERROR@+1: SYMBOL/002 "missing_low"
  %sum = low.invoke @missing_low(%lhs) : (i32) -> (i32)
  func.return %sum : i32
}
