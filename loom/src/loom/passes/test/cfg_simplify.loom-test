func.def @threads_direct_branch_through_known_block_arg(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^left, ^exit : i1
^left:
  cfg.br ^dispatch(%cond : i1)
^dispatch(%known : i1):
  cfg.cond_br %known, ^taken, ^dead : i1
^taken:
  cfg.br ^ret(%a : i32)
^dead:
  cfg.br ^ret(%b : i32)
^exit:
  cfg.br ^ret(%b : i32)
^ret(%result : i32):
  func.return %result : i32
}

