func.def @folds_dominated_true_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %sum = test.addi %a, %a : i32
  cfg.br ^inner
^inner:
  cfg.cond_br %cond, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%sum : i32)
^dead:
  cfg.br ^join(%b : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_true_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %sum = test.addi %a, %a : i32
  cfg.br ^join(%sum : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @folds_dominated_false_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  %sum = test.addi %b, %b : i32
  cfg.br ^inner
^inner:
  cfg.cond_br %cond, ^dead, ^taken : i1
^dead:
  cfg.br ^join(%a : i32)
^taken:
  cfg.br ^join(%sum : i32)
^join(%result : i32):
  func.return %result : i32
}

