// ====

func.def @folds_dominated_boolean_and_relations(%i: index, %n: index, %j: index, %z: index, %a: i32, %b: i32) -> (i32) {
  %i_in_range = index.cmp slt, %i, %n : index
  %j_nonzero = index.cmp ne, %j, %z : index
  %cond = scalar.andi %i_in_range, %j_nonzero : i1
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %i_again = index.cmp slt, %i, %n : index
  %j_again = index.cmp ne, %j, %z : index
  %both = scalar.andi %i_again, %j_again : i1
  cfg.cond_br %both, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%a : i32)
^dead:
  cfg.br ^join(%b : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_boolean_and_relations(%i: index, %n: index, %j: index, %z: index, %a: i32, %b: i32) -> (i32) {
  %i_in_range = index.cmp slt, %i, %n : index
  %j_nonzero = index.cmp ne, %j, %z : index
  %cond = scalar.andi %i_in_range, %j_nonzero : i1
  cfg.cond_br %cond, ^taken, ^else : i1
^taken:
  cfg.br ^join(%a : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @removes_dependent_block_args(%layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^join(%layout, %view : encoding<layout>, view<4xf32, %layout>)
^join(%arg_layout : encoding<layout>, %arg_view : view<4xf32, %arg_layout>):
  test.use %arg_view : view<4xf32, %arg_layout>
  func.return
}

// ----
func.def @removes_dependent_block_args(%layout: encoding<layout>, %view: view<4xf32, %layout>) {
  test.use %view : view<4xf32, %layout>
  func.return
}

// ====

func.def @preserves_unused_block_arg_with_type_use(%guard: i1, %layout_a: encoding<layout>, %layout_b: encoding<layout>, %buffer: buffer, %offset: offset) {
  cfg.cond_br %guard, ^left, ^right : i1
^left:
  cfg.br ^join(%layout_a : encoding<layout>)
^right:
  cfg.br ^join(%layout_b : encoding<layout>)
^join(%arg_layout : encoding<layout>):
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %arg_layout>
  func.return
}

// ====

func.def @fuses_single_predecessor_block_args(%a: i32) -> (i32) {
  cfg.br ^middle(%a : i32)
^middle(%x : i32):
  cfg.br ^exit(%x : i32)
^exit(%result : i32):
  func.return %result : i32
}

// ----
func.def @fuses_single_predecessor_block_args(%a: i32) -> (i32) {
  func.return %a : i32
}

// ====

func.def @fuses_block_with_cond_terminator(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.br ^dispatch(%a : i32)
^dispatch(%x : i32):
  %sum = test.addi %x, %b : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %sum : i32
^else:
  func.return %b : i32
}

// ----
func.def @fuses_block_with_cond_terminator(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %sum = test.addi %a, %b : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %sum : i32
^else:
  func.return %b : i32
}

// ====

func.def @preserves_loop_carried_args(%n: index, %seed: i32, %x: i32) -> (i32) {
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  cfg.br ^loop(%zero, %seed : index, i32)
^loop(%i : index, %acc : i32):
  %keep_going = index.cmp slt, %i, %n : index
  cfg.cond_br %keep_going, ^body, ^exit : i1
^body:
  %next = test.addi %acc, %x : i32
  %next_i = index.add %i, %one : index
  cfg.br ^loop(%next_i, %next : index, i32)
^exit:
  func.return %acc : i32
}

// ====

func.def @removes_self_forwarded_loop_arg(%cond: i1, %seed: i32) -> (i32) {
  cfg.br ^loop(%seed : i32)
^loop(%carry : i32):
  cfg.cond_br %cond, ^body, ^exit : i1
^body:
  cfg.br ^loop(%carry : i32)
^exit:
  func.return %carry : i32
}

// ----
func.def @removes_self_forwarded_loop_arg(%cond: i1, %seed: i32) -> (i32) {
  cfg.br ^loop
^loop:
  cfg.cond_br %cond, ^loop, ^exit : i1
^exit:
  func.return %seed : i32
}

// ====

func.def @removes_self_forwarded_dependent_loop_args(%cond: i1, %layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^loop(%layout, %view : encoding<layout>, view<4xf32, %layout>)
^loop(%arg_layout : encoding<layout>, %arg_view : view<4xf32, %arg_layout>):
  cfg.cond_br %cond, ^body, ^exit : i1
^body:
  cfg.br ^loop(%arg_layout, %arg_view : encoding<layout>, view<4xf32, %arg_layout>)
^exit:
  test.use %arg_view : view<4xf32, %arg_layout>
  func.return
}

// ----
func.def @removes_self_forwarded_dependent_loop_args(%cond: i1, %layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^loop
^loop:
  cfg.cond_br %cond, ^loop, ^exit : i1
^exit:
  test.use %view : view<4xf32, %layout>
  func.return
}

// ====

func.def @preserves_effectful_forward_block(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  cfg.cond_br %cond, ^effect, ^exit : i1
^effect:
  view.store %value, %view[0] : f32, view<1xf32, %layout>
  cfg.br ^exit
^exit:
  func.return
}
