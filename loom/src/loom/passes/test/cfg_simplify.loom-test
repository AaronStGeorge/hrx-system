  cfg.cond_br %cond, ^dispatch, ^exit : i1
^dispatch:
  cfg.cond_br %cond, ^taken, ^dead : i1
^taken:
  cfg.br ^ret(%a : i32)
^dead:
  cfg.br ^ret(%b : i32)
^exit:
  cfg.br ^ret(%b : i32)
^ret(%result : i32):
