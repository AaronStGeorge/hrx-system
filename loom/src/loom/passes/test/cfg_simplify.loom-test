func.def @folds_transported_compare_result_and_drops_args(%guard: i1, %li: index, %ln: index, %ri: index, %rn: index) -> (i1) {
  cfg.cond_br %guard, ^left, ^right : i1
^left:
  %left_cond = index.cmp slt, %li, %ln : index
  cfg.cond_br %left_cond, ^left_pass, ^exit : i1
^left_pass:
  cfg.br ^join(%li, %ln : index, index)
^right:
  %right_cond = index.cmp slt, %ri, %rn : index
  cfg.cond_br %right_cond, ^right_pass, ^exit : i1
^right_pass:
  cfg.br ^join(%ri, %rn : index, index)
^join(%x : index, %y : index):
  %again = index.cmp slt, %x, %y : index
  func.return %again : i1
^exit:
  %false = scalar.constant 0 : i1
  func.return %false : i1
}

// ----
func.def @folds_transported_compare_result_and_drops_args(%guard: i1, %li: index, %ln: index, %ri: index, %rn: index) -> (i1) {
  cfg.cond_br %guard, ^left, ^right : i1
^left:
  %left_cond = index.cmp slt, %li, %ln : index
  cfg.cond_br %left_cond, ^join, ^exit : i1
^right:
  %right_cond = index.cmp slt, %ri, %rn : index
  cfg.cond_br %right_cond, ^join, ^exit : i1
^join:
  %again = scalar.constant true : i1
  func.return %again : i1
^exit:
  %false = scalar.constant 0 : i1
  func.return %false : i1
}

