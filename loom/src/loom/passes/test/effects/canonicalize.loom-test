// RUN: pass canonicalize

// An unannotated function body with no read-like or write-like effects is pure
// by structure. Canonicalize can stamp that fact onto call sites without a
// recursive body walk.
func.def @pure_by_body(%value: f32) -> (f32) {
  %doubled = scalar.addf %value, %value : f32
  func.return %doubled : f32
}

func.def @caller(%value: f32) -> (f32) {
  %result = func.call @pure_by_body(%value) : (f32) -> (f32)
  func.return %result : f32
}

// ----
func.def @pure_by_body(%value: f32) -> (f32) {
  %doubled = scalar.addf %value, %value : f32
  func.return %doubled : f32
}

func.def @caller(%value: f32) -> (f32) {
  %result = func.call pure @pure_by_body(%value) : (f32) -> (f32)
  func.return %result : f32
}

// ====

// Canonicalize's mini-DCE can erase dead region ops when their nested bodies
// have no writes. The subtree erase removes child operand uses too, so view and
// layout producers cascade away instead of lingering behind unreachable loads.
func.def @dead_read_only_region_dies(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %result = scf.if %cond -> (f32) {
    %loaded = view.load %view[0] : view<1xf32, %layout> -> f32
    scf.yield %loaded : f32
  } else {
    scf.yield %value : f32
  }
  func.return
}

// ----
func.def @dead_read_only_region_dies(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  func.return
}

// ====

// Mini-DCE uses the same region effect summaries for scf.while: dead read-only
// loop regions disappear, but write-bearing ones remain covered by DCE tests.
func.def @dead_read_only_while_dies(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %result = scf.while(%before = %value : f32) -> (f32) {
    scf.condition %cond, %before : i1, f32
  } do(%body: f32) {
    %loaded = view.load %view[0] : view<1xf32, %layout> -> f32
    scf.yield %loaded : f32
  }
  func.return
}

// ----
func.def @dead_read_only_while_dies(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  func.return
}

// ====

// The canonicalize pass drives the body projection of a function-like op. A
// projected config region uses the same driver through explicit region APIs,
// but it is not an accidental part of a body pass.
test.split_func @split_func_body_only_canonicalize(%arg: i32) {
  %zero = test.constant 0 : i32
  %sum = test.addi %arg, %zero : i32
  test.use %sum : i32
  test.yield
} config(%cfg_arg: i32) {
  %cfg_zero = test.constant 0 : i32
  %cfg_sum = test.addi %cfg_arg, %cfg_zero : i32
  test.use %cfg_sum : i32
  test.yield
}

// ----
test.split_func @split_func_body_only_canonicalize(%arg: i32) {
  test.use %arg : i32
  test.yield
} config(%cfg_arg: i32) {
  %cfg_zero = test.constant 0 : i32
  %cfg_sum = test.addi %cfg_arg, %cfg_zero : i32
  test.use %cfg_sum : i32
  test.yield
}
