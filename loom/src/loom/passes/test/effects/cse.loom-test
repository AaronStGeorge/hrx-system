// CSE must use effective traits, not only static vtable traits. func.call is
// statically unknown-effect, but canonicalize can stamp pure call sites when
// the callee body has no observable effects.
// RUN: pass canonicalize,cse
func.def @pure_identity(%value: i32) -> (i32) {
  func.return %value : i32
}

func.def @pure_calls_cse_after_canonicalize(%value: i32) -> (i32, i32) {
  %lhs = func.call @pure_identity(%value) : (i32) -> (i32)
  %rhs = func.call @pure_identity(%value) : (i32) -> (i32)
  func.return %lhs, %rhs : i32, i32
}

// ----
func.def @pure_identity(%value: i32) -> (i32) {
  func.return %value : i32
}

func.def @pure_calls_cse_after_canonicalize(%value: i32) -> (i32, i32) {
  %lhs = func.call pure @pure_identity(%value) : (i32) -> (i32)
  func.return %lhs, %lhs : i32, i32
}

// ====

// func.apply uses the same call-site purity propagation and effective-trait
// path as func.call.
// RUN: pass canonicalize,cse
func.template<test.effect> @pure_template(%value: i32) -> (i32) {
  func.return %value : i32
}

func.def @pure_applies_cse_after_canonicalize(%value: i32) -> (i32, i32) {
  %lhs = func.apply @pure_template(%value) : (i32) -> (i32)
  %rhs = func.apply @pure_template(%value) : (i32) -> (i32)
  func.return %lhs, %rhs : i32, i32
}

// ----
func.template<test.effect> @pure_template(%value: i32) -> (i32) {
  func.return %value : i32
}

func.def @pure_applies_cse_after_canonicalize(%value: i32) -> (i32, i32) {
  %lhs = func.apply pure @pure_template(%value) : (i32) -> (i32)
  func.return %lhs, %lhs : i32, i32
}

// ====

// Unresolved or effectful callees remain unknown-effect. Even identical calls
// are not CSE candidates until a pass has explicit proof that the callee is
// pure.
// RUN: pass canonicalize,cse
func.decl @unknown_effects(%value: i32) -> (i32)

func.def @unknown_effect_calls_do_not_cse(%value: i32) -> (i32, i32) {
  %lhs = func.call @unknown_effects(%value) : (i32) -> (i32)
  %rhs = func.call @unknown_effects(%value) : (i32) -> (i32)
  func.return %lhs, %rhs : i32, i32
}

// ====

// A write nested inside a region op is a barrier for memory reads in the
// enclosing scope. The second load must not be replaced with the first load.
// RUN: pass cse
func.def @nested_write_blocks_outer_load_cse(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %before = view.load %view[0] : view<1xf32, %layout> -> f32
  scf.if %cond {
    view.store %value, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  } else {
    scf.yield
  }
  %after = view.load %view[0] : view<1xf32, %layout> -> f32
  func.return %after : f32
}

// ====

// scf.while contributes both before/after region effects to the parent op's
// summary, so a nested write still blocks CSE of surrounding loads.
// RUN: pass cse
func.def @nested_while_write_blocks_outer_load_cse(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %before = view.load %view[0] : view<1xf32, %layout> -> f32
  %result = scf.while(%loop_value = %value : f32) -> (f32) {
    scf.condition %cond, %loop_value : i1, f32
  } do(%body: f32) {
    view.store %body, %view[0] : f32, view<1xf32, %layout>
    scf.yield %body : f32
  }
  %after = view.load %view[0] : view<1xf32, %layout> -> f32
  func.return %after : f32
}

// ====

// Descriptor-backed low ops must expose their descriptor effects through the
// generic op trait cache. test.add.i32 is pure even though low.op's static
// vtable default is conservative.
// RUN: pass cse
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_ops_cse(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>, reg<test.i32>) asm<test.low.core> {
  %a = test.add.i32 %lhs, %rhs
  %b = test.add.i32 %lhs, %rhs
  return %a, %b
}

// ----
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_ops_cse(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>, reg<test.i32>) {
  %a = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %a, %a : reg<test.i32>, reg<test.i32>
}

// ====

// Descriptor-backed reads are CSE candidates until a descriptor-backed write
// invalidates the read scope.
// RUN: pass cse
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_reads_cse(%ptr: reg<test.ptr>) -> (reg<test.i32 x4>) asm<test.low.core> {
  %a = test.load.v4i32 %ptr
  %b = test.load.v4i32 %ptr
  %out = test.add.v4i32 %a, %b
  return %out
}

// ----
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_reads_cse(%ptr: reg<test.ptr>) -> (reg<test.i32 x4>) {
  %a = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %out = low.op<test.add.v4i32>(%a, %a) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  low.return %out : reg<test.i32 x4>
}

// ====

// Descriptor-backed writes are barriers for descriptor-backed reads.
// RUN: pass cse
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_write_blocks_read_cse(%ptr: reg<test.ptr>, %value: reg<test.i32 x4>) -> (reg<test.i32 x4>) asm<test.low.core> {
  %before = test.load.v4i32 %ptr
  test.store.v4i32 %ptr, %value
  %after = test.load.v4i32 %ptr
  %out = test.add.v4i32 %before, %after
  return %out
}

// ----
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @descriptor_low_write_blocks_read_cse(%ptr: reg<test.ptr>, %value: reg<test.i32 x4>) -> (reg<test.i32 x4>) {
  %before = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  low.op<test.store.v4i32>(%ptr, %value) : (reg<test.ptr>, reg<test.i32 x4>)
  %after = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %out = low.op<test.add.v4i32>(%before, %after) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  low.return %out : reg<test.i32 x4>
}
