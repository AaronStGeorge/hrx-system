// RUN: pass kernel-async-legality

func.def @single_group_wait() {
  %group = kernel.async.group -> kernel.async.group
  kernel.async.wait %group {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @two_group_pipeline_waits_oldest_first() {
  %load0 = kernel.async.group -> kernel.async.group
  %load1 = kernel.async.group -> kernel.async.group
  kernel.async.wait %load0 {newer_groups = 1} : kernel.async.group
  kernel.async.wait %load1 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_wrong_newer_group_count() {
  %load0 = kernel.async.group -> kernel.async.group
  %load1 = kernel.async.group -> kernel.async.group
  // ERROR@+1: LOWERING/001 "kernel.async.wait" "kernel-async-legality" "newer_groups is 0 but 1 younger async group(s) remain outstanding"
  kernel.async.wait %load0 {newer_groups = 0} : kernel.async.group
  kernel.async.wait %load1 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_wait_before_local_group(%group: kernel.async.group) {
  // ERROR@+1: LOWERING/001 "kernel.async.wait" "kernel-async-legality" "waited async group is not committed in the current straight-line async stream"
  kernel.async.wait %group {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_completed_group_wait() {
  %load0 = kernel.async.group -> kernel.async.group
  %load1 = kernel.async.group -> kernel.async.group
  kernel.async.wait %load1 {newer_groups = 0} : kernel.async.group
  // ERROR@+1: LOWERING/001 "kernel.async.wait" "kernel-async-legality" "async group was already completed by an earlier wait in the current stream"
  kernel.async.wait %load0 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_carried_group_use() {
  // ERROR@+1: LOWERING/001 "kernel.async.group" "kernel-async-legality" "carried async groups require pipeline-aware legality analysis before lowering"
  %group = kernel.async.group -> kernel.async.group
  test.use %group : kernel.async.group
  func.return
}

// ====

func.def @rejects_unwaited_group() {
  // ERROR@+1: LOWERING/001 "kernel.async.group" "kernel-async-legality" "async group has no wait in the current async stream"
  %group = kernel.async.group -> kernel.async.group
  func.return
}

// ====

func.def @rejects_region_wait_without_parent_wait(%cond: i1) {
  // ERROR@+1: LOWERING/001 "kernel.async.group" "kernel-async-legality" "async group is not waited before leaving its block"
  %group = kernel.async.group -> kernel.async.group
  scf.if %cond {
    kernel.async.wait %group {newer_groups = 0} : kernel.async.group
    scf.yield
  } else {
    scf.yield
  }
  func.return
}

// ====

func.def @allows_static_disjoint_pending_async_destinations(%input: buffer) {
  %zero = index.constant 0 : offset
  %sixteen = index.constant 16 : offset
  %bytes = index.constant 64 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %source0 = buffer.view %global[%zero] : buffer -> view<16xi8, #dense>
  %source1 = buffer.view %global[%sixteen] : buffer -> view<16xi8, #dense>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %dest0 = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %dest1 = buffer.view %scratch[%sixteen] : buffer -> view<16xi8, #dense>
  %copy0 = kernel.async.copy %source0 to %dest0 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group0 = kernel.async.group %copy0 : kernel.async.token -> kernel.async.group
  %copy1 = kernel.async.copy %source1 to %dest1 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group1 = kernel.async.group %copy1 : kernel.async.token -> kernel.async.group
  kernel.async.wait %group0 {newer_groups = 1} : kernel.async.group
  kernel.async.wait %group1 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_overlapping_pending_async_destinations(%input: buffer) {
  %zero = index.constant 0 : offset
  %bytes = index.constant 64 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %source = buffer.view %global[%zero] : buffer -> view<16xi8, #dense>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %dest0 = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %dest1 = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %copy0 = kernel.async.copy %source to %dest0 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group0 = kernel.async.group %copy0 : kernel.async.token -> kernel.async.group
  %copy1 = kernel.async.copy %source to %dest1 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  // ERROR@+1: LOWERING/001 "kernel.async.group" "kernel-async-legality" "pending async destination may overlap an earlier uncompleted async destination"
  %group1 = kernel.async.group %copy1 : kernel.async.token -> kernel.async.group
  kernel.async.wait %group0 {newer_groups = 1} : kernel.async.group
  kernel.async.wait %group1 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_unknown_same_root_pending_async_overlap(%input: buffer, %dest_offset: offset) {
  %zero = index.constant 0 : offset
  %bytes = index.constant 64 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %source = buffer.view %global[%zero] : buffer -> view<16xi8, #dense>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %dest0 = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %dest1 = buffer.view %scratch[%dest_offset] : buffer -> view<16xi8, #dense>
  %copy0 = kernel.async.copy %source to %dest0 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group0 = kernel.async.group %copy0 : kernel.async.token -> kernel.async.group
  %copy1 = kernel.async.copy %source to %dest1 {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  // ERROR@+1: LOWERING/001 "kernel.async.group" "kernel-async-legality" "pending async destination may overlap an earlier uncompleted async destination"
  %group1 = kernel.async.group %copy1 : kernel.async.token -> kernel.async.group
  kernel.async.wait %group0 {newer_groups = 1} : kernel.async.group
  kernel.async.wait %group1 {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_destination_overwrite_before_wait(%input: buffer) {
  %zero = index.constant 0 : offset
  %bytes = index.constant 64 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %source = buffer.view %global[%zero] : buffer -> view<16xi8, #dense>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %dest = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %copy = kernel.async.copy %source to %dest {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group = kernel.async.group %copy : kernel.async.token -> kernel.async.group
  %value = scalar.constant 1 : i8
  // ERROR@+1: LOWERING/001 "view.store" "kernel-async-legality" "synchronous write may overwrite a pending async destination before wait"
  view.store %value, %dest[0] : i8, view<16xi8, #dense>
  kernel.async.wait %group {newer_groups = 0} : kernel.async.group
  func.return
}

// ====

func.def @rejects_destination_read_before_wait(%input: buffer) {
  %zero = index.constant 0 : offset
  %bytes = index.constant 64 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %source = buffer.view %global[%zero] : buffer -> view<16xi8, #dense>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %dest = buffer.view %scratch[%zero] : buffer -> view<16xi8, #dense>
  %copy = kernel.async.copy %source to %dest {cache_scope = cu, cache_temporal = regular, direction = global_to_workgroup} : view<16xi8, #dense> to view<16xi8, #dense> -> kernel.async.token
  %group = kernel.async.group %copy : kernel.async.token -> kernel.async.group
  // ERROR@+1: LOWERING/001 "view.load" "kernel-async-legality" "synchronous read may observe a pending async destination before wait"
  %loaded = view.load %dest[0] : view<16xi8, #dense> -> i8
  test.use %loaded : i8
  kernel.async.wait %group {newer_groups = 0} : kernel.async.group
  func.return
}
