load("//loom/build_tools/bazel:loom_check.bzl", "loom_check_test", "loom_check_test_suite")

package(
    default_visibility = ["//visibility:public"],
    licenses = ["notice"],  # Apache 2.0
)

loom_check_test_suite(
    name = "core_test",
    srcs = [
        "low_allocation.loom-test",
        "low_allocation_materialization.loom-test",
        "low_packet.loom-test",
        "low_schedule.loom-test",
        "low_verify.loom-test",
        "pass.loom-test",
        "requires.loom-test",
        "roundtrip.loom-test",
        "verify.loom-test",
    ],
)

loom_check_test(
    name = "run",
    src = "run.loom-test",
    data = ["//loom/src/loom/tools/iree-run-loom"],
    env = {
        "LOOM_CHECK_IREE_RUN_LOOM": "$(rootpath //loom/src/loom/tools/iree-run-loom)",
    },
)

test_suite(
    name = "test",
    tests = [
        ":core_test",
        ":run",
    ],
)
