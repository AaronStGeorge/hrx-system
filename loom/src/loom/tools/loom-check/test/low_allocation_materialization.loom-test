target.snapshot @vm_snapshot {artifact_format = vm_bytecode, codegen_format = vm, data_layout = "", default_pointer_bitwidth = 64, index_bitwidth = 64, memory_space_constant = 0, memory_space_descriptor = 0, memory_space_generic = 0, memory_space_global = 0, memory_space_host = 0, memory_space_private = 0, memory_space_workgroup = 0, offset_bitwidth = 64, target_cpu = "", target_features = "", target_triple = "iree-vm"}

