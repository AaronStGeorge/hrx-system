target.config @vm_config {contract_feature_bits = 0, contract_set_key = "test.low.core"}

target.bundle @test_target {config = @vm_config, export_plan = @vm_export, snapshot = @vm_snapshot}

low.func.def target(@test_target) @spill(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>) -> (reg<test.i32>) {
  low.spill %a, @spill_spill_0 {offset = 0} : reg<test.i32>
  %8 = low.reload @spill_spill_0 {offset = 0} : reg<test.i32>
  %ab = low.op<test.add.i32>(%8, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.spill %ab, @spill_spill_1 {offset = 0} : reg<test.i32>
  %bc = low.op<test.add.i32>(%b, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %10 = low.reload @spill_spill_1 {offset = 0} : reg<test.i32>
  %sum = low.op<test.add.i32>(%10, %bc) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %9 = low.reload @spill_spill_0 {offset = 0} : reg<test.i32>
  %out = low.op<test.add.i32>(%sum, %9) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

low.slot @spill_spill_0 {align = 4, function = @spill, size = 4, space = private}

low.slot @spill_spill_1 {align = 4, function = @spill, size = 4, space = private}

