target.config @vm_config {contract_feature_bits = 0, contract_set_key = "iree.vm.core"}

target.bundle @vm_target {config = @vm_config, export_plan = @vm_export, snapshot = @vm_snapshot}

low.func.def target(@vm_target) @spill(%a: reg<vm.i32>, %b: reg<vm.i32>, %c: reg<vm.i32>) -> (reg<vm.i32>) {
  low.spill %c, @spill_spill_0 {offset = 0} : reg<vm.i32>
  %ab = low.op<iree.vm.add.i32>(%a, %b) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  %8 = low.reload @spill_spill_0 {offset = 0} : reg<vm.i32>
  %bc = low.op<iree.vm.add.i32>(%b, %8) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.spill %bc, @spill_spill_1 {offset = 0} : reg<vm.i32>
  %9 = low.reload @spill_spill_1 {offset = 0} : reg<vm.i32>
  %sum = low.op<iree.vm.add.i32>(%ab, %9) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  %out = low.op<iree.vm.add.i32>(%sum, %a) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %out : reg<vm.i32>
}

low.slot @spill_spill_0 {align = 4, function = @spill, size = 4, space = private}

low.slot @spill_spill_1 {align = 4, function = @spill, size = 4, space = private}

