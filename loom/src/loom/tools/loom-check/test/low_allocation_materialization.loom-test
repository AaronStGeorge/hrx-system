// RUN: pass low-materialize-allocation{budgets=test.i32=2}

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @spill(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>) -> (reg<test.i32>) {
  %ab = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %bc = low.op<test.add.i32>(%b, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %sum = low.op<test.add.i32>(%ab, %bc) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%sum, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

// ----
target.profile @test_target preset("test-low")

low.func.def target(@test_target) @spill(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>) -> (reg<test.i32>) {
  %spill_spill_storage_0 = low.storage.reserve {byte_alignment = 4, byte_length = 4} : low.storage<private>
  %spill_spill_storage_1 = low.storage.reserve {byte_alignment = 4, byte_length = 4} : low.storage<private>
  low.spill %a, %spill_spill_storage_0 : reg<test.i32>, low.storage<private>
  %10 = low.reload %spill_spill_storage_0 : low.storage<private> -> reg<test.i32>
  %ab = low.op<test.add.i32>(%10, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.spill %ab, %spill_spill_storage_1 : reg<test.i32>, low.storage<private>
  %bc = low.op<test.add.i32>(%b, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %12 = low.reload %spill_spill_storage_1 : low.storage<private> -> reg<test.i32>
  %sum = low.op<test.add.i32>(%12, %bc) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %11 = low.reload %spill_spill_storage_0 : low.storage<private> -> reg<test.i32>
  %out = low.op<test.add.i32>(%sum, %11) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

// ====

// RUN: pass low-materialize-allocation{budgets=test.i32=2,diagnostics=spills}

target.profile @test_target preset("test-low")

// WARNING@+1: BACKEND/009 "test_target" "value 'a'" "test.i32" "spill_spill_storage_0"
low.func.def target(@test_target) @spill(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>) -> (reg<test.i32>) {
  // WARNING@+1: BACKEND/009 "test_target" "value 'ab'" "test.i32" "spill_spill_storage_1"
  %ab = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %bc = low.op<test.add.i32>(%b, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %sum = low.op<test.add.i32>(%ab, %bc) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%sum, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

