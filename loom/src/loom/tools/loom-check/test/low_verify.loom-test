target.bundle @vm_target {snapshot = @vm_snapshot, export_plan = @vm_export, config = @vm_config}
// ERROR@+1: LOWERING/003 "missing.low"
low.func.def target(@vm_target) @constant() -> (reg<vm.i32>) {
  %c0 = low.const<iree.vm.const.i32> {i32_value = 7} : reg<vm.i32>
  low.return %c0 : reg<vm.i32>
}

