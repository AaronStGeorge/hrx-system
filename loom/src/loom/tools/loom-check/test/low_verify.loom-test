target.config @vm_config {contract_set_key = "missing.low", contract_feature_bits = 0}
target.bundle @test_target {snapshot = @vm_snapshot, export_plan = @vm_export, config = @vm_config}
// ERROR@+1: LOWERING/003 "missing.low"
low.func.def target(@test_target) @constant() -> (reg<test.i32>) {
  %c0 = low.const<test.const.i32> {i32_value = 7} : reg<test.i32>
  low.return %c0 : reg<test.i32>
}

