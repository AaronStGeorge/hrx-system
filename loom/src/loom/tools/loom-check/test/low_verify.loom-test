test.target<low_core> @test_target
low.func.def target(@test_target) @constant() -> (reg<test.i32>) {
  // ERROR@+1: LOWERING/010 "2147483648"
  %c0 = low.const<test.const.i32> {i32_value = 2147483648} : reg<test.i32>
