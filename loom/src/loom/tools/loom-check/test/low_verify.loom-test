// ====

test.target<low_core> @test_target
low.func.def target(@test_target) @branch(%arg: reg<test.i32>) -> (reg<test.i32>) {
  // ERROR@+1: STRUCTURE/025 "low.br" "successor 0" "expected 1"
  low.br ^exit
^exit(%value: reg<test.i32>):
  low.return %value : reg<test.i32>
}

// ====

test.target<low_core> @test_target
low.func.def target(@test_target) @branch(%arg: reg<test.i32>) {
  // ERROR@+1: STRUCTURE/026 "low.br" "successor 0" "expected reg<test.i64>"
  low.br ^exit(%arg: reg<test.i32>)
^exit(%value: reg<test.i64>):
  low.return
}

// ====

test.target<low_core> @test_target
low.func.def target(@test_target) @branch(%cond: reg<test.i32>) {
  // ERROR@+1: STRUCTURE/025 "low.cond_br" "successor 0" "expected 1"
  low.cond_br %cond, ^then, ^else : reg<test.i32>
^then(%value: reg<test.i32>):
  low.return
^else:
  low.return
}
