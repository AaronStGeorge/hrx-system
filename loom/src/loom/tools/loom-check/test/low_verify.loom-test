low.func.def target(@test_target) @branch(%cond : reg<test.i32>) {
  // ERROR@+1: STRUCTURE/025 "low.cond_br" "successor 0" "expected 1"
  low.cond_br %cond, ^then, ^else : reg<test.i32>
^then(%value : reg<test.i32>):
  low.return
^else:
  low.return
}
