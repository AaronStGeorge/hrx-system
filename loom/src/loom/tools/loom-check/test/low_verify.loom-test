// RUN: verify

// ====

target.snapshot @vm_snapshot {codegen_format = vm, target_triple = "iree-vm", data_layout = "", artifact_format = vm_bytecode, target_cpu = "", target_features = "", default_pointer_bitwidth = 64, index_bitwidth = 64, offset_bitwidth = 64, memory_space_generic = 0, memory_space_global = 0, memory_space_workgroup = 0, memory_space_constant = 0, memory_space_private = 0, memory_space_host = 0, memory_space_descriptor = 0}
target.export @vm_export {export_symbol = "add", abi = vm_module_function, linkage = default, hal_binding_alignment = 0, hal_workgroup_size_x = 0, hal_workgroup_size_y = 0, hal_workgroup_size_z = 0, hal_flat_workgroup_size_min = 0, hal_flat_workgroup_size_max = 0, hal_buffer_resource_flags = 0}
target.config @vm_config {contract_set_key = "test.low.core", contract_feature_bits = 0}
target.bundle @test_target {snapshot = @vm_snapshot, export_plan = @vm_export, config = @vm_config}
low.func.def target(@test_target) @add(%lhs : reg<test.i32>, %rhs : reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ====

target.preset @test_target {key = "test-low", source = @concat}
low.func.def target(@test_target) @concat(%lo : reg<test.i32>, %hi : reg<test.i32>) -> (reg<test.i32 x2>) {
  %pair = low.concat(%lo, %hi) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32 x2>
  %lane = low.slice %pair[1] : reg<test.i32 x2> -> reg<test.i32>
  low.return %pair : reg<test.i32 x2>
}

// ====

target.preset @test_target {key = "test-low", source = @copy_bad_units}
low.func.def target(@test_target) @copy_bad_units(%pair : reg<test.i32 x2>) {
  // ERROR@+1: LOWERING/024
  %copy = low.copy %pair : reg<test.i32 x2> -> reg<test.i32>
  low.return
}

// ====

target.preset @test_target {key = "test-low", source = @slice_bad_class}
low.func.def target(@test_target) @slice_bad_class(%pair : reg<test.i32 x2>) {
  // ERROR@+1: TYPE/001
  %lane = low.slice %pair[0] : reg<test.i32 x2> -> reg<test.i64>
  low.return
}

// ====

target.preset @test_target {key = "test-low", source = @slice_negative_offset}
low.func.def target(@test_target) @slice_negative_offset(%pair : reg<test.i32 x2>) {
  // ERROR@+1: LOWERING/024
  %lane = low.slice %pair[-1] : reg<test.i32 x2> -> reg<test.i32>
  low.return
}

// ====

target.preset @test_target {key = "test-low", source = @slice_out_of_range}
low.func.def target(@test_target) @slice_out_of_range(%pair : reg<test.i32 x2>) {
  // ERROR@+1: LOWERING/024
  %lane = low.slice %pair[2] : reg<test.i32 x2> -> reg<test.i32>
  low.return
}

// ====

target.preset @test_target {key = "test-low", source = @concat_bad_class}
low.func.def target(@test_target) @concat_bad_class(%lo : reg<test.i32>, %hi : reg<test.i64>) {
  // ERROR@+1: TYPE/001
  %pair = low.concat(%lo, %hi) : (reg<test.i32>, reg<test.i64>) -> reg<test.i32 x2>
