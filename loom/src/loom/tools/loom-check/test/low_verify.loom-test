}

// ====

target.preset @test_target {key = "test-low", source = @concat_bad_units}
low.func.def target(@test_target) @concat_bad_units(%lo : reg<test.i32>) {
  // ERROR@+1: TYPE/004
  %pair = low.concat(%lo) : (reg<test.i32>) -> reg<test.i32 x2>
  low.return
}

