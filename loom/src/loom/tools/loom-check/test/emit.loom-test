// RUN: emit llvmir

func.def @add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}
// ----
source_filename = "loom/src/loom/tools/loom-check/test/emit.loom-test"
target datalayout = "e-p:64:64-i64:64-n8:16:32:64-S128"
target triple = "loom-test64-unknown-none"

define internal i32 @add(i32 %lhs, i32 %rhs) {
entry:
  %sum = add i32 %lhs, %rhs
  ret i32 %sum
}
