// RUN: emit low-schedule-json @resource_diag diagnostics=resources

target.profile @test_target preset("test-low")

// REMARK@+1: BACKEND/013 "test_target" "resource 'test.scalar' is a schedule bottleneck" "3 estimated cycle(s)" "3 use(s)"
low.func.def target(@test_target) @resource_diag(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>) -> (reg<test.i32>) {
  %ab = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %abc = low.op<test.add.i32>(%ab, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%abc, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

