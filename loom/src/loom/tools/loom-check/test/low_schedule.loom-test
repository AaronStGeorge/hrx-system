// RUN: emit low-schedule-json @resource_mix

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @resource_mix(%ptr: reg<test.ptr>, %lhs: reg<test.i32 x4>, %rhs: reg<test.i32 x4>, %arg: reg<test.i32>) -> (reg<test.i32 x4>) {
  %loaded = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %loaded2 = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %sum = low.op<test.add.v4i32>(%loaded, %lhs) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  low.op<test.store.v4i32>(%ptr, %sum) : (reg<test.ptr>, reg<test.i32 x4>)
  %call = low.op<test.call.i32>(%arg) {callee_ordinal = 0} : (reg<test.i32>) -> reg<test.i32>
  %mix = low.op<test.add.v4i32>(%loaded2, %rhs) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  %out = low.op<test.add.v4i32>(%sum, %mix) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  low.return %out : reg<test.i32 x4>
}

