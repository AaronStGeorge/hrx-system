// RUN: emit low-schedule-json @hazard_diag diagnostics=hazards

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @hazard_diag(%ptr: reg<test.ptr>) -> (reg<test.i32 x4>) {
  %a = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  // REMARK@+1: BACKEND/014 "test_target" "min_distance" "test.load" "requires distance 2"
  %b = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %out = low.op<test.add.v4i32>(%a, %b) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  low.return %out : reg<test.i32 x4>
}

