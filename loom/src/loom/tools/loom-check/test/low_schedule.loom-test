// RUN: emit low-schedule-json @pressure diagnostics=pressure

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @pressure(%lhs: reg<test.phys>, %rhs: reg<test.phys>) -> (reg<test.phys>) {
  // REMARK@+1: BACKEND/003 "test_target" "test.phys pressure is 2" "against budget 32" "contributors: [lhs, rhs]"
  %sum = low.op<test.add.phys>(%lhs, %rhs) : (reg<test.phys>, reg<test.phys>) -> reg<test.phys>
  low.return %sum : reg<test.phys>
}

