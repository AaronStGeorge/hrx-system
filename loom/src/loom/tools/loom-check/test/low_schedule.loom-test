// RUN: emit low-schedule-json @model_diag diagnostics=model

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @model_diag(%ptr: reg<test.ptr>, %arg: reg<test.i32>) -> (reg<test.i32 x4>) {
  // REMARK@+1: BACKEND/016 "schedule class 'test.load'" "fallback model quality" "2 scheduled use(s)"
  %a = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  %b = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.i32 x4>
  // REMARK@+1: BACKEND/016 "schedule class 'test.vector.alu'" "estimated model quality" "1 scheduled use(s)"
  %sum = low.op<test.add.v4i32>(%a, %b) : (reg<test.i32 x4>, reg<test.i32 x4>) -> reg<test.i32 x4>
  // REMARK@+1: BACKEND/016 "schedule class 'test.store'" "fallback model quality" "1 scheduled use(s)"
  low.op<test.store.v4i32>(%ptr, %sum) : (reg<test.ptr>, reg<test.i32 x4>)
  // REMARK@+1: BACKEND/016 "schedule class 'test.call'" "fallback model quality" "1 scheduled use(s)"
  %call = low.op<test.call.i32>(%arg) {callee_ordinal = 0} : (reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32 x4>
}

