// ====

// RUN: emit low-schedule-json @pressure_order strategy=pressure

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @pressure_order(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>, %e: reg<test.i32>) -> (reg<test.i32>) {
  %hold = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %drop = low.op<test.add.i32>(%c, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %drop2 = low.op<test.add.i32>(%drop, %e) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %hold2 = low.op<test.add.i32>(%hold, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%hold2, %drop2) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out2 = low.op<test.add.i32>(%out, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out2 : reg<test.i32>
}

