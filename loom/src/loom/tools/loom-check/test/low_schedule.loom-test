// ====

// RUN: emit low-schedule-json @pressure diagnostics=pressure output=none

target.preset @test_target {key = "test-low", source = @pressure}

low.func.def target(@test_target) @pressure(%lhs : reg<test.phys>, %rhs : reg<test.phys>) -> (reg<test.phys>) {
  // REMARK@+1: BACKEND/003 "test_target" "test.phys pressure is 2" "against budget 32" "contributors: [lhs, rhs]"
  %sum = low.op<test.add.phys>(%lhs, %rhs) : (reg<test.phys>, reg<test.phys>) -> reg<test.phys>
  low.return %sum : reg<test.phys>
}

// ----

// ====

// RUN: emit low-schedule-json @resource_diag diagnostics=resources output=none

target.preset @test_target {key = "test-low", source = @resource_diag}

// REMARK@+1: BACKEND/013 "test_target" "resource 'test.scalar' is a schedule bottleneck" "3 estimated cycle(s)" "3 use(s)"
low.func.def target(@test_target) @resource_diag(%a : reg<test.i32>, %b : reg<test.i32>, %c : reg<test.i32>) -> (reg<test.i32>) {
  %ab = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %abc = low.op<test.add.i32>(%ab, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%abc, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out : reg<test.i32>
}

// ----

// ====

// RUN: emit low-schedule-json @hazard_diag diagnostics=hazards output=none

target.preset @test_target {key = "test-low", source = @hazard_diag}

low.func.def target(@test_target) @hazard_diag(%ptr : reg<test.ptr>) -> (reg<test.v4i32>) {
  %a = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.v4i32>
  // REMARK@+1: BACKEND/014 "test_target" "min_distance" "test.load" "requires distance 2"
  %b = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.v4i32>
  %out = low.op<test.add.v4i32>(%a, %b) : (reg<test.v4i32>, reg<test.v4i32>) -> reg<test.v4i32>
  low.return %out : reg<test.v4i32>
}

