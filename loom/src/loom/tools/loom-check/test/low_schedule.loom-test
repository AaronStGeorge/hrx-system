// RUN: emit low-schedule-json @pressure_candidates strategy=pressure diagnostics=candidates

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @pressure_candidates(%a: reg<test.i32>, %b: reg<test.i32>, %c: reg<test.i32>, %e: reg<test.i32>) -> (reg<test.i32>) {
  %hold = low.op<test.add.i32>(%a, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  // REMARK@+1: BACKEND/015 "pressure scheduler chose 'test.add.i32' over 'test.add.i32'" "ordinal 0: 2 ready candidate(s)" "chosen projected/killed/produced 4/1/1" "rejected projected/killed/produced 5/0/1"
  %drop = low.op<test.add.i32>(%c, %c) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  // REMARK@+1: BACKEND/015 "pressure scheduler chose 'test.add.i32' over 'test.add.i32'" "ordinal 1: 2 ready candidate(s)" "chosen projected/killed/produced 3/2/1" "rejected projected/killed/produced 5/0/1"
  %drop2 = low.op<test.add.i32>(%drop, %e) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %hold2 = low.op<test.add.i32>(%hold, %a) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out = low.op<test.add.i32>(%hold2, %drop2) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %out2 = low.op<test.add.i32>(%out, %b) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %out2 : reg<test.i32>
}

