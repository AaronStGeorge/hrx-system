// RUN: emit low-schedule-json @sched

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @sched(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) asm<test.low.core> {
  %a = test.call.i32 %lhs {callee = 0}
  %c0 = test.const.i32 7
  %b = test.call.i32 %rhs {callee = 1}
  %sum = test.add.i32 %a, %b
  return %sum
}

