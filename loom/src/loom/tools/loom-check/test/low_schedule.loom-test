// RUN: emit low-schedule-json @resource_mix

target.preset @test_target {key = "test-low", source = @resource_mix}

low.func.def target(@test_target) @resource_mix(%ptr : reg<test.ptr>, %lhs : reg<test.v4i32>, %rhs : reg<test.v4i32>, %arg : reg<test.i32>) -> (reg<test.v4i32>) {
  %loaded = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.v4i32>
  %loaded2 = low.op<test.load.v4i32>(%ptr) : (reg<test.ptr>) -> reg<test.v4i32>
  %sum = low.op<test.add.v4i32>(%loaded, %lhs) : (reg<test.v4i32>, reg<test.v4i32>) -> reg<test.v4i32>
  low.op<test.store.v4i32>(%ptr, %sum) : (reg<test.ptr>, reg<test.v4i32>)
  %call = low.op<test.call.i32>(%arg) {callee_ordinal = 0} : (reg<test.i32>) -> reg<test.i32>
  %mix = low.op<test.add.v4i32>(%loaded2, %rhs) : (reg<test.v4i32>, reg<test.v4i32>) -> reg<test.v4i32>
  %out = low.op<test.add.v4i32>(%sum, %mix) : (reg<test.v4i32>, reg<test.v4i32>) -> reg<test.v4i32>
  low.return %out : reg<test.v4i32>
}

