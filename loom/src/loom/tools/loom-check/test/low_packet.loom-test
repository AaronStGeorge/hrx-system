// RUN: emit low-packet-json @hazard_packet

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @hazard_packet(%ptr: reg<test.ptr>, %lhs: reg<test.i32 x4>) -> (reg<test.i32 x4>) asm<test.low.core> {
  %a = test.load.v4i32 %ptr
  %b = test.load.v4i32 %ptr
  %out = test.add.v4i32 %a, %b
  return %out
}

