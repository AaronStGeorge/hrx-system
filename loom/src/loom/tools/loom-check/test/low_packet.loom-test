// RUN: emit low-packet-json @packet

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @packet(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) asm<test.low.core> {
  %c0 = test.const.i32 7
  %sum = test.add.i32 %lhs, %c0
  %out = test.add.i32 %sum, %rhs
  return %out
}

