// RUN: emit llvmir-bitcode
// REQUIRES: llvm-dis

// LLVM bitcode emission writes a module that llvm-dis can round-trip.
func.def public @bitcode_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
source_filename = "loom/src/loom/tools/loom-check/test/llvmir/toolchain.loom-test"
target datalayout = "e-p:64:64-i64:64-n8:16:32:64-S128"
target triple = "loom-test64-unknown-none"

define dso_local i32 @bitcode_add(i32 %lhs, i32 %rhs) {
entry:
  %sum = add i32 %lhs, %rhs
  ret i32 %sum
}

// ====
// RUN: emit llvmir-object x86_64-object
// REQUIRES: llc, llc-x86

// LLVM object emission proves that llc accepts the produced bitcode.
func.def public @object_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi<nsw> %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
object emitted: x86_64-object

// ====
// RUN: emit llvmir-bitcode x86_64-packed-dot-object
// REQUIRES: llvm-dis

// Packed-dot bitcode preserves target-specific intrinsic declarations.
func.def @bitcode_dot2_bf16(%lhs: vector<16xbf16>, %rhs: vector<16xbf16>, %acc: vector<8xf32>) -> (vector<8xf32>) {
  %dot = vector.dot2f %lhs, %rhs, %acc : vector<16xbf16>, vector<16xbf16>, vector<8xf32>
  func.return %dot : vector<8xf32>
}

// ----
source_filename = "loom/src/loom/tools/loom-check/test/llvmir/toolchain.loom-test"
target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
target triple = "x86_64-unknown-linux-gnu"

define internal <8 x float> @bitcode_dot2_bf16(<16 x bfloat> %lhs, <16 x bfloat> %rhs, <8 x float> %acc) {
entry:
  %dot = call <8 x float> @llvm.x86.avx512bf16.dpbf16ps.256(<8 x float> %acc, <16 x bfloat> %lhs, <16 x bfloat> %rhs)
  ret <8 x float> %dot
}

declare <8 x float> @llvm.x86.avx512bf16.dpbf16ps.256(<8 x float>, <16 x bfloat>, <16 x bfloat>) #0

attributes #0 = { nocallback nofree nosync nounwind willreturn memory(none) }

// ====
// RUN: emit llvmir-object x86_64-packed-dot-object
// REQUIRES: llc, llc-x86

// Packed-dot object emission proves llc receives the profile's feature flags.
func.def @object_dot4_s8s8(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
object emitted: x86_64-packed-dot-object

// ====
// RUN: emit llvmir-assembly-mnemonics x86_64-packed-dot-object
// REQUIRES: llc, llc-x86

// BF16 packed-dot lowering selects the AVX512 BF16 dot instruction.
func.def @asm_dot2_bf16(%lhs: vector<16xbf16>, %rhs: vector<16xbf16>, %acc: vector<8xf32>) -> (vector<8xf32>) {
  %dot = vector.dot2f %lhs, %rhs, %acc : vector<16xbf16>, vector<16xbf16>, vector<8xf32>
  func.return %dot : vector<8xf32>
}

// ----
vdpbf16ps
vmovaps
retq

// ====
// RUN: emit llvmir-assembly-mnemonics x86_64-packed-dot-object
// REQUIRES: llc, llc-x86

// Unsigned-by-signed i8 packed-dot lowering selects the AVX VNNI instruction.
func.def @asm_dot4_u8s8(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
vpdpbusd
vmovdqa
retq

// ====
// RUN: emit llvmir-assembly-mnemonics x86_64-packed-dot-object
// REQUIRES: llc, llc-x86

// Assembly mnemonic emission gives exact instruction-selection evidence.
func.def @asm_dot4_s8s8(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
vpdpbssd
vmovaps
retq
