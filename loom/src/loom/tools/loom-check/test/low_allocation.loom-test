// RUN: emit low-allocation-json @copy_diagnostics diagnostics=copy-decisions

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @copy_diagnostics(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  // REMARK@+1: BACKEND/006 "test_target" "accepted coalescing 'lhs' with 'copy'" "assigned locations match and are register-like"
  %copy = low.copy %lhs : reg<test.i32> -> reg<test.i32>
  %sum = low.op<test.add.i32>(%copy, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

