low.func.def target(@vm_target) @spill(%a : reg<vm.i32>, %b : reg<vm.i32>, %c : reg<vm.i32>) -> (reg<vm.i32>) {
  %ab = low.op<iree.vm.add.i32>(%a, %b) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  %bc = low.op<iree.vm.add.i32>(%b, %c) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  %sum = low.op<iree.vm.add.i32>(%ab, %bc) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  %out = low.op<iree.vm.add.i32>(%sum, %a) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %out : reg<vm.i32>
}

