// RUN: emit low-allocation-json @alloc

target.profile @test_target preset("test-low")

low.func.def target(@test_target) @alloc(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) asm<test.low.core> {
  %sum = test.add.i32 %lhs, %rhs
  %one = test.const.i32 1
  %next = test.add.i32 %sum, %one
  return %next
}

