low.func.def target(@test_target) @alloc(%lhs : reg<test.i32>, %rhs : reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %one = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %next = low.op<test.add.i32>(%sum, %one) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %next : reg<test.i32>
}

