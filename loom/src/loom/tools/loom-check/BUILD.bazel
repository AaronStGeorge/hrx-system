        "//loom/src/loom/target/emit/llvmir:check_provider",
    ],
    "//conditions:default": [],
})

_SPIRV_CHECK_COPTS = iree_select({
    ":spirv_provider_enabled": [
        "-DLOOM_CHECK_HAVE_SPIRV=1",
    ],
    "//conditions:default": [],
})

