load("@bazel_skylib//rules:common_settings.bzl", "string_list_flag")
load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "iree_select",
    "loom_assert_no_dependencies",
    "loom_cc_binary",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

ALL_CHECK_PROVIDERS = [
    "amdgpu",
    "ireevm",
    "llvmir",
    "spirv",
    "wasm",
    "x86",
]

#===------------------------------------------------------------------------===#
# Provider selection
#===------------------------------------------------------------------------===#

string_list_flag(
    name = "enabled_providers",
    build_setting_default = ALL_CHECK_PROVIDERS,
)

[
    config_setting(
        name = "{}_provider_enabled".format(provider),
        flag_values = {
            ":enabled_providers": provider,
        },
    )
    for provider in ALL_CHECK_PROVIDERS
]

#===------------------------------------------------------------------------===#
# Layering checks
#===------------------------------------------------------------------------===#

loom_assert_no_dependencies(
    name = "core_no_test_dependencies",
    dependencies = [
        "//loom/src/loom/ops/test",
        "//loom/src/loom/target:low_descriptor_registry_core_test",
    ],
    targets = [
        ":execute",
        ":file",
        ":main",
        ":output",
        ":provider",
    ],
)

_AMDGPU_CHECK_COPTS = iree_select({
    ":amdgpu_provider_enabled": [
        "-DLOOM_CHECK_HAVE_AMDGPU=1",
    ],
    "//conditions:default": [],
})

_AMDGPU_CHECK_DEPS = iree_select({
    ":amdgpu_provider_enabled": [
        "//loom/src/loom/target/arch/amdgpu:check_provider",
    ],
    "//conditions:default": [],
})

_IREEVM_CHECK_COPTS = iree_select({
    ":ireevm_provider_enabled": [
        "-DLOOM_CHECK_HAVE_IREEVM=1",
    ],
    "//conditions:default": [],
})

_IREEVM_CHECK_DEPS = iree_select({
    ":ireevm_provider_enabled": [
