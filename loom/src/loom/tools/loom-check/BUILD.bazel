    ":spirv_provider_enabled": [
        "//loom/src/loom/target/arch/spirv:check_provider",
        "//loom/src/loom/target/emit/spirv:check_provider",
    ],
    "//conditions:default": [],
})

_WASM_CHECK_COPTS = iree_select({
    ":wasm_provider_enabled": [
        "-DLOOM_CHECK_HAVE_WASM=1",
    ],
    "//conditions:default": [],
})

_WASM_CHECK_DEPS = iree_select({
    ":wasm_provider_enabled": [
        "//loom/src/loom/target/arch/wasm:check_provider",
        "//loom/src/loom/target/emit/wasm:check_provider",
    ],
    "//conditions:default": [],
})

_X86_CHECK_COPTS = iree_select({
    ":x86_provider_enabled": [
        "-DLOOM_CHECK_HAVE_X86=1",
    ],
    "//conditions:default": [],
})

_X86_CHECK_DEPS = iree_select({
    ":x86_provider_enabled": [
        "//loom/src/loom/target/arch/x86:check_provider",
    ],
    "//conditions:default": [],
})

_LOOM_CHECK_PROVIDER_COPTS = (
    _AMDGPU_CHECK_COPTS +
    _IREEVM_CHECK_COPTS +
    _LLVMIR_CHECK_COPTS +
    _SPIRV_CHECK_COPTS +
    _WASM_CHECK_COPTS +
    _X86_CHECK_COPTS
)

_LOOM_CHECK_PROVIDER_DEPS = (
    _AMDGPU_CHECK_DEPS +
    _IREEVM_CHECK_DEPS +
    _LLVMIR_CHECK_DEPS +
    _SPIRV_CHECK_DEPS +
    _WASM_CHECK_DEPS +
    _X86_CHECK_DEPS
)

