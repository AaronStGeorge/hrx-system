{
  "version": 1,
  "cases": [
    {
      "name": "runs amdgpu cases",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/amdgpu_hal_actual.loom",
          "--device=amdgpu"
        ]
      },
      "stdout": {
        "contains": {
          "unordered": [
            "\"format\":\"loom.test.v0\"",
            { "regex": "\"case\":\"store_i32_case\"[^}]*\"passed\":true" },
            {
              "regex": "\"case\":\"store_then_double_i32_case\"[^}]*\"passed\":true"
            },
            "\"failed_sample_count\":0"
          ]
        }
      }
    },
    {
      "name": "runs generated fp8 tensor case",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/generated_tensor_cases.loom",
          "--case=@fp8_generated_fill",
          "--device=amdgpu"
        ]
      },
      "stdout": {
        "contains": {
          "unordered": [
            "\"format\":\"loom.test.v0\"",
            {
              "regex": "\"case\":\"fp8_generated_fill\"[^}]*\"passed\":true"
            },
            "\"failed_sample_count\":0"
          ]
        }
      }
    },
    {
      "name": "keeps valid loom-authored amdgpu asan access silent",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/../../test/corpus/sanitizer/amdgpu_asan_actual.loom",
          "--case=@asan_global_store_valid_case",
          "--device=amdgpu",
          "--sanitizer=asan",
          "--sanitizer-reporting=report-only",
          "--amdgpu_asan=true",
          "--amdgpu_asan_report_policy=report-only"
        ]
      },
      "stdout": {
        "contains": {
          "unordered": [
            "\"format\":\"loom.test.v0\"",
            {
              "regex": "\"case\":\"asan_global_store_valid_case\"[^}]*\"passed\":true"
            },
            "\"failed_sample_count\":0"
          ]
        }
      }
    },
