    },
    {
      "name": "reports loom-authored amdgpu tsan race",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/../../test/corpus/sanitizer/amdgpu_tsan_actual.loom",
          "--case=@tsan_workgroup_write_race_case",
          "--device=amdgpu",
          "--sanitizer=tsan",
