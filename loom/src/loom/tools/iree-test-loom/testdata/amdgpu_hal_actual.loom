}

check.case @store_i32_cdna3_case {
  check.requires<hal.amdgpu.descriptor_set> {descriptor_set = "amdgpu.cdna3.core"}
  %output = check.generate.fill value(0) : tensor<1xi32>
  func.call @store_i32_cdna3(%output) : (tensor<1xi32>)
  %expected = check.generate.fill value(42) : tensor<1xi32>
  check.expect.equal actual(%output) expected(%expected) : tensor<1xi32>
  check.return
}

check.case @store_then_double_i32_cdna3_case {
  check.requires<hal.amdgpu.descriptor_set> {descriptor_set = "amdgpu.cdna3.core"}
  %output = check.generate.fill value(21) : tensor<1xi32>
  func.call @store_i32_cdna3(%output) : (tensor<1xi32>)
  func.call @double_i32_cdna3(%output) : (tensor<1xi32>)
  %expected = check.generate.fill value(84) : tensor<1xi32>
  check.expect.equal actual(%output) expected(%expected) : tensor<1xi32>
  check.return
}

check.case @store_i32_rdna3_case {
  check.requires<hal.amdgpu.descriptor_set> {descriptor_set = "amdgpu.rdna3.core"}
  %output = check.generate.fill value(0) : tensor<1xi32>
  func.call @store_i32_rdna3(%output) : (tensor<1xi32>)
  %expected = check.generate.fill value(42) : tensor<1xi32>
  check.expect.equal actual(%output) expected(%expected) : tensor<1xi32>
  check.return
}

