spirv.target<vulkan1_3> @target {abi = hal_kernel}

kernel.def target(@target) @quantized_projection_u8_scalar_128() {
  %m_count = index.constant 128 : index
  %n_count = index.constant 128 : index
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%n_count, %m_count, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch(%lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %column = kernel.workgroup.id<x> : index
  %row = kernel.workgroup.id<y> : index
  %k_count = index.constant 128 : index
  %n_count = index.constant 128 : index
  %unit = index.constant 1 : index
  %zero = index.constant 0 : index
  %f32_bytes = index.constant 4 : index
  %lhs_aligned = buffer.assume.alignment %lhs_buffer {minimum_alignment = 1} : buffer
  %rhs_aligned = buffer.assume.alignment %rhs_buffer {minimum_alignment = 1} : buffer
  %init_aligned = buffer.assume.alignment %init_buffer {minimum_alignment = 4} : buffer
  %out_aligned = buffer.assume.alignment %out_buffer {minimum_alignment = 4} : buffer
  %out_element_index = index.madd %row, %n_count, %column : index
  %out_byte_index = index.mul %out_element_index, %f32_bytes : index
  %out_byte_offset = index.cast %out_byte_index : index to offset
  %out_byte_offset_aligned = index.assume %out_byte_offset [mul(%out_byte_offset, 4)] : offset
  %init_view = buffer.view %init_aligned[%out_byte_offset_aligned] : buffer -> view<1xf32, #dense>
  %init = view.load %init_view[0] : view<1xf32, #dense> -> f32
  %result = scf.for %k = [%zero to %k_count step %unit](%acc = %init : f32) -> (f32) {
    %lhs_element_index = index.madd %row, %k_count, %k : index
    %rhs_element_index = index.madd %k, %n_count, %column : index
    %lhs_byte_offset = index.cast %lhs_element_index : index to offset
    %rhs_byte_offset = index.cast %rhs_element_index : index to offset
    %lhs_view = buffer.view %lhs_aligned[%lhs_byte_offset] : buffer -> view<1xi8, #dense>
    %rhs_view = buffer.view %rhs_aligned[%rhs_byte_offset] : buffer -> view<1xi8, #dense>
    %lhs_i8 = view.load %lhs_view[0] : view<1xi8, #dense> -> i8
    %rhs_i8 = view.load %rhs_view[0] : view<1xi8, #dense> -> i8
    %lhs_i32 = scalar.extui %lhs_i8 : i8 to i32
    %rhs_i32 = scalar.extui %rhs_i8 : i8 to i32
    %lhs_f32 = scalar.uitofp %lhs_i32 : i32 to f32
    %rhs_f32 = scalar.uitofp %rhs_i32 : i32 to f32
    %product = scalar.mulf %lhs_f32, %rhs_f32 : f32
    %next = scalar.addf %acc, %product : f32
    scf.yield %next : f32
  }
  %out_view = buffer.view %out_aligned[%out_byte_offset_aligned] : buffer -> view<1xf32, #dense>
  view.store %result, %out_view[0] : f32, view<1xf32, #dense>
  kernel.return
}

check.case @quantized_projection_u8_scalar_128_case {
  check.requires<hal.vulkan.feature> {feature = "shader_int8"}
  check.requires<hal.vulkan.feature> {feature = "storage_buffer_8bit_access"}
  %lhs = check.generate.fill value(1) : tensor<128x128xi8>
  %rhs = check.generate.fill value(2) : tensor<128x128xi8>
  %init = check.generate.fill value(5.0) : tensor<128x128xf32>
  %output = check.generate.fill value(0.0) : tensor<128x128xf32>
  func.call @quantized_projection_u8_scalar_128(%lhs, %rhs, %init, %output) : (tensor<128x128xi8>, tensor<128x128xi8>, tensor<128x128xf32>, tensor<128x128xf32>)
  %expected = check.oracle.call<reference.matmul> {accumulator = "f32", lhs = "u8", result = "f32", rhs = "u8"} callee(@quantized_projection_u8_scalar_128) inputs(%lhs, %rhs, %init) : (tensor<128x128xi8>, tensor<128x128xi8>, tensor<128x128xf32>) -> (tensor<128x128xf32>)
  check.expect.close actual(%output) expected(%expected) atol(0.0) rtol(0.0) nan(different) : tensor<128x128xf32>
  check.return
}

check.benchmark<@quantized_projection_u8_scalar_128_case>
