load("@bazel_skylib//rules:common_settings.bzl", "string_list_flag")
load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "iree_lit_test_suite",
    "iree_select",
    "loom_cc_binary",
    "loom_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

ALL_EXECUTION_PROVIDERS = [
    "amdgpu",
    "ireevm",
    "spirv",
]

#===------------------------------------------------------------------------===#
# Provider selection
#===------------------------------------------------------------------------===#

string_list_flag(
    name = "enabled_providers",
    build_setting_default = ALL_EXECUTION_PROVIDERS,
)

[
    config_setting(
        name = "{}_provider_enabled".format(provider),
        flag_values = {
            ":enabled_providers": provider,
        },
    )
    for provider in ALL_EXECUTION_PROVIDERS
]

_AMDGPU_PROVIDER_COPTS = iree_select({
    ":amdgpu_provider_enabled": [
        "-DIREE_TEST_LOOM_HAVE_AMDGPU=1",
    ],
    "//conditions:default": [],
})

_AMDGPU_PROVIDER_DEPS = iree_select({
    ":amdgpu_provider_enabled": [
        "//loom/src/loom/tooling/target/amdgpu:artifact_provider",
        "//loom/src/loom/tooling/target/amdgpu:provider",
    ],
    "//conditions:default": [],
})

_IREEVM_EXECUTION_COPTS = iree_select({
    ":ireevm_provider_enabled": [
        "-DIREE_TEST_LOOM_HAVE_IREEVM=1",
    ],
    "//conditions:default": [],
})

_IREEVM_EXECUTION_DEPS = iree_select({
    ":ireevm_provider_enabled": [
        "//loom/src/loom/tooling/execution/ireevm:provider",
    ],
    "//conditions:default": [],
})

_SPIRV_PROVIDER_COPTS = iree_select({
    ":spirv_provider_enabled": [
        "-DIREE_TEST_LOOM_HAVE_SPIRV=1",
    ],
    "//conditions:default": [],
})

_SPIRV_PROVIDER_DEPS = iree_select({
    ":spirv_provider_enabled": [
        "//loom/src/loom/tooling/target/spirv:artifact_provider",
        "//loom/src/loom/tooling/target/spirv:provider",
        "//loom/src/loom/tooling/target/spirv:testbench_requirements",
    ],
    "//conditions:default": [],
})

_IREE_TEST_LOOM_PROVIDER_COPTS = (
    _AMDGPU_PROVIDER_COPTS +
    _IREEVM_EXECUTION_COPTS +
    _SPIRV_PROVIDER_COPTS
)

_IREE_TEST_LOOM_PROVIDER_DEPS = (
    _AMDGPU_PROVIDER_DEPS +
    _IREEVM_EXECUTION_DEPS +
    _SPIRV_PROVIDER_DEPS
)

loom_cc_library(
    name = "main",
    srcs = ["main.c"],
    hdrs = ["main.h"],
    deps = [
        "//loom/src/loom/ops:op_registry",
        "//loom/src/loom/target:provider",
        "//loom/src/loom/tooling/execution:session",
        "//loom/src/loom/tooling/execution/hal:artifact",
        "//loom/src/loom/tooling/execution/hal:testbench_actual",
        "//loom/src/loom/tooling/io:file",
        "//loom/src/loom/tooling/testbench:executor",
        "//loom/src/loom/tooling/testbench:reference",
        "//loom/src/loom/tooling/testbench:requirements",
        "//loom/src/loom/util:json",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/tooling:flags",
        "//runtime/src/iree/io:file_handle",
    ],
)

loom_cc_binary(
    name = "iree-test-loom",
    srcs = ["iree-test-loom.c"],
    copts = _IREE_TEST_LOOM_PROVIDER_COPTS,
    deps = [
        ":main",
        "//loom/src/loom/tooling/execution:execution_provider",
        "//runtime/src/iree/base",
    ] + _IREE_TEST_LOOM_PROVIDER_DEPS,
)

iree_lit_test_suite(
    name = "lit_test",
    srcs = ["iree-test-loom_test.txt"],
    cfg = "//runtime:lit.cfg.py",
    data = [
        "testdata/scalar_cases.loom",
    ],
    tags = ["hostonly"],
    tools = [
        ":iree-test-loom",
        "@llvm-project//llvm:FileCheck",
    ],
)

iree_lit_test_suite(
    name = "amdgpu_lit_test",
    srcs = ["iree-test-loom_amdgpu_test.txt"],
    cfg = "//runtime:lit.cfg.py",
    data = [
        "testdata/amdgpu_hal_actual.loom",
    ],
    tags = [
        "driver=amdgpu",
        "manual",
        "requires-gpu-amd",
    ],
    tools = [
        ":iree-test-loom",
        "@llvm-project//llvm:FileCheck",
    ],
)

iree_lit_test_suite(
    name = "spirv_vulkan_lit_test",
    srcs = ["iree-test-loom_spirv_vulkan_test.txt"],
    cfg = "//runtime:lit.cfg.py",
    data = [
        "testdata/spirv_vulkan_coop_hal_actual.loom",
        "testdata/spirv_vulkan_coop_u8_hal_actual.loom",
        "testdata/spirv_vulkan_hal_actual.loom",
        "testdata/spirv_vulkan_quantized_hal_actual.loom",
        "//build_tools/sanitizer:lsan_suppressions_vulkan.txt",
    ],
    tags = [
        "driver=vulkan",
        "manual",
        "requires-gpu-vulkan",
    ],
    tools = [
        ":iree-test-loom",
        "@llvm-project//llvm:FileCheck",
    ],
)
