{
  "version": 1,
  "cases": [
    {
      "name": "prints agent documentation",
      "run": {
        "tool": "iree-test-loom",
        "args": ["--agents_md"]
      },
      "stdout": {
        "contains": {
          "unordered": [
            "## iree-test-loom",
            "--case=@case_q8_block_unroll_wg64",
            "--sample=1",
            "--max-samples-per-case=16",
            "--sanitizer=tsan",
            "--sanitizer-reporting=report-only",
            "loom.test.v0",
            "failed_sample_count",
            "{case, provider, op, code, provider_code}",
            "{case, kind, op, source_location, fix_hint}",
            "planning_issue_count",
            "`display_message` is human-facing only"
          ]
        }
      }
    },
    {
      "name": "runs selected sampled case",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/scalar_cases.loom",
          "--case=@sampled_choice",
          "--sanitizer=tsan",
          "--sanitizer-reporting=report-only",
          "--sample=1"
        ]
      },
      "stdout": {
        "contains": [
          "\"format\":\"loom.test.v0\"",
          "\"case_count\":1",
          "\"sample_count\":1",
          "\"failed_sample_count\":0",
          "\"skipped_case_count\":0",
          "\"case\":\"sampled_choice\",\"sample_ordinal\":1,\"passed\":true"
        ]
      }
    },
    {
      "name": "reports unsupported check.case planning issue before sample validation",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/planning_issue_cases.loom",
          "--case=@unsupported_constant_case",
          "--sample=0"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stdout": {
        "contains": [
          "\"format\":\"loom.test.v0\"",
          "\"case_count\":1",
          "\"sample_count\":0",
          "\"failed_sample_count\":0",
          "\"planning_issue_count\":1",
          "\"planning_issues\":[",
          "\"kind\":\"unsupported_case_body_op\"",
          "\"case\":\"unsupported_constant_case\"",
          "\"op\":\"index.constant\"",
          "\"source_location\":",
          "\"fix_hint\":\"use check.literal for scalar literals inside check.case\""
        ]
      }
    },
    {
      "name": "runs all scalar cases",
      "run": {
        "tool": "iree-test-loom",
        "args": ["{srcdir}/testdata/scalar_cases.loom"]
      },
      "stdout": {
        "contains": [
          "\"format\":\"loom.test.v0\"",
          "\"case_count\":2",
          "\"sample_count\":3",
          "\"failed_sample_count\":0",
          "\"skipped_case_count\":0",
          "\"case\":\"scalar_equal\",\"sample_ordinal\":0,\"passed\":true",
          "\"case\":\"sampled_choice\",\"sample_ordinal\":0,\"passed\":true",
          "\"case\":\"sampled_choice\",\"sample_ordinal\":1,\"passed\":true"
        ]
      }
    },
    {
      "name": "reports skipped requirements with stable codes",
      "run": {
        "tool": "iree-test-loom",
        "args": ["{srcdir}/testdata/requirement_cases.loom"]
      },
      "stdout": {
        "contains": [
          "\"format\":\"loom.test.v0\"",
          "\"case_count\":2",
          "\"sample_count\":0",
          "\"failed_sample_count\":0",
          "\"skipped_case_count\":2",
          "\"case\":\"missing_provider_requirement\",\"provider\":\"missing.provider\",\"op\":\"requires\",\"code\":\"provider_not_registered\"",
          "\"case\":\"missing_provider_skip_if\",\"provider\":\"missing.provider\",\"op\":\"skip_if\",\"code\":\"provider_not_registered\",\"display_message\":\"human skip display text\""
        ],
        "not_contains": ["\"reason\""]
      }
    },
    {
      "name": "accepts config flags on host-only cases",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/scalar_cases.loom",
          "--case=@scalar_equal",
          "--config=model.hidden_size=4096"
        ]
      },
      "stdout": {
        "contains": [
          "\"format\":\"loom.test.v0\"",
          "\"case_count\":1",
          "\"failed_sample_count\":0"
        ]
      }
    },
    {
      "name": "rejects malformed config assignment",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/scalar_cases.loom",
          "--config=model.hidden_size"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": ["config assignment must use key=value syntax"]
      }
    },
    {
      "name": "rejects unknown sanitizer token",
      "run": {
        "tool": "iree-test-loom",
        "args": ["{srcdir}/testdata/scalar_cases.loom", "--sanitizer=bogus"]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": ["--sanitizer has unknown token 'bogus'"]
      }
    },
    {
      "name": "rejects unknown sanitizer reporting mode",
      "run": {
        "tool": "iree-test-loom",
        "args": [
          "{srcdir}/testdata/scalar_cases.loom",
          "--sanitizer=asan",
          "--sanitizer-reporting=printf"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": [
          "--sanitizer-reporting expected 'default', 'trap', or 'report-only', got 'printf'"
        ]
      }
    }
  ]
}
