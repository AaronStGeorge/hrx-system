{
  "version": 1,
  "cases": [
    {
      "name": "lists registered passes",
      "run": {
        "tool": "loom-opt",
        "args": ["--list-passes"]
      },
      "stdout": {
        "contains": {
          "unordered": [
            "branch-fusion",
            "canonicalize",
            "cse",
            "dce",
            "source-to-low",
            "symbol-dce",
            "vector-to-scalar"
          ]
        }
      }
    },
    {
      "name": "prints pass help",
      "run": {
        "tool": "loom-opt",
        "args": ["--pass-help=canonicalize"]
      },
      "stdout": {
        "contains": [
          "canonicalize",
          "kind: func",
          "options:",
          "max-iterations: uint32 [1..4294967295]"
        ]
      }
    },
    {
      "name": "runs canonicalize and dce pipeline",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--pass=canonicalize{max-iterations=2}",
          "--pass=dce"
        ],
        "stdin": {
          "text": "func.def @dce_single(%x: i32) -> (i32) {\n  %dead = scalar.constant 42 : i32\n  func.return %x : i32\n}\n"
        }
      },
      "stdout": {
        "contains": [
          "func.def @dce_single(%x: i32) -> (i32) {",
          "func.return %x : i32"
        ],
        "not_contains": ["%dead"]
      }
    },
    {
      "name": "dumps selected pass IR as JSONL",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--pass=dce",
          "--dump-ir-after=dce",
          "--dump-ir-format=jsonl",
          "--dump-ir-output=stderr",
          "--output={tmp}/dumped.loom"
        ],
        "stdin": {
          "text": "func.def @trace_smoke(%x: i32) -> (i32) {\n  func.return %x : i32\n}\n"
        }
      },
      "stderr": {
        "contains": [
          "\"tool\":\"loom-opt\"",
          "\"stage\":\"command-line\"",
          "\"pass\":\"dce\"",
          "\"point\":\"after\"",
          "\"ir\":\""
        ]
      },
      "files": [
        {
          "path": "{tmp}/dumped.loom",
          "non_empty": true
        }
      ]
    },
    {
      "name": "dumps selected before and after IR to a bundle",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--pass=dce",
          "--dump-ir-before=dce",
          "--dump-ir-after=dce",
          "--dump-ir-format=jsonl",
          "--dump-ir-output={tmp}/trace-bundle/",
          "--output={tmp}/bundle-out.loom"
        ],
        "stdin": {
          "text": "func.def @trace_bundle(%x: i32) -> (i32) {\n  %dead = scalar.constant 42 : i32\n  func.return %x : i32\n}\n"
        }
      },
      "files": [
        {
          "path": "{tmp}/trace-bundle/trace.jsonl",
          "non_empty": true
        },
        {
          "path": "{tmp}/trace-bundle/ir/000000-before-dce.loom",
          "non_empty": true
        },
        {
          "path": "{tmp}/trace-bundle/ir/000001-after-dce.loom",
          "non_empty": true
        },
        {
          "path": "{tmp}/bundle-out.loom",
          "non_empty": true
        }
      ]
    },
    {
      "name": "reports template selection fallback statistics",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--pass=select-templates",
          "--pass-report=json",
          "--output={tmp}/selected.loom"
        ],
        "stdin": {
          "text": "func.template<demo.report> priority(10) @aligned(%m: index) -> (index) where [mul(%m, 16)] {\n  func.return %m : index\n}\n\nfunc.template<demo.report> priority(1) @fallback(%m: index) -> (index) {\n  func.return %m : index\n}\n\nfunc.def public @entry() -> (index) {\n  %n = index.constant 15 : index\n  %result = func.apply<demo.report>(%n) : (index) -> (index)\n  func.return %result : index\n}\n"
        }
      },
      "stderr": {
        "contains": [
          "\"pass\":\"select-templates\"",
          "\"apply-sites\":1",
          "\"selected-sites\":1",
          "\"fallback-selected-sites\":1",
          "\"unresolved-sites\":0",
          "\"rejected-sites\":0",
          "\"category\":\"template-selection\"",
          "\"outcome\":\"fallback_selected\"",
          "\"function\":\"entry\"",
          "\"selected_provider\":\"fallback\"",
          "\"selected_priority\":1",
          "\"highest_provider_priority\":10",
          "\"provider_count\":2",
          "\"target_applicable_count\":2",
          "\"possible_count\":1",
          "\"best_exact_count\":1"
        ]
      },
      "files": [
        {
          "path": "{tmp}/selected.loom",
          "contains": ["func.call inline @fallback"]
        }
      ]
    },
    {
      "name": "materializes config values",
      "run": {
        "tool": "loom-opt",
        "args": ["--config=model36.model.hidden_size=4096"],
        "stdin": {
          "text": "config.decl @model36.model.hidden_size : index\n\nfunc.def @read_config() -> (index) {\n  %hidden = config.get @model36.model.hidden_size : index\n  func.return %hidden : index\n}\n"
        }
      },
      "stdout": {
        "contains": [
          "config.def @model36.model.hidden_size = 4096 : index",
          "%hidden = config.get @model36.model.hidden_size : index"
        ],
        "not_contains": ["config.decl @model36.model.hidden_size"]
      }
    },
    {
      "name": "rejects duplicate config binding",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--config=answer=40",
          "--config=@answer=41",
          "--output={tmp}/unused.loom"
        ],
        "stdin": {
          "text": "config.decl @answer : index\n"
        }
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": ["duplicate config binding for 'answer'"]
      }
    },
    {
      "name": "writes pass pipeline reproducer",
      "run": {
        "tool": "loom-opt",
        "args": [
          "--pipeline=@boom",
          "--pass-reproducer={tmp}/pass.repro",
          "--dump-ir-after=dce",
          "--dump-ir-format=jsonl",
          "--dump-ir-output={tmp}/failed-pass-trace.jsonl",
          "--output={tmp}/unused.loom"
        ],
        "stdin": {
          "text": "pass.pipeline<module> @boom pipeline {\n  for func {\n    dce\n  }\n  fail \"boom\"\n}\n\nfunc.def @reproducer_input(%x: i32) -> (i32) {\n  func.return %x : i32\n}\n"
        }
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": [
          "pass pipeline reproducer written to",
          "boom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/pass.repro",
          "non_empty": true
        },
        {
          "path": "{tmp}/failed-pass-trace.jsonl",
          "non_empty": true
        }
      ]
    }
  ]
}
