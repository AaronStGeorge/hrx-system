{
  "version": 1,
  "cases": [
    {
      "name": "runs spirv vulkan scalar benchmark with bundle",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/spirv_vulkan_hal_actual.loom",
          "--benchmark=@double_i32_at_byte_offset",
          "--device=vulkan",
          "--vulkan_validation_layers=false",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup-iterations=0",
          "--batch-size=1",
          "--min-time-ms=0",
          "--max-batches=1",
          "--input-ring-count=1",
          "--output-format=jsonl",
          "--artifact-bundle-dir={tmp}/spirv.bundle",
          "--artifact-bundle-policy=debug"
        ]
      },
      "files": [
        {
          "path": "{tmp}/spirv.bundle/results.jsonl",
          "non_empty": true
        },
        {
          "path": "{tmp}/spirv.bundle/manifest.json",
          "non_empty": true
        }
      ]
    },
    {
      "name": "runs spirv vulkan cooperative f16 benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/spirv_vulkan_coop_hal_actual.loom",
          "--benchmark=@dense_projection_tiled_f16_128",
          "--device=vulkan",
          "--vulkan_validation_layers=false",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup-iterations=0",
          "--batch-size=1",
          "--min-time-ms=0",
          "--max-batches=1",
          "--input-ring-count=1",
          "--output-format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"plan\"",
          "\"benchmark\":\"dense_projection_tiled_f16_128\"",
          "\"measure\":\"dispatch_complete\"",
          "\"row\":\"benchmark\"",
          "\"row\":\"summary\"",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    },
    {
      "name": "runs spirv vulkan comparison benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/spirv_vulkan_coop_hal_actual.loom",
          "--compare=@narrow_score_tiled_f16_128x16_m1,@narrow_score_tiled_f16_128x16_m2",
          "--device=vulkan",
          "--vulkan_validation_layers=false",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup-iterations=0",
          "--batch-size=1",
          "--min-time-ms=0",
          "--max-batches=1",
          "--input-ring-count=1",
          "--repetitions=1",
          "--output-format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"comparison\"",
          "\"method\":\"ABABA\"",
          "\"benchmark_count\":2",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    }
  ]
}
