loom_cc_binary(
    name = "iree-benchmark-loom",
    srcs = ["iree-benchmark-loom.c"],
    copts = _IREE_BENCHMARK_LOOM_EXECUTE_COPTS,
    deps = [
        ":main",
        "//loom/src/loom/tooling/execution:execution_provider",
        "//loom/src/loom/tooling/execution/hal:artifact",
        "//runtime/src/iree/base",
    ] + _IREE_BENCHMARK_LOOM_EXECUTE_DEPS,
)

iree_execution_test_suite(
    name = "execution_test",
    data = [
        "testdata/duplicate_symbol.loom",
        "testdata/scalar_benchmarks.loom",
    ],
    manifests = ["iree-benchmark-loom.test.json"],
    tags = ["hostonly"],
    tools = {
        "iree-benchmark-loom": ":iree-benchmark-loom",
    },
)

iree_execution_test_suite(
    name = "amdgpu_execution_test",
    data = [
        "//loom/src/loom/tools/iree-test-loom:testdata/amdgpu_hal_actual.loom",
    ],
    manifests = ["iree-benchmark-loom_amdgpu.test.json"],
    tags = [
        "driver=amdgpu",
        "manual",
        "requires-gpu-amd",
    ],
    tools = {
        "iree-benchmark-loom": ":iree-benchmark-loom",
    },
)

