{
  "version": 1,
  "cases": [
    {
      "name": "runs amdgpu store benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/amdgpu_hal_actual.loom",
          "--benchmark=@store_i32",
          "--device=amdgpu",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup_iterations=0",
          "--batch_size=1",
          "--min_time_ms=0",
          "--max_batches=1",
          "--input_ring_count=1",
          "--output_format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"plan\"",
          "\"benchmark\":\"store_i32\"",
          { "regex": "\"case\":\"store_i32_case\"" },
          "\"measure\":\"dispatch_complete\"",
          "\"driver\":\"amdgpu\"",
          "\"provider\":\"amdgpu-hal\"",
          "\"row\":\"benchmark\"",
          "\"status\":\"ok\"",
          "\"correctness_failed_sample_count\":0",
          "\"failure_count\":0",
          "\"failed_benchmark_count\":0"
        ]
      }
    },
    {
      "name": "runs amdgpu dependent store benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/amdgpu_hal_actual.loom",
          "--benchmark=@store_then_double_i32",
          "--device=amdgpu",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup_iterations=0",
          "--batch_size=1",
          "--min_time_ms=0",
          "--max_batches=1",
          "--input_ring_count=1",
          "--output_format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"plan\"",
          "\"benchmark\":\"store_then_double_i32\"",
          { "regex": "\"case\":\"store_then_double_i32_case\"" },
          "\"actual_invocation_count\":2",
          "\"driver\":\"amdgpu\"",
          "\"provider\":\"amdgpu-hal\"",
          "\"row\":\"benchmark\"",
          "\"status\":\"ok\"",
          "\"failure_count\":0",
          "\"failed_benchmark_count\":0"
        ]
      }
    }
  ]
}
