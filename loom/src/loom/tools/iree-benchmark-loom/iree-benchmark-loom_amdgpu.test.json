{
  "version": 1,
  "cases": [
    {
      "name": "runs amdgpu store benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/amdgpu_hal_actual.loom",
          "--benchmark=@store_i32_latency",
          "--device=amdgpu",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup-iterations=0",
          "--batch-size=1",
          "--min-time-ms=0",
          "--max-batches=1",
          "--input-ring-count=1",
          "--output-format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"plan\"",
          "\"benchmark\":\"store_i32_latency\"",
          { "regex": "\"case\":\"store_i32_case\"" },
          "\"measure\":\"dispatch_complete\"",
          "\"driver\":\"amdgpu\"",
          "\"provider\":\"amdgpu-hal\"",
          "\"row\":\"benchmark\"",
          "\"state\":\"ok\"",
          "\"correctness\":{\"sample_count\":1,\"failed_sample_count\":0}",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    },
    {
      "name": "runs amdgpu dependent store benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/amdgpu_hal_actual.loom",
          "--benchmark=@store_then_double_i32_latency",
          "--device=amdgpu",
          "--measure=dispatch_complete",
          "--iterations=1",
          "--warmup-iterations=0",
          "--batch-size=1",
          "--min-time-ms=0",
          "--max-batches=1",
          "--input-ring-count=1",
          "--output-format=jsonl"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"plan\"",
          "\"benchmark\":\"store_then_double_i32_latency\"",
          { "regex": "\"case\":\"store_then_double_i32_case\"" },
          "\"actual_invocation_count\":2",
          "\"driver\":\"amdgpu\"",
          "\"provider\":\"amdgpu-hal\"",
          "\"row\":\"benchmark\"",
          "\"state\":\"ok\"",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    }
  ]
}
