{
  "version": 1,
  "cases": [
    {
      "name": "runs scalar latency benchmark",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_latency"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"run\"",
          "\"row\":\"plan\"",
          "\"benchmark\":\"scalar_equal_latency\"",
          "\"case\":\"scalar_equal\"",
          "\"measure\":\"case_end_to_end\"",
          "\"row\":\"sample\"",
          "\"passed\":true",
          "\"row\":\"benchmark\"",
          "\"state\":\"ok\"",
          "\"row\":\"summary\"",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    },
    {
      "name": "includes benchmark identity on compact work items",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--benchmark=@scalar_equal_latency",
          "--iterations=1",
          "--warmup-iterations=0",
          "--min-time-ms=0",
          "--max-batches=1"
        ]
      },
      "stdout": {
        "contains": [
          "\"output_format\":\"snapshot\"",
          "\"work_items\":[{\"work_item_index\":0,\"benchmark\":\"scalar_equal_latency\",\"case\":\"scalar_equal\"",
          "\"benchmarks\":[{\"candidate_id\":",
          "\"benchmark\":\"scalar_equal_latency\"",
          "\"case\":\"scalar_equal\""
        ]
      }
    },
    {
      "name": "reports selected benchmark check.case planning issues",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/../iree-test-loom/testdata/planning_issue_cases.loom",
          "--output-format=jsonl",
          "--benchmark=@unsupported_constant_latency"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stdout": {
        "contains": [
          "\"row\":\"failure\"",
          "\"stage\":\"plan\"",
          "\"kind\":\"testbench_planning\"",
          "\"planning_issue_count\":1",
          "\"planning_issues\":[",
          "\"kind\":\"unsupported_case_body_op\"",
          "\"case\":\"unsupported_constant_case\"",
          "\"op\":\"index.constant\"",
          "\"source_location\":",
          "\"fix_hint\":\"use check.literal for scalar literals inside check.case\"",
          "\"row\":\"summary\"",
          "\"failures\":{\"row_count\":1,\"failed_benchmark_count\":0}"
        ],
        "not_contains": ["zero executable samples"]
      }
    },
    {
      "name": "honors sampled benchmark selection and cli iteration overrides",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@sampled_choice_latency",
          "--sample=1",
          "--iterations=2",
          "--warmup-iterations=0"
        ]
      },
      "stdout": {
        "contains": [
          "\"selected_sample\":1",
          "\"case\":\"sampled_choice\"",
          "\"sample_ordinal\":1",
          "\"benchmark\":\"sampled_choice_latency\"",
          "\"warmup_iterations\":0",
          "\"iterations\":2",
          "\"correctness\":{\"sample_count\":1,\"failed_sample_count\":0}"
        ]
      }
    },
    {
      "name": "reports sanitizer policy in dry-run output",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_latency",
          "--dry-run",
          "--sanitizer=tsan",
          "--sanitizer-reporting=report-only"
        ]
      },
      "stdout": {
        "contains": [
          "\"sanitizer\":{\"checks\":\"race\",\"reporting_mode\":\"report-only\"}",
          "\"row\":\"summary\"",
          "\"failures\":{\"row_count\":0,\"failed_benchmark_count\":0}"
        ]
      }
    },
    {
      "name": "writes dry-run output file",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_latency",
          "--dry-run",
          "--output={tmp}/dry_run.jsonl"
        ]
      },
      "files": [
        {
          "path": "{tmp}/dry_run.jsonl",
          "non_empty": true
        }
      ]
    },
    {
      "name": "writes dry-run artifact bundle",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_latency",
          "--dry-run",
          "--artifact-bundle-dir={tmp}/bundle"
        ]
      },
      "files": [
        {
          "path": "{tmp}/bundle/results.jsonl",
          "non_empty": true
        },
        {
          "path": "{tmp}/bundle/manifest.json",
          "non_empty": true
        }
      ]
    },
    {
      "name": "accepts config flags during dry-run planning",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_latency",
          "--dry-run",
          "--config=model.hidden_size=4096"
        ]
      },
      "stdout": {
        "contains": [
          "\"row\":\"run\"",
          "\"row\":\"plan\"",
          "\"benchmark\":\"scalar_equal_latency\"",
          "\"row\":\"summary\"",
          "\"row_count\":0"
        ]
      }
    },
    {
      "name": "rejects malformed config assignment",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--benchmark=@scalar_equal_latency",
          "--config=model.hidden_size"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": ["config assignment must use key=value syntax"]
      }
    },
    {
      "name": "rejects dispatch measurement without actual invocation",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/scalar_benchmarks.loom",
          "--output-format=jsonl",
          "--benchmark=@scalar_equal_dispatch_latency",
          "--measure=dispatch_complete"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": [
          "HAL actual invocations require exactly one actual invocation"
        ]
      }
    },
    {
      "name": "reports duplicate symbols",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/testdata/duplicate_symbol.loom",
          "--output-format=jsonl",
          "--benchmark=@duplicate_symbol_latency"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stdout": {
        "contains": [
          "\"row\":\"failure\"",
          "\"stage\":\"verify\"",
          "\"domain\":\"SYMBOL\"",
          "\"message\":\"symbol '@duplicate_symbol' is already defined\"",
          "\"row\":\"summary\"",
          "\"failures\":{\"row_count\":1,\"failed_benchmark_count\":0}"
        ]
      }
    },
    {
      "name": "prints agent documentation",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": ["--agents_md"]
      },
      "stdout": {
        "contains": [
          "## iree-benchmark-loom",
          "default output is a compact JSON snapshot",
          "work_items",
          "--output-format=jsonl",
          "compile_report",
          ".compile_report.entries.rows[]",
          "compile_report_path",
          "artifact_manifest_path",
          "target_artifact_path"
        ],
        "not_contains": ["static_summary"]
      }
    },
    {
      "name": "prints help",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": ["--help"]
      },
      "stdout": {
        "contains": [
          "Runs correctness-gated check.benchmark records from a Loom module.",
          "Usage:"
        ]
      }
    }
  ]
}
