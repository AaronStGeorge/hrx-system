check.case @compare_case {
  check.return
}

check.benchmark @base_dispatch case(@compare_case) attrs({
  batch_size = 1,
  iterations = 1,
  measure = "dispatch_complete",
  warmup_iterations = 0
})

check.benchmark @variant_dispatch case(@compare_case) attrs({
  batch_size = 1,
  iterations = 1,
  measure = "dispatch_complete",
  warmup_iterations = 0
})
