check.case @scalar_equal {
  %actual = check.literal value(42) : i32
  %expected = check.literal value(42) : i32
  check.expect.equal actual(%actual) expected(%expected) : i32
  check.return
}

check.benchmark @scalar_equal_latency case(@scalar_equal) {
  family = "scalar_equal",
  iterations = 3,
  knobs = {variant = "literal"},
  measure = "case_end_to_end",
  phase = "unit",
  problem = {dtype = "i32", element_count = 1},
  strategy = "literal_compare",
  warmup_iterations = 1
}
check.benchmark @scalar_equal_dispatch_latency case(@scalar_equal) {measure = "dispatch_complete"}

check.case @sampled_choice {
  %value = check.param.choice values([5, 7]) : i32
  check.expect.equal actual(%value) expected(%value) : i32
  check.return
}

check.benchmark @sampled_choice_latency case(@sampled_choice) {measure = "case_end_to_end"}
