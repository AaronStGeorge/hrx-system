load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "benchmark",
    srcs = ["benchmark.c"],
    hdrs = ["benchmark.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "compile_options",
    srcs = ["compile_options.c"],
    hdrs = ["compile_options.h"],
    deps = [
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/target:artifact_manifest",
        "//loom/src/loom/target:compile_report",
        "//loom/src/loom/target:pipeline_options",
        "//loom/src/loom/verify",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "compile_report_capture",
    srcs = ["compile_report_capture.c"],
    hdrs = ["compile_report_capture.h"],
    deps = [
        ":compile_options",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:json_sink",
        "//loom/src/loom/error:renderer",
        "//loom/src/loom/target:compile_report",
        "//loom/src/loom/target:compile_report_format",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "execution_provider",
    srcs = ["execution_provider.c"],
    hdrs = ["execution_provider.h"],
    deps = [
        ":execution_backend",
        ":session",
        "//loom/src/loom/target:provider",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "execution_backend",
    srcs = ["execution_backend.c"],
    hdrs = ["execution_backend.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "measurement",
    srcs = ["measurement.c"],
    hdrs = ["measurement.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "one_shot",
    srcs = ["one_shot.c"],
    hdrs = ["one_shot.h"],
    deps = [
        ":compile_options",
        ":session",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/kernel",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "session",
    srcs = ["session.c"],
    hdrs = ["session.h"],
    deps = [
        "//loom/src/loom/codegen/low:text_asm",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/format/bytecode:format",
        "//loom/src/loom/format/bytecode:reader",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/verify",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_test(
    name = "benchmark_test",
    srcs = ["benchmark_test.cc"],
    deps = [
        ":benchmark",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "compile_report_capture_test",
    srcs = ["compile_report_capture_test.cc"],
    deps = [
        ":compile_options",
        ":compile_report_capture",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/error:json_sink",
        "//runtime/src/iree/base",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "one_shot_test",
    srcs = ["one_shot_test.cc"],
    deps = [
        ":one_shot",
        ":session",
        "//loom/src/loom/ops:op_registry",
        "//loom/src/loom/target:low_descriptor_registry_core_test",
        "//runtime/src/iree/base",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "measurement_test",
    srcs = ["measurement_test.cc"],
    deps = [
        ":measurement",
        "//runtime/src/iree/base",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
