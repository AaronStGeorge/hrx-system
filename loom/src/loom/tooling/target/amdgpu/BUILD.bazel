load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "artifact_provider",
    srcs = ["artifact_provider.c"],
    hdrs = ["artifact_provider.h"],
    deps = [
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/target:compile_report",
        "//loom/src/loom/target:types",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//loom/src/loom/target/arch/amdgpu/ops",
        "//loom/src/loom/target/arch/amdgpu/records:target_records",
        "//loom/src/loom/target/arch/amdgpu/target_id",
        "//loom/src/loom/target/emit/native/amdgpu:hal_kernel_library",
        "//loom/src/loom/target/emit/native/amdgpu:runtime_globals",
        "//loom/src/loom/tooling/execution:compile_options",
        "//loom/src/loom/tooling/execution/hal:artifact",
        "//loom/src/loom/tooling/execution/hal:runtime",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "testbench_requirements",
    srcs = ["testbench_requirements.c"],
    hdrs = ["testbench_requirements.h"],
    deps = [
        "//loom/src/loom/target/arch/amdgpu:target_info_defs",
        "//loom/src/loom/tooling/execution/hal:testbench_actual",
        "//loom/src/loom/tooling/testbench:requirements",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "artifact_provider_test",
    srcs = ["artifact_provider_test.cc"],
    deps = [
        ":artifact_provider",
        "//loom/src/loom/codegen/low:text_asm",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_registry",
        "//loom/src/loom/sanitizer:options",
        "//loom/src/loom/target:compile_report",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//loom/src/loom/target/arch/amdgpu/descriptors:low_registry",
        "//loom/src/loom/target/arch/amdgpu/ops",
        "//loom/src/loom/target/arch/amdgpu/records:target_records",
        "//loom/src/loom/target/emit/native/amdgpu:runtime_globals",
        "//loom/src/loom/testing:module_ptr",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
