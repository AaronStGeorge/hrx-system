// RUN: roundtrip

kernel.def @f32_arith(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %sum = vector.addf %lhs, %rhs : vector<1xf32>
  %product = vector.mulf %sum, %rhs : vector<1xf32>
  %negated = vector.negf %product : vector<1xf32>
  %absolute = vector.absf %negated : vector<1xf32>
  vector.store %absolute, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  kernel.return
}

// ====

kernel.def @f32_fma(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %bias = vector.constant 0.5 : vector<1xf32>
  %fma = vector.fmaf %lhs, %rhs, %bias : vector<1xf32>
  %result = vector.subf %fma, %bias : vector<1xf32>
  vector.store %result, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  kernel.return
}

// ====

kernel.def @f32_arcp_div(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %quotient = vector.divf<nnan|ninf|nsz|arcp> %lhs, %rhs : vector<4xf32>
  vector.store %quotient, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  kernel.return
}

// ====

kernel.def @f32_scalarized(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %lhs0 = vector.extract %lhs[0] : vector<4xf32> -> f32
  %rhs0 = vector.extract %rhs[0] : vector<4xf32> -> f32
  %lane0 = scalar.addf %lhs0, %rhs0 : f32
  %lhs1 = vector.extract %lhs[1] : vector<4xf32> -> f32
  %rhs1 = vector.extract %rhs[1] : vector<4xf32> -> f32
  %lane1 = scalar.mulf %lhs1, %rhs1 : f32
  %lhs2 = vector.extract %lhs[2] : vector<4xf32> -> f32
  %rhs2 = vector.extract %rhs[2] : vector<4xf32> -> f32
  %difference = scalar.subf %lhs2, %rhs2 : f32
  %negated = scalar.negf %difference : f32
  %lane2 = scalar.absf %negated : f32
  %lhs3 = vector.extract %lhs[3] : vector<4xf32> -> f32
  %rhs3 = vector.extract %rhs[3] : vector<4xf32> -> f32
  %bias = scalar.constant 0.5 : f32
  %lane3 = scalar.fmaf %lhs3, %rhs3, %bias : f32
  %result = vector.from_elements %lane0, %lane1, %lane2, %lane3 : vector<4xf32>
  vector.store %result, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  kernel.return
}

// ====

func.def @f32_uniform_vector_bitops(%input: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %input_global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %input_noalias = buffer.assume.noalias %input_global : buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<4xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %negated = vector.negf %loaded : vector<4xf32>
  %absolute = vector.absf %loaded : vector<4xf32>
  %result = vector.addf %negated, %absolute : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====

func.def @f32_uniform_vector_binary(%lhs_buffer: buffer, %rhs_buffer: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %lhs_global = buffer.assume.memory_space %lhs_buffer {memory_space = global} : buffer
  %rhs_global = buffer.assume.memory_space %rhs_buffer {memory_space = global} : buffer
  %lhs_noalias, %rhs_noalias = buffer.assume.noalias %lhs_global, %rhs_global : buffer, buffer
  %lhs_view = buffer.view %lhs_noalias[%base] : buffer -> view<4xf32, #dense>
  %rhs_view = buffer.view %rhs_noalias[%base] : buffer -> view<4xf32, #dense>
  %lhs = vector.load %lhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %sum = vector.addf %lhs, %rhs : vector<4xf32>
  %difference = vector.subf %lhs, %rhs : vector<4xf32>
  %combined = vector.addf %product, %sum : vector<4xf32>
  %two = vector.constant 2.0 : vector<4xf32>
  %scaled = vector.mulf %lhs, %two : vector<4xf32>
  %with_difference = vector.addf %combined, %difference : vector<4xf32>
  %result = vector.addf %with_difference, %scaled : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====

func.def @f32_uniform_scalar_binary(%lhs_buffer: buffer, %rhs_buffer: buffer) -> (f32) {
  %base = index.constant 0 : offset
  %lhs_global = buffer.assume.memory_space %lhs_buffer {memory_space = global} : buffer
  %rhs_global = buffer.assume.memory_space %rhs_buffer {memory_space = global} : buffer
  %lhs_noalias, %rhs_noalias = buffer.assume.noalias %lhs_global, %rhs_global : buffer, buffer
  %lhs_view = buffer.view %lhs_noalias[%base] : buffer -> view<1xf32, #dense>
  %rhs_view = buffer.view %rhs_noalias[%base] : buffer -> view<1xf32, #dense>
  %lhs = view.load %lhs_view[0] : view<1xf32, #dense> -> f32
  %rhs = view.load %rhs_view[0] : view<1xf32, #dense> -> f32
  %sum = scalar.addf %lhs, %rhs : f32
  func.return %sum : f32
}

// ====

func.def @f32_uniform_scalar_fma(%a_buffer: buffer, %b_buffer: buffer, %c_buffer: buffer) -> (f32) {
  %base = index.constant 0 : offset
  %a_global = buffer.assume.memory_space %a_buffer {memory_space = global} : buffer
  %b_global = buffer.assume.memory_space %b_buffer {memory_space = global} : buffer
  %c_global = buffer.assume.memory_space %c_buffer {memory_space = global} : buffer
  %a_noalias, %b_noalias, %c_noalias = buffer.assume.noalias %a_global, %b_global, %c_global : buffer, buffer, buffer
  %a_view = buffer.view %a_noalias[%base] : buffer -> view<1xf32, #dense>
  %b_view = buffer.view %b_noalias[%base] : buffer -> view<1xf32, #dense>
  %c_view = buffer.view %c_noalias[%base] : buffer -> view<1xf32, #dense>
  %a = view.load %a_view[0] : view<1xf32, #dense> -> f32
  %b = view.load %b_view[0] : view<1xf32, #dense> -> f32
  %c = view.load %c_view[0] : view<1xf32, #dense> -> f32
  %result = scalar.fmaf %a, %b, %c : f32
  func.return %result : f32
}

// ====

func.def @f32_uniform_vector_fma(%a_buffer: buffer, %b_buffer: buffer, %c_buffer: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %a_global = buffer.assume.memory_space %a_buffer {memory_space = global} : buffer
  %b_global = buffer.assume.memory_space %b_buffer {memory_space = global} : buffer
  %c_global = buffer.assume.memory_space %c_buffer {memory_space = global} : buffer
  %a_noalias, %b_noalias, %c_noalias = buffer.assume.noalias %a_global, %b_global, %c_global : buffer, buffer, buffer
  %a_view = buffer.view %a_noalias[%base] : buffer -> view<4xf32, #dense>
  %b_view = buffer.view %b_noalias[%base] : buffer -> view<4xf32, #dense>
  %c_view = buffer.view %c_noalias[%base] : buffer -> view<4xf32, #dense>
  %a = vector.load %a_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %b = vector.load %b_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %c = vector.load %c_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %result = vector.fmaf %a, %b, %c : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====

kernel.def @f32_direct_arg_scale(%output: buffer, %scale: f32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %zero_offset = index.constant 0 : offset
  %zero_index = index.constant 0 : index
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<1xf32, #dense>
  %unit = scalar.constant 1.0 : f32
  %scaled = scalar.mulf %unit, %scale : f32
  view.store %scaled, %output_view[%zero_index] : f32, view<1xf32, #dense>
  kernel.return
}
