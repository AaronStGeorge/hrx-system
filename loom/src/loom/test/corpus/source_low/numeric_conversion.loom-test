kernel.def @scalar_extf_bf16_load_store() {
  %count = index.constant 1 : index
  kernel.launch.config workgroups(%count, %count, %count) workgroup_size(%count, %count, %count) : index
} launch(%input: buffer, %output: buffer) {
  %base = index.constant 0 : offset
  %index = index.constant 0 : index
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %input_noalias, %output_noalias = buffer.assume.noalias %input_global, %output_global : buffer, buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<1xbf16, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<1xf32, #dense>
  %loaded = view.load %input_view[%index] : view<1xbf16, #dense> -> bf16
  %converted = scalar.extf %loaded : bf16 to f32
  view.store %converted, %output_view[%index] : f32, view<1xf32, #dense>
  kernel.return
}

