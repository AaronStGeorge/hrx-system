// RUN: roundtrip

// ====

func.def @vector_sitofp_i32x2(%input: vector<2xi32>, %scale: vector<2xf32>) -> (vector<2xf32>) {
  %converted = vector.sitofp %input : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  func.return %scaled : vector<2xf32>
}

// ====

func.def @scalar_uitofp_i32(%input: i32) -> (f32) {
  %converted = scalar.uitofp %input : i32 to f32
  func.return %converted : f32
}

// ====

func.def @scalar_sitofp_i32(%input: i32) -> (f32) {
  %converted = scalar.sitofp %input : i32 to f32
  func.return %converted : f32
}

// ====

func.def @vector_uitofp_i32x2(%input: vector<2xi32>) -> (vector<2xf32>) {
  %converted = vector.uitofp %input : vector<2xi32> to vector<2xf32>
  func.return %converted : vector<2xf32>
}
