// ====

func.def @vector_quantize_round_f32_to_i8x4(%values: vector<4xf32>, %inverse_scale: f32) -> (vector<4xi8>) {
  %scale = vector.splat %inverse_scale : vector<4xf32>
  %scaled = vector.mulf %values, %scale : vector<4xf32>
  %rounded = vector.roundf %scaled : vector<4xf32>
  %i32 = vector.fptosi %rounded : vector<4xf32> to vector<4xi32>
  %packed = vector.trunci %i32 : vector<4xi32> to vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ====

func.def @vector_quantize_round_afn_f32_to_i8x4(%values: vector<4xf32>, %inverse_scale: f32) -> (vector<4xi8>) {
  %scale = vector.splat %inverse_scale : vector<4xf32>
  %scaled = vector.mulf %values, %scale : vector<4xf32>
  %rounded = vector.roundf<afn> %scaled : vector<4xf32>
  %i32 = vector.fptosi %rounded : vector<4xf32> to vector<4xi32>
  %packed = vector.trunci %i32 : vector<4xi32> to vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ====

func.def @vector_quantize_roundeven_f32_to_i8x4(%values: vector<4xf32>, %inverse_scale: f32) -> (vector<4xi8>) {
  %scale = vector.splat %inverse_scale : vector<4xf32>
  %scaled = vector.mulf %values, %scale : vector<4xf32>
  %rounded = vector.roundevenf %scaled : vector<4xf32>
  %i32 = vector.fptosi %rounded : vector<4xf32> to vector<4xi32>
  %packed = vector.trunci %i32 : vector<4xi32> to vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ====

func.def @vector_quantize_scalarized_roundeven_f32_to_i8x4(%values: vector<4xf32>, %inverse_scale: f32) -> (vector<4xi8>) {
  %scale = vector.splat %inverse_scale : vector<4xf32>
  %scaled = vector.mulf %values, %scale : vector<4xf32>
  %lane0 = vector.extract %scaled[0] : vector<4xf32> -> f32
  %rounded0 = scalar.roundevenf %lane0 : f32
  %i32_0 = scalar.fptosi %rounded0 : f32 to i32
  %i8_0 = scalar.trunci %i32_0 : i32 to i8
  %lane1 = vector.extract %scaled[1] : vector<4xf32> -> f32
  %rounded1 = scalar.roundevenf %lane1 : f32
  %i32_1 = scalar.fptosi %rounded1 : f32 to i32
  %i8_1 = scalar.trunci %i32_1 : i32 to i8
  %lane2 = vector.extract %scaled[2] : vector<4xf32> -> f32
  %rounded2 = scalar.roundevenf %lane2 : f32
  %i32_2 = scalar.fptosi %rounded2 : f32 to i32
  %i8_2 = scalar.trunci %i32_2 : i32 to i8
  %lane3 = vector.extract %scaled[3] : vector<4xf32> -> f32
  %rounded3 = scalar.roundevenf %lane3 : f32
  %i32_3 = scalar.fptosi %rounded3 : f32 to i32
  %i8_3 = scalar.trunci %i32_3 : i32 to i8
  %packed = vector.from_elements %i8_0, %i8_1, %i8_2, %i8_3 : vector<4xi8>
  func.return %packed : vector<4xi8>
}

