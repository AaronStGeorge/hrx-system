// ====

func.def @scalar_f16_cfg_cond_join(%lhs: i32, %rhs: i32, %then_input: i32, %else_input: i32) -> (f16) {
  %condition = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %condition, ^then, ^else
^then:
  %then_half = scalar.sitofp %then_input : i32 to f16
  cfg.br ^join(%then_half: f16)
^else:
  %else_half = scalar.sitofp %else_input : i32 to f16
  cfg.br ^join(%else_half: f16)
^join(%selected: f16):
  func.return %selected : f16
}

