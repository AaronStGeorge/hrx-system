func.def @vector_uitofp_i32x2(%input: vector<2xi32>) -> (vector<2xf32>) {
  %converted = vector.uitofp %input : vector<2xi32> to vector<2xf32>
  func.return %converted : vector<2xf32>
}

// ====

func.def @scalar_extsi_i32_store(%output: buffer, %input: i32) {
  %base = index.constant 0 : offset
  %output_view = buffer.view %output[%base] : buffer -> view<1xi64, #dense>
  %converted = scalar.extsi %input : i32 to i64
  view.store %converted, %output_view[0] : i64, view<1xi64, #dense>
  func.return
}
