func.def @bf16_strided_gather_dot2(%latent: vector<2xbf16>, %weights: buffer, %origin: index, %accumulator: vector<1xf32>) -> (vector<1xf32>) {
  %base = index.constant 0 : offset
  %start = index.constant 0 : index
  %step = index.constant 7 : index
  %origin_bounded = index.assume %origin [range(%origin, 0, 4088)] : index
  %weights_view = buffer.view %weights[%base] : buffer -> view<4096xbf16, #dense>
  %offsets = vector.iota %start step %step : vector<2xindex>
  %weight = vector.gather %weights_view[%origin_bounded][%offsets] : view<4096xbf16, #dense>, vector<2xindex> -> vector<2xbf16>
  %dot = vector.dot2f %latent, %weight, %accumulator : vector<2xbf16>, vector<2xbf16>, vector<1xf32>
  func.return %dot : vector<1xf32>
}

// ====

kernel.def @i32_dynamic_flat_store(%input: buffer, %output: buffer, %row_count_i32: i32, %row_i32: i32) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %start = index.constant 0 : index
  %row_count0 = index.cast %row_count_i32 : i32 to index
  %row_count = index.assume %row_count0 [range(%row_count0, 1, 2147483647)] : index
  %row0 = index.cast %row_i32 : i32 to index
  %row = index.assume %row0 [range(%row0, 0, 2147483646)] : index
  %input_view = buffer.view %input[%base] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<[%row_count]x128xi32, #dense>
  %loaded = view.load %input_view[%start] : view<1xi32, #dense> -> i32
  view.store %loaded, %output_view[%row, %start] : i32, view<[%row_count]x128xi32, #dense>
  kernel.return
}

// ====

kernel.def @rank2_vector_tile_transpose(%input: buffer, %output: buffer) {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 16 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %block = kernel.workitem.id<x> : index
  %tile_width = index.constant 4 : index
  %tile_base0 = index.mul %block, %tile_width : index
  %tile_base = index.assume %tile_base0 [range(%tile_base0, 0, 60)] : index
  %input_view = buffer.view %input[%base] : buffer -> view<4x64xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<64x4xf32, #dense>
  %nct_tile = vector.load %input_view[0, %tile_base] : view<4x64xf32, #dense> -> vector<4x4xf32>
  %ntc_tile = vector.transpose<[1, 0]> %nct_tile : vector<4x4xf32> -> vector<4x4xf32>
  vector.store %ntc_tile, %output_view[%tile_base, 0] : vector<4x4xf32>, view<64x4xf32, #dense>
  kernel.return
}
