kernel.def @rank2_vector_tile_transpose() {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 16 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %base = index.constant 0 : offset
  %block = kernel.workitem.id<x> : index
  %tile_width = index.constant 4 : index
  %tile_base0 = index.mul %block, %tile_width : index
  %tile_base = index.assume %tile_base0 [range(%tile_base0, 0, 60)] : index
  %input_view = buffer.view %input[%base] : buffer -> view<4x64xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<64x4xf32, #dense>
  %nct_tile = vector.load %input_view[0, %tile_base] : view<4x64xf32, #dense> -> vector<4x4xf32>
  %ntc_tile = vector.transpose<[1, 0]> %nct_tile : vector<4x4xf32> -> vector<4x4xf32>
  vector.store %ntc_tile, %output_view[%tile_base, 0] : vector<4x4xf32>, view<64x4xf32, #dense>
  kernel.return
}

