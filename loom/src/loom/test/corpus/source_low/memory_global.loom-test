kernel.def target(@target) @f32x4_readonly_uniform_smem_copy() {
  %unit = index.constant 1 : index
  %workgroups = index.constant 16 : index
  kernel.launch.config workgroups(%workgroups, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %workgroup = kernel.workgroup.id<x> : index
  %base = index.constant 0 : offset
  %vector_width = index.constant 4 : index
  %source_base0 = index.mul %workgroup, %vector_width : index
  %source_base = index.assume %source_base0 [range(%source_base0, 0, 60), mul(%source_base0, 4)] : index
  %output_prefix = index.constant 6 : index
  %output_base0 = index.add %source_base, %output_prefix : index
  %output_base = index.assume %output_base0 [range(%output_base0, 6, 66)] : index
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %input_noalias, %output_noalias = buffer.assume.noalias %input_global, %output_global : buffer, buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<70xf32, #dense>
  %loaded = vector.load %input_view[%source_base] : view<64xf32, #dense> -> vector<4xf32>
  vector.store %loaded, %output_view[%output_base] : vector<4xf32>, view<70xf32, #dense>
  kernel.return
}

