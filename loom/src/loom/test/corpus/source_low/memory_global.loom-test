  %index = index.assume %raw_index [range(%raw_index, 0, 1073741823), lt(%raw_index, %element_count)] : index
  %input_view = buffer.view %input[%base] : buffer -> view<[%element_count]xf16, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<1xf32, #dense>
  %half = view.load %input_view[%index] : view<[%element_count]xf16, #dense> -> f16
  %loaded = scalar.extf %half : f16 to f32
  view.store %loaded, %output_view[%start] : f32, view<1xf32, #dense>
  kernel.return
}

