func.def @scf_select_i1_mask_condition(%values: vector<2xi32>, %limit: i32, %fallback_condition: i1, %true_value: f32, %false_value: f32) -> (f32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %lane_condition = scalar.cmpi slt, %lane, %limit : i32
  %selected_condition = scf.select %lane_condition, %lane_condition, %fallback_condition : i1
  %result = scf.select %selected_condition, %true_value, %false_value : f32
  func.return %result : f32
}

