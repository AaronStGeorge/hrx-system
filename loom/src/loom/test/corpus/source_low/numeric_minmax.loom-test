// RUN: roundtrip

func.def @scalar_f32_minnum_maxnum(%lhs: f32, %rhs: f32) -> (f32) {
  %min = scalar.minnumf %lhs, %rhs : f32
  %max = scalar.maxnumf %lhs, %rhs : f32
  %sum = scalar.addf %min, %max : f32
  func.return %sum : f32
}

// ====

func.def @vector_f32_minnum_maxnum(%lhs: vector<2xf32>, %rhs: vector<2xf32>) -> (vector<2xf32>) {
  %min = vector.minnumf %lhs, %rhs : vector<2xf32>
  %max = vector.maxnumf %lhs, %rhs : vector<2xf32>
  %sum = vector.addf %min, %max : vector<2xf32>
  func.return %sum : vector<2xf32>
}

// ====

func.def @scalar_f32_clampf_number(%input: f32) -> (f32) {
  %lower = scalar.constant -1.0 : f32
  %upper = scalar.constant 1.0 : f32
  %result = scalar.clampf<number, nnan|nsz> %input, %lower, %upper : f32
  func.return %result : f32
}

// ====

func.def @vector_f32_clampf_number(%input: vector<2xf32>) -> (vector<2xf32>) {
  %lower = vector.constant -1.0 : vector<2xf32>
  %upper = vector.constant 1.0 : vector<2xf32>
  %result = vector.clampf<number, nnan|nsz> %input, %lower, %upper : vector<2xf32>
  func.return %result : vector<2xf32>
}

// ====

func.def @scalar_f32_clampf_ordered(%input: f32, %lower: f32, %upper: f32) -> (f32) {
  %result = scalar.clampf<ordered> %input, %lower, %upper : f32
  func.return %result : f32
}

// ====

func.def @vector_f32_clampf_ordered(%input: vector<2xf32>, %lower: vector<2xf32>, %upper: vector<2xf32>) -> (vector<2xf32>) {
  %result = vector.clampf<ordered> %input, %lower, %upper : vector<2xf32>
  func.return %result : vector<2xf32>
}

// ====

func.def @index_minmax_sgpr(%lhs0: index, %rhs0: index) -> (index) {
  %lhs = index.assume %lhs0 [range(%lhs0, 0, 1024)] : index
  %rhs = index.assume %rhs0 [range(%rhs0, 0, 1024)] : index
  %min = index.min %lhs, %rhs : index
  %max = index.max %lhs, %rhs : index
  %sum = index.add %min, %max : index
  func.return %sum : index
}

// ====

func.def @scf_select_sgpr(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  %selected = scf.select %cond, %a, %b : i32
  func.return %selected : i32
}

// ====

func.def @scf_select_i64_sgpr(%lhs: i32, %rhs: i32, %a: i64, %b: i64) -> (i64) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  %selected = scf.select %cond, %a, %b : i64
  func.return %selected : i64
}

// ====

func.def @scf_select_q6_nibble_i8(%code: i32, %use_high: i32) -> (i8) {
  %zero = scalar.constant 0 : i32
  %four = scalar.constant 4 : i32
  %mask = scalar.constant 15 : i32
  %high_shifted = scalar.shrui %code, %four : i32
  %low_i32 = scalar.andi %code, %mask : i32
  %high_i32 = scalar.andi %high_shifted, %mask : i32
  %low = scalar.trunci %low_i32 : i32 to i8
  %high = scalar.trunci %high_i32 : i32 to i8
  %cond = scalar.cmpi ne, %use_high, %zero : i32
  %selected = scf.select %cond, %high, %low : i8
  func.return %selected : i8
}

// ====

func.def @scf_select_scale_piece_i16(%packed: i32, %use_high: i32) -> (i16) {
  %zero = scalar.constant 0 : i32
  %sixteen = scalar.constant 16 : i32
  %low = scalar.trunci %packed : i32 to i16
  %high_shifted = scalar.shrui %packed, %sixteen : i32
  %high = scalar.trunci %high_shifted : i32 to i16
  %cond = scalar.cmpi ne, %use_high, %zero : i32
  %selected = scf.select %cond, %high, %low : i16
  func.return %selected : i16
}

// ====

func.def @scf_select_vgpr(%lhs: f32, %rhs: f32, %a: f32, %b: f32) -> (f32) {
  %cond = scalar.cmpf olt, %lhs, %rhs : f32
  %selected = scf.select %cond, %a, %b : f32
  func.return %selected : f32
}

// ====

func.def @scf_select_chained_vgpr_i32(%values: vector<2xi32>, %limit: i32, %fallback: i32) -> (i32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %is_lane = scalar.cmpi slt, %lane, %limit : i32
  %selected = scf.select %is_lane, %lane, %fallback : i32
  %is_selected = scalar.cmpi ne, %selected, %fallback : i32
  %result = scf.select %is_selected, %selected, %fallback : i32
  func.return %result : i32
}

// ====

func.def @scf_select_tail_zero_i32(%values: vector<2xi32>, %limit: i32) -> (i32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %zero = scalar.constant 0 : i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %selected = scf.select %cond, %lane, %zero : i32
  func.return %selected : i32
}

// ====

func.def @scf_select_vgpr_i64(%values: vector<2xi32>, %limit: i32, %fallback: i32) -> (i64) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %wide_lane = scalar.extsi %lane : i32 to i64
  %wide_fallback = scalar.extsi %fallback : i32 to i64
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %selected = scf.select %cond, %wide_lane, %wide_fallback : i64
  func.return %selected : i64
}

// ====

func.def @scf_select_vector_extract_i64(%values: vector<2xi64>, %guards: vector<2xi32>, %limit: i32, %fallback: i64) -> (i64) {
  %lane = vector.extract %guards[0] : vector<2xi32> -> i32
  %extracted = vector.extract %values[0] : vector<2xi64> -> i64
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %selected = scf.select %cond, %extracted, %fallback : i64
  func.return %selected : i64
}

