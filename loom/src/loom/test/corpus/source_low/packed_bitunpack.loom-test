// RUN: roundtrip

// ====

func.def @i32_to_u8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ====

func.def @i32_to_s8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacks<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ====

func.def @i32_to_u4x8_bitunpack(%packed: vector<1xi32>) -> (vector<8xi32>) {
  %unpacked = vector.bitunpacku<4> %packed : vector<1xi32> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ====

func.def @i8x2_to_u2x8_bitunpack(%packed: vector<2xi8>) -> (vector<8xi32>) {
  %unpacked = vector.bitunpacku<2> %packed : vector<2xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ====

func.def @q3_width_rejected(%packed: vector<3xi8>) -> (vector<8xi32>) {
  %unpacked = vector.bitunpacks<3> %packed : vector<3xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ====

func.def @bitunpack_lane_count_rejected(%packed: vector<16xi8>) -> (vector<32xi32>) {
  %unpacked = vector.bitunpacku<4> %packed : vector<16xi8> -> vector<32xi32>
  func.return %unpacked : vector<32xi32>
}

// ====

func.def @bitunpack_result_type_rejected(%packed: vector<1xi32>) -> (vector<4xi8>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi8>
  func.return %unpacked : vector<4xi8>
}
