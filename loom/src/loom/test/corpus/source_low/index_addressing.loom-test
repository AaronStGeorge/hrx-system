// RUN: roundtrip

kernel.def @index_madd_global_b32(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c4, %c4, %c1) : index
} launch {
  %x0 = kernel.workitem.id<x> : index
  %x = index.assume %x0 [range(%x0, 0, 3)] : index
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 3)] : index
  %zero = index.constant 0 : offset
  %row_stride = index.constant 4 : index
  %linear = index.madd %y, %row_stride, %x : index
  %input_view = buffer.view %input[%zero] : buffer -> view<16xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<16xi32, #dense>
  %loaded = vector.load %input_view[%linear] : view<16xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%linear] : vector<1xi32>, view<16xi32, #dense>
  kernel.return
}

// ====

kernel.def @index_madd_constant_addend_global_b32(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c4, %c1, %c1) : index
} launch {
  %x0 = kernel.workitem.id<x> : index
  %x = index.assume %x0 [range(%x0, 0, 3)] : index
  %zero = index.constant 0 : offset
  %row_stride = index.constant 4 : index
  %column = index.constant 1 : index
  %linear = index.madd %x, %row_stride, %column : index
  %input_view = buffer.view %input[%zero] : buffer -> view<16xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<16xi32, #dense>
  %loaded = vector.load %input_view[%linear] : view<16xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%linear] : vector<1xi32>, view<16xi32, #dense>
  kernel.return
}

// ====

kernel.def @index_shli_global_b32(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c4, %c1, %c1) : index
} launch {
  %x0 = kernel.workitem.id<x> : index
  %x = index.assume %x0 [range(%x0, 0, 3)] : index
  %zero = index.constant 0 : offset
  %shift = index.constant 2 : index
  %linear = index.shli %x, %shift : index
  %input_view = buffer.view %input[%zero] : buffer -> view<16xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<16xi32, #dense>
  %loaded = vector.load %input_view[%linear] : view<16xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%linear] : vector<1xi32>, view<16xi32, #dense>
  kernel.return
}

// ====

kernel.def @index_shli_previous_row_global_b128(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  %c32 = index.constant 32 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c32, %c1, %c1) : index
} launch {
  %x0 = kernel.workitem.id<x> : index
  %x = index.assume %x0 [range(%x0, 1, 31)] : index
  %base_offset = index.constant 0 : offset
  %one = index.constant 1 : index
  %previous = index.sub %x, %one : index
  %shift = index.constant 2 : index
  %linear = index.shli %previous, %shift : index
  %input_view = buffer.view %input[%base_offset] : buffer -> view<128xi32, #dense>
  %output_view = buffer.view %output[%base_offset] : buffer -> view<128xi32, #dense>
  %loaded = vector.load %input_view[%linear] : view<128xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[%linear] : vector<4xi32>, view<128xi32, #dense>
  kernel.return
}

// ====

kernel.def @workitem_y_lds_uses_explicit_vaddr(%output: buffer) {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c64, %c1) : index
} launch {
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %value = vector.constant 7 : vector<1xi32>
  vector.store %value, %scratch_view[%y] : vector<1xi32>, view<64xi32, #dense>
  %loaded = vector.load %scratch_view[%y] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%y] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ====

kernel.def @dispatch_id_xy_global_b32(%output: buffer) {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c8, %c4, %c1) : index
} launch {
  %dispatch_x0 = kernel.workitem.dispatch.id<x> : index
  %dispatch_x = index.assume %dispatch_x0 [range(%dispatch_x0, 0, 31)] : index
  %dispatch_y0 = kernel.workitem.dispatch.id<y> : index
  %dispatch_y = index.assume %dispatch_y0 [range(%dispatch_y0, 0, 15)] : index
  %row_stride = index.constant 32 : index
  %linear = index.madd %dispatch_y, %row_stride, %dispatch_x : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<512xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%linear] : vector<1xi32>, view<512xi32, #dense>
  kernel.return
}
