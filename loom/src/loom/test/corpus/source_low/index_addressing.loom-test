kernel.def @index_div_rem_power_of_two_global_b32() {
  %unit = index.constant 1 : index
  %lane_count = index.constant 32 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%lane_count, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %lane = kernel.workitem.id<x> : index
  %base_offset = index.constant 0 : offset
  %divisor = index.constant 8 : index
  %quotient = index.div %lane, %divisor : index
  %remainder = index.rem %lane, %divisor : index
  %input_view = buffer.view %input[%base_offset] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%base_offset] : buffer -> view<8xi32, #dense>
  %loaded = vector.load %input_view[%quotient] : view<4xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%remainder] : vector<1xi32>, view<8xi32, #dense>
  kernel.return
}

