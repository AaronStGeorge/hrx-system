// ====

kernel.def @lds_atomic_cmpxchg_i32() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %expected = scalar.constant 7 : i32
  %replacement = scalar.constant 9 : i32
  %old = view.atomic.cmpxchg %expected, %replacement, %scratch_view[%tid] {failure_ordering = relaxed, scope = workgroup, success_ordering = relaxed} : i32, view<64xi32, #dense> -> i32
  kernel.return
}

// ====

kernel.def @lds_atomic_minmax_i32() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %limit = scalar.constant 1 : i32
  view.atomic.reduce<minsi> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense>
  view.atomic.reduce<maxsi> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense>
  view.atomic.reduce<minui> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense>
  view.atomic.reduce<maxui> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense>
  %old_minsi = view.atomic.rmw<minsi> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense> -> i32
  %old_maxsi = view.atomic.rmw<maxsi> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense> -> i32
  %old_minui = view.atomic.rmw<minui> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense> -> i32
  %old_maxui = view.atomic.rmw<maxui> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense> -> i32
  kernel.return
}
