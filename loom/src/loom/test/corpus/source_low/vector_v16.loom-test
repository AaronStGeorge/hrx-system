// RUN: roundtrip

func.def @i32x16_arith(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<16xi32>
  %diff = vector.subi %sum, %rhs : vector<16xi32>
  func.return %diff : vector<16xi32>
}

// ====

func.def @i32x16_minmax_logic(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %min_s = vector.minsi %lhs, %rhs : vector<16xi32>
  %max_s = vector.maxsi %lhs, %rhs : vector<16xi32>
  %min_u = vector.minui %lhs, %rhs : vector<16xi32>
  %max_u = vector.maxui %lhs, %rhs : vector<16xi32>
  %mask = vector.andi %min_s, %max_s : vector<16xi32>
  %mixed = vector.xori %mask, %min_u : vector<16xi32>
  %result = vector.ori %mixed, %max_u : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ====

func.def @i32x16_variable_shift(%value: vector<16xi32>, %amount: vector<16xi32>) -> (vector<16xi32>) {
  %left = vector.shli %value, %amount : vector<16xi32>
  %signed = vector.shrsi %left, %amount : vector<16xi32>
  %result = vector.shrui %signed, %amount : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ====

func.def @i32x16_splat_add(%value: i32, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %splat = vector.splat %value : vector<16xi32>
  %sum = vector.addi %splat, %rhs : vector<16xi32>
  func.return %sum : vector<16xi32>
}

// ====

func.def @i32x16_compare_select(%lhs: vector<16xi32>, %rhs: vector<16xi32>, %fallback: vector<16xi32>) -> (vector<16xi32>) {
  %signed = vector.cmpi sgt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %unsigned = vector.cmpi ugt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %selected = vector.select %signed, %lhs, %rhs : vector<16xi32>
  %result = vector.select %unsigned, %selected, %fallback : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ====

func.def @i32x16_mask_and_select(%lhs: vector<16xi32>, %rhs: vector<16xi32>, %fallback: vector<16xi32>) -> (vector<16xi32>) {
  %greater = vector.cmpi sgt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %less = vector.cmpi slt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %either = vector.ori %greater, %less : vector<16xi1>
  %greater_again = vector.andi %either, %greater : vector<16xi1>
  %condition = vector.xori %greater_again, %less : vector<16xi1>
  %result = vector.select %condition, %lhs, %fallback : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ====

func.def @f32x16_arith(%lhs: vector<16xf32>, %rhs: vector<16xf32>) -> (vector<16xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<16xf32>
  %difference = vector.subf %sum, %lhs : vector<16xf32>
  %product = vector.mulf %difference, %rhs : vector<16xf32>
  %fma = vector.fmaf %lhs, %rhs, %product : vector<16xf32>
  func.return %fma : vector<16xf32>
}

// ====

func.def @f32x16_splat_add(%value: f32, %rhs: vector<16xf32>) -> (vector<16xf32>) {
  %splat = vector.splat %value : vector<16xf32>
  %sum = vector.addf %splat, %rhs : vector<16xf32>
  func.return %sum : vector<16xf32>
}

// ====

func.def @f32x16_compare_select(%lhs: vector<16xf32>, %rhs: vector<16xf32>, %fallback: vector<16xf32>) -> (vector<16xf32>) {
  %ordered_lt = vector.cmpf olt, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %unordered_ne = vector.cmpf une, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %selected = vector.select %ordered_lt, %lhs, %rhs : vector<16xf32>
  %result = vector.select %unordered_ne, %selected, %fallback : vector<16xf32>
  func.return %result : vector<16xf32>
}

// ====

func.def @f32x16_static_memory(%input: buffer, %output: buffer) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[4] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[8] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ====

func.def @f32x16_dynamic_memory(%input: buffer, %output: buffer, %i: index) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%i] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%i] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ====

func.def @f32x16_index_add_memory(%input: buffer, %output: buffer, %i: index, %j: index) {
  %zero = index.constant 0 : offset
  %sum = index.add %i, %j : index
  %input_view = buffer.view %input[%zero] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%sum] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%sum] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ====

func.def @f32x16_index_madd_memory(%input: buffer, %output: buffer, %row: index, %stride: index, %col: index) {
  %zero = index.constant 0 : offset
  %linear = index.madd %row, %stride, %col : index
  %input_view = buffer.view %input[%zero] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%linear] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%linear] : vector<16xf32>, view<32xf32, #dense>
  func.return
}
