// RUN: roundtrip

func.def @i32x4_slice_middle(%values: vector<4xi32>) -> (vector<2xi32>) {
  %middle = vector.slice %values[1] : vector<4xi32> -> vector<2xi32>
  func.return %middle : vector<2xi32>
}

// ====

func.def @i8x4_slice_low_half(%bytes: vector<4xi8>) -> (vector<2xi8>) {
  %low = vector.slice %bytes[0] : vector<4xi8> -> vector<2xi8>
  func.return %low : vector<2xi8>
}

// ====

func.def @i8x4_slice_high_half(%bytes: vector<4xi8>) -> (vector<2xi8>) {
  %high = vector.slice %bytes[2] : vector<4xi8> -> vector<2xi8>
  func.return %high : vector<2xi8>
}

// ====

func.def @f16x4_slice_low_half(%values: vector<4xf16>) -> (vector<2xf16>) {
  %low = vector.slice %values[0] : vector<4xf16> -> vector<2xf16>
  func.return %low : vector<2xf16>
}

// ====

func.def @f16x4_slice_high_half(%values: vector<4xf16>) -> (vector<2xf16>) {
  %high = vector.slice %values[2] : vector<4xf16> -> vector<2xf16>
  func.return %high : vector<2xf16>
}

// ====

func.def @bf16x4_slice_high_half(%values: vector<4xbf16>) -> (vector<2xbf16>) {
  %high = vector.slice %values[2] : vector<4xbf16> -> vector<2xbf16>
  func.return %high : vector<2xbf16>
}
