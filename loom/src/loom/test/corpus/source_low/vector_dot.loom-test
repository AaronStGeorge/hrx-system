// RUN: roundtrip

func.def @f32_dotf(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %dot = vector.dotf %lhs, %rhs, %acc : vector<4xf32>, vector<4xf32>, f32
  func.return %dot : f32
}

// ====

func.def @f16_dot2f(%lhs: vector<8xf16>, %rhs: vector<8xf16>, %acc: vector<4xf32>) -> (vector<4xf32>) {
  %dot = vector.dot2f %lhs, %rhs, %acc : vector<8xf16>, vector<8xf16>, vector<4xf32>
  func.return %dot : vector<4xf32>
}

// ====

func.def @bf16_dot2f(%lhs: vector<8xbf16>, %rhs: vector<8xbf16>, %acc: vector<4xf32>) -> (vector<4xf32>) {
  %dot = vector.dot2f %lhs, %rhs, %acc : vector<8xbf16>, vector<8xbf16>, vector<4xf32>
  func.return %dot : vector<4xf32>
}

// ====

func.def @f32_uniform_smem_vector_operands(%lhs: vector<4xf32>, %weights: buffer) -> (f32) {
  %base = index.constant 0 : offset
  %weights_global = buffer.assume.memory_space %weights {memory_space = global} : buffer
  %weights_noalias = buffer.assume.noalias %weights_global : buffer
  %weights_view = buffer.view %weights_noalias[%base] : buffer -> view<2x4xf32, #dense>
  %rhs = vector.load %weights_view[0, 0] : view<2x4xf32, #dense> -> vector<4xf32>
  %bias_vector = vector.load %weights_view[1, 0] : view<2x4xf32, #dense> -> vector<4xf32>
  %bias = vector.extract %bias_vector[0] : vector<4xf32> -> f32
  %scaled = vector.mulf %lhs, %rhs : vector<4xf32>
  %dot = vector.dotf %scaled, %rhs, %bias : vector<4xf32>, vector<4xf32>, f32
  func.return %dot : f32
}
