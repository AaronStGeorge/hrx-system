{
  "version": 1,
  "cases": [
    {
      "name": "proves hip lane distribution recipe",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/lane_distribution.loom",
          "--pass=canonicalize",
          "--output={tmp}/lane_distribution.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/lane_distribution.loom",
          "contains": [
            "%block_is_uniform = scalar.constant true : i1",
            "%block_is_varying = scalar.constant false : i1",
            "%thread_is_varying = scalar.constant true : i1",
            "%thread_is_uniform = scalar.constant false : i1",
            "%element_is_varying = scalar.constant true : i1",
            "%element_is_uniform = scalar.constant false : i1",
            "%lane_is_varying = scalar.constant true : i1",
            "%predicate_is_lane = scalar.constant true : i1",
            "%selected_is_varying = scalar.constant true : i1",
            "%dot_operand_is_varying = scalar.constant true : i1",
            "%dot_operand_is_uniform = scalar.constant false : i1"
          ]
        }
      ]
    },
    {
      "name": "plans q8 block unroll recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/q8_block_unroll.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_q8_block_unroll_wg64",
          "case_q8_block_unroll_wg64"
        ]
      }
    },
    {
      "name": "unrolls q8 hip-shaped dynamic lower bound loop",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/q8_block_unroll.loom",
          "--pass=unroll-scf-for",
          "--pass-report=json",
          "--output={tmp}/q8_block_unrolled.loom"
        ]
      },
      "stderr": {
        "contains": [
          "\"pass\":\"unroll-scf-for\"",
          "\"loops-unrolled\":1",
          "\"category\":\"scf-unroll\"",
          "\"outcome\":\"unrolled\"",
          "\"trip_count\":2",
          "\"step\":8",
          "\"lower_bound_kind\":\"dynamic\"",
          "\"lower_range_min\":0",
          "\"lower_range_max\":7"
        ]
      },
      "files": [
        {
          "path": "{tmp}/q8_block_unrolled.loom",
          "contains": [
            "vector.bitunpacks<8>",
            "vector.dotf"
          ],
          "not_contains": [
            "scf.for %block_idx_raw"
          ]
        }
      ]
    },
