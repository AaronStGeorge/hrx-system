{
  "version": 1,
  "cases": [
    {
      "name": "proves hip lane distribution recipe",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/lane_distribution.loom",
          "--pass=canonicalize",
          "--output={tmp}/lane_distribution.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/lane_distribution.loom",
          "contains": [
            "%block_is_uniform = scalar.constant true : i1",
            "%block_is_varying = scalar.constant false : i1",
            "%thread_is_varying = scalar.constant true : i1",
            "%thread_is_uniform = scalar.constant false : i1",
            "%element_is_varying = scalar.constant true : i1",
            "%element_is_uniform = scalar.constant false : i1",
            "%lane_is_varying = scalar.constant true : i1",
            "%predicate_is_lane = scalar.constant true : i1",
            "%selected_is_varying = scalar.constant true : i1",
            "%dot_operand_is_varying = scalar.constant true : i1",
            "%dot_operand_is_uniform = scalar.constant false : i1"
          ]
        }
      ]
    },
    {
      "name": "plans q8 block unroll recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/q8_block_unroll.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_q8_block_unroll_wg64",
          "case_q8_block_unroll_wg64"
        ]
      }
    },
    {
      "name": "unrolls q8 hip-shaped dynamic lower bound loop",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/q8_block_unroll.loom",
          "--pass=unroll-scf-for",
          "--pass-report=json",
          "--output={tmp}/q8_block_unrolled.loom"
        ]
      },
      "stderr": {
        "contains": [
          "\"pass\":\"unroll-scf-for\"",
          "\"loops-unrolled\":1",
          "\"category\":\"scf-unroll\"",
          "\"outcome\":\"unrolled\"",
          "\"trip_count\":2",
          "\"step\":8",
          "\"lower_bound_kind\":\"dynamic\"",
          "\"lower_range_min\":0",
          "\"lower_range_max\":7"
        ]
      },
      "files": [
        {
          "path": "{tmp}/q8_block_unrolled.loom",
          "contains": [
            "vector.bitunpacks<8>",
            "vector.dotf"
          ],
          "not_contains": [
            "scf.for %block_idx_raw"
          ]
        }
      ]
    },
    {
      "name": "plans q8 load width recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/q8_load_width.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_q8_load_widths",
          "case_q8_load_widths"
        ]
      }
    },
    {
      "name": "preserves explicit q8 vector load width recipe",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/q8_load_width.loom",
          "--pass=canonicalize",
          "--output={tmp}/q8_load_width.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/q8_load_width.loom",
          "contains": [
            "vector.load %input_words[0] : view<4xi32, #dense> -> vector<1xi32>",
            "vector.load %input_words[0] : view<4xi32, #dense> -> vector<4xi32>",
            "vector.store %wide, %vector_words[0] : vector<4xi32>, view<4xi32, #dense>"
          ]
        }
      ]
    },
    {
      "name": "plans q8 q4 signedness recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/q8_q4_signedness.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_q8_q4_signedness",
          "case_q8_q4_signedness",
          "bench_q8_mixed_dot4_signedness",
          "case_q8_mixed_dot4_signedness"
        ]
      }
    },
    {
      "name": "preserves q8 q4 signedness source shape",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/q8_q4_signedness.loom",
          "--output={tmp}/q8_q4_signedness.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/q8_q4_signedness.loom",
          "contains": [
            "vector.bitunpacku<8>",
            "vector.bitunpacks<8>",
            "vector.bitunpacku<4>",
            "vector.bitunpacks<4>",
            "vector.dot4i<u8s8>"
          ]
        }
      ]
    },
    {
      "name": "plans packed field contracts recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/packed_field_contracts.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_packed_field_contracts",
          "case_packed_field_contracts"
        ]
      }
    },
    {
      "name": "preserves packed field contract source shape",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/packed_field_contracts.loom",
          "--output={tmp}/packed_field_contracts.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/packed_field_contracts.loom",
          "contains": [
            "vector.bitunpacku<2>",
            "vector.bitfield.extractu %packed {offset = 3, width = 3}",
            "vector.dot8i4<s4u4>",
            "vector.bitunpacku<1>",
            "vector.bitfield.insert %high4 into %low_codes {offset = 4, width = 1}",
            "vector.bitunpacku<2> %high_packed",
            "vector.table.lookup %grid[%codes]"
          ]
        }
      ]
    },
    {
      "name": "folds packed field contract reference values",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/packed_field_contracts.loom",
          "--pass=canonicalize",
          "--output={tmp}/packed_field_contracts_canonical.loom"
        ]
      },
      "files": [
        {
          "path": "{tmp}/packed_field_contracts_canonical.loom",
          "contains": [
            "%r0 = scalar.constant -2 : i32",
            "%r3 = scalar.constant 1 : i32",
            "%r0 = scalar.constant -4 : i32",
            "%r3 = scalar.constant 3 : i32",
            "%r0 = scalar.constant -112 : i32",
            "%r1 = scalar.constant 112 : i32",
            "%r0 = scalar.constant -16 : i32",
            "%r2 = scalar.constant -15 : i32",
            "%r0 = scalar.constant -32 : i32",
            "%r6 = scalar.constant -26 : i32",
            "%r0 = scalar.constant -8 : i32",
            "%r3 = scalar.constant 9 : i32"
          ]
        }
      ]
    },
    {
      "name": "plans target provider selection recipe",
      "run": {
        "tool": "iree-benchmark-loom",
        "args": [
          "{srcdir}/target_provider_selection.loom",
          "--dry-run"
        ]
      },
      "stdout": {
        "contains": [
          "bench_target_provider_selection",
          "case_target_provider_selection"
        ]
      }
    },
    {
      "name": "selects target-specific provider recipe",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/target_provider_selection.loom",
          "--pass=select-templates,inline-callables",
          "--pass-report=json",
          "--output={tmp}/target_provider_selected.loom"
        ]
      },
      "stderr": {
        "contains": [
          "\"pass\":\"select-templates\"",
          "\"category\":\"template-selection\"",
          "\"outcome\":\"selected\"",
          "\"contract\":\"hip.recipe.scale_i32\"",
          "\"target\":\"gfx1100\"",
          "\"selected_provider\":\"scale_i32_gfx1100\"",
          "\"provider_count\":3",
          "\"target_applicable_count\":2",
          "\"best_exact_count\":1"
        ]
      },
      "files": [
        {
          "path": "{tmp}/target_provider_selected.loom",
          "contains": [
            "func.def public target(@gfx1100) @selects_gfx1100_provider",
            "scalar.muli"
          ],
          "not_contains": [
            "func.apply",
            "scale_i32_gfx1200",
            "scale_i32_fallback"
          ]
        }
      ]
    },
    {
      "name": "reports unresolved hip shaped dynamic lower bound unroll",
      "run": {
        "tool": "loom-opt",
        "args": [
          "{srcdir}/q8_hip_shaped_unroll_unresolved.loom",
          "--pass=unroll-scf-for",
          "--diagnostic-format=json",
          "--output={tmp}/unused.loom"
        ]
      },
      "exit": {
        "nonzero": true
      },
      "stderr": {
        "contains": [
          "\"error_id\":\"ERR_STRUCTURE_014\"",
          "\"domain\":\"STRUCTURE\"",
          "\"code\":14",
          "\"attr_name\":\"unroll\"",
          "\"expected_constraint\":\"exact static trip count\""
        ]
      }
    }
  ]
}
