// Low function exactness modes and imported-code contracts.
test.record @vm_target

low.func.def allocation(assigned) schedule(constrained) target(@vm_target) @vm_add(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>) {
  %sum = low.op<iree.vm.add.i32>(%lhs, %rhs) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %sum : reg<vm.i32>
}

low.func.def target(@vm_target) @vm_slot_roundtrip(%input: reg<vm.i32>) -> (reg<vm.i32>) {
  low.spill %input, @vm_slot_roundtrip_spill {offset = 0} : reg<vm.i32>
  %reload = low.reload @vm_slot_roundtrip_spill {offset = 0} : reg<vm.i32>
  %addr = low.frame_index @vm_slot_roundtrip_spill {offset = 0} : reg<vm.ptr>
  low.return %reload : reg<vm.i32>
}

low.slot @vm_slot_roundtrip_spill {align = 4, function = @vm_slot_roundtrip, size = 4, space = scratch}

target.profile @low_vm_resource_target preset("iree-vm") {contract_set_key = "test.low.core"}

low.func.def target(@low_vm_resource_target) abi(vm_module_function) export("low_vm_resource") @low_vm_resource() -> (reg<vm.i32>) {
  %state = low.resource<vm_state> {index = 0, semantic_type = vm.state} : reg<vm.i32>
  low.return %state : reg<vm.i32>
}

target.profile @low_native_resource_target preset("test-low") {contract_set_key = "test.low.core", target_triple = "x86_64-unknown-linux-gnu"}

low.func.def target(@low_native_resource_target) abi(object_function) export("low_native_resource", {linkage = "dso_local"}) @low_native_resource() -> (reg<native.ptr>) {
  %ptr = low.resource<native_pointer> {index = 0, semantic_type = buffer} : reg<native.ptr>
  low.return %ptr : reg<native.ptr>
}

target.profile @low_hal_resource_target preset("amdgpu-gfx11") {contract_set_key = "test.low.core"}

low.kernel.def target(@low_hal_resource_target) export("low_hal_resource") workgroup_size(1, 1, 1) @low_hal_resource() {
  %binding = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer} : reg<amdgpu.sgpr x4>
  low.return
}

func.decl @extern_add(%lhs: i32, %rhs: i32) -> (i32)

func.def @caller(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = low.invoke @vm_add_i32(%lhs, %rhs) : (i32, i32) -> (i32)
  func.return %sum : i32
}

low.func.decl allocation(fixed) schedule(locked) import(vm, "iree.vm.core.add_i32") target(@vm_target) @vm_add_i32(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>)
