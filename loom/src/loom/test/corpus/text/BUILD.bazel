load("//build_tools/embed_data:build_defs.bzl", "iree_c_embed_data")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

iree_c_embed_data(
    name = "golden_text_corpus",
    testonly = True,
    srcs = glob(["*.loom"]),
    c_file_output = "golden_text_corpus.c",
    flatten = True,
    h_file_output = "golden_text_corpus.h",
    identifier = "loom_test_corpus_text",
)
