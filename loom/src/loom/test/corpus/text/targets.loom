target.profile @matmul_x86_target preset("test-object") {target_cpu = "x86-64-v3", target_features = "+avx2,+fma", target_triple = "x86_64-pc-linux-gnu"}

target.artifact @matmul_x86_object target(@matmul_x86_target) {abi = object_file, artifact_format = elf}

func.def target(@matmul_x86_target) abi(object_function) export("matmul", {artifact = @matmul_x86_object, linkage = "dso_local"}) @matmul_x86() {
  func.return
}

target.profile @matmul_gfx1100_target preset("amdgpu-gfx11") {contract_feature_bits = 1, contract_set_key = "amdgpu.gfx11", target_features = "+wavefrontsize32"}

target.artifact @matmul_gfx1100_hsaco target(@matmul_gfx1100_target) {abi = hal_executable, artifact_format = elf}

func.def target(@matmul_gfx1100_target) abi(hal_kernel, {hal_binding_alignment = 16, hal_flat_workgroup_size_max = 64, hal_flat_workgroup_size_min = 64, hal_workgroup_size_x = 16, hal_workgroup_size_y = 4, hal_workgroup_size_z = 1}) export("matmul", {artifact = @matmul_gfx1100_hsaco}) @matmul_gfx1100() {
  func.return
}
