test.target<low_core> @matmul_native_target

func.def target(@matmul_native_target) abi(object_function) export("matmul", {linkage = "dso_local"}) @matmul_native() {
  func.return
}

test.target<low_core> @matmul_hal_target {abi = hal_kernel}

kernel.def target(@matmul_hal_target) export("matmul") @matmul_hal() {
  %c1 = index.constant 1 : index
  %c16 = index.constant 16 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c16, %c4, %c1) : index
} launch() {
  kernel.return
}
