load("//build_tools/bazel:executable.bzl", "iree_executable_test")
load("//loom/build_tools/bazel:build_defs.bzl", "loom_config_compatible_with")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_CHECKED_BENCHMARK_CASES = [
    {
        "name": "packed_s8_fields_f16scale_f32dot",
        "rows": [
            {
                "benchmark": "@packed_s8_fields_f16scale_f32dot_smoke",
                "target_name": "packed_s8_fields_f16scale_f32dot",
            },
        ],
        "source": "packed_s8_fields_f16scale_f32dot.loom",
        "targets": [
            "amdgpu",
        ],
    },
]

exports_files([_case["source"] for _case in _CHECKED_BENCHMARK_CASES])

_AMDGPU_ARTIFACTS_COMPATIBLE_WITH = loom_config_compatible_with([
    "//loom/config/target:amdgpu_artifacts",
])

_AMDGPU_HAL_COMPATIBLE_WITH = loom_config_compatible_with([
    "//loom/config/execute:amdgpu_hal",
])

[
    iree_executable_test(
        name = _row["target_name"] + "_plan_test",
        src = "//loom/src/loom/tools/iree-benchmark-loom",
        args = [
            "$(location %s)" % _case["source"],
            "--benchmark=%s" % _row["benchmark"],
            "--dry-run",
            "--output-format=jsonl",
        ],
        data = [
            _case["source"],
        ],
        tags = ["hostonly"],
        target_compatible_with = _AMDGPU_ARTIFACTS_COMPATIBLE_WITH,
    )
    for _case in _CHECKED_BENCHMARK_CASES
    for _row in _case["rows"]
]

[
    iree_executable_test(
        name = _row["target_name"] + "_amdgpu_test",
        src = "//loom/src/loom/tools/iree-benchmark-loom",
        args = [
            "$(location %s)" % _case["source"],
            "--benchmark=%s" % _row["benchmark"],
            "--device=amdgpu",
            "--measure=dispatch_complete",
            "--iterations=1",
            "--warmup-iterations=0",
            "--batch-size=1",
            "--min-time-ms=0",
            "--max-batches=1",
            "--input-ring-count=1",
            "--output-format=jsonl",
        ],
        data = [
            _case["source"],
        ],
        tags = [
            "iree-run-requirement=runtime.resource.amd_gpu",
            "manual",
            "requires-gpu-amd",
            "runtime-resource=amd-gpu",
        ],
        target_compatible_with = _AMDGPU_HAL_COMPATIBLE_WITH,
    )
    for _case in _CHECKED_BENCHMARK_CASES
    if "amdgpu" in _case["targets"]
    for _row in _case["rows"]
]
