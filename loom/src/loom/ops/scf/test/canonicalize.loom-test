// RUN: pass canonicalize

// Constant-condition scf.if inlines the selected branch and erases the
// unselected branch. Selected body ops keep their order and become ordinary
// enclosing-block ops.
func.def @if_true_inlines_selected_branch(%value: f32) -> (f32) {
  %cond = scalar.constant true : i1
  %result = scf.if %cond -> (f32) {
    %doubled = scalar.addf %value, %value : f32
    scf.yield %doubled : f32
  } else {
    %negated = scalar.negf %value : f32
    scf.yield %negated : f32
  }
  func.return %result : f32
}

// ----
func.def @if_true_inlines_selected_branch(%value: f32) -> (f32) {
  %doubled = scalar.addf %value, %value : f32
  func.return %doubled : f32
}

// ====

// Side effects in the selected branch stay live; side effects in the
// unselected branch disappear because the branch is unreachable.
func.def @if_false_keeps_selected_store(%buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %cond = scalar.constant false : i1
  %zero = scalar.constant 0.0 : f32
  scf.if %cond {
    view.store %zero, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  } else {
    view.store %value, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  }
  func.return
}

// ----
func.def @if_false_keeps_selected_store(%buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  view.store %value, %view[0] : f32, view<1xf32, %layout>
  func.return
}

// ====

// A dynamic signed index comparison can still prune scf.if once range facts
// prove the condition exact.
func.def @if_prunes_from_signed_index_range(%x: index, %y: index) -> (index) {
  %lo = index.assume %x [range(%x, 0, 4)] : index
  %hi = index.assume %y [range(%y, 8, 16)] : index
  %cond = index.cmp slt, %lo, %hi : index
  %result = scf.if %cond -> (index) {
    %one = index.constant 1 : index
    scf.yield %one : index
  } else {
    %two = index.constant 2 : index
    scf.yield %two : index
  }
  func.return %result : index
}

// ----
func.def @if_prunes_from_signed_index_range(%x: index, %y: index) -> (index) {
  %one = index.constant 1 : index
  func.return %one : index
}

// ====

// Unsigned comparisons prune through scf.if when the address facts prove both
// operands are non-negative.
func.def @if_prunes_from_unsigned_index_range(%x: index, %y: index) -> (index) {
  %lo = index.assume %x [range(%x, 0, 4)] : index
  %hi = index.assume %y [range(%y, 8, 16)] : index
  %cond = index.cmp ugt, %lo, %hi : index
  %result = scf.if %cond -> (index) {
    %one = index.constant 1 : index
    scf.yield %one : index
  } else {
    %two = index.constant 2 : index
    scf.yield %two : index
  }
  func.return %result : index
}

// ----
func.def @if_prunes_from_unsigned_index_range(%x: index, %y: index) -> (index) {
  %two = index.constant 2 : index
  func.return %two : index
}

// ====

// A maybe-negative operand keeps unsigned comparison branches alive because
// signed interval separation does not imply unsigned order.
func.def @if_preserves_inconclusive_unsigned_cmp(%x: index, %y: index) -> (index) {
  %maybe_negative = index.assume %x [range(%x, -4, 4)] : index
  %positive = index.assume %y [range(%y, 8, 16)] : index
  %cond = index.cmp ult, %maybe_negative, %positive : index
  %result = scf.if %cond -> (index) {
    %one = index.constant 1 : index
    scf.yield %one : index
  } else {
    %two = index.constant 2 : index
    scf.yield %two : index
  }
  func.return %result : index
}

// ====

// A resultless dynamic conditional with no branch effects is dead.
func.def @if_resultless_empty_erases(%cond: i1) {
  scf.if %cond {
    scf.yield
  } else {
    scf.yield
  }
  func.return
}

// ----
func.def @if_resultless_empty_erases(%cond: i1) {
  func.return
}

// ====

// When both dynamic branches yield the same value, the scf.if result forwards to
// that value and the effect-free conditional disappears.
func.def @if_forwards_equal_result_and_erases(%cond: i1, %value: f32) -> (f32) {
  %result = scf.if %cond -> (f32) {
    scf.yield %value : f32
  } else {
    scf.yield %value : f32
  }
  func.return %result : f32
}

// ----
func.def @if_forwards_equal_result_and_erases(%cond: i1, %value: f32) -> (f32) {
  func.return %value : f32
}

// ====

// A dynamic yield-only conditional over scalar values canonicalizes to a generic
// whole-value select. No region body work remains, so control flow is
// unnecessary.
func.def @if_yield_only_f32_value(%cond: i1, %a: f32, %b: f32) -> (f32) {
  %result = scf.if %cond -> (f32) {
    scf.yield %a : f32
  } else {
    scf.yield %b : f32
  }
  func.return %result : f32
}

// ----
func.def @if_yield_only_f32_value(%cond: i1, %a: f32, %b: f32) -> (f32) {
  %result = scf.select %cond, %a, %b : f32
  func.return %result : f32
}

// ====

// The same generic select handles address-domain values without making scf
// canonicalization depend on the index dialect.
func.def @if_yield_only_index_value(%cond: i1, %a: index, %b: index) -> (index) {
  %result = scf.if %cond -> (index) {
    scf.yield %a : index
  } else {
    scf.yield %b : index
  }
  func.return %result : index
}

// ----
func.def @if_yield_only_index_value(%cond: i1, %a: index, %b: index) -> (index) {
  %result = scf.select %cond, %a, %b : index
  func.return %result : index
}

// ====

// Matching pure tail ops factor out of both branches. The conditional first
// chooses the operands, then the common op is rebuilt once after it.
func.def @if_factors_common_pure_tail(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %result = scf.if %cond -> (i32) {
    %then = test.addi %a, %b : i32
    scf.yield %then : i32
  } else {
    %else = test.addi %b, %a : i32
    scf.yield %else : i32
  }
  func.return %result : i32
}

// ----
func.def @if_factors_common_pure_tail(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %10 = scf.select %cond, %a, %b : i32
  %11 = scf.select %cond, %b, %a : i32
  %result = test.addi %10, %11 : i32
  func.return %result : i32
}

// ====

// Branch effects remain branch-local. Only the shared pure tail is factored.
func.def @if_factors_tail_and_preserves_branch_effects(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %result = scf.if %cond -> (i32) {
    test.use %a : i32
    %then = test.addi %a, %b : i32
    scf.yield %then : i32
  } else {
    test.use %b : i32
    %else = test.addi %b, %a : i32
    scf.yield %else : i32
  }
  func.return %result : i32
}

// ----
func.def @if_factors_tail_and_preserves_branch_effects(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %7, %8 = scf.if %cond -> (i32, i32) {
    test.use %a : i32
    scf.yield %a, %b : i32, i32
  } else {
    test.use %b : i32
    scf.yield %b, %a : i32, i32
  }
  %result = test.addi %7, %8 : i32
  func.return %result : i32
}

// ====

// Different tail op kinds do not factor: the conditional still chooses between
// two distinct computations.
func.def @if_preserves_different_tail_kinds(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %result = scf.if %cond -> (i32) {
    %then = test.addi %a, %b : i32
    scf.yield %then : i32
  } else {
    %else = test.constant 4 : i32
    scf.yield %else : i32
  }
  func.return %result : i32
}

// ====

// scf.select is a plain value op, so identical arms fold without needing
// control-flow reasoning.
func.def @select_identical_arms(%cond: i1, %value: vector<4xf32>) -> (vector<4xf32>) {
  %result = scf.select %cond, %value, %value : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
func.def @select_identical_arms(%cond: i1, %value: vector<4xf32>) -> (vector<4xf32>) {
  func.return %value : vector<4xf32>
}

// ====

// Exact condition facts fold scf.select to the chosen arm even for non-scalar
// aggregate values.
func.def @select_constant_condition(%value: tile<4xf32>, %other: tile<4xf32>) -> (tile<4xf32>) {
  %cond = scalar.constant false : i1
  %result = scf.select %cond, %value, %other : tile<4xf32>
  func.return %result : tile<4xf32>
}

// ----
func.def @select_constant_condition(%value: tile<4xf32>, %other: tile<4xf32>) -> (tile<4xf32>) {
  func.return %other : tile<4xf32>
}

// ====

// Exact condition facts fold scalar scf.select values to the selected arm.
func.def @select_true_scalar() -> (i32) {
  %cond = scalar.constant true : i1
  %a = scalar.constant 42 : i32
  %b = scalar.constant 99 : i32
  %result = scf.select %cond, %a, %b : i32
  func.return %result : i32
}

// ----
func.def @select_true_scalar() -> (i32) {
  %result = scalar.constant 42 : i32
  func.return %result : i32
}

// ====

func.def @select_false_scalar() -> (i32) {
  %cond = scalar.constant false : i1
  %a = scalar.constant 42 : i32
  %b = scalar.constant 99 : i32
  %result = scf.select %cond, %a, %b : i32
  func.return %result : i32
}

// ----
func.def @select_false_scalar() -> (i32) {
  %result = scalar.constant 99 : i32
  func.return %result : i32
}

// ====

// Boolean identity select folds without making scf depend on scalar xori for
// the complement form.
func.def @select_boolean_identity(%condition: i1) -> (i1) {
  %true = scalar.constant true : i1
  %false = scalar.constant false : i1
  %result = scf.select %condition, %true, %false : i1
  func.return %result : i1
}

// ----
func.def @select_boolean_identity(%condition: i1) -> (i1) {
  func.return %condition : i1
}

// ====

// Equal yielded results forward even when branch side effects keep the dynamic
// conditional itself live.
func.def @if_forwards_equal_result_keeps_effects(%buffer: buffer, %offset: offset, %cond: i1, %value: f32, %other: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %result = scf.if %cond -> (f32) {
    view.store %value, %view[0] : f32, view<1xf32, %layout>
    scf.yield %value : f32
  } else {
    view.store %other, %view[0] : f32, view<1xf32, %layout>
    scf.yield %value : f32
  }
  func.return %result : f32
}

// ----
func.def @if_forwards_equal_result_keeps_effects(%buffer: buffer, %offset: offset, %cond: i1, %value: f32, %other: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  scf.if %cond {
    view.store %value, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  } else {
    view.store %other, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  }
  func.return %value : f32
}

// ====

// Hints are not semantic effects, but forwarding must still preserve them until
// an explicit hint-stripping pass removes them.
func.def @if_forwards_equal_result_keeps_hint(%buffer: buffer, %offset: offset, %cond: i1, %row: index, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  %result = scf.if %cond -> (f32) {
    view.prefetch %view[%row] {intent = read, locality = l1} : view<4xf32, %layout>
    scf.yield %value : f32
  } else {
    scf.yield %value : f32
  }
  func.return %result : f32
}

// ----
func.def @if_forwards_equal_result_keeps_hint(%buffer: buffer, %offset: offset, %cond: i1, %row: index, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  scf.if %cond {
    view.prefetch %view[%row] {intent = read, locality = l1} : view<4xf32, %layout>
    scf.yield
  } else {
    scf.yield
  }
  func.return %value : f32
}

// ====

// Partially equal branch results compact the scf.if result list and keep only
// the value that really depends on the selected branch.
func.def @if_forwards_one_of_two_results(%cond: i1, %a: f32, %b: f32) -> (f32, f32) {
  %same, %selected = scf.if %cond -> (f32, f32) {
    %then = scalar.addf %a, %b : f32
    scf.yield %a, %then : f32, f32
  } else {
    %else = scalar.addf %b, %b : f32
    scf.yield %a, %else : f32, f32
  }
  func.return %same, %selected : f32, f32
}

// ----
func.def @if_forwards_one_of_two_results(%cond: i1, %a: f32, %b: f32) -> (f32, f32) {
  %14 = scf.select %cond, %a, %b : f32
  %selected = scalar.addf %14, %b : f32
  func.return %a, %selected : f32, f32
}

// ====

// Unused conditional results are dropped independently of forwarding. Effects
// remain in their original branches, and later DCE can clean now-dead pure
// producers inside the kept conditional.
func.def @if_drops_unused_result_keeps_effects(%buffer: buffer, %offset: offset, %cond: i1, %a: f32, %b: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %dead, %live = scf.if %cond -> (f32, f32) {
    %then_dead = scalar.addf %a, %a : f32
    %then_live = scalar.addf %a, %b : f32
    view.store %then_live, %view[0] : f32, view<1xf32, %layout>
    scf.yield %then_dead, %then_live : f32, f32
  } else {
    %else_dead = scalar.addf %b, %b : f32
    %else_live = scalar.addf %b, %a : f32
    view.store %else_live, %view[0] : f32, view<1xf32, %layout>
    scf.yield %else_dead, %else_live : f32, f32
  }
  func.return %live : f32
}

// ----
func.def @if_drops_unused_result_keeps_effects(%buffer: buffer, %offset: offset, %cond: i1, %a: f32, %b: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %live = scf.if %cond -> (f32) {
    %then_live = scalar.addf %a, %b : f32
    view.store %then_live, %view[0] : f32, view<1xf32, %layout>
    scf.yield %then_live : f32
  } else {
    %else_live = scalar.addf %b, %a : f32
    view.store %else_live, %view[0] : f32, view<1xf32, %layout>
    scf.yield %else_live : f32
  }
  func.return %live : f32
}

// ====

// Result compaction must respect type-use references. %layout has no ordinary
// operand uses, but the view type references it and must keep the conditional
// result alive.
func.def @if_keeps_result_used_by_type(%buffer: buffer, %offset: offset, %cond: i1) -> (f32) {
  %layout = scf.if %cond -> (encoding<layout>) {
    %dense = encoding.layout.dense : encoding<layout>
    scf.yield %dense : encoding<layout>
  } else {
    %strided = encoding.layout.strided [1] : encoding<layout>
    scf.yield %strided : encoding<layout>
  }
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %loaded = view.load %view[0] : view<1xf32, %layout> -> f32
  func.return %loaded : f32
}

// ====

// A zero-trip loop returns its iter_args and drops the body, even when the body
// would have written memory if it executed.
func.def @for_zero_trip_returns_initial_value(%buffer: buffer, %offset: offset, %init: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %bound = index.constant 4 : index
  %step = index.constant 1 : index
  %result = scf.for %iv = [%bound to %bound step %step](%acc = %init : f32) -> (f32) {
    view.store %acc, %view[0] : f32, view<1xf32, %layout>
    scf.yield %acc : f32
  }
  func.return %result : f32
}

// ----
func.def @for_zero_trip_returns_initial_value(%buffer: buffer, %offset: offset, %init: f32) -> (f32) {
  func.return %init : f32
}

// ====

// A fact-proven single-trip resultless loop inlines its body once. The IV
// substitution feeds ordinary index cleanup, so the add-by-zero address math
// disappears after promotion.
func.def @for_single_trip_resultless_inlines_effect(%buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, %layout>
  %lo = index.constant 3 : index
  %hi = index.constant 4 : index
  %step = index.constant 1 : index
  %zero = index.constant 0 : index
  scf.for %iv = [%lo to %hi step %step] {
    %addr = index.add %iv, %zero : index
    view.store %value, %view[%addr] : f32, view<16xf32, %layout>
    scf.yield
  }
  func.return
}

// ----
func.def @for_single_trip_resultless_inlines_effect(%buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, %layout>
  %addr = index.constant 3 : index
  view.store %value, %view[%addr] : f32, view<16xf32, %layout>
  func.return
}

// ====

// A single-trip loop with carried state turns into straight-line scalar work.
func.def @for_single_trip_carried_result(%init: f32) -> (f32) {
  %lo = index.constant 0 : index
  %hi = index.constant 1 : index
  %step = index.constant 1 : index
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    %next = scalar.addf %acc, %acc : f32
    scf.yield %next : f32
  }
  func.return %result : f32
}

// ----
func.def @for_single_trip_carried_result(%init: f32) -> (f32) {
  %next = scalar.addf %init, %init : f32
  func.return %next : f32
}

// ====

// Dynamic values can still prove a single trip when their fact ranges guarantee
// lower < upper and lower + step >= upper.
func.def @for_single_trip_dynamic_range_inlines(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<32xf32, %layout>
  %lo1 = index.assume %lo [range(%lo, 8, 15)] : index
  %hi1 = index.assume %hi [range(%hi, 16, 23)] : index
  %step = index.constant 16 : index
  scf.for %iv = [%lo1 to %hi1 step %step] {
    view.store %value, %view[%iv] : f32, view<32xf32, %layout>
    scf.yield
  }
  func.return
}

// ----
func.def @for_single_trip_dynamic_range_inlines(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<32xf32, %layout>
  %lo1 = index.assume %lo [range(%lo, 8, 15)] : index
  view.store %value, %view[%lo1] : f32, view<32xf32, %layout>
  func.return
}

// ====

// Without a positive-step fact, even an apparently empty identity loop stays in
// place: erasing it would also erase malformed or nonterminating control flow.
func.def @for_identity_unknown_step_is_preserved(%lo: index, %hi: index, %step: index, %init: f32) -> (f32) {
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    scf.yield %acc : f32
  }
  func.return %result : f32
}

// ----
func.def @for_identity_unknown_step_is_preserved(%lo: index, %hi: index, %step: index, %init: f32) -> (f32) {
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    scf.yield %acc : f32
  }
  func.return %result : f32
}

// ====

// Static bounds that prove multiple trips must not promote the loop.
func.def @for_single_trip_multi_trip_is_preserved(%init: f32) -> (f32) {
  %lo = index.constant 0 : index
  %hi = index.constant 4 : index
  %step = index.constant 2 : index
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    %next = scalar.addf %acc, %acc : f32
    scf.yield %next : f32
  }
  func.return %result : f32
}

// ====

// Non-positive steps are preserved even when the numeric bounds look like they
// might otherwise execute once.
func.def @for_single_trip_non_positive_step_is_preserved(%init: f32) -> (f32) {
  %lo = index.constant 0 : index
  %hi = index.constant 1 : index
  %step = index.constant 0 : index
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    %next = scalar.addf %acc, %acc : f32
    scf.yield %next : f32
  }
  func.return %result : f32
}

// ====

// A loop that only yields its carried values is the identity when the step is
// known positive.
func.def @for_identity_body_returns_iter_arg(%lo: index, %hi: index, %init: f32) -> (f32) {
  %step = index.constant 1 : index
  %result = scf.for %iv = [%lo to %hi step %step](%acc = %init : f32) -> (f32) {
    scf.yield %acc : f32
  }
  func.return %result : f32
}

// ----
func.def @for_identity_body_returns_iter_arg(%lo: index, %hi: index, %init: f32) -> (f32) {
  func.return %init : f32
}

// ====

// A resultless loop with an empty body has no observable behavior once the step
// is known positive.
func.def @for_void_empty_body(%lo: index, %hi: index) {
  %step = index.constant 1 : index
  scf.for %iv = [%lo to %hi step %step] {
    scf.yield
  }
  func.return
}

// ----
func.def @for_void_empty_body(%lo: index, %hi: index) {
  func.return
}

// ====

// A mixed loop forwards unchanged carried results independently and keeps only
// the state that is actually updated by the loop.
func.def @for_forwards_one_of_two_results(%lo: index, %hi: index, %init: f32, %acc: f32) -> (f32, f32) {
  %step = index.constant 1 : index
  %same, %sum = scf.for %iv = [%lo to %hi step %step](%same_arg = %init : f32, %acc_arg = %acc : f32) -> (f32, f32) {
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %same_arg, %next : f32, f32
  }
  func.return %same, %sum : f32, f32
}

// ----
func.def @for_forwards_one_of_two_results(%lo: index, %hi: index, %init: f32, %acc: f32) -> (f32, f32) {
  %step = index.constant 1 : index
  %sum = scf.for %iv = [%lo to %hi step %step](%acc_arg = %acc : f32) -> (f32) {
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %next : f32
  }
  func.return %init, %sum : f32, f32
}

// ====

// Forwarding does not discard side effects. The forwarded carried value becomes
// a direct capture of the original iter_arg inside the compacted loop body.
func.def @for_forwards_mixed_effectful_result(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %init: f32, %acc: f32) -> (f32, f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %step = index.constant 1 : index
  %same, %sum = scf.for %iv = [%lo to %hi step %step](%same_arg = %init : f32, %acc_arg = %acc : f32) -> (f32, f32) {
    view.store %same_arg, %view[0] : f32, view<1xf32, %layout>
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %same_arg, %next : f32, f32
  }
  func.return %same, %sum : f32, f32
}

// ----
func.def @for_forwards_mixed_effectful_result(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %init: f32, %acc: f32) -> (f32, f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %step = index.constant 1 : index
  %sum = scf.for %iv = [%lo to %hi step %step](%acc_arg = %acc : f32) -> (f32) {
    view.store %init, %view[0] : f32, view<1xf32, %layout>
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %next : f32
  }
  func.return %init, %sum : f32, f32
}

// ====

// A single forwarded result with side effects becomes a resultless loop, so the
// effect remains ordered but the function result reads directly from the input.
func.def @for_single_forwarded_result_keeps_effect(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %init: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %step = index.constant 1 : index
  %same = scf.for %iv = [%lo to %hi step %step](%same_arg = %init : f32) -> (f32) {
    view.store %same_arg, %view[0] : f32, view<1xf32, %layout>
    scf.yield %same_arg : f32
  }
  func.return %same : f32
}

// ----
func.def @for_single_forwarded_result_keeps_effect(%buffer: buffer, %offset: offset, %lo: index, %hi: index, %init: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %step = index.constant 1 : index
  scf.for %iv = [%lo to %hi step %step] {
    view.store %init, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  }
  func.return %init : f32
}

// ====

// All-result identity still erases the whole loop when the body is otherwise
// empty.
func.def @for_identity_multiple_results(%lo: index, %hi: index, %a: f32, %b: i32) -> (f32, i32) {
  %step = index.constant 1 : index
  %ra, %rb = scf.for %iv = [%lo to %hi step %step](%aa = %a : f32, %bb = %b : i32) -> (f32, i32) {
    scf.yield %aa, %bb : f32, i32
  }
  func.return %ra, %rb : f32, i32
}

// ----
func.def @for_identity_multiple_results(%lo: index, %hi: index, %a: f32, %b: i32) -> (f32, i32) {
  func.return %a, %b : f32, i32
}

// ====

// Unknown steps are not rewritten: if a loop may be malformed or nonterminating,
// forwarding an externally visible result would be a semantic change.
func.def @for_forward_unknown_step_is_preserved(%lo: index, %hi: index, %step: index, %init: f32, %acc: f32) -> (f32, f32) {
  %same, %sum = scf.for %iv = [%lo to %hi step %step](%same_arg = %init : f32, %acc_arg = %acc : f32) -> (f32, f32) {
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %same_arg, %next : f32, f32
  }
  func.return %same, %sum : f32, f32
}

// ----
func.def @for_forward_unknown_step_is_preserved(%lo: index, %hi: index, %step: index, %init: f32, %acc: f32) -> (f32, f32) {
  %same, %sum = scf.for %iv = [%lo to %hi step %step](%same_arg = %init : f32, %acc_arg = %acc : f32) -> (f32, f32) {
    %next = scalar.addf %acc_arg, %acc_arg : f32
    scf.yield %same_arg, %next : f32, f32
  }
  func.return %same, %sum : f32, f32
}

// ====

// Exact selector facts replace scf.lookup with the matching explicit case row.
func.def @lookup_exact_case(%a: index, %b: index, %fallback: index) -> (index) {
  %variant = index.constant 1 : index
  %result = scf.lookup %variant {0 = (%a), 1 = (%b)} default(%fallback) : index
  func.return %result : index
}

// ----
func.def @lookup_exact_case(%a: index, %b: index, %fallback: index) -> (index) {
  func.return %b : index
}

// ====

// Exact selector facts that miss every explicit key select the final default
// payload row.
func.def @lookup_exact_default(%a: index, %b: index, %fallback: index) -> (index) {
  %variant = index.constant 5 : index
  %result = scf.lookup %variant {0 = (%a), 1 = (%b)} default(%fallback) : index
  func.return %result : index
}

// ----
func.def @lookup_exact_default(%a: index, %b: index, %fallback: index) -> (index) {
  func.return %fallback : index
}

// ====

// A column whose payload value is identical for every explicit/default row does
// not need to stay in the lookup. The remaining columns keep table selection.
func.def @lookup_compacts_uniform_column(%variant: index, %common: index, %x0: index, %x1: index, %xf: index) -> (index, index) {
  %same, %selected = scf.lookup %variant {0 = (%common, %x0), 1 = (%common, %x1)} default(%common, %xf) : index, index
  func.return %same, %selected : index, index
}

// ----
func.def @lookup_compacts_uniform_column(%variant: index, %common: index, %x0: index, %x1: index, %xf: index) -> (index, index) {
  %selected = scf.lookup %variant {0 = (%x0), 1 = (%x1)} default(%xf) : index
  func.return %common, %selected : index, index
}

// ====

// Selector facts prune unreachable explicit rows. The lookup remains total by
// keeping a dead default row, but the dead row reuses a reachable payload so it
// does not keep otherwise-unneeded values live.
func.def @lookup_prunes_unreachable_cases(%variant: index, %a: index, %b: index, %dead: index, %fallback: index) -> (index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %result = scf.lookup %bounded {0 = (%a), 1 = (%b), 2 = (%dead)} default(%fallback) : index
  func.return %result : index
}

// ----
func.def @lookup_prunes_unreachable_cases(%variant: index, %a: index, %b: index, %dead: index, %fallback: index) -> (index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %result = scf.lookup %bounded {0 = (%a), 1 = (%b)} default(%a) : index
  func.return %result : index
}

// ====

// Even when every explicit key remains reachable, an exhaustive key set makes
// the default row dead. Replacing it with a reachable payload lets ordinary DCE
// remove fallback producers without needing lookup-specific liveness rules.
func.def @lookup_replaces_unreachable_default(%variant: index, %a: index, %b: index, %fallback: index) -> (index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %result = scf.lookup %bounded {0 = (%a), 1 = (%b)} default(%fallback) : index
  func.return %result : index
}

// ----
func.def @lookup_replaces_unreachable_default(%variant: index, %a: index, %b: index, %fallback: index) -> (index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %result = scf.lookup %bounded {0 = (%a), 1 = (%b)} default(%a) : index
  func.return %result : index
}

// ====

// Reachability drives column forwarding. Values that are uniform across the
// possible rows can be forwarded even if unreachable rows disagree.
func.def @lookup_compacts_reachable_uniform_column(%variant: index, %common: index, %x0: index, %x1: index, %dead_common: index, %dead_x: index, %fallback_common: index, %fallback_x: index) -> (index, index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %same, %selected = scf.lookup %bounded {0 = (%common, %x0), 1 = (%common, %x1), 2 = (%dead_common, %dead_x)} default(%fallback_common, %fallback_x) : index, index
  func.return %same, %selected : index, index
}

// ----
func.def @lookup_compacts_reachable_uniform_column(%variant: index, %common: index, %x0: index, %x1: index, %dead_common: index, %dead_x: index, %fallback_common: index, %fallback_x: index) -> (index, index) {
  %bounded = index.assume %variant [range(%variant, 0, 1)] : index
  %selected = scf.lookup %bounded {0 = (%x0), 1 = (%x1)} default(%x0) : index
  func.return %common, %selected : index, index
}
