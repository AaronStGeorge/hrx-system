load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "scf",
    srcs = [
        "builders.c",
        "canonicalize.c",
        "facts.c",
        "tables.c",
        "type_transfer.c",
        "verify.c",
    ],
    hdrs = ["ops.h"],
    deps = [
        "//loom/src/loom/analysis:availability",
        "//loom/src/loom/analysis:motion",
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/rewrite:rewriter",
        "//loom/src/loom/rewrite:type_propagation",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:math",
    ],
)
