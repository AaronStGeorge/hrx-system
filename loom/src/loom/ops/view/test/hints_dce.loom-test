// RUN: pass dce

func.def @prefetch_survives_dce(%buffer: buffer, %offset: offset, %row: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  view.prefetch %view[%row] {intent = read, locality = l1} : view<4xf32, %layout>
  func.return
}

// ====

func.def @prefetch_in_if_survives_dce(%buffer: buffer, %offset: offset, %cond: i1, %row: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  scf.if %cond {
    view.prefetch %view[%row] {intent = read, locality = l1} : view<4xf32, %layout>
    scf.yield
  } else {
    scf.yield
  }
  func.return
}
