// RUN: roundtrip

// ====

// Dense view over an opaque buffer root with a dynamic logical extent.
func.def @dense_view(%buffer: buffer, %offset: index, %m: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]xf32, %layout>
  test.use %view : view<[%m]xf32, %layout>
  func.return
}

// ====

// Strided view and logical subview share the same explicit layout value.
func.def @strided_subview(%buffer: buffer, %offset: index, %row_stride: index, %row: index, %m: index, %n: index) {
  %layout = view.layout.strided [%row_stride, 1] : encoding
  %source = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %sub = view.subview %source[%row, 0] : view<[%m]x[%n]xf32, %layout> -> view<16x[%n]xf32, %layout>
  test.use %sub : view<16x[%n]xf32, %layout>
  func.return
}

// ====

// Static strides are carried in the same index-list shape as dynamic strides.
func.def @static_strided_view(%buffer: buffer, %offset: index) {
  %layout = view.layout.strided [4096, 1] : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<8x16xi8, %layout>
  test.use %view : view<8x16xi8, %layout>
  func.return
}
