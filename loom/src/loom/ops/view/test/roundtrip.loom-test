// RUN: roundtrip

// ====

// Dense view over an opaque buffer root with a dynamic logical extent.
func.def @dense_view(%buffer: buffer, %offset: offset, %m: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]xf32, %layout>
  test.use %view : view<[%m]xf32, %layout>
  func.return
}

// ====

// Scratch roots carry explicit memory-space and root-alignment facts.
func.def @workgroup_scratch_view(%bytes: offset) {
  %zero = index.constant 0 : offset
  %layout = encoding.layout.dense : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 64, memory_space = workgroup} : buffer
  %view = buffer.view %scratch[%zero] : buffer -> view<16xf32, %layout>
  test.use %view : view<16xf32, %layout>
  func.return
}

// ====

// Buffer arguments can be explicitly refined when ABI or kernel-boundary facts
// establish a concrete memory space.
func.def @global_arg_view(%buffer: buffer, %offset: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %global = buffer.assume.memory_space %buffer {memory_space = global} : buffer
  %view = buffer.view %global[%offset] : buffer -> view<16xf32, %layout>
  test.use %view : view<16xf32, %layout>
  func.return
}

// ====

// Strided view and logical subview share the same explicit layout value.
func.def @strided_subview(%buffer: buffer, %offset: offset, %row_stride: index, %row: index, %m: index, %n: index) {
  %layout = encoding.layout.strided [%row_stride, 1] : encoding<layout>
  %source = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %sub = view.subview %source[%row, 0] : view<[%m]x[%n]xf32, %layout> -> view<16x[%n]xf32, %layout>
  test.use %sub : view<16x[%n]xf32, %layout>
  func.return
}

// ====

// Static strides are carried in the same index-list shape as dynamic strides.
func.def @static_strided_view(%buffer: buffer, %offset: offset) {
  %layout = encoding.layout.strided [4096, 1] : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<8x16xi8, %layout>
  test.use %view : view<8x16xi8, %layout>
  func.return
}

// ====

// Refinement is an explicit SSA edge from a wider symbolic view type to a
// narrower type that later memory ops can consume directly.
func.def @refine_view(%buffer: buffer, %offset: offset, %m: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]xf32, %layout>
  %refined = view.refine %view : view<[%m]xf32, %layout> -> view<16xf32, %layout>
  test.use %refined : view<16xf32, %layout>
  func.return
}

// ====

// Encoded physical storage composes an address layout with a storage schema.
// Loads from this view still produce physical i8 records; decode is explicit.
func.def @encoded_physical_storage_view(%buffer: buffer, %offset: offset, %m: index, %kb: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %schema = encoding.define #ggml_q4_0<block_elems=32, storage_bytes=18> : encoding<schema>
  %storage = encoding.define #physical_storage {layout = %layout : encoding<layout>, schema = %schema : encoding<schema>} : encoding<storage>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%kb]x18xi8, %storage>
  test.use %view : view<[%m]x[%kb]x18xi8, %storage>
  func.return
}

// ====

// Prefetch is a compiler hint over a logical view origin, not a semantic load.
func.def @prefetch_hint(%buffer: buffer, %offset: offset, %row: index, %col: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<8x16xf32, %layout>
  view.prefetch %view[%row, %col] {intent = read, locality = l2} : view<8x16xf32, %layout>
  func.return
}
