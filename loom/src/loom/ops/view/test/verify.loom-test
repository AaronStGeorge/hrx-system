// RUN: verify

// ====

// buffer.view result types must carry the address layout in their encoding slot
// so the root-to-view relationship remains explicit in the IR.
func.def @buffer_view_missing_layout(%buffer: buffer, %offset: index) {
  // ERROR@+1: ENCODING/001 "result type layout" "view result type"
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32>
  func.return
}

// ====

// view.subview requires one logical offset position per source rank.
func.def @subview_offset_count(%buffer: buffer, %offset: index) {
  %layout = encoding.layout.strided [4, 1] : encoding<layout>
  %source = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: SUBRANGE/001 "source" "1" "2"
  %sub = view.subview %source[0] : view<4x4xf32, %layout> -> view<4x4xf32, %layout>
  func.return
}

// ====

// A concrete strided layout must provide one stride per result view rank.
func.def @buffer_view_stride_rank_mismatch(%buffer: buffer, %offset: index) {
  %layout = encoding.layout.strided [1] : encoding<layout>
  // ERROR@+1: SHAPE/001 "result type" "2" "layout stride list" "1"
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  func.return
}

// ====

// Encoded physical storage views still expose their address layout explicitly.
// buffer.view must recover it through #physical_storage instead of treating the
// storage schema as part of address arithmetic.
func.def @buffer_view_physical_storage_stride_rank_mismatch(%buffer: buffer, %offset: index) {
  %layout = encoding.layout.strided [1] : encoding<layout>
  %schema = encoding.define #ggml_q4_0<block_elems=32, storage_bytes=18> : encoding<schema>
  %storage = encoding.define #physical_storage {layout = %layout : encoding<layout>, schema = %schema : encoding<schema>} : encoding<storage>
  // ERROR@+1: SHAPE/001 "result type" "2" "layout stride list" "1"
  %view = buffer.view %buffer[%offset] : buffer -> view<4x18xi8, %storage>
  func.return
}

// ====

// view.prefetch names one logical index position per view rank.
func.def @prefetch_index_count_mismatch(%buffer: buffer, %offset: index, %row: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: SUBRANGE/001 "view" "1" "2"
  view.prefetch %view[%row] {intent = read, locality = l1} : view<4x4xf32, %layout>
  func.return
}
