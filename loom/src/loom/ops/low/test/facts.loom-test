// RUN: pass canonicalize

test.target<low_core> @target

func.def @low_const_concat_uniform_zero() -> (i64, i64) {
  %zero = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %quad = low.concat(%zero, %zero, %zero, %zero) : (reg<test.i32>, reg<test.i32>, reg<test.i32>, reg<test.i32>) -> reg<test.i32 x4>
  %copy = low.copy %quad : reg<test.i32 x4> -> reg<test.i32 x4>
  %slice = low.slice %copy[1] : reg<test.i32 x4> -> reg<test.i32 x2>
  %wide = low.concat(%slice, %slice) : (reg<test.i32 x2>, reg<test.i32 x2>) -> reg<test.i32 x4>
  %lo = test.fact_all_equal_range_lo %wide : reg<test.i32 x4> -> i64
  %hi = test.fact_all_equal_range_hi %wide : reg<test.i32 x4> -> i64
  func.return %lo, %hi : i64, i64
}

// ----
test.target<low_core> @target

func.def @low_const_concat_uniform_zero() -> (i64, i64) {
  %lo = scalar.constant 0 : i64
  %hi = scalar.constant 0 : i64
  func.return %lo, %hi : i64, i64
}

// ====

test.target<low_core> @target

func.def @low_concat_rejects_mixed_elements() -> (i64, i64) {
  %zero = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %one = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %pair = low.concat(%zero, %one) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32 x2>
  %lo = test.fact_all_equal_range_lo %pair : reg<test.i32 x2> -> i64
  %hi = test.fact_all_equal_range_hi %pair : reg<test.i32 x2> -> i64
  func.return %lo, %hi : i64, i64
}

// ----
test.target<low_core> @target

func.def @low_concat_rejects_mixed_elements() -> (i64, i64) {
  %lo = scalar.constant -9223372036854775808 : i64
  %hi = scalar.constant -9223372036854775808 : i64
  func.return %lo, %hi : i64, i64
}

// ====

test.target<low_core> @target

low.kernel.def target(@target) @low_storage_reserve_and_view_facts() {
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %view = low.storage.view %storage {offset = 16, byte_length = 64} : low.storage<workgroup> -> low.storage<workgroup>
  %is = test.fact_is_storage_reference %storage : low.storage<workgroup> -> i1
  %same = test.fact_storage_same_backing %storage, %view : low.storage<workgroup>, low.storage<workgroup> -> i1
  %offset_lo = test.fact_storage_byte_offset_lo %view : low.storage<workgroup> -> i64
  %offset_hi = test.fact_storage_byte_offset_hi %view : low.storage<workgroup> -> i64
  %offset_div = test.fact_storage_byte_offset_divisor %view : low.storage<workgroup> -> i64
  %length_lo = test.fact_storage_byte_length_lo %view : low.storage<workgroup> -> i64
  %length_hi = test.fact_storage_byte_length_hi %view : low.storage<workgroup> -> i64
  %alignment = test.fact_storage_min_alignment %view : low.storage<workgroup> -> i64
  %space = test.fact_storage_space %storage : low.storage<workgroup> -> i64
  test.use %is, %same, %offset_lo, %offset_hi, %offset_div, %length_lo, %length_hi, %alignment, %space : i1, i1, i64, i64, i64, i64, i64, i64, i64
  low.return
}

// ----
test.target<low_core> @target

low.kernel.def target(@target) @low_storage_reserve_and_view_facts() {
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %is = scalar.constant true : i1
  %same = scalar.constant true : i1
  %offset_lo = scalar.constant 16 : i64
  %offset_hi = scalar.constant 16 : i64
  %offset_div = scalar.constant 16 : i64
  %length_lo = scalar.constant 64 : i64
  %length_hi = scalar.constant 64 : i64
  %alignment = scalar.constant 16 : i64
  %space = scalar.constant 3 : i64
  test.use %is, %same, %offset_lo, %offset_hi, %offset_div, %length_lo, %length_hi, %alignment, %space : i1, i1, i64, i64, i64, i64, i64, i64, i64
  low.return
}

// ====

test.target<low_core> @target

low.kernel.def target(@target) @low_storage_select_same_backing() {
  %condition_seed = scalar.constant true : i1
  %cond = test.convergent %condition_seed : i1
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %a = low.storage.view %storage {offset = 16, byte_length = 32} : low.storage<workgroup> -> low.storage<workgroup>
  %b = low.storage.view %storage {offset = 32, byte_length = 32} : low.storage<workgroup> -> low.storage<workgroup>
  %selected = scf.select %cond, %a, %b : low.storage<workgroup>
  %same = test.fact_storage_same_backing %selected, %storage : low.storage<workgroup>, low.storage<workgroup> -> i1
  %offset_lo = test.fact_storage_byte_offset_lo %selected : low.storage<workgroup> -> i64
  %offset_hi = test.fact_storage_byte_offset_hi %selected : low.storage<workgroup> -> i64
  %offset_div = test.fact_storage_byte_offset_divisor %selected : low.storage<workgroup> -> i64
  %alignment = test.fact_storage_min_alignment %selected : low.storage<workgroup> -> i64
  test.use %same, %offset_lo, %offset_hi, %offset_div, %alignment : i1, i64, i64, i64, i64
  low.return
}

// ----
test.target<low_core> @target

low.kernel.def target(@target) @low_storage_select_same_backing() {
  %condition_seed = scalar.constant true : i1
  %cond = test.convergent %condition_seed : i1
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %same = scalar.constant true : i1
  %offset_lo = scalar.constant 16 : i64
  %offset_hi = scalar.constant 32 : i64
  %offset_div = scalar.constant 16 : i64
  %alignment = scalar.constant 16 : i64
  test.use %same, %offset_lo, %offset_hi, %offset_div, %alignment : i1, i64, i64, i64, i64
  low.return
}

// ====

test.target<low_core> @target

low.kernel.def target(@target) @low_storage_select_different_backing() {
  %condition_seed = scalar.constant true : i1
  %cond = test.convergent %condition_seed : i1
  %lhs = low.storage.reserve {byte_alignment = 64, byte_length = 128} : low.storage<private>
  %rhs = low.storage.reserve {byte_alignment = 64, byte_length = 128} : low.storage<private>
  %selected = scf.select %cond, %lhs, %rhs : low.storage<private>
  %is = test.fact_is_storage_reference %selected : low.storage<private> -> i1
  %offset_lo = test.fact_storage_byte_offset_lo %selected : low.storage<private> -> i64
  test.use %is, %offset_lo : i1, i64
  low.return
}

// ----
test.target<low_core> @target

low.kernel.def target(@target) @low_storage_select_different_backing() {
  %condition_seed = scalar.constant true : i1
  %cond = test.convergent %condition_seed : i1
  %lhs = low.storage.reserve {byte_alignment = 64, byte_length = 128} : low.storage<private>
  %rhs = low.storage.reserve {byte_alignment = 64, byte_length = 128} : low.storage<private>
  %is = scalar.constant false : i1
  %offset_lo = scalar.constant -9223372036854775808 : i64
  test.use %is, %offset_lo : i1, i64
  low.return
}

// ====

test.target<low_core> @target

low.kernel.def target(@target) @low_storage_loop_widens_unstable_offset() {
  %lo = index.constant 0 : index
  %upper = index.constant 4 : index
  %step = index.constant 1 : index
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %initial = low.storage.view %storage {byte_length = 128} : low.storage<workgroup> -> low.storage<workgroup>
  %result = scf.for %iv = [%lo to %upper step %step](%carry = %initial : low.storage<workgroup>) -> (low.storage<workgroup>) {
    %next = low.storage.view %carry {offset = 16, byte_length = 64} : low.storage<workgroup> -> low.storage<workgroup>
    scf.yield %next : low.storage<workgroup>
  }
  %is = test.fact_is_storage_reference %result : low.storage<workgroup> -> i1
  %offset_lo = test.fact_storage_byte_offset_lo %result : low.storage<workgroup> -> i64
  %offset_hi = test.fact_storage_byte_offset_hi %result : low.storage<workgroup> -> i64
  test.use %is, %offset_lo, %offset_hi : i1, i64, i64
  low.return
}

// ----
test.target<low_core> @target

low.kernel.def target(@target) @low_storage_loop_widens_unstable_offset() {
  %storage = low.storage.reserve {byte_alignment = 64, byte_length = 256} : low.storage<workgroup>
  %is = scalar.constant true : i1
  %offset_lo = scalar.constant -9223372036854775808 : i64
  %offset_hi = scalar.constant 9223372036854775807 : i64
  test.use %is, %offset_lo, %offset_hi : i1, i64, i64
  low.return
}
