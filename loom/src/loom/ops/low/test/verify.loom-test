// RUN: verify

test.target<low_core> @test_target

target.artifact @test_artifact target(@test_target) {abi = hal_executable, artifact_format = elf}

// ERROR@+1: STRUCTURE/014 {attr_name="export", actual_value="0", expected_constraint="present when artifact, ordinal, or linkage is present"}
low.kernel.def target(@test_target) artifact(@test_artifact) @kernel_artifact_requires_export() {
  low.return
}

// ====

test.target<low_core> @test_target

// ERROR@+1: STRUCTURE/014 {attr_name="workgroup_size_x", actual_value="0", expected_constraint="positive u32"}
low.kernel.def target(@test_target) workgroup_size(0, 1, 1) @kernel_rejects_zero_workgroup_size() {
  low.return
}

// ====

test.target<low_core> @test_target

low.kernel.def target(@test_target) @kernel_return_rejects_values(%value: reg<test.i32>) {
  // ERROR@+1: STRUCTURE/001 {op_name="low.return", actual_count="1", expected_count="0"}
  low.return %value : reg<test.i32>
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @storage_view_passes(%value: reg<test.i32>) -> (reg<test.i32>) {
  %storage = low.storage.reserve {byte_alignment = 16, byte_length = 64} : low.storage<scratch>
  %view = low.storage.view %storage {offset = 16, byte_length = 16} : low.storage<scratch> -> low.storage<scratch>
  low.spill %value, %view : reg<test.i32>, low.storage<scratch>
  %reload = low.reload %view : low.storage<scratch> -> reg<test.i32>
  low.return %reload : reg<test.i32>
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @storage_view_rejects_overflowing_length() {
  %storage = low.storage.reserve {byte_alignment = 16, byte_length = 64} : low.storage<scratch>
  // ERROR@+1: SUBRANGE/004 {dim_index="0", offset="48", size="32", total="80", bound="64"}
  %view = low.storage.view %storage {offset = 48, byte_length = 32} : low.storage<scratch> -> low.storage<scratch>
  low.return
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @storage_view_bounds_storage_traffic(%value: reg<test.i32>) {
  %storage = low.storage.reserve {byte_alignment = 16, byte_length = 64} : low.storage<scratch>
  %view = low.storage.view %storage {offset = 16, byte_length = 16} : low.storage<scratch> -> low.storage<scratch>
  // ERROR@+1: SUBRANGE/004 {dim_index="0", offset="16", size="1", total="17", bound="16"}
  low.spill %value, %view {offset = 16} : reg<test.i32>, low.storage<scratch>
  low.return
}

// ====

test.target<low_core> @test_target

// low.live_in and low.resource form the entry-block preamble.
low.func.def target(@test_target) @entry_preamble() -> (reg<test.ptr>) {
  %state = low.resource<native_pointer> {index = 0, source_type = buffer} : reg<test.ptr>
  %arg0 = low.live_in<test.arg0> : reg<test.ptr>
  %copy = low.copy %state : reg<test.ptr> -> reg<test.ptr>
  low.return %copy : reg<test.ptr>
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @live_in_after_preamble(%input: reg<test.i32>) -> (reg<test.i32>) {
  %arg0 = low.live_in<test.arg0> : reg<test.i32>
  %copy = low.copy %arg0 : reg<test.i32> -> reg<test.i32>
  // ERROR@+1: STRUCTURE/030 {op_name="low.live_in", placement="before", reference_name="ordinary low packets"}
  %late = low.live_in<test.arg1> : reg<test.i32>
  low.return %late : reg<test.i32>
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @resource_after_preamble() -> (reg<test.ptr>) {
  %arg0 = low.live_in<test.arg0> : reg<test.ptr>
  %copy = low.copy %arg0 : reg<test.ptr> -> reg<test.ptr>
  // ERROR@+1: STRUCTURE/030 {op_name="low.resource", placement="before", reference_name="ordinary low packets"}
  %late = low.resource<native_pointer> {index = 0, source_type = buffer} : reg<test.ptr>
  low.return %late : reg<test.ptr>
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @live_in_non_entry_block() -> (reg<test.i32>) {
  %arg0 = low.live_in<test.arg0> : reg<test.i32>
  low.br ^exit
^exit:
  // ERROR@+1: STRUCTURE/031 {op_name="low.live_in", expected_block="the low entry block", actual_block="a non-entry block"}
  %late = low.live_in<test.arg1> : reg<test.i32>
  low.return %late : reg<test.i32>
}

// ====

test.target<low_core> @test_target

// Import attrs on low.func.decl are valid without changing the referenced low
// descriptor contract set.
low.func.decl import(vm, "iree.vm.core.add_i32") target(@test_target) @extern_imported(%lhs: reg<test.i32>) -> (reg<test.i32>)

// ====

test.target<low_core> @test_target

func.def @semantic(%value: i32, %state: vm.state) -> (i32) {
  func.return %value : i32
}

low.func.def target(@test_target) @semantic_low(%value: reg<test.i32>) -> (reg<test.i32>) {
  low.return %value : reg<test.i32>
}

func.def @invoke_explicit_low(%value: i32, %state: vm.state) -> (i32) {
  %result = low.invoke @semantic_low(%value, %state) : (i32, vm.state) -> (i32)
  func.return %result : i32
}

// ====

test.target<low_core> @test_target

low.func.def target(@test_target) @semantic_low(%value: reg<test.i32>) -> (reg<test.i32>) {
  low.return %value : reg<test.i32>
}

// low.invoke crosses from source IR to a low entry and therefore does not
// require the low callee's register signature to match the source signature.
func.def @invoke_source_signature(%value: f32) -> (i32) {
  %result = low.invoke @semantic_low(%value) : (f32) -> (i32)
  func.return %result : i32
}

