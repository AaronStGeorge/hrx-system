func.decl @semantic(%arg: i32) -> (i32)

func.def @invoke_non_low(%lhs: i32) -> (i32) {
  // ERROR@+1: SYMBOL/003 {symbol_name="semantic", actual_kind="function", expected_kind="low function"}
  %sum = low.invoke @semantic(%lhs) : (i32) -> (i32)
  func.return %sum : i32
}

