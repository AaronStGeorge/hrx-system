// RUN: roundtrip

// Multi-region function-like op with region-local projections of one logical
// function signature. The body receives the signature args through FuncArgs;
// the config region spells its own block args so the two regions have distinct
// SSA values with matching types.
test.split_func @projected(%arg: i32, %other: index) {
  test.use %arg : i32
  test.use %other : index
  test.yield
} launch {
  test.use %arg : i32
  test.use %other : index
  test.yield
}

// ====

// Owned-resource operations model generic lifetime effects without depending
// on a target dialect.
test.func @owned_resources(%size: index) {
  %fresh = test.resource.alloc %size : index -> pool<16>
  test.resource.borrow %fresh : pool<16>
  test.resource.borrow_ref %fresh : pool<16>
  %retained = test.resource.retain %fresh : pool<16> -> pool<16>
  %alias = test.resource.alias %retained : pool<16> -> pool<16>
  %borrowed = test.resource.borrowed %alias : pool<16> -> pool<16>
  test.resource.release %retained : pool<16>
  test.resource.discard %alias : pool<16>
  test.resource.escape %borrowed : pool<16>
  test.resource.consume %fresh : pool<16>
  test.yield
}
