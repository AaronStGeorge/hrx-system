load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "iree_assert_no_dependency",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

#===------------------------------------------------------------------------===#
# Layering checks
#===------------------------------------------------------------------------===#

iree_assert_no_dependency(
    name = "production_op_registry_no_test_dialect_dep",
    dependency = "//loom/src/loom/ops/test",
    target = "//loom/src/loom/ops:op_registry",
)

iree_assert_no_dependency(
    name = "text_parser_no_test_dialect_dep",
    dependency = "//loom/src/loom/ops/test",
    target = "//loom/src/loom/format/text:parser",
)

iree_assert_no_dependency(
    name = "text_printer_no_test_dialect_dep",
    dependency = "//loom/src/loom/ops/test",
    target = "//loom/src/loom/format/text:printer",
)

iree_assert_no_dependency(
    name = "bytecode_reader_no_test_dialect_dep",
    dependency = "//loom/src/loom/ops/test",
    target = "//loom/src/loom/format/bytecode:reader",
)

iree_assert_no_dependency(
    name = "bytecode_writer_no_test_dialect_dep",
    dependency = "//loom/src/loom/ops/test",
    target = "//loom/src/loom/format/bytecode:writer",
)

#===------------------------------------------------------------------------===#
# Synthetic test dialect
#===------------------------------------------------------------------------===#

loom_cc_library(
    name = "test",
    srcs = [
        "builders.c",
        "canonicalize.c",
        "facts.c",
        "registry.c",
        "symbol_facts.c",
        "tables.c",
        "verify.c",
    ],
    hdrs = [
        "facts.h",
        "ops.h",
        "registry.h",
    ],
    deps = [
        "//loom/src/loom/analysis:symbol_facts",
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/rewrite:rewriter",
        "//loom/src/loom/util:fact_table",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "ops_test",
    srcs = ["ops_test.cc"],
    deps = [
        ":test",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
