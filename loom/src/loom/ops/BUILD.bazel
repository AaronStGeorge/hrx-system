load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
    "loom_generated_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "op_defs",
    srcs = ["op_defs.c"],
    hdrs = [
        "builder_macros.h",
        "op_defs.h",
    ],
    textual_hdrs = [
        "keyword_enum.inc",
        "keyword_table.inc",
    ],
    deps = [
        "//loom/src/loom/ir",
        "//loom/src/loom/util:bstring",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_test(
    name = "op_defs_test",
    srcs = ["op_defs_test.cc"],
    deps = [
        ":op_defs",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_library(
    name = "func_symbol_facts",
    srcs = ["func_symbol_facts.c"],
    hdrs = ["func_symbol_facts.h"],
    deps = [
