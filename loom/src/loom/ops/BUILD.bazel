loom_generated_cc_library(
    name = "type_registry",
    hdrs = ["type_registry.h"],
    args = ["--registry"],
    generated_src_flags = ["--type-registry-source"],
    generated_srcs = ["type_registry.c"],
    generator = "//loom/py/loom/gen/ops:c_tables_generator",
    deps = [
        ":op_defs",
