        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "storage_facts",
    srcs = ["storage_facts.c"],
    hdrs = ["storage_facts.h"],
    deps = [
        "//loom/src/loom/ir",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:math",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "func_symbol_facts_test",
    srcs = ["func_symbol_facts_test.cc"],
