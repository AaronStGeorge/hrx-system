// RUN: pass canonicalize

// Address-domain constants contribute exact value facts.
func.def @constant_exact() -> (i64, i64) {
  %c = index.constant 42 : index
  %lo = test.fact_range_lo %c : index -> i64
  %hi = test.fact_range_hi %c : index -> i64
  func.return %lo, %hi : i64, i64
}
// ----
func.def @constant_exact() -> (i64, i64) {
  %lo = scalar.constant 42 : i64
  %hi = scalar.constant 42 : i64
  func.return %lo, %hi : i64, i64
}

// ====

// Offset arithmetic uses the same address-domain fact transfer as index
// arithmetic.
func.def @offset_add_sub_exact() -> (i64, i64) {
  %base = index.constant 128 : offset
  %delta = index.constant 64 : offset
  %sum = index.add %base, %delta : offset
  %back = index.sub %sum, %delta : offset
  %sum_lo = test.fact_range_lo %sum : offset -> i64
  %back_lo = test.fact_range_lo %back : offset -> i64
  func.return %sum_lo, %back_lo : i64, i64
}
// ----
func.def @offset_add_sub_exact() -> (i64, i64) {
  %sum_lo = scalar.constant 192 : i64
  %back_lo = scalar.constant 128 : i64
  func.return %sum_lo, %back_lo : i64, i64
}

// ====

// index.assume applies predicate facts to matching index and offset results.
func.def @assume_refines_address_facts(%n: index, %base: offset) -> (i64, i64) {
  %n2, %base2 = index.assume %n, %base [mul(%n, 16), range(%base, 64, 4096)] : index, offset
  %n_div = test.fact_divisor %n2 : index -> i64
  %base_lo = test.fact_range_lo %base2 : offset -> i64
  func.return %n_div, %base_lo : i64, i64
}
// ----
func.def @assume_refines_address_facts(%n: index, %base: offset) -> (i64, i64) {
  %n_div = scalar.constant 16 : i64
  %base_lo = scalar.constant 64 : i64
  func.return %n_div, %base_lo : i64, i64
}

// ====

// index.mul by a constant propagates divisibility.
func.def @mul_divisibility(%x: index) -> (i64) {
  %c64 = index.constant 64 : index
  %r = index.mul %x, %c64 : index
  %div = test.fact_divisor %r : index -> i64
  func.return %div : i64
}
// ----
func.def @mul_divisibility(%x: index) -> (i64) {
  %div = scalar.constant 64 : i64
  func.return %div : i64
}

// ====

// index.add meets divisibility across operands.
func.def @add_divisibility(%x: index, %y: index) -> (i64) {
  %c64 = index.constant 64 : index
  %c16 = index.constant 16 : index
  %a = index.mul %x, %c64 : index
  %b = index.mul %y, %c16 : index
  %r = index.add %a, %b : index
  %div = test.fact_divisor %r : index -> i64
  func.return %div : i64
}
// ----
func.def @add_divisibility(%x: index, %y: index) -> (i64) {
  %div = scalar.constant 16 : i64
  func.return %div : i64
}

// ====

// index.madd keeps multiply-add coordinate facts in the index dialect.
func.def @madd_divisibility(%x: index, %y: index) -> (i64) {
  %c8 = index.constant 8 : index
  %c4 = index.constant 4 : index
  %c16 = index.constant 16 : index
  %a = index.mul %x, %c8 : index
  %c = index.mul %y, %c16 : index
  %r = index.madd %a, %c4, %c : index
  %div = test.fact_divisor %r : index -> i64
  func.return %div : i64
}
// ----
func.def @madd_divisibility(%x: index, %y: index) -> (i64) {
  %div = scalar.constant 16 : i64
  func.return %div : i64
}

// ====

// index.div by an exact positive constant scales known divisibility down.
func.def @div_divisibility(%x: index) -> (i64) {
  %c64 = index.constant 64 : index
  %c8 = index.constant 8 : index
  %aligned = index.mul %x, %c64 : index
  %q = index.div %aligned, %c8 : index
  %div = test.fact_divisor %q : index -> i64
  func.return %div : i64
}
// ----
func.def @div_divisibility(%x: index) -> (i64) {
  %div = scalar.constant 8 : i64
  func.return %div : i64
}

// ====

// index.rem by an exact positive divisor folds to zero when the dividend is
// known divisible by that divisor.
func.def @rem_exact_zero(%x: index) -> (i64, i64) {
  %c64 = index.constant 64 : index
  %c8 = index.constant 8 : index
  %x2 = index.assume %x [range(%x, 0, 4096)] : index
  %aligned = index.mul %x2, %c64 : index
  %r = index.rem %aligned, %c8 : index
  %lo = test.fact_range_lo %r : index -> i64
  %hi = test.fact_range_hi %r : index -> i64
  func.return %lo, %hi : i64, i64
}
// ----
func.def @rem_exact_zero(%x: index) -> (i64, i64) {
  %lo = scalar.constant 0 : i64
  %hi = scalar.constant 0 : i64
  func.return %lo, %hi : i64, i64
}

// ====

// index.cast preserves facts across address/integer boundaries.
func.def @cast_preserves_exact() -> (i64) {
  %a = index.constant 100 : index
  %r = index.cast %a : index to i64
  func.return %r : i64
}
// ----
func.def @cast_preserves_exact() -> (i64) {
  %r = scalar.constant 100 : i64
  func.return %r : i64
}

// ====

// index.add removes a fact-proven zero operand without requiring the other
// operand to be constant.
func.def @add_zero_identity(%x: index) -> (index) {
  %zero = index.constant 0 : index
  %r = index.add %x, %zero : index
  func.return %r : index
}
// ----
func.def @add_zero_identity(%x: index) -> (index) {
  func.return %x : index
}

// ====

// index.mul removes one and annihilates with zero.
func.def @mul_identities(%x: index) -> (index, index) {
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %same = index.mul %x, %one : index
  %zeroed = index.mul %x, %zero : index
  func.return %same, %zeroed : index, index
}
// ----
func.def @mul_identities(%x: index) -> (index, index) {
  %zeroed = index.constant 0 : index
  func.return %x, %zeroed : index, index
}

// ====

// index.madd simplifies the common address form a*1 + c to add.
func.def @madd_identity_multiplier(%a: index, %c: index) -> (index) {
  %one = index.constant 1 : index
  %r = index.madd %a, %one, %c : index
  func.return %r : index
}
// ----
func.def @madd_identity_multiplier(%a: index, %c: index) -> (index) {
  %r = index.add %a, %c : index
  func.return %r : index
}

// ====

// index.cmp folds same-operand predicates and simple disjoint signed ranges.
func.def @cmp_proven(%x: index, %y: index) -> (i1, i1) {
  %same = index.cmp sle, %x, %x : index
  %x2 = index.assume %x [range(%x, 0, 4)] : index
  %y2 = index.assume %y [range(%y, 8, 16)] : index
  %lt = index.cmp slt, %x2, %y2 : index
  func.return %same, %lt : i1, i1
}
// ----
func.def @cmp_proven(%x: index, %y: index) -> (i1, i1) {
  %same = scalar.constant true : i1
  %lt = scalar.constant true : i1
  func.return %same, %lt : i1, i1
}

// ====

// index.select folds exact conditions and identical arms.
func.def @select_identities(%x: index, %y: index) -> (index, index) {
  %false = scalar.constant 0 : i1
  %a = index.select %false, %x, %y : index
  %b = index.select %false, %x, %x : index
  func.return %a, %b : index, index
}
// ----
func.def @select_identities(%x: index, %y: index) -> (index, index) {
  func.return %y, %x : index, index
}
