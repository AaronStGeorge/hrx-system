// RUN: pass canonicalize

// addi: 3 + 4 = 7.
func.def @addi() -> (i32) {
  %a = scalar.constant 3 : i32
  %b = scalar.constant 4 : i32
  %r = scalar.addi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @addi() -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// addi: negative operands. -10 + 3 = -7.
func.def @addi_negative() -> (i32) {
  %a = scalar.constant -10 : i32
  %b = scalar.constant 3 : i32
  %r = scalar.addi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @addi_negative() -> (i32) {
  %r = scalar.constant -7 : i32
  func.return %r : i32
}

// ====

// addi: zero identity. 42 + 0 = 42.
func.def @addi_zero() -> (i32) {
  %a = scalar.constant 42 : i32
  %b = scalar.constant 0 : i32
  %r = scalar.addi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @addi_zero() -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// subi: 10 - 3 = 7.
func.def @subi() -> (i32) {
  %a = scalar.constant 10 : i32
  %b = scalar.constant 3 : i32
  %r = scalar.subi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @subi() -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// subi: self-cancel. 42 - 42 = 0.
func.def @subi_self() -> (i32) {
  %a = scalar.constant 42 : i32
  %b = scalar.constant 42 : i32
  %r = scalar.subi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @subi_self() -> (i32) {
  %r = scalar.constant 0 : i32
  func.return %r : i32
}

// ====

// muli: 6 * 7 = 42.
func.def @muli() -> (i32) {
  %a = scalar.constant 6 : i32
  %b = scalar.constant 7 : i32
  %r = scalar.muli %a, %b : i32
  func.return %r : i32
}
// ----
func.def @muli() -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// muli: zero annihilator. 999 * 0 = 0.
func.def @muli_zero() -> (i32) {
  %a = scalar.constant 999 : i32
  %b = scalar.constant 0 : i32
  %r = scalar.muli %a, %b : i32
  func.return %r : i32
}
// ----
func.def @muli_zero() -> (i32) {
  %r = scalar.constant 0 : i32
  func.return %r : i32
}

// ====

// negi: -(42) = -42.
func.def @negi() -> (i32) {
  %a = scalar.constant 42 : i32
  %r = scalar.negi %a : i32
  func.return %r : i32
}
// ----
func.def @negi() -> (i32) {
  %r = scalar.constant -42 : i32
  func.return %r : i32
}

// ====

// negi: double negation. -(-(5)) = 5.
func.def @negi_double() -> (i32) {
  %a = scalar.constant 5 : i32
  %b = scalar.negi %a : i32
  %r = scalar.negi %b : i32
  func.return %r : i32
}
// ----
func.def @negi_double() -> (i32) {
  %r = scalar.constant 5 : i32
  func.return %r : i32
}

// ====

// absi: abs(-7) = 7.
func.def @absi_negative() -> (i32) {
  %a = scalar.constant -7 : i32
  %r = scalar.absi %a : i32
  func.return %r : i32
}
// ----
func.def @absi_negative() -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// absi: abs(7) = 7.
func.def @absi_positive() -> (i32) {
  %a = scalar.constant 7 : i32
  %r = scalar.absi %a : i32
  func.return %r : i32
}
// ----
func.def @absi_positive() -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// minsi: min(3, 7) = 3.
func.def @minsi() -> (i32) {
  %a = scalar.constant 3 : i32
  %b = scalar.constant 7 : i32
  %r = scalar.minsi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @minsi() -> (i32) {
  %r = scalar.constant 3 : i32
  func.return %r : i32
}

// ====

// maxsi: max(3, 7) = 7.
func.def @maxsi() -> (i32) {
  %a = scalar.constant 3 : i32
  %b = scalar.constant 7 : i32
  %r = scalar.maxsi %a, %b : i32
  func.return %r : i32
}
// ----
func.def @maxsi() -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// Multi-hop chain: (3 + 4) * 6 = 42.
func.def @chain() -> (i32) {
  %a = scalar.constant 3 : i32
  %b = scalar.constant 4 : i32
  %c = scalar.constant 6 : i32
  %sum = scalar.addi %a, %b : i32
  %r = scalar.muli %sum, %c : i32
  func.return %r : i32
}
// ----
func.def @chain() -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// Dynamic operands: no fold.
func.def @no_fold(%x: i32, %y: i32) -> (i32) {
  %r = scalar.addi %x, %y : i32
  func.return %r : i32
}

// ====

// fmai: basic constant folding. 2*3 + 4 = 10.
func.def @fmai_const() -> (i32) {
  %a = scalar.constant 2 : i32
  %b = scalar.constant 3 : i32
  %c = scalar.constant 4 : i32
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_const() -> (i32) {
  %r = scalar.constant 10 : i32
  func.return %r : i32
}

// ====

// fmai: zero multiplier folds to exact c.
func.def @fmai_zero_mul(%x: i32) -> (i32) {
  %zero = scalar.constant 0 : i32
  %c = scalar.constant 42 : i32
  %r = scalar.fmai %x, %zero, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_zero_mul(%x: i32) -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// fmai: zero multiplier first operand.
func.def @fmai_zero_mul_first(%x: i32) -> (i32) {
  %zero = scalar.constant 0 : i32
  %c = scalar.constant 42 : i32
  %r = scalar.fmai %zero, %x, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_zero_mul_first(%x: i32) -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// fmai: zero addend canonicalizes to muli then folds.
func.def @fmai_zero_addend() -> (i32) {
  %a = scalar.constant 6 : i32
  %b = scalar.constant 7 : i32
  %c = scalar.constant 0 : i32
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_zero_addend() -> (i32) {
  %r = scalar.constant 42 : i32
  func.return %r : i32
}

// ====

// fmai: identity multiplier canonicalizes to addi then folds.
func.def @fmai_identity_mul() -> (i32) {
  %a = scalar.constant 5 : i32
  %b = scalar.constant 1 : i32
  %c = scalar.constant 10 : i32
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_identity_mul() -> (i32) {
  %r = scalar.constant 15 : i32
  func.return %r : i32
}

// ====

// fmai: identity multiplier first operand.
func.def @fmai_identity_mul_first() -> (i32) {
  %a = scalar.constant 1 : i32
  %b = scalar.constant 5 : i32
  %c = scalar.constant 10 : i32
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_identity_mul_first() -> (i32) {
  %r = scalar.constant 15 : i32
  func.return %r : i32
}

// ====

// fmai: negative numbers. (-3)*4 + 5 = -7.
func.def @fmai_negative() -> (i32) {
  %a = scalar.constant -3 : i32
  %b = scalar.constant 4 : i32
  %c = scalar.constant 5 : i32
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}
// ----
func.def @fmai_negative() -> (i32) {
  %r = scalar.constant -7 : i32
  func.return %r : i32
}

// ====

// fmai: large values.
func.def @fmai_large() -> (i64) {
  %a = scalar.constant 1000000 : i64
  %b = scalar.constant 1000000 : i64
  %c = scalar.constant 500000 : i64
  %r = scalar.fmai %a, %b, %c : i64
  func.return %r : i64
}
// ----
func.def @fmai_large() -> (i64) {
  %r = scalar.constant 1000000500000 : i64
  func.return %r : i64
}

// ====

// fmai: dynamic operands - no fold (negative test).
func.def @fmai_dynamic(%a: i32, %b: i32, %c: i32) -> (i32) {
  %r = scalar.fmai %a, %b, %c : i32
  func.return %r : i32
}

// ====

// fmai: one dynamic operand - no fold (negative test).
func.def @fmai_one_dynamic(%x: i32) -> (i32) {
  %a = scalar.constant 2 : i32
  %b = scalar.constant 3 : i32
  %r = scalar.fmai %a, %b, %x : i32
  func.return %r : i32
}

// ====

// fmai: with overflow flags - no fold on dynamic (negative test).
func.def @fmai_nuw_dynamic(%a: i32, %b: i32, %c: i32) -> (i32) {
  %r = scalar.fmai<nuw> %a, %b, %c : i32
  func.return %r : i32
}
