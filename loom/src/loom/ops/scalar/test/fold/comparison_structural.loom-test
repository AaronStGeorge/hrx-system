// RUN: pass canonicalize

// cmpi folds same-SSA reflexive and irreflexive predicates.
func.def @cmpi_same_value(%x: i32) -> (i1, i1) {
  %eq = scalar.cmpi eq, %x, %x : i32
  %ult = scalar.cmpi ult, %x, %x : i32
  func.return %eq, %ult : i1, i1
}
// ----
func.def @cmpi_same_value(%x: i32) -> (i1, i1) {
  %eq = scalar.constant true : i1
  %ult = scalar.constant false : i1
  func.return %eq, %ult : i1, i1
}

// ====

// cmpi moves a literal lhs to the rhs and swaps the predicate.
func.def @cmpi_literal_rhs(%x: i32) -> (i1) {
  %c7 = scalar.constant 7 : i32
  %r = scalar.cmpi slt, %c7, %x : i32
  func.return %r : i1
}
// ----
func.def @cmpi_literal_rhs(%x: i32) -> (i1) {
  %c7 = scalar.constant 7 : i32
  %r = scalar.cmpi sgt, %x, %c7 : i32
  func.return %r : i1
}

// ====

// Unsigned comparisons against zero collapse to constants or equality tests.
func.def @cmpi_unsigned_zero(%x: i32) -> (i1, i1) {
  %zero = scalar.constant 0 : i32
  %lt = scalar.cmpi ult, %x, %zero : i32
  %gt = scalar.cmpi ugt, %x, %zero : i32
  func.return %lt, %gt : i1, i1
}
// ----
func.def @cmpi_unsigned_zero(%x: i32) -> (i1, i1) {
  %zero = scalar.constant 0 : i32
  %lt = scalar.constant false : i1
  %gt = scalar.cmpi ne, %x, %zero : i32
  func.return %lt, %gt : i1, i1
}

// ====

// cmpi uses integer range facts for simple proofs.
func.def @cmpi_range_proof(%x: i32, %y: i32) -> (i1, i1) {
  %lo = scalar.assume %x [range(%x, 0, 4)] : i32
  %hi = scalar.assume %y [range(%y, 8, 16)] : i32
  %lt = scalar.cmpi slt, %lo, %hi : i32
  %ne = scalar.cmpi ne, %lo, %hi : i32
  func.return %lt, %ne : i1, i1
}
// ----
func.def @cmpi_range_proof(%x: i32, %y: i32) -> (i1, i1) {
  %lt = scalar.constant true : i1
  %ne = scalar.constant true : i1
  func.return %lt, %ne : i1, i1
}

// ====

// cmpf same-value proofs require nnan; NaN-sensitive forms stay conservative.
func.def @cmpf_same_value(%x: f32) -> (i1, i1, i1) {
  %eq = scalar.cmpf<nnan> oeq, %x, %x : f32
  %uno = scalar.cmpf<nnan> uno, %x, %x : f32
  %nan_sensitive = scalar.cmpf oeq, %x, %x : f32
  func.return %eq, %uno, %nan_sensitive : i1, i1, i1
}
// ----
func.def @cmpf_same_value(%x: f32) -> (i1, i1, i1) {
  %eq = scalar.constant true : i1
  %uno = scalar.constant false : i1
  %nan_sensitive = scalar.cmpf oeq, %x, %x : f32
  func.return %eq, %uno, %nan_sensitive : i1, i1, i1
}

// ====

// select on i1 can become the condition or its boolean complement.
func.def @select_boolean_identity(%c: i1) -> (i1, i1) {
  %true = scalar.constant true : i1
  %false = scalar.constant false : i1
  %id = scalar.select %c, %true, %false : i1
  %not = scalar.select %c, %false, %true : i1
  func.return %id, %not : i1, i1
}
// ----
func.def @select_boolean_identity(%c: i1) -> (i1, i1) {
  %true = scalar.constant true : i1
  %not = scalar.xori %c, %true : i1
  func.return %c, %not : i1, i1
}
