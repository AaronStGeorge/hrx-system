// RUN: pass canonicalize

func.def @addi_dynamic_identities(%x: i32) -> (i32, i32) {
  %zero = scalar.constant 0 : i32
  %lhs = scalar.addi %zero, %x : i32
  %rhs = scalar.addi %x, %zero : i32
  func.return %lhs, %rhs : i32, i32
}

// ----
func.def @addi_dynamic_identities(%x: i32) -> (i32, i32) {
  func.return %x, %x : i32, i32
}

// ====

func.def @addi_cancels_sub(%x: i32, %y: i32) -> (i32, i32) {
  %delta = scalar.subi %x, %y : i32
  %left = scalar.addi %delta, %y : i32
  %right = scalar.addi %y, %delta : i32
  func.return %left, %right : i32, i32
}

// ----
func.def @addi_cancels_sub(%x: i32, %y: i32) -> (i32, i32) {
  func.return %x, %x : i32, i32
}

