func.def @negi_and_absi_structural(%x: i32) -> (i32, i32, i32) {
  %neg = scalar.negi %x : i32
  %double = scalar.negi %neg : i32
  %abs = scalar.absi %x : i32
  %abs_abs = scalar.absi %abs : i32
  %abs_neg = scalar.absi %neg : i32
  func.return %double, %abs_abs, %abs_neg : i32, i32, i32
}

// ----
func.def @negi_and_absi_structural(%x: i32) -> (i32, i32, i32) {
  %abs = scalar.absi %x : i32
  %abs_neg = scalar.absi %x : i32
  func.return %x, %abs, %abs_neg : i32, i32, i32
}

