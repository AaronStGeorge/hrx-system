func.def @flagged_sub_add_cancellation_stays(%x: i32, %y: i32) -> (i32) {
  %delta = scalar.subi<nsw> %x, %y : i32
  %r = scalar.addi %delta, %y : i32
  func.return %r : i32
}

// ====

func.def @subi_dynamic_identities(%x: i32, %y: i32) -> (i32, i32, i32) {
  %zero = scalar.constant 0 : i32
  %identity = scalar.subi %x, %zero : i32
  %self = scalar.subi %x, %x : i32
  %sum = scalar.addi %x, %y : i32
  %cancel = scalar.subi %sum, %y : i32
  func.return %identity, %self, %cancel : i32, i32, i32
}

// ----
func.def @subi_dynamic_identities(%x: i32, %y: i32) -> (i32, i32, i32) {
  %self = scalar.constant 0 : i32
  func.return %x, %self, %x : i32, i32, i32
}

