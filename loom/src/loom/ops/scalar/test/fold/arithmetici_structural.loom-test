  func.return %x2 : i32
}

// ====

func.def @signed_minmax_extremes(%x: i32) -> (i32, i32, i32, i32, i32, i32) {
  %min = scalar.constant -2147483648 : i32
  %max = scalar.constant 2147483647 : i32
  %min_self = scalar.minsi %x, %x : i32
  %min_absorb = scalar.minsi %x, %min : i32
  %min_identity = scalar.minsi %x, %max : i32
  %max_self = scalar.maxsi %x, %x : i32
  %max_absorb = scalar.maxsi %x, %max : i32
  %max_identity = scalar.maxsi %x, %min : i32
  func.return %min_self, %min_absorb, %min_identity, %max_self, %max_absorb, %max_identity : i32, i32, i32, i32, i32, i32
}

// ----
func.def @signed_minmax_extremes(%x: i32) -> (i32, i32, i32, i32, i32, i32) {
  %min_absorb = scalar.constant -2147483648 : i32
  %max_absorb = scalar.constant 2147483647 : i32
  func.return %x, %min_absorb, %x, %x, %max_absorb, %x : i32, i32, i32, i32, i32, i32
}

// ====

func.def @unsigned_minmax_extremes(%x: i32) -> (i32, i32, i32, i32) {
  %zero = scalar.constant 0 : i32
  %umax = scalar.constant 4294967295 : i32
  %min_absorb = scalar.minui %x, %zero : i32
  %min_identity = scalar.minui %x, %umax : i32
  %max_identity = scalar.maxui %x, %zero : i32
  %max_absorb = scalar.maxui %x, %umax : i32
  func.return %min_absorb, %min_identity, %max_identity, %max_absorb : i32, i32, i32, i32
}

// ----
func.def @unsigned_minmax_extremes(%x: i32) -> (i32, i32, i32, i32) {
  %zero = scalar.constant 0 : i32
  %umax = scalar.constant 4294967295 : i32
  func.return %zero, %x, %x, %umax : i32, i32, i32, i32
}
