// RUN: verify

// ====

// Dead poison computations are valid until their value reaches an observation
// boundary.
func.def @dead_poison_not_observed(%x: i32) {
  %p = scalar.poison : i32
  %dead = scalar.addi %p, %x : i32
  func.return
}

// ====

// Function returns observe poison escaping ordinary SSA propagation.
func.def @return_poison() -> (i32) {
  %p = scalar.poison : i32
  // ERROR@+1: TYPE/012 "poison" "function return" "func.return"
  func.return %p : i32
}

// ====

// Integer constants require integer literal payloads.
func.def @integer_constant_value_kind() -> (i32) {
  // ERROR@+1: TYPE/005 "value"
  %c = scalar.constant 1.0 : i32
  func.return %c : i32
}

// ====

// Floating-point constants require floating-point literal payloads.
func.def @float_constant_value_kind() -> (f32) {
  // ERROR@+1: TYPE/005 "value"
  %c = scalar.constant 1 : f32
  func.return %c : f32
}

// ====

// Boolean integer literals must be 0 or 1.
func.def @boolean_constant_value_range() -> (i1) {
  // ERROR@+1: TYPE/005 "value"
  %c = scalar.constant 2 : i1
  func.return %c : i1
}

// ====

// Logical coordinate constants must be authored with index.constant so that
// address-domain values are structurally unambiguous.
func.def @index_constant_requires_index_dialect() -> (index) {
  // ERROR@+1: TYPE/004 "result" "index" "integer or floating-point scalar; use index.constant"
  %c = scalar.constant 0 : index
  func.return %c : index
}

// ====

// Physical byte offset constants use the index dialect too.
func.def @offset_constant_requires_index_dialect() -> (offset) {
  // ERROR@+1: TYPE/004 "result" "offset" "integer or floating-point scalar; use index.constant"
  %c = scalar.constant 0 : offset
  func.return %c : offset
}
