// RUN: format bytecode

// Config symbols serialize through the compact value-symbol bytecode payload
// while retaining config-specific symbol interfaces after materialization.
config.decl @model36.model.max_context : %value: index where [range(%value, 1, 131072)]

config.def @model36.model.hidden_size = 2048 : index

config.def @model36.quant.dense_schema = #q8_0<block=32> : encoding<schema>

func.def @read_config() -> (index, encoding<schema>) {
  %hidden = config.get @model36.model.hidden_size : index
  %schema = config.get @model36.quant.dense_schema : encoding<schema>
  func.return %hidden, %schema : index, encoding<schema>
}
