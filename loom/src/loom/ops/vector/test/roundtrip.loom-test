// RUN: roundtrip

// Construction ops keep scalar/vector interop explicit.
func.def @construction(%x: f32, %i: i32, %n: index) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %ci0 = scalar.constant 0 : i32
  %ci1 = scalar.constant 1 : i32
  %ci4 = scalar.constant 4 : i32
  %ps = scalar.poison : f32
  %pv = vector.poison : vector<4xf32>
  %empty = vector.empty : vector<0xf32>
  %vf = vector.splat %x : vector<16xf32>
  %empty_splat = vector.splat %x : vector<0xf32>
  %vi = vector.splat %i : vector<[%n]xi32>
  %lanes = vector.iota %c0 step %c1 : vector<16xindex>
  %int_lanes = vector.iota %ci0 step %i : vector<4xi32>
  %dyn_lanes = vector.iota %c0 step %c1 : vector<[%n]xindex>
  %tail = vector.mask.range [%c0 to %n step %c1] : index -> vector<16xi1>
  %int_tail = vector.mask.range [%ci0 to %ci4 step %ci1] : i32 -> vector<4xi1>
  %c = vector.constant 0.0 : vector<4xf32>
  %wide = vector.broadcast %c : vector<4xf32> -> vector<4x4xf32>
  %lane0 = vector.extract %c[0] : vector<4xf32> -> f32
  %updated = vector.insert %lane0 into %c[%n] : f32, vector<4xf32>
  %from = vector.from_elements %x, %x, %x, %x : vector<4xf32>
  test.use %ps, %pv, %empty, %vf, %empty_splat, %vi, %lanes, %int_lanes, %dyn_lanes, %tail, %int_tail, %wide, %updated, %from : f32, vector<4xf32>, vector<0xf32>, vector<16xf32>, vector<0xf32>, vector<[%n]xi32>, vector<16xindex>, vector<4xi32>, vector<[%n]xindex>, vector<16xi1>, vector<4xi1>, vector<4x4xf32>, vector<4xf32>, vector<4xf32>
  func.return
}

// ====

// Float lanewise arithmetic follows scalar spelling and keeps vector/vector
// operands.
func.def @lanewise_float_arithmetic(%a: vector<16xf32>, %b: vector<16xf32>, %c: vector<16xf32>) {
  %sum = vector.addf %a, %b : vector<16xf32>
  %diff = vector.subf %sum, %c : vector<16xf32>
  %prod = vector.mulf<nnan> %diff, %c : vector<16xf32>
  %quot = vector.divf %prod, %c : vector<16xf32>
  %rem = vector.remf %prod, %c : vector<16xf32>
  %neg = vector.negf %rem : vector<16xf32>
  %abs = vector.absf %neg : vector<16xf32>
  %min = vector.minimumf %abs, %quot : vector<16xf32>
  %max = vector.maximumf %abs, %quot : vector<16xf32>
  %minnum = vector.minnumf %min, %max : vector<16xf32>
  %maxnum = vector.maxnumf %min, %max : vector<16xf32>
  %signed = vector.copysignf %minnum, %maxnum : vector<16xf32>
  %fma = vector.fmaf %a, %b, %signed : vector<16xf32>
  test.use %signed, %fma : vector<16xf32>, vector<16xf32>
  func.return
}

// ====

// Integer arithmetic keeps overflow and signedness semantics visible in the op
// spelling.
func.def @lanewise_integer_arithmetic(%i: vector<16xi32>, %j: vector<16xi32>) {
  %isum = vector.addi<nuw> %i, %j : vector<16xi32>
  %idiff = vector.subi<nsw> %isum, %j : vector<16xi32>
  %iprod = vector.muli %idiff, %j : vector<16xi32>
  %idivsi = vector.divsi %iprod, %j : vector<16xi32>
  %idivui = vector.divui %iprod, %j : vector<16xi32>
  %iremsi = vector.remsi %iprod, %j : vector<16xi32>
  %iremui = vector.remui %iprod, %j : vector<16xi32>
  %iceilsi = vector.ceildivsi %iprod, %j : vector<16xi32>
  %iceilui = vector.ceildivui %iprod, %j : vector<16xi32>
  %ifloorsi = vector.floordivsi %iprod, %j : vector<16xi32>
  %ineg = vector.negi %ifloorsi : vector<16xi32>
  %iabs = vector.absi %ineg : vector<16xi32>
  %iminsi = vector.minsi %iabs, %iremsi : vector<16xi32>
  %imaxsi = vector.maxsi %iabs, %iremsi : vector<16xi32>
  %iminui = vector.minui %imaxsi, %iremui : vector<16xi32>
  %imaxui = vector.maxui %iminsi, %idivui : vector<16xi32>
  %ifmai = vector.fmai<nuw> %iminui, %imaxui, %idivsi : vector<16xi32>
  test.use %idivsi, %idivui, %iceilsi, %iceilui, %ifloorsi, %iminsi, %imaxsi, %iminui, %imaxui, %ifmai : vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>, vector<16xi32>
  func.return
}

// ====

// Integer bitwise operations include shifts, rotates, and bit counts.
func.def @lanewise_integer_bits(%i: vector<16xi32>, %j: vector<16xi32>) {
  %isum = vector.addi %i, %j : vector<16xi32>
  %and = vector.andi %isum, %j : vector<16xi32>
  %or = vector.ori %and, %i : vector<16xi32>
  %xor = vector.xori %or, %j : vector<16xi32>
  %shl = vector.shli<nuw> %xor, %j : vector<16xi32>
  %shrs = vector.shrsi %shl, %j : vector<16xi32>
  %shru = vector.shrui %shl, %j : vector<16xi32>
  %rotl = vector.rotli %shrs, %j : vector<16xi32>
  %rotr = vector.rotri %shru, %j : vector<16xi32>
  %clz = vector.ctlzi %rotl : vector<16xi32>
  %ctz = vector.cttzi %rotr : vector<16xi32>
  %pop = vector.ctpopi %xor : vector<16xi32>
  test.use %clz, %ctz, %pop : vector<16xi32>, vector<16xi32>, vector<16xi32>
  func.return
}

// ====

// Predicate and sign operations can change element types while preserving the
// vector shape.
func.def @lanewise_predicate_sign(%a: vector<16xf32>, %i: vector<16xi32>) {
  %fsign = vector.signf %a : vector<16xf32>
  %isign = vector.signi %i : vector<16xi32>
  %isnan = vector.isnanf %a : vector<16xf32> -> vector<16xi1>
  %isinf = vector.isinff %a : vector<16xf32> -> vector<16xi1>
  %isfinite = vector.isfinitef %a : vector<16xf32> -> vector<16xi1>
  test.use %fsign, %isign, %isnan, %isinf, %isfinite : vector<16xf32>, vector<16xi32>, vector<16xi1>, vector<16xi1>, vector<16xi1>
  func.return
}

// ====

// Exp/log math mirrors scalar spelling for activation and normalization
// reference paths.
func.def @lanewise_math_exp_log(%a: vector<16xf32>) {
  %exp = vector.expf %a : vector<16xf32>
  %exp2 = vector.exp2f %a : vector<16xf32>
  %expm1 = vector.expm1f %a : vector<16xf32>
  %log = vector.logf %exp : vector<16xf32>
  %log2 = vector.log2f %exp2 : vector<16xf32>
  %log10 = vector.log10f %exp : vector<16xf32>
  %log1p = vector.log1pf %expm1 : vector<16xf32>
  test.use %log, %log2, %log10, %log1p : vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>
  func.return
}

// ====

func.def @lanewise_math_power_roots(%a: vector<16xf32>, %b: vector<16xf32>) {
  %pow = vector.powf %a, %b : vector<16xf32>
  %sqrt = vector.sqrtf %pow : vector<16xf32>
  %rsqrt = vector.rsqrtf %pow : vector<16xf32>
  %cbrt = vector.cbrtf %pow : vector<16xf32>
  test.use %sqrt, %rsqrt, %cbrt : vector<16xf32>, vector<16xf32>, vector<16xf32>
  func.return
}

// ====

func.def @lanewise_math_trig(%a: vector<16xf32>, %b: vector<16xf32>) {
  %sin = vector.sinf %a : vector<16xf32>
  %cos = vector.cosf %a : vector<16xf32>
  %tan = vector.tanf %a : vector<16xf32>
  %asin = vector.asinf %a : vector<16xf32>
  %acos = vector.acosf %a : vector<16xf32>
  %atan = vector.atanf %a : vector<16xf32>
  %atan2 = vector.atan2f %a, %b : vector<16xf32>
  test.use %sin, %cos, %tan, %asin, %acos, %atan, %atan2 : vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>
  func.return
}

// ====

func.def @lanewise_math_hyperbolic(%a: vector<16xf32>) {
  %sinh = vector.sinhf %a : vector<16xf32>
  %cosh = vector.coshf %a : vector<16xf32>
  %tanh = vector.tanhf %a : vector<16xf32>
  %asinh = vector.asinhf %a : vector<16xf32>
  %acosh = vector.acoshf %a : vector<16xf32>
  %atanh = vector.atanhf %a : vector<16xf32>
  test.use %sinh, %cosh, %tanh, %asinh, %acosh, %atanh : vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>
  func.return
}

// ====

func.def @lanewise_math_rounding(%a: vector<16xf32>) {
  %erf = vector.erff %a : vector<16xf32>
  %erfc = vector.erfcf %a : vector<16xf32>
  %ceil = vector.ceilf %a : vector<16xf32>
  %floor = vector.floorf %a : vector<16xf32>
  %round = vector.roundf %a : vector<16xf32>
  %roundeven = vector.roundevenf %a : vector<16xf32>
  %trunc = vector.truncf %a : vector<16xf32>
  test.use %erf, %erfc, %ceil, %floor, %round, %roundeven, %trunc : vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>, vector<16xf32>
  func.return
}

// ====

// Comparisons spell the same-shape i1 mask result explicitly.
func.def @cmp_select(%a: vector<16xf32>, %b: vector<16xf32>, %i: vector<16xi32>, %j: vector<16xi32>) -> (vector<16xf32>) {
  %mask = vector.cmpf olt, %a, %b : vector<16xf32> -> vector<16xi1>
  %imask = vector.cmpi slt, %i, %j : vector<16xi32> -> vector<16xi1>
  %choice = vector.select %mask, %a, %b : vector<16xf32>
  test.use %imask : vector<16xi1>
  func.return %choice : vector<16xf32>
}

// ====

// Numeric casts preserve vector shape; bitcast reinterprets total register bits.
func.def @casts(%h: vector<8xf16>, %f: vector<8xf32>, %i8: vector<8xi8>, %i32: vector<8xi32>, %scale_bytes: vector<2xi8>) {
  %w = vector.extf %h : vector<8xf16> to vector<8xf32>
  %n = vector.fptrunc %f : vector<8xf32> to vector<8xf16>
  %si = vector.extsi %i8 : vector<8xi8> to vector<8xi32>
  %ui = vector.extui %i8 : vector<8xi8> to vector<8xi32>
  %tr = vector.trunci %i32 : vector<8xi32> to vector<8xi8>
  %sf = vector.sitofp %i32 : vector<8xi32> to vector<8xf32>
  %uf = vector.uitofp %i32 : vector<8xi32> to vector<8xf32>
  %fs = vector.fptosi %f : vector<8xf32> to vector<8xi32>
  %fu = vector.fptoui %f : vector<8xf32> to vector<8xi32>
  %bits = vector.bitcast %f : vector<8xf32> to vector<8xi32>
  %scale = vector.bitcast %scale_bytes : vector<2xi8> to vector<1xf16>
  test.use %w, %n, %si, %ui, %tr, %sf, %uf, %fs, %fu, %bits, %scale : vector<8xf32>, vector<8xf16>, vector<8xi32>, vector<8xi32>, vector<8xi8>, vector<8xf32>, vector<8xf32>, vector<8xi32>, vector<8xi32>, vector<8xi32>, vector<1xf16>
  func.return
}

// ====

// Bitfield ops make packed register interpretation explicit.
func.def @bitfields(%bytes: vector<16xi8>, %zero: vector<16xi8>) {
  %lo = vector.bitfield.extractu %bytes {offset = 0, width = 4} : vector<16xi8> -> vector<16xi32>
  %hi = vector.bitfield.extracts %bytes {offset = 4, width = 4} : vector<16xi8> -> vector<16xi32>
  %packed_lo = vector.bitfield.insert %lo into %zero {offset = 0, width = 4} : vector<16xi32>, vector<16xi8>
  %packed = vector.bitfield.insert %hi into %packed_lo {offset = 4, width = 4} : vector<16xi32>, vector<16xi8>
  test.use %packed : vector<16xi8>
  func.return
}

// ====

// Bitpack ops cross lane boundaries explicitly; bitunpack signedness is spelled
// in the op name because it controls the recovered lane values.
func.def @bitpack(%codes: vector<32xi8>, %signed_deltas: vector<32xi8>, %signs: vector<128xi1>, %n: index, %m: index, %dyn_codes: vector<[%n]xi8>, %dyn_packed: vector<[%m]xi8>) {
  %q4 = vector.bitpack<4> %codes : vector<32xi8> -> vector<16xi8>
  %q4_unpacked = vector.bitunpacku<4> %q4 : vector<16xi8> -> vector<32xi8>
  %sign_stream = vector.bitpack<1> %signs : vector<128xi1> -> vector<16xi8>
  %sign_mask = vector.bitunpacku<1> %sign_stream : vector<16xi8> -> vector<128xi1>
  %q3 = vector.bitpack<3> %signed_deltas : vector<32xi8> -> vector<12xi8>
  %q3_unpacked = vector.bitunpacks<3> %q3 : vector<12xi8> -> vector<32xi8>
  %dyn_stream = vector.bitpack<4> %dyn_codes : vector<[%n]xi8> -> vector<[%m]xi8>
  %dyn_unpacked = vector.bitunpacku<4> %dyn_packed : vector<[%m]xi8> -> vector<[%n]xi8>
  test.use %q4_unpacked, %sign_mask, %q3_unpacked, %dyn_stream, %dyn_unpacked : vector<32xi8>, vector<128xi1>, vector<32xi8>, vector<[%m]xi8>, vector<[%n]xi8>
  func.return
}

// ====

// Floating dot products keep the scalar accumulator explicit and use fused
// multiply-add semantics over logical lane order.
func.def @dotf(%lhs: vector<16xf32>, %rhs: vector<16xf32>, %acc: f32, %n: index, %dyn_lhs: vector<[%n]xf32>, %dyn_rhs: vector<[%n]xf32>) {
  %r = vector.dotf %lhs, %rhs, %acc : vector<16xf32>, vector<16xf32>, f32
  %dyn = vector.dotf %dyn_lhs, %dyn_rhs, %acc : vector<[%n]xf32>, vector<[%n]xf32>, f32
  test.use %r, %dyn : f32, f32
  func.return
}

// ====

// Two-lane floating dot products widen f16/bf16 sources into f32 accumulator
// lanes and group the last source axis by pairs.
func.def @dot2f(%lhs: vector<16xf16>, %rhs: vector<16xf16>, %acc: vector<8xf32>, %lhs2: vector<2x16xbf16>, %rhs2: vector<2x16xbf16>, %acc2: vector<2x8xf32>, %n: index, %m: index, %dyn_lhs: vector<[%n]xf16>, %dyn_rhs: vector<[%n]xf16>, %dyn_acc: vector<[%m]xf32>) {
  %f16 = vector.dot2f %lhs, %rhs, %acc : vector<16xf16>, vector<16xf16>, vector<8xf32>
  %bf16 = vector.dot2f %lhs2, %rhs2, %acc2 : vector<2x16xbf16>, vector<2x16xbf16>, vector<2x8xf32>
  %dyn = vector.dot2f %dyn_lhs, %dyn_rhs, %dyn_acc : vector<[%n]xf16>, vector<[%n]xf16>, vector<[%m]xf32>
  test.use %f16, %bf16, %dyn : vector<8xf32>, vector<2x8xf32>, vector<[%m]xf32>
  func.return
}

// ====

// Four-lane integer dot products keep signedness explicit and group the last
// source axis into i32 accumulator lanes.
func.def @dot4i(%lhs: vector<16xi8>, %rhs: vector<16xi8>, %acc: vector<4xi32>, %lhs2: vector<2x16xi8>, %rhs2: vector<2x16xi8>, %acc2: vector<2x4xi32>, %n: index, %m: index, %dyn_lhs: vector<[%n]xi8>, %dyn_rhs: vector<[%n]xi8>, %dyn_acc: vector<[%m]xi32>) {
  %ss = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<16xi8>, vector<16xi8>, vector<4xi32>
  %us = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<16xi8>, vector<16xi8>, vector<4xi32>
  %su = vector.dot4i<s8u8> %lhs, %rhs, %acc : vector<16xi8>, vector<16xi8>, vector<4xi32>
  %uu = vector.dot4i<u8u8> %lhs2, %rhs2, %acc2 : vector<2x16xi8>, vector<2x16xi8>, vector<2x4xi32>
  %dyn = vector.dot4i<s8s8> %dyn_lhs, %dyn_rhs, %dyn_acc : vector<[%n]xi8>, vector<[%n]xi8>, vector<[%m]xi32>
  test.use %ss, %us, %su, %uu, %dyn : vector<4xi32>, vector<4xi32>, vector<4xi32>, vector<2x4xi32>, vector<[%m]xi32>
  func.return
}

// ====

// Eight-lane i4 dot products consume packed i32 storage lanes directly instead
// of inventing an i4 scalar type.
func.def @dot8i4(%lhs: vector<4xi32>, %rhs: vector<4xi32>, %acc: vector<4xi32>, %n: index, %dyn_lhs: vector<[%n]xi32>, %dyn_rhs: vector<[%n]xi32>, %dyn_acc: vector<[%n]xi32>) {
  %ss = vector.dot8i4<s4s4> %lhs, %rhs, %acc : vector<4xi32>
  %us = vector.dot8i4<u4s4> %lhs, %rhs, %acc : vector<4xi32>
  %su = vector.dot8i4<s4u4> %lhs, %rhs, %acc : vector<4xi32>
  %uu = vector.dot8i4<u4u4> %dyn_lhs, %dyn_rhs, %dyn_acc : vector<[%n]xi32>
  test.use %ss, %us, %su, %uu : vector<4xi32>, vector<4xi32>, vector<4xi32>, vector<[%n]xi32>
  func.return
}

// ====

// Four-lane f8 dot products consume packed i32 storage lanes and accumulate
// into matching f32 lanes.
func.def @dot4f8(%lhs: vector<4xi32>, %rhs: vector<4xi32>, %acc: vector<4xf32>, %n: index, %dyn_lhs: vector<[%n]xi32>, %dyn_rhs: vector<[%n]xi32>, %dyn_acc: vector<[%n]xf32>) {
  %fb = vector.dot4f8<fp8bf8> %lhs, %rhs, %acc : vector<4xi32>, vector<4xf32>
  %bf = vector.dot4f8<bf8fp8> %lhs, %rhs, %acc : vector<4xi32>, vector<4xf32>
  %ff = vector.dot4f8<fp8fp8> %lhs, %rhs, %acc : vector<4xi32>, vector<4xf32>
  %bb = vector.dot4f8<bf8bf8> %dyn_lhs, %dyn_rhs, %dyn_acc : vector<[%n]xi32>, vector<[%n]xf32>
  test.use %fb, %bf, %ff, %bb : vector<4xf32>, vector<4xf32>, vector<4xf32>, vector<[%n]xf32>
  func.return
}

// ====

// Block-quant register decode snippets make storage reinterpretation and lane
// ordering explicit without hidden decode pseudo-ops.
func.def @q4_0_register_decode(%scale_bytes: vector<2xi8>, %qs: vector<16xi8>) {
  %scale = vector.bitcast %scale_bytes : vector<2xi8> to vector<1xf16>
  %lo = vector.bitfield.extractu %qs {offset = 0, width = 4} : vector<16xi8> -> vector<16xi8>
  %hi = vector.bitfield.extractu %qs {offset = 4, width = 4} : vector<16xi8> -> vector<16xi8>
  %logical = vector.concat<0> %lo, %hi : vector<16xi8>, vector<16xi8> -> vector<32xi8>
  %paired = vector.interleave<0> %lo, %hi : vector<16xi8>, vector<16xi8> -> vector<32xi8>
  %paired_lo, %paired_hi = vector.deinterleave<0> %paired : vector<32xi8> -> vector<16xi8>, vector<16xi8>
  test.use %scale, %logical, %paired_lo, %paired_hi : vector<1xf16>, vector<32xi8>, vector<16xi8>, vector<16xi8>
  func.return
}

// ====

// Q6-style decode is explicit about forming 6-bit lanes from low nibbles and
// high-bit side registers before choosing a logical lane order.
func.def @q6_k_register_decode(%scale_bytes: vector<2xi8>, %low_packed: vector<16xi8>, %high_packed: vector<8xi8>) {
  %scale = vector.bitcast %scale_bytes : vector<2xi8> to vector<1xf16>
  %lo4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<16xi8> -> vector<16xi8>
  %hi4 = vector.bitfield.extractu %low_packed {offset = 4, width = 4} : vector<16xi8> -> vector<16xi8>
  %high2 = vector.bitunpacku<2> %high_packed : vector<8xi8> -> vector<32xi8>
  %lo2 = vector.slice %high2[0] : vector<32xi8> -> vector<16xi8>
  %hi2 = vector.slice %high2[16] : vector<32xi8> -> vector<16xi8>
  %lo6 = vector.bitfield.insert %lo2 into %lo4 {offset = 4, width = 2} : vector<16xi8>, vector<16xi8>
  %hi6 = vector.bitfield.insert %hi2 into %hi4 {offset = 4, width = 2} : vector<16xi8>, vector<16xi8>
  %logical = vector.interleave<0> %lo6, %hi6 : vector<16xi8>, vector<16xi8> -> vector<32xi8>
  test.use %scale, %logical : vector<1xf16>, vector<32xi8>
  func.return
}

// ====

// Online encode sketches produce packed streams explicitly instead of relying
// on quant-specific packing pseudo-ops.
func.def @block_quant_register_encode(%q4_codes: vector<32xi8>, %q6_high: vector<32xi8>, %residual_signs: vector<128xi1>) {
  %q4_stream = vector.bitpack<4> %q4_codes : vector<32xi8> -> vector<16xi8>
  %q6_high_stream = vector.bitpack<2> %q6_high : vector<32xi8> -> vector<8xi8>
  %sign_stream = vector.bitpack<1> %residual_signs : vector<128xi1> -> vector<16xi8>
  test.use %q4_stream, %q6_high_stream, %sign_stream : vector<16xi8>, vector<8xi8>, vector<16xi8>
  func.return
}

// ====

// Reductions consume a vector input and scalar accumulator/result of the same element type.
func.def @reduce(%v: vector<16xf32>, %zero: f32, %i: vector<16xi32>, %izero: i32) -> (f32, i32) {
  %sum = vector.reduce<addf> %v, %zero : vector<16xf32>, f32
  %max = vector.reduce<maxsi> %i, %izero : vector<16xi32>, i32
  func.return %sum, %max : f32, i32
}

// ====

// Register layout ops are pure vector-to-vector transforms with explicit
// compile-time axis/lane maps.
func.def @register_layout(%v: vector<8x16xf32>, %a: vector<4xf32>, %b: vector<4xf32>, %n: index, %half: index, %full: index, %dyn: vector<[%n]xf32>, %i: index, %dyn_lo: vector<[%half]xi8>, %dyn_hi: vector<[%half]xi8>, %dyn_paired: vector<[%full]xi8>) {
  %static_slice = vector.slice %v[0, 4] : vector<8x16xf32> -> vector<4x8xf32>
  %dynamic_slice = vector.slice %dyn[%i] : vector<[%n]xf32> -> vector<4xf32>
  %wide = vector.concat<0> %a, %b : vector<4xf32>, vector<4xf32> -> vector<8xf32>
  %transposed = vector.transpose<[1, 0]> %v : vector<8x16xf32> -> vector<16x8xf32>
  %reversed = vector.shuffle<[3, 2, 1, 0]> %a : vector<4xf32>
  %duplicated = vector.shuffle<[0, 0, 2, 2]> %b : vector<4xf32>
  %paired = vector.interleave<0> %dyn_lo, %dyn_hi : vector<[%half]xi8>, vector<[%half]xi8> -> vector<[%full]xi8>
  %unpaired_lo, %unpaired_hi = vector.deinterleave<0> %dyn_paired : vector<[%full]xi8> -> vector<[%half]xi8>, vector<[%half]xi8>
  test.use %static_slice, %dynamic_slice, %wide, %transposed, %reversed, %duplicated, %paired, %unpaired_lo, %unpaired_hi : vector<4x8xf32>, vector<4xf32>, vector<8xf32>, vector<16x8xf32>, vector<4xf32>, vector<4xf32>, vector<[%full]xi8>, vector<[%half]xi8>, vector<[%half]xi8>
  func.return
}

// ====

// Table lookup is a pure register lookup: rank-1 table, integer indices, and
// result shape following the indices.
func.def @table_lookup(%grid: vector<16xf16>, %codes: vector<32xi8>, %codes2d: vector<4x8xi8>) -> (vector<32xf16>, vector<4x8xf16>) {
  %values = vector.table.lookup %grid[%codes] : vector<16xf16>, vector<32xi8> -> vector<32xf16>
  %tile = vector.table.lookup %grid[%codes2d] : vector<16xf16>, vector<4x8xi8> -> vector<4x8xf16>
  func.return %values, %tile : vector<32xf16>, vector<4x8xf16>
}

// ====

// Table quantize is the encode sibling of table lookup: rank-1 ordered
// thresholds produce unsigned ordinal code lanes.
func.def @table_quantize(%values: vector<32xf32>, %thresholds: vector<15xf32>) -> (vector<32xi8>) {
  %codes = vector.table.quantize %values, %thresholds {nan = zero, tie = lower} : vector<32xf32>, vector<15xf32> -> vector<32xi8>
  func.return %codes : vector<32xi8>
}

// ====

// Encoded numeric boundaries keep compact schema facts separate from the
// per-record data used to interpret a particular payload.
func.def @schema_decode_storage_payload(%payload: vector<4xi32>, %scale: vector<1xf16>) -> (vector<32xf32>) {
  %schema = encoding.define #ggml_q4_0<block_elems=32, storage_bytes=18> : encoding<schema>
  %values = vector.decode %payload using %schema {scale = %scale : vector<1xf16>} : vector<4xi32>, encoding<schema> -> vector<32xf32>
  func.return %values : vector<32xf32>
}

// ====

// Online encoded data, such as a KV-cache record, exposes table/state operands
// normally instead of sequestering them behind the schema witness.
func.def @schema_encode_online_kv_payload(%values: vector<128xf16>, %schema: encoding<schema>, %centroids: vector<4xf16>, %thresholds: vector<3xf32>, %residual: vector<16xi8>, %amax: vector<1xf32>) -> (vector<40xi8>) {
  %payload = vector.encode %values using %schema {amax = %amax : vector<1xf32>, centroids = %centroids : vector<4xf16>, residual = %residual : vector<16xi8>, thresholds = %thresholds : vector<3xf32>} : vector<128xf16>, encoding<schema> -> vector<40xi8>
  func.return %payload : vector<40xi8>
}

// ====

// Pure schema-only payload interpretation is also legal for formats whose
// complete interpretation is static or target-provided.
func.def @schema_decode_static_payload(%payload: vector<4xi32>, %schema: encoding<schema>) -> (vector<32xf16>) {
  %values = vector.decode %payload using %schema : vector<4xi32>, encoding<schema> -> vector<32xf16>
  func.return %values : vector<32xf16>
}

// ====

// Fragment boundaries preserve packed physical vectors while attaching the
// matrix role, dynamic row/column shape, and optional encoded interpretation
// operands that target selection consumes later.
func.def @matrix_fragments(%lhs: vector<6xi32>, %rhs: vector<6xi32>, %acc: vector<8xf32>, %m: index, %n: index, %k: index, %scale: vector<1xf16>) {
  %schema = encoding.define #matrix_operand<affine=0, codebook=0, element_format=268435456, payload_elements=32, payload_packing=256, payload_registers=6, rounding=0, scale_format=0, scale_group_elements=32, scale_operands=1, scale_topology=32, secondary_scale_format=0, sparsity=0, zero_scale_fallback=true> : encoding<schema>
  %lhs_fragment = vector.fragment<lhs> %lhs shape [%m, %k] using {scale = %scale : vector<1xf16>, schema = %schema : encoding<schema>} : vector<6xi32>
  %rhs_fragment = vector.fragment<rhs> %rhs shape [%k, %n] using {scale = %scale : vector<1xf16>, schema = %schema : encoding<schema>} where [mul(%k, 32)] : vector<6xi32>
  %init_fragment = vector.fragment<init> %acc shape [%m, %n] : vector<8xf32>
  %result_fragment = vector.fragment<result> %acc shape [%m, %n] where [mul(%n, 16)] : vector<8xf32>
  test.use %lhs_fragment, %rhs_fragment, %init_fragment, %result_fragment : vector<6xi32>, vector<6xi32>, vector<8xf32>, vector<8xf32>
  func.return
}

// ====

// Numeric transforms are explicit register transforms described by SSA
// encodings. The descriptor carries its input and output last-axis extents so
// target matching does not infer transform domains from loose metadata.
func.def @numeric_transform_hadamard(%v: vector<128xf32>, %signs: vector<128xi1>) -> (vector<128xf32>) {
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, normalization="orthonormal", output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %r = vector.transform %v, %xf : vector<128xf32>, encoding<transform> -> vector<128xf32>
  func.return %r : vector<128xf32>
}

// ====

// JL-style descriptors can change only the last vector axis; leading axes stay
// tied to the source so batched sketches remain structurally obvious.
func.def @numeric_transform_jl(%v: vector<4x128xf32>, %matrix: vector<64x128xf32>) -> (vector<4x64xf32>) {
  %jl = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %matrix : vector<64x128xf32>} : encoding<transform>
  %sketch = vector.transform %v, %jl : vector<4x128xf32>, encoding<transform> -> vector<4x64xf32>
  func.return %sketch : vector<4x64xf32>
}

// ====

// Dynamic transform extents use the same SSA values as the source/result type
// dimensions, preserving the use-def link instead of relying on an attribute
// side channel.
func.def @numeric_transform_dynamic(%n: index, %v: vector<[%n]xf32>) -> (vector<[%n]xf32>) {
  %xf = encoding.define #numeric_transform<family="hadamard", normalization="none"> {input_elems = %n : index, output_elems = %n : index} : encoding<transform>
  %r = vector.transform %v, %xf : vector<[%n]xf32>, encoding<transform> -> vector<[%n]xf32>
  func.return %r : vector<[%n]xf32>
}

// ====

// Vector memory ops use typed views and full-rank logical origins.
func.def @memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load %view[%row, %col] {cache_scope = device, cache_temporal = high_temporal} : view<[%m]x[%n]xf32, %layout> -> vector<4x8xf32>
  vector.store %loaded, %view[%row, %col] {cache_scope = system, cache_temporal = writeback} : vector<4x8xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}

// ====

// Strided layouts remain explicit on the view used by the memory op.
func.def @strided_memory(%buffer: buffer, %offset: offset, %row_stride: index, %row: index, %col: index, %m: index, %n: index) {
  %layout = encoding.layout.strided [%row_stride, 1] : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load %view[%row, %col] : view<[%m]x[%n]xf32, %layout> -> vector<4x8xf32>
  test.use %loaded : vector<4x8xf32>
  func.return
}

// ====

// Masked loads spell the passthrough value explicitly; masked stores leave
// masked-off memory lanes unchanged.
func.def @masked_tail_memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index, %old: vector<4x8xf32>, %mask: vector<4x8xi1>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load.mask %view[%row, %col], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4x8xi1>, vector<4x8xf32>
  vector.store.mask %loaded, %view[%row, %col], %mask : vector<4x8xf32>, view<[%m]x[%n]xf32, %layout>, vector<4x8xi1>
  func.return
}

// ====

// Expand/compress memory ops use a rank-1 mask to map active lanes to a
// consecutive memory run. Inactive expand-load lanes take passthrough;
// inactive compress-store lanes do not write or advance the memory cursor.
func.def @expanded_compressed_memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index, %old: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load.expand %view[%row, %col], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4xi1>, vector<4xf32>
  vector.store.compress %loaded, %view[%row, %col], %mask : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi1>
  func.return
}

// ====

// Gathers and scatters use a full-rank logical origin plus one per-lane
// element-offset vector. Non-atomic scatters require active lane addresses to
// be distinct.
func.def @gather_scatter(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index, %offsets: vector<4xindex>, %i32_offsets: vector<4xi32>, %old: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %gathered = vector.gather %view[%row, %col][%offsets] {cache_scope = device, cache_temporal = non_temporal} : view<[%m]x[%n]xf32, %layout>, vector<4xindex> -> vector<4xf32>
  vector.scatter %gathered, %view[%row, %col][%offsets] : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xindex>
  %masked = vector.gather.mask %view[%row, %col][%i32_offsets], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>, vector<4xf32>
  vector.scatter.mask %masked, %view[%row, %col][%i32_offsets], %mask : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>
  func.return
}

// ====

// Vector atomics use the gather/scatter address form with required explicit
// ordering and scope attributes.
func.def @atomic_memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index, %offsets: vector<4xindex>, %i32_offsets: vector<4xi32>, %iv: vector<4xi32>, %fv: vector<4xf32>, %oldf: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = encoding.layout.dense : encoding<layout>
  %iview = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xi32, %layout>
  %fview = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  vector.atomic.reduce<addi> %iv, %iview[%row, %col][%offsets] {cache_scope = device, cache_temporal = non_temporal, ordering = relaxed, scope = workgroup} : vector<4xi32>, view<[%m]x[%n]xi32, %layout>, vector<4xindex>
  vector.atomic.reduce.mask<addf> %fv, %fview[%row, %col][%i32_offsets], %mask {ordering = relaxed, scope = device} : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>
  %oldi = vector.atomic.rmw<xchgi> %iv, %iview[%row, %col][%offsets] {ordering = acq_rel, scope = system} : vector<4xi32>, view<[%m]x[%n]xi32, %layout>, vector<4xindex>
  %masked = vector.atomic.rmw.mask<addf> %fv, %fview[%row, %col][%i32_offsets], %mask, %oldf {ordering = seq_cst, scope = device} : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>, vector<4xf32>
  %cmp = vector.atomic.cmpxchg %iv, %iv, %iview[%row, %col][%offsets] {failure_ordering = acquire, scope = workgroup, success_ordering = acq_rel} : vector<4xi32>, view<[%m]x[%n]xi32, %layout>, vector<4xindex> -> vector<4xi32>
  test.use %oldi, %masked, %cmp : vector<4xi32>, vector<4xf32>, vector<4xi32>
  func.return
}
