// RUN: roundtrip

// ====

// Construction ops keep scalar/vector interop explicit.
func.def @construction(%x: f32, %i: i32, %n: index) {
  %vf = vector.splat %x : f32 -> vector<16xf32>
  %vi = vector.splat %i : i32 -> vector<[%n]xi32>
  %c = vector.constant 0.0 : vector<4xf32>
  %wide = vector.broadcast %c : vector<4xf32> -> vector<4x4xf32>
  %lane0 = vector.extract %c[0] : vector<4xf32> -> f32
  %updated = vector.insert %lane0 into %c[%n] : f32, vector<4xf32> -> vector<4xf32>
  %from = vector.from_elements %x, %x, %x, %x : f32, f32, f32, f32 -> vector<4xf32>
  test.use %vf, %vi, %wide, %updated, %from : vector<16xf32>, vector<[%n]xi32>, vector<4x4xf32>, vector<4xf32>, vector<4xf32>
  func.return
}

// ====

// Lanewise arithmetic follows scalar spelling and keeps vector/vector operands.
func.def @lanewise(%a: vector<16xf32>, %b: vector<16xf32>, %c: vector<16xf32>, %i: vector<16xi32>, %j: vector<16xi32>) {
  %sum = vector.addf %a, %b : vector<16xf32>
  %prod = vector.mulf<nnan> %sum, %c : vector<16xf32>
  %fma = vector.fmaf %a, %b, %prod : vector<16xf32>
  %isum = vector.addi<nuw> %i, %j : vector<16xi32>
  %iprod = vector.muli %isum, %j : vector<16xi32>
  %root = vector.sqrtf %prod : vector<16xf32>
  test.use %fma, %iprod, %root : vector<16xf32>, vector<16xi32>, vector<16xf32>
  func.return
}

// ====

// Comparisons spell the same-shape i1 mask result explicitly.
func.def @cmp_select(%a: vector<16xf32>, %b: vector<16xf32>, %i: vector<16xi32>, %j: vector<16xi32>) -> (vector<16xf32>) {
  %mask = vector.cmpf olt, %a, %b : vector<16xf32> -> vector<16xi1>
  %imask = vector.cmpi slt, %i, %j : vector<16xi32> -> vector<16xi1>
  %choice = vector.select %mask, %a, %b : vector<16xf32>
  test.use %imask : vector<16xi1>
  func.return %choice : vector<16xf32>
}

// ====

// Casts preserve vector shape and make source/result element types explicit.
func.def @casts(%h: vector<8xf16>, %f: vector<8xf32>, %i8: vector<8xi8>, %i32: vector<8xi32>) {
  %w = vector.extf %h : vector<8xf16> to vector<8xf32>
  %n = vector.fptrunc %f : vector<8xf32> to vector<8xf16>
  %si = vector.extsi %i8 : vector<8xi8> to vector<8xi32>
  %ui = vector.extui %i8 : vector<8xi8> to vector<8xi32>
  %tr = vector.trunci %i32 : vector<8xi32> to vector<8xi8>
  %sf = vector.sitofp %i32 : vector<8xi32> to vector<8xf32>
  %uf = vector.uitofp %i32 : vector<8xi32> to vector<8xf32>
  %fs = vector.fptosi %f : vector<8xf32> to vector<8xi32>
  %fu = vector.fptoui %f : vector<8xf32> to vector<8xi32>
  %bits = vector.bitcast %f : vector<8xf32> to vector<8xi32>
  test.use %w, %n, %si, %ui, %tr, %sf, %uf, %fs, %fu, %bits : vector<8xf32>, vector<8xf16>, vector<8xi32>, vector<8xi32>, vector<8xi8>, vector<8xf32>, vector<8xf32>, vector<8xi32>, vector<8xi32>, vector<8xi32>
  func.return
}

// ====

// Bitfield ops make packed register interpretation explicit.
func.def @bitfields(%bytes: vector<16xi8>, %zero: vector<16xi8>) {
  %lo = vector.bitfield.extractu %bytes {offset = 0, width = 4} : vector<16xi8> -> vector<16xi32>
  %hi = vector.bitfield.extracts %bytes {offset = 4, width = 4} : vector<16xi8> -> vector<16xi32>
  %packed_lo = vector.bitfield.insert %lo into %zero {offset = 0, width = 4} : vector<16xi32>, vector<16xi8> -> vector<16xi8>
  %packed = vector.bitfield.insert %hi into %packed_lo {offset = 4, width = 4} : vector<16xi32>, vector<16xi8> -> vector<16xi8>
  test.use %packed : vector<16xi8>
  func.return
}

// ====

// Reductions consume a vector input and scalar accumulator/result of the same element type.
func.def @reduce(%v: vector<16xf32>, %zero: f32, %i: vector<16xi32>, %izero: i32) -> (f32, i32) {
  %sum = vector.reduce<addf> %v, %zero : vector<16xf32> -> f32
  %max = vector.reduce<maxsi> %i, %izero : vector<16xi32> -> i32
  func.return %sum, %max : f32, i32
}

// ====

// Register layout ops are pure vector-to-vector transforms with explicit
// compile-time axis/lane maps.
func.def @register_layout(%v: vector<8x16xf32>, %a: vector<4xf32>, %b: vector<4xf32>, %n: index, %dyn: vector<[%n]xf32>, %i: index) {
  %static_slice = vector.slice %v[0, 4] : vector<8x16xf32> -> vector<4x8xf32>
  %dynamic_slice = vector.slice %dyn[%i] : vector<[%n]xf32> -> vector<4xf32>
  %wide = vector.concat<0> %a, %b : vector<4xf32>, vector<4xf32> -> vector<8xf32>
  %transposed = vector.transpose<[1, 0]> %v : vector<8x16xf32> -> vector<16x8xf32>
  %reversed = vector.shuffle<[3, 2, 1, 0]> %a : vector<4xf32>
  %duplicated = vector.shuffle<[0, 0, 2, 2]> %b : vector<4xf32>
  test.use %static_slice, %dynamic_slice, %wide, %transposed, %reversed, %duplicated : vector<4x8xf32>, vector<4xf32>, vector<8xf32>, vector<16x8xf32>, vector<4xf32>, vector<4xf32>
  func.return
}

// ====

// Table lookup is a pure register lookup: rank-1 table, integer indices, and
// result shape following the indices.
func.def @table_lookup(%grid: vector<16xf16>, %codes: vector<32xi8>, %codes2d: vector<4x8xi8>) -> (vector<32xf16>, vector<4x8xf16>) {
  %values = vector.table.lookup %grid[%codes] : vector<16xf16>, vector<32xi8> -> vector<32xf16>
  %tile = vector.table.lookup %grid[%codes2d] : vector<16xf16>, vector<4x8xi8> -> vector<4x8xf16>
  func.return %values, %tile : vector<32xf16>, vector<4x8xf16>
}

// ====

// Vector memory ops use typed views and full-rank logical origins.
func.def @memory(%buffer: buffer, %offset: index, %row: index, %col: index, %m: index, %n: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load %view[%row, %col] : view<[%m]x[%n]xf32, %layout> -> vector<4x8xf32>
  vector.store %loaded, %view[%row, %col] : vector<4x8xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}

// ====

// Strided layouts remain explicit on the view used by the memory op.
func.def @strided_memory(%buffer: buffer, %offset: index, %row_stride: index, %row: index, %col: index, %m: index, %n: index) {
  %layout = view.layout.strided [%row_stride, 1] : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load %view[%row, %col] : view<[%m]x[%n]xf32, %layout> -> vector<4x8xf32>
  test.use %loaded : vector<4x8xf32>
  func.return
}

// ====

// Masked loads spell the passthrough value explicitly; masked stores leave
// masked-off memory lanes unchanged.
func.def @masked_tail_memory(%buffer: buffer, %offset: index, %row: index, %col: index, %m: index, %n: index, %old: vector<4x8xf32>, %mask: vector<4x8xi1>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load.mask %view[%row, %col], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4x8xi1>, vector<4x8xf32> -> vector<4x8xf32>
  vector.store.mask %loaded, %view[%row, %col], %mask : vector<4x8xf32>, view<[%m]x[%n]xf32, %layout>, vector<4x8xi1>
  func.return
}

// ====

// Expand/compress memory ops use a rank-1 mask to map active lanes to a
// consecutive memory run. Inactive expand-load lanes take passthrough;
// inactive compress-store lanes do not write or advance the memory cursor.
func.def @expanded_compressed_memory(%buffer: buffer, %offset: index, %row: index, %col: index, %m: index, %n: index, %old: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.load.expand %view[%row, %col], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4xi1>, vector<4xf32> -> vector<4xf32>
  vector.store.compress %loaded, %view[%row, %col], %mask : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi1>
  func.return
}

// ====

// Gathers and scatters use a full-rank logical origin plus one per-lane
// element-offset vector. Non-atomic scatters require active lane addresses to
// be distinct.
func.def @gather_scatter(%buffer: buffer, %offset: index, %row: index, %col: index, %m: index, %n: index, %offsets: vector<4xindex>, %i32_offsets: vector<4xi32>, %old: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %gathered = vector.gather %view[%row, %col][%offsets] : view<[%m]x[%n]xf32, %layout>, vector<4xindex> -> vector<4xf32>
  vector.scatter %gathered, %view[%row, %col][%offsets] : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xindex>
  %masked = vector.gather.mask %view[%row, %col][%i32_offsets], %mask, %old : view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>, vector<4xf32> -> vector<4xf32>
  vector.scatter.mask %masked, %view[%row, %col][%i32_offsets], %mask : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>
  func.return
}

// ====

// Vector atomics use the gather/scatter address form with required explicit
// ordering and scope attributes.
func.def @atomic_memory(%buffer: buffer, %offset: index, %row: index, %col: index, %m: index, %n: index, %offsets: vector<4xindex>, %i32_offsets: vector<4xi32>, %iv: vector<4xi32>, %fv: vector<4xf32>, %oldf: vector<4xf32>, %mask: vector<4xi1>) {
  %layout = view.layout.dense : encoding
  %iview = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xi32, %layout>
  %fview = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  vector.atomic.reduce<addi> %iv, %iview[%row, %col][%offsets] {ordering = relaxed, scope = workgroup} : vector<4xi32>, view<[%m]x[%n]xi32, %layout>, vector<4xindex>
  vector.atomic.reduce.mask<addf> %fv, %fview[%row, %col][%i32_offsets], %mask {ordering = relaxed, scope = device} : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>
  %oldi = vector.atomic.rmw<xchgi> %iv, %iview[%row, %col][%offsets] {ordering = acq_rel, scope = system} : vector<4xi32>, view<[%m]x[%n]xi32, %layout>, vector<4xindex> -> vector<4xi32>
  %masked = vector.atomic.rmw.mask<addf> %fv, %fview[%row, %col][%i32_offsets], %mask, %oldf {ordering = seq_cst, scope = device} : vector<4xf32>, view<[%m]x[%n]xf32, %layout>, vector<4xi32>, vector<4xi1>, vector<4xf32> -> vector<4xf32>
  test.use %oldi, %masked : vector<4xi32>, vector<4xf32>
  func.return
}
