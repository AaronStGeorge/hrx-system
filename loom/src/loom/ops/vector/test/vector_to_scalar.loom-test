// RUN: pass vector-to-scalar

// Static lanewise ops become scalar lane programs and an explicit aggregate
// pack at the vector ABI boundary.
func.def @static_add_select_cast(%a: vector<4xi32>, %b: vector<4xi32>, %mask: vector<4xi1>) -> (vector<4xf32>) {
  %sum = vector.addi %a, %b : vector<4xi32>
  %chosen = vector.select %mask, %sum, %a : vector<4xi32>
  %r = vector.sitofp %chosen : vector<4xi32> to vector<4xf32>
  func.return %r : vector<4xf32>
}

// ----
func.def @static_add_select_cast(%a: vector<4xi32>, %b: vector<4xi32>, %mask: vector<4xi1>) -> (vector<4xf32>) {
  %7 = vector.extract %mask[0] : vector<4xi1> -> i1
  %8 = vector.extract %a[0] : vector<4xi32> -> i32
  %9 = vector.extract %b[0] : vector<4xi32> -> i32
  %10 = scalar.addi %8, %9 : i32
  %11 = vector.extract %a[0] : vector<4xi32> -> i32
  %12 = scf.select %7, %10, %11 : i32
  %13 = scalar.sitofp %12 : i32 to f32
  %14 = vector.extract %mask[1] : vector<4xi1> -> i1
  %15 = vector.extract %a[1] : vector<4xi32> -> i32
  %16 = vector.extract %b[1] : vector<4xi32> -> i32
  %17 = scalar.addi %15, %16 : i32
  %18 = vector.extract %a[1] : vector<4xi32> -> i32
  %19 = scf.select %14, %17, %18 : i32
  %20 = scalar.sitofp %19 : i32 to f32
  %21 = vector.extract %mask[2] : vector<4xi1> -> i1
  %22 = vector.extract %a[2] : vector<4xi32> -> i32
  %23 = vector.extract %b[2] : vector<4xi32> -> i32
  %24 = scalar.addi %22, %23 : i32
  %25 = vector.extract %a[2] : vector<4xi32> -> i32
  %26 = scf.select %21, %24, %25 : i32
  %27 = scalar.sitofp %26 : i32 to f32
  %28 = vector.extract %mask[3] : vector<4xi1> -> i1
  %29 = vector.extract %a[3] : vector<4xi32> -> i32
  %30 = vector.extract %b[3] : vector<4xi32> -> i32
  %31 = scalar.addi %29, %30 : i32
  %32 = vector.extract %a[3] : vector<4xi32> -> i32
  %33 = scf.select %28, %31, %32 : i32
  %34 = scalar.sitofp %33 : i32 to f32
  %r = vector.from_elements %13, %20, %27, %34 : vector<4xf32>
  func.return %r : vector<4xf32>
}

// ====

// Dynamic lanewise ops lower to an scf.for loop carrying the vector aggregate
// because the number of scalar lanes is not statically known.
func.def @dynamic_add(%n: index, %a: vector<[%n]xi32>, %b: vector<[%n]xi32>) -> (vector<[%n]xi32>) {
  %r = vector.addi %a, %b : vector<[%n]xi32>
  func.return %r : vector<[%n]xi32>
}

// ----
func.def @dynamic_add(%n: index, %a: vector<[%n]xi32>, %b: vector<[%n]xi32>) -> (vector<[%n]xi32>) {
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %a : vector<[%n]xi32>) -> (vector<[%n]xi32>) {
    %10 = vector.extract %a[%7] : vector<[%n]xi32> -> i32
    %11 = vector.extract %b[%7] : vector<[%n]xi32> -> i32
    %12 = scalar.addi %10, %11 : i32
    %13 = vector.insert %12 into %8[%7] : i32, vector<[%n]xi32>
    scf.yield %13 : vector<[%n]xi32>
  }
  func.return %r : vector<[%n]xi32>
}

// ====

// Multi-axis dynamic vectors become nested scf.for loops over the logical
// row-major shape.
func.def @dynamic_2d_add(%m: index, %n: index, %a: vector<[%m]x[%n]xi32>, %b: vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
  %r = vector.addi %a, %b : vector<[%m]x[%n]xi32>
  func.return %r : vector<[%m]x[%n]xi32>
}

// ----
func.def @dynamic_2d_add(%m: index, %n: index, %a: vector<[%m]x[%n]xi32>, %b: vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %m step %7](%9 = %a : vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %n step %12](%14 = %9 : vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
      %16 = vector.extract %a[%8, %13] : vector<[%m]x[%n]xi32> -> i32
      %17 = vector.extract %b[%8, %13] : vector<[%m]x[%n]xi32> -> i32
      %18 = scalar.addi %16, %17 : i32
      %19 = vector.insert %18 into %14[%8, %13] : i32, vector<[%m]x[%n]xi32>
      scf.yield %19 : vector<[%m]x[%n]xi32>
    }
    scf.yield %15 : vector<[%m]x[%n]xi32>
  }
  func.return %r : vector<[%m]x[%n]xi32>
}

// ====

// Dynamic splats use loops too; no dynamic number of scalar SSA values is
// required.
func.def @dynamic_2d_splat(%m: index, %n: index, %x: f32) -> (vector<[%m]x[%n]xf32>) {
  %r = vector.splat %x : vector<[%m]x[%n]xf32>
  func.return %r : vector<[%m]x[%n]xf32>
}

// ----
func.def @dynamic_2d_splat(%m: index, %n: index, %x: f32) -> (vector<[%m]x[%n]xf32>) {
  %5 = vector.constant 0.0 : vector<[%m]x[%n]xf32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %m step %7](%9 = %5 : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %n step %12](%14 = %9 : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
      %16 = vector.insert %x into %14[%8, %13] : f32, vector<[%m]x[%n]xf32>
      scf.yield %16 : vector<[%m]x[%n]xf32>
    }
    scf.yield %15 : vector<[%m]x[%n]xf32>
  }
  func.return %r : vector<[%m]x[%n]xf32>
}

// ====

// New float/math lanewise ops use the same generic lane-program path as the
// original seed ops.
func.def @static_float_math(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %diff = vector.subf %a, %b : vector<2xf32>
  %exp = vector.expf %diff : vector<2xf32>
  %r = vector.maxnumf %exp, %a : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ----
func.def @static_float_math(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %6 = vector.extract %a[0] : vector<2xf32> -> f32
  %7 = vector.extract %b[0] : vector<2xf32> -> f32
  %8 = scalar.subf %6, %7 : f32
  %9 = scalar.expf %8 : f32
  %10 = vector.extract %a[0] : vector<2xf32> -> f32
  %11 = scalar.maxnumf %9, %10 : f32
  %12 = vector.extract %a[1] : vector<2xf32> -> f32
  %13 = vector.extract %b[1] : vector<2xf32> -> f32
  %14 = scalar.subf %12, %13 : f32
  %15 = scalar.expf %14 : f32
  %16 = vector.extract %a[1] : vector<2xf32> -> f32
  %17 = scalar.maxnumf %15, %16 : f32
  %r = vector.from_elements %11, %17 : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ====

// Dynamic float/math ops lower to scalar work inside the aggregate loop.
func.def @dynamic_float_math(%n: index, %a: vector<[%n]xf32>, %b: vector<[%n]xf32>) -> (vector<[%n]xf32>) {
  %quotient = vector.divf %a, %b : vector<[%n]xf32>
  %r = vector.sqrtf %quotient : vector<[%n]xf32>
  func.return %r : vector<[%n]xf32>
}

// ----
func.def @dynamic_float_math(%n: index, %a: vector<[%n]xf32>, %b: vector<[%n]xf32>) -> (vector<[%n]xf32>) {
  %6 = vector.constant 0.0 : vector<[%n]xf32>
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %n step %8](%10 = %6 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %12 = vector.extract %a[%9] : vector<[%n]xf32> -> f32
    %13 = vector.extract %b[%9] : vector<[%n]xf32> -> f32
    %14 = scalar.divf %12, %13 : f32
    %15 = scalar.sqrtf %14 : f32
    %16 = vector.insert %15 into %10[%9] : f32, vector<[%n]xf32>
    scf.yield %16 : vector<[%n]xf32>
  }
  func.return %r : vector<[%n]xf32>
}

// ====

// Vector value-domain assumptions project onto the matching scalar fast-math
// bits when the lanewise op is scalarized.
func.def @static_float_assumptions_wave2(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %r = vector.mulf<nnan|ninf|nsz> %a, %b : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ----
func.def @static_float_assumptions_wave2(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %4 = vector.extract %a[0] : vector<2xf32> -> f32
  %5 = vector.extract %b[0] : vector<2xf32> -> f32
  %6 = scalar.mulf<nnan|ninf|nsz> %4, %5 : f32
  %7 = vector.extract %a[1] : vector<2xf32> -> f32
  %8 = vector.extract %b[1] : vector<2xf32> -> f32
  %9 = scalar.mulf<nnan|ninf|nsz> %7, %8 : f32
  %r = vector.from_elements %6, %9 : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ====

// Integer subtraction keeps overflow flags on the scalarized operation.
func.def @static_integer_sub_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>) {
  %r = vector.subi<nuw> %a, %b : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ----
func.def @static_integer_sub_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>) {
  %4 = vector.extract %a[0] : vector<2xi32> -> i32
  %5 = vector.extract %b[0] : vector<2xi32> -> i32
  %6 = scalar.subi<nuw> %4, %5 : i32
  %7 = vector.extract %a[1] : vector<2xi32> -> i32
  %8 = vector.extract %b[1] : vector<2xi32> -> i32
  %9 = scalar.subi<nuw> %7, %8 : i32
  %r = vector.from_elements %6, %9 : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ====

// Integer division spelling carries signedness and rounding mode explicitly.
func.def @static_integer_division_wave2(%a: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %divs = vector.divsi %a, %c : vector<2xi32>
  %divu = vector.divui %a, %c : vector<2xi32>
  %ceilsi = vector.ceildivsi %a, %c : vector<2xi32>
  %ceilui = vector.ceildivui %a, %c : vector<2xi32>
  %floorsi = vector.floordivsi %a, %c : vector<2xi32>
  func.return %divs, %divu, %ceilsi, %ceilui, %floorsi : vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_integer_division_wave2(%a: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %40 = vector.extract %a[0] : vector<2xi32> -> i32
  %41 = vector.extract %c[0] : vector<2xi32> -> i32
  %42 = scalar.divsi %40, %41 : i32
  %43 = vector.extract %a[1] : vector<2xi32> -> i32
  %44 = vector.extract %c[1] : vector<2xi32> -> i32
  %45 = scalar.divsi %43, %44 : i32
  %divs = vector.from_elements %42, %45 : vector<2xi32>
  %33 = vector.extract %a[0] : vector<2xi32> -> i32
  %34 = vector.extract %c[0] : vector<2xi32> -> i32
  %35 = scalar.divui %33, %34 : i32
  %36 = vector.extract %a[1] : vector<2xi32> -> i32
  %37 = vector.extract %c[1] : vector<2xi32> -> i32
  %38 = scalar.divui %36, %37 : i32
  %divu = vector.from_elements %35, %38 : vector<2xi32>
  %26 = vector.extract %a[0] : vector<2xi32> -> i32
  %27 = vector.extract %c[0] : vector<2xi32> -> i32
  %28 = scalar.ceildivsi %26, %27 : i32
  %29 = vector.extract %a[1] : vector<2xi32> -> i32
  %30 = vector.extract %c[1] : vector<2xi32> -> i32
  %31 = scalar.ceildivsi %29, %30 : i32
  %ceilsi = vector.from_elements %28, %31 : vector<2xi32>
  %19 = vector.extract %a[0] : vector<2xi32> -> i32
  %20 = vector.extract %c[0] : vector<2xi32> -> i32
  %21 = scalar.ceildivui %19, %20 : i32
  %22 = vector.extract %a[1] : vector<2xi32> -> i32
  %23 = vector.extract %c[1] : vector<2xi32> -> i32
  %24 = scalar.ceildivui %22, %23 : i32
  %ceilui = vector.from_elements %21, %24 : vector<2xi32>
  %12 = vector.extract %a[0] : vector<2xi32> -> i32
  %13 = vector.extract %c[0] : vector<2xi32> -> i32
  %14 = scalar.floordivsi %12, %13 : i32
  %15 = vector.extract %a[1] : vector<2xi32> -> i32
  %16 = vector.extract %c[1] : vector<2xi32> -> i32
  %17 = scalar.floordivsi %15, %16 : i32
  %floorsi = vector.from_elements %14, %17 : vector<2xi32>
  func.return %divs, %divu, %ceilsi, %ceilui, %floorsi : vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ====

// Integer remainders lower directly to the matching scalar signedness.
func.def @static_integer_remainder_wave2(%a: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %rems = vector.remsi %a, %c : vector<2xi32>
  %remu = vector.remui %a, %c : vector<2xi32>
  func.return %rems, %remu : vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_integer_remainder_wave2(%a: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %13 = vector.extract %a[0] : vector<2xi32> -> i32
  %14 = vector.extract %c[0] : vector<2xi32> -> i32
  %15 = scalar.remsi %13, %14 : i32
  %16 = vector.extract %a[1] : vector<2xi32> -> i32
  %17 = vector.extract %c[1] : vector<2xi32> -> i32
  %18 = scalar.remsi %16, %17 : i32
  %rems = vector.from_elements %15, %18 : vector<2xi32>
  %6 = vector.extract %a[0] : vector<2xi32> -> i32
  %7 = vector.extract %c[0] : vector<2xi32> -> i32
  %8 = scalar.remui %6, %7 : i32
  %9 = vector.extract %a[1] : vector<2xi32> -> i32
  %10 = vector.extract %c[1] : vector<2xi32> -> i32
  %11 = scalar.remui %9, %10 : i32
  %remu = vector.from_elements %8, %11 : vector<2xi32>
  func.return %rems, %remu : vector<2xi32>, vector<2xi32>
}

// ====

// Integer unary ops materialize one scalar lane per vector lane.
func.def @static_integer_unary_wave2(%a: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %neg = vector.negi %a : vector<2xi32>
  %abs = vector.absi %neg : vector<2xi32>
  func.return %neg, %abs : vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_integer_unary_wave2(%a: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %12 = vector.extract %a[0] : vector<2xi32> -> i32
  %13 = scalar.negi %12 : i32
  %14 = vector.extract %a[1] : vector<2xi32> -> i32
  %15 = scalar.negi %14 : i32
  %neg = vector.from_elements %13, %15 : vector<2xi32>
  %5 = vector.extract %a[0] : vector<2xi32> -> i32
  %6 = scalar.negi %5 : i32
  %7 = scalar.absi %6 : i32
  %8 = vector.extract %a[1] : vector<2xi32> -> i32
  %9 = scalar.negi %8 : i32
  %10 = scalar.absi %9 : i32
  %abs = vector.from_elements %7, %10 : vector<2xi32>
  func.return %neg, %abs : vector<2xi32>, vector<2xi32>
}

// ====

// Integer min/max ops keep signed and unsigned ordering distinct.
func.def @static_integer_minmax_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %minsi = vector.minsi %a, %b : vector<2xi32>
  %maxsi = vector.maxsi %a, %b : vector<2xi32>
  %minui = vector.minui %a, %b : vector<2xi32>
  %maxui = vector.maxui %a, %b : vector<2xi32>
  func.return %minsi, %maxsi, %minui, %maxui : vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_integer_minmax_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %31 = vector.extract %a[0] : vector<2xi32> -> i32
  %32 = vector.extract %b[0] : vector<2xi32> -> i32
  %33 = scalar.minsi %31, %32 : i32
  %34 = vector.extract %a[1] : vector<2xi32> -> i32
  %35 = vector.extract %b[1] : vector<2xi32> -> i32
  %36 = scalar.minsi %34, %35 : i32
  %minsi = vector.from_elements %33, %36 : vector<2xi32>
  %24 = vector.extract %a[0] : vector<2xi32> -> i32
  %25 = vector.extract %b[0] : vector<2xi32> -> i32
  %26 = scalar.maxsi %24, %25 : i32
  %27 = vector.extract %a[1] : vector<2xi32> -> i32
  %28 = vector.extract %b[1] : vector<2xi32> -> i32
  %29 = scalar.maxsi %27, %28 : i32
  %maxsi = vector.from_elements %26, %29 : vector<2xi32>
  %17 = vector.extract %a[0] : vector<2xi32> -> i32
  %18 = vector.extract %b[0] : vector<2xi32> -> i32
  %19 = scalar.minui %17, %18 : i32
  %20 = vector.extract %a[1] : vector<2xi32> -> i32
  %21 = vector.extract %b[1] : vector<2xi32> -> i32
  %22 = scalar.minui %20, %21 : i32
  %minui = vector.from_elements %19, %22 : vector<2xi32>
  %10 = vector.extract %a[0] : vector<2xi32> -> i32
  %11 = vector.extract %b[0] : vector<2xi32> -> i32
  %12 = scalar.maxui %10, %11 : i32
  %13 = vector.extract %a[1] : vector<2xi32> -> i32
  %14 = vector.extract %b[1] : vector<2xi32> -> i32
  %15 = scalar.maxui %13, %14 : i32
  %maxui = vector.from_elements %12, %15 : vector<2xi32>
  func.return %minsi, %maxsi, %minui, %maxui : vector<2xi32>, vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ====

// Integer fma preserves overflow flags on the scalarized operation.
func.def @static_integer_fma_wave2(%a: vector<2xi32>, %b: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>) {
  %fma = vector.fmai<nsw> %a, %b, %c : vector<2xi32>
  func.return %fma : vector<2xi32>
}

// ----
func.def @static_integer_fma_wave2(%a: vector<2xi32>, %b: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>) {
  %5 = vector.extract %a[0] : vector<2xi32> -> i32
  %6 = vector.extract %b[0] : vector<2xi32> -> i32
  %7 = vector.extract %c[0] : vector<2xi32> -> i32
  %8 = scalar.fmai<nsw> %5, %6, %7 : i32
  %9 = vector.extract %a[1] : vector<2xi32> -> i32
  %10 = vector.extract %b[1] : vector<2xi32> -> i32
  %11 = vector.extract %c[1] : vector<2xi32> -> i32
  %12 = scalar.fmai<nsw> %9, %10, %11 : i32
  %fma = vector.from_elements %8, %12 : vector<2xi32>
  func.return %fma : vector<2xi32>
}

// ====

// Integer shifts preserve overflow flags independently from fma.
func.def @static_integer_shift_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %shl = vector.shli<nuw> %a, %b : vector<2xi32>
  %shru = vector.shrui %a, %b : vector<2xi32>
  func.return %shl, %shru : vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_integer_shift_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>) {
  %13 = vector.extract %a[0] : vector<2xi32> -> i32
  %14 = vector.extract %b[0] : vector<2xi32> -> i32
  %15 = scalar.shli<nuw> %13, %14 : i32
  %16 = vector.extract %a[1] : vector<2xi32> -> i32
  %17 = vector.extract %b[1] : vector<2xi32> -> i32
  %18 = scalar.shli<nuw> %16, %17 : i32
  %shl = vector.from_elements %15, %18 : vector<2xi32>
  %6 = vector.extract %a[0] : vector<2xi32> -> i32
  %7 = vector.extract %b[0] : vector<2xi32> -> i32
  %8 = scalar.shrui %6, %7 : i32
  %9 = vector.extract %a[1] : vector<2xi32> -> i32
  %10 = vector.extract %b[1] : vector<2xi32> -> i32
  %11 = scalar.shrui %9, %10 : i32
  %shru = vector.from_elements %8, %11 : vector<2xi32>
  func.return %shl, %shru : vector<2xi32>, vector<2xi32>
}

// ====

// Rotate, population-count, and sign ops are still represented as a short
// producer chain so the pass keeps exercising recursive lane materialization.
func.def @static_integer_rotate_count_sign_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>) {
  %rotr = vector.rotri %a, %b : vector<2xi32>
  %ctz = vector.cttzi %rotr : vector<2xi32>
  %pop = vector.ctpopi %ctz : vector<2xi32>
  %r = vector.signi %pop : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ----
func.def @static_integer_rotate_count_sign_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>) {
  %7 = vector.extract %a[0] : vector<2xi32> -> i32
  %8 = vector.extract %b[0] : vector<2xi32> -> i32
  %9 = scalar.rotri %7, %8 : i32
  %10 = scalar.cttzi %9 : i32
  %11 = scalar.ctpopi %10 : i32
  %12 = scalar.signi %11 : i32
  %13 = vector.extract %a[1] : vector<2xi32> -> i32
  %14 = vector.extract %b[1] : vector<2xi32> -> i32
  %15 = scalar.rotri %13, %14 : i32
  %16 = scalar.cttzi %15 : i32
  %17 = scalar.ctpopi %16 : i32
  %18 = scalar.signi %17 : i32
  %r = vector.from_elements %12, %18 : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ====

// Direct bit/rotate/count coverage keeps the descriptor test readable.
func.def @static_bit_count_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %shrs = vector.shrsi %a, %b : vector<2xi32>
  %rotl = vector.rotli %a, %b : vector<2xi32>
  %clz = vector.ctlzi %a : vector<2xi32>
  func.return %shrs, %rotl, %clz : vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_bit_count_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %20 = vector.extract %a[0] : vector<2xi32> -> i32
  %21 = vector.extract %b[0] : vector<2xi32> -> i32
  %22 = scalar.shrsi %20, %21 : i32
  %23 = vector.extract %a[1] : vector<2xi32> -> i32
  %24 = vector.extract %b[1] : vector<2xi32> -> i32
  %25 = scalar.shrsi %23, %24 : i32
  %shrs = vector.from_elements %22, %25 : vector<2xi32>
  %13 = vector.extract %a[0] : vector<2xi32> -> i32
  %14 = vector.extract %b[0] : vector<2xi32> -> i32
  %15 = scalar.rotli %13, %14 : i32
  %16 = vector.extract %a[1] : vector<2xi32> -> i32
  %17 = vector.extract %b[1] : vector<2xi32> -> i32
  %18 = scalar.rotli %16, %17 : i32
  %rotl = vector.from_elements %15, %18 : vector<2xi32>
  %8 = vector.extract %a[0] : vector<2xi32> -> i32
  %9 = scalar.ctlzi %8 : i32
  %10 = vector.extract %a[1] : vector<2xi32> -> i32
  %11 = scalar.ctlzi %10 : i32
  %clz = vector.from_elements %9, %11 : vector<2xi32>
  func.return %shrs, %rotl, %clz : vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ====

// Predicate and sign ops can change element type while preserving vector shape.
func.def @static_predicate_wave2(%a: vector<2xf32>, %i: vector<2xi32>) -> (vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>) {
  %is_nan = vector.isnanf %a : vector<2xf32> -> vector<2xi1>
  %is_inf = vector.isinff %a : vector<2xf32> -> vector<2xi1>
  %is_finite = vector.isfinitef %a : vector<2xf32> -> vector<2xi1>
  %fsign = vector.signf %a : vector<2xf32>
  %isign = vector.signi %i : vector<2xi32>
  func.return %is_nan, %is_inf, %is_finite, %fsign, %isign : vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>
}

// ----
func.def @static_predicate_wave2(%a: vector<2xf32>, %i: vector<2xi32>) -> (vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>) {
  %32 = vector.extract %a[0] : vector<2xf32> -> f32
  %33 = scalar.isnanf %32 : f32
  %34 = vector.extract %a[1] : vector<2xf32> -> f32
  %35 = scalar.isnanf %34 : f32
  %is_nan = vector.from_elements %33, %35 : vector<2xi1>
  %27 = vector.extract %a[0] : vector<2xf32> -> f32
  %28 = scalar.isinff %27 : f32
  %29 = vector.extract %a[1] : vector<2xf32> -> f32
  %30 = scalar.isinff %29 : f32
  %is_inf = vector.from_elements %28, %30 : vector<2xi1>
  %22 = vector.extract %a[0] : vector<2xf32> -> f32
  %23 = scalar.isfinitef %22 : f32
  %24 = vector.extract %a[1] : vector<2xf32> -> f32
  %25 = scalar.isfinitef %24 : f32
  %is_finite = vector.from_elements %23, %25 : vector<2xi1>
  %17 = vector.extract %a[0] : vector<2xf32> -> f32
  %18 = scalar.signf %17 : f32
  %19 = vector.extract %a[1] : vector<2xf32> -> f32
  %20 = scalar.signf %19 : f32
  %fsign = vector.from_elements %18, %20 : vector<2xf32>
  %12 = vector.extract %i[0] : vector<2xi32> -> i32
  %13 = scalar.signi %12 : i32
  %14 = vector.extract %i[1] : vector<2xi32> -> i32
  %15 = scalar.signi %14 : i32
  %isign = vector.from_elements %13, %15 : vector<2xi32>
  func.return %is_nan, %is_inf, %is_finite, %fsign, %isign : vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>
}

// ====

// Dynamic predicate results initialize an i1 vector and update lanes in a loop.
func.def @dynamic_float_predicate(%n: index, %a: vector<[%n]xf32>) -> (vector<[%n]xi1>) {
  %r = vector.isfinitef %a : vector<[%n]xf32> -> vector<[%n]xi1>
  func.return %r : vector<[%n]xi1>
}

// ----
func.def @dynamic_float_predicate(%n: index, %a: vector<[%n]xf32>) -> (vector<[%n]xi1>) {
  %4 = vector.constant false : vector<[%n]xi1>
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %4 : vector<[%n]xi1>) -> (vector<[%n]xi1>) {
    %10 = vector.extract %a[%7] : vector<[%n]xf32> -> f32
    %11 = scalar.isfinitef %10 : f32
    %12 = vector.insert %11 into %8[%7] : i1, vector<[%n]xi1>
    scf.yield %12 : vector<[%n]xi1>
  }
  func.return %r : vector<[%n]xi1>
}

// ====

// Reductions expose scalar accumulator order directly.
func.def @static_reduce(%v: vector<4xf32>, %zero: f32) -> (f32) {
  %r = vector.reduce<addf> %v, %zero : vector<4xf32>, f32
  func.return %r : f32
}

// ----
func.def @static_reduce(%v: vector<4xf32>, %zero: f32) -> (f32) {
  %4 = vector.extract %v[0] : vector<4xf32> -> f32
  %5 = scalar.addf %zero, %4 : f32
  %6 = vector.extract %v[1] : vector<4xf32> -> f32
  %7 = scalar.addf %5, %6 : f32
  %8 = vector.extract %v[2] : vector<4xf32> -> f32
  %9 = scalar.addf %7, %8 : f32
  %10 = vector.extract %v[3] : vector<4xf32> -> f32
  %r = scalar.addf %9, %10 : f32
  func.return %r : f32
}

// ====

// Floating reduction value-domain assumptions project onto scalar fast-math bits.
func.def @static_reduce_assumptions(%v: vector<2xf32>, %zero: f32) -> (f32) {
  %r = vector.reduce<addf, nnan|ninf|nsz> %v, %zero : vector<2xf32>, f32
  func.return %r : f32
}

// ----
func.def @static_reduce_assumptions(%v: vector<2xf32>, %zero: f32) -> (f32) {
  %4 = vector.extract %v[0] : vector<2xf32> -> f32
  %5 = scalar.addf<nnan|ninf|nsz> %zero, %4 : f32
  %6 = vector.extract %v[1] : vector<2xf32> -> f32
  %r = scalar.addf<nnan|ninf|nsz> %5, %6 : f32
  func.return %r : f32
}

// ====

// Producer lanes feeding reductions are materialized directly instead of
// packing a temporary vector only to extract it again.
func.def @producer_reduce(%a: vector<4xi32>, %b: vector<4xi32>, %zero: i32) -> (i32) {
  %sum = vector.addi %a, %b : vector<4xi32>
  %r = vector.reduce<addi> %sum, %zero : vector<4xi32>, i32
  func.return %r : i32
}

// ----
func.def @producer_reduce(%a: vector<4xi32>, %b: vector<4xi32>, %zero: i32) -> (i32) {
  %6 = vector.extract %a[0] : vector<4xi32> -> i32
  %7 = vector.extract %b[0] : vector<4xi32> -> i32
  %8 = scalar.addi %6, %7 : i32
  %9 = scalar.addi %zero, %8 : i32
  %10 = vector.extract %a[1] : vector<4xi32> -> i32
  %11 = vector.extract %b[1] : vector<4xi32> -> i32
  %12 = scalar.addi %10, %11 : i32
  %13 = scalar.addi %9, %12 : i32
  %14 = vector.extract %a[2] : vector<4xi32> -> i32
  %15 = vector.extract %b[2] : vector<4xi32> -> i32
  %16 = scalar.addi %14, %15 : i32
  %17 = scalar.addi %13, %16 : i32
  %18 = vector.extract %a[3] : vector<4xi32> -> i32
  %19 = vector.extract %b[3] : vector<4xi32> -> i32
  %20 = scalar.addi %18, %19 : i32
  %r = scalar.addi %17, %20 : i32
  func.return %r : i32
}

// ====

// Replacing a named result with a pre-existing value must not rename that
// replacement.
func.def @empty_reduce_preserves_init_name(%v: vector<0xi32>, %zero: i32) -> (i32) {
  %r = vector.reduce<addi> %v, %zero : vector<0xi32>, i32
  func.return %r : i32
}

// ----
func.def @empty_reduce_preserves_init_name(%v: vector<0xi32>, %zero: i32) -> (i32) {
  func.return %zero : i32
}

// ====

// Dynamic reductions use scf.for with a scalar carried accumulator.
func.def @dynamic_reduce(%n: index, %v: vector<[%n]xi32>, %zero: i32) -> (i32) {
  %r = vector.reduce<addi> %v, %zero : vector<[%n]xi32>, i32
  func.return %r : i32
}

// ----
func.def @dynamic_reduce(%n: index, %v: vector<[%n]xi32>, %zero: i32) -> (i32) {
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %zero : i32) -> (i32) {
    %10 = vector.extract %v[%7] : vector<[%n]xi32> -> i32
    %11 = scalar.addi %8, %10 : i32
    scf.yield %11 : i32
  }
  func.return %r : i32
}

// ====

// Axis-preserving reductions materialize one scalar reduction per result lane.
func.def @static_reduce_axes(%v: vector<2x3xi32>, %init: vector<3xi32>) -> (vector<3xi32>) {
  %r = vector.reduce.axes<addi> %v, %init axes [0] : vector<2x3xi32>, vector<3xi32>
  func.return %r : vector<3xi32>
}

// ----
func.def @static_reduce_axes(%v: vector<2x3xi32>, %init: vector<3xi32>) -> (vector<3xi32>) {
  %4 = vector.extract %init[0] : vector<3xi32> -> i32
  %5 = vector.extract %v[0, 0] : vector<2x3xi32> -> i32
  %6 = scalar.addi %4, %5 : i32
  %7 = vector.extract %v[1, 0] : vector<2x3xi32> -> i32
  %8 = scalar.addi %6, %7 : i32
  %9 = vector.extract %init[1] : vector<3xi32> -> i32
  %10 = vector.extract %v[0, 1] : vector<2x3xi32> -> i32
  %11 = scalar.addi %9, %10 : i32
  %12 = vector.extract %v[1, 1] : vector<2x3xi32> -> i32
  %13 = scalar.addi %11, %12 : i32
  %14 = vector.extract %init[2] : vector<3xi32> -> i32
  %15 = vector.extract %v[0, 2] : vector<2x3xi32> -> i32
  %16 = scalar.addi %14, %15 : i32
  %17 = vector.extract %v[1, 2] : vector<2x3xi32> -> i32
  %18 = scalar.addi %16, %17 : i32
  %r = vector.from_elements %8, %13, %18 : vector<3xi32>
  func.return %r : vector<3xi32>
}

// ====

// Reducing every explicit axis is still legal through the reference scalar path.
func.def @static_reduce_axes_scalar(%v: vector<2x2xf32>, %zero: f32) -> (f32) {
  %r = vector.reduce.axes<addf> %v, %zero axes [0, 1] : vector<2x2xf32>, f32
  func.return %r : f32
}

// ----
func.def @static_reduce_axes_scalar(%v: vector<2x2xf32>, %zero: f32) -> (f32) {
  %4 = vector.extract %v[0, 0] : vector<2x2xf32> -> f32
  %5 = scalar.addf %zero, %4 : f32
  %6 = vector.extract %v[0, 1] : vector<2x2xf32> -> f32
  %7 = scalar.addf %5, %6 : f32
  %8 = vector.extract %v[1, 0] : vector<2x2xf32> -> f32
  %9 = scalar.addf %7, %8 : f32
  %10 = vector.extract %v[1, 1] : vector<2x2xf32> -> f32
  %r = scalar.addf %9, %10 : f32
  func.return %r : f32
}

// ====

// Dynamic reduced axes use nested scf.for loops carrying scalar accumulators.
func.def @dynamic_reduce_axes(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>, %init: vector<[%m]xi32>) -> (vector<[%m]xi32>) {
  %r = vector.reduce.axes<addi> %v, %init axes [1] : vector<[%m]x[%n]xi32>, vector<[%m]xi32>
  func.return %r : vector<[%m]xi32>
}

// ----
func.def @dynamic_reduce_axes(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>, %init: vector<[%m]xi32>) -> (vector<[%m]xi32>) {
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %m step %7](%9 = %init : vector<[%m]xi32>) -> (vector<[%m]xi32>) {
    %11 = vector.extract %init[%8] : vector<[%m]xi32> -> i32
    %12 = index.constant 0 : index
    %13 = index.constant 1 : index
    %16 = scf.for %14 = [%12 to %n step %13](%15 = %11 : i32) -> (i32) {
      %17 = vector.extract %v[%8, %14] : vector<[%m]x[%n]xi32> -> i32
      %18 = scalar.addi %15, %17 : i32
      scf.yield %18 : i32
    }
    %19 = vector.insert %16 into %9[%8] : i32, vector<[%m]xi32>
    scf.yield %19 : vector<[%m]xi32>
  }
  func.return %r : vector<[%m]xi32>
}

// ====

// vector.dotf lowers through scalar.fmaf so the fused dot semantics survive.
func.def @dotf(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %r = vector.dotf %lhs, %rhs, %acc : vector<4xf32>, vector<4xf32>, f32
  func.return %r : f32
}

// ----
func.def @dotf(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %5 = vector.extract %lhs[0] : vector<4xf32> -> f32
  %6 = vector.extract %rhs[0] : vector<4xf32> -> f32
  %7 = scalar.fmaf %5, %6, %acc : f32
  %8 = vector.extract %lhs[1] : vector<4xf32> -> f32
  %9 = vector.extract %rhs[1] : vector<4xf32> -> f32
  %10 = scalar.fmaf %8, %9, %7 : f32
  %11 = vector.extract %lhs[2] : vector<4xf32> -> f32
  %12 = vector.extract %rhs[2] : vector<4xf32> -> f32
  %13 = scalar.fmaf %11, %12, %10 : f32
  %14 = vector.extract %lhs[3] : vector<4xf32> -> f32
  %15 = vector.extract %rhs[3] : vector<4xf32> -> f32
  %r = scalar.fmaf %14, %15, %13 : f32
  func.return %r : f32
}

// ====

// Coordinate constructors lower to explicit scalar/index arithmetic.
func.def @coordinates(%n: index) -> (vector<4xindex>, vector<[%n]xi1>) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %lanes = vector.iota %c0 step %c1 : vector<4xindex>
  %mask = vector.mask.range [%c0 to %n step %c1] : index -> vector<[%n]xi1>
  func.return %lanes, %mask : vector<4xindex>, vector<[%n]xi1>
}

// ----
func.def @coordinates(%n: index) -> (vector<4xindex>, vector<[%n]xi1>) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %17 = index.constant 0 : index
  %18 = index.mul %17, %c1 : index
  %19 = index.add %c0, %18 : index
  %20 = index.constant 1 : index
  %21 = index.mul %20, %c1 : index
  %22 = index.add %c0, %21 : index
  %23 = index.constant 2 : index
  %24 = index.mul %23, %c1 : index
  %25 = index.add %c0, %24 : index
  %26 = index.constant 3 : index
  %27 = index.mul %26, %c1 : index
  %28 = index.add %c0, %27 : index
  %lanes = vector.from_elements %19, %22, %25, %28 : vector<4xindex>
  %7 = vector.constant false : vector<[%n]xi1>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %mask = scf.for %10 = [%8 to %n step %9](%11 = %7 : vector<[%n]xi1>) -> (vector<[%n]xi1>) {
    %13 = index.mul %10, %c1 : index
    %14 = index.add %c0, %13 : index
    %15 = index.cmp slt, %14, %n : index
    %16 = vector.insert %15 into %11[%10] : i1, vector<[%n]xi1>
    scf.yield %16 : vector<[%n]xi1>
  }
  func.return %lanes, %mask : vector<4xindex>, vector<[%n]xi1>
}

// ====

func.def @integer_coordinates(%limit: i32) -> (vector<4xi32>, vector<4xi1>) {
  %c0 = scalar.constant 0 : i32
  %c2 = scalar.constant 2 : i32
  %lanes = vector.iota %c0 step %c2 : vector<4xi32>
  %mask = vector.mask.range [%c0 to %limit step %c2] : i32 -> vector<4xi1>
  func.return %lanes, %mask : vector<4xi32>, vector<4xi1>
}

// ----
func.def @integer_coordinates(%limit: i32) -> (vector<4xi32>, vector<4xi1>) {
  %c0 = scalar.constant 0 : i32
  %c2 = scalar.constant 2 : i32
  %24 = scalar.constant 0 : i32
  %25 = scalar.muli %24, %c2 : i32
  %26 = scalar.addi %c0, %25 : i32
  %27 = scalar.constant 1 : i32
  %28 = scalar.muli %27, %c2 : i32
  %29 = scalar.addi %c0, %28 : i32
  %30 = scalar.constant 2 : i32
  %31 = scalar.muli %30, %c2 : i32
  %32 = scalar.addi %c0, %31 : i32
  %33 = scalar.constant 3 : i32
  %34 = scalar.muli %33, %c2 : i32
  %35 = scalar.addi %c0, %34 : i32
  %lanes = vector.from_elements %26, %29, %32, %35 : vector<4xi32>
  %7 = scalar.constant 0 : i32
  %8 = scalar.muli %7, %c2 : i32
  %9 = scalar.addi %c0, %8 : i32
  %10 = scalar.cmpi slt, %9, %limit : i32
  %11 = scalar.constant 1 : i32
  %12 = scalar.muli %11, %c2 : i32
  %13 = scalar.addi %c0, %12 : i32
  %14 = scalar.cmpi slt, %13, %limit : i32
  %15 = scalar.constant 2 : i32
  %16 = scalar.muli %15, %c2 : i32
  %17 = scalar.addi %c0, %16 : i32
  %18 = scalar.cmpi slt, %17, %limit : i32
  %19 = scalar.constant 3 : i32
  %20 = scalar.muli %19, %c2 : i32
  %21 = scalar.addi %c0, %20 : i32
  %22 = scalar.cmpi slt, %21, %limit : i32
  %mask = vector.from_elements %10, %14, %18, %22 : vector<4xi1>
  func.return %lanes, %mask : vector<4xi32>, vector<4xi1>
}

// ====

// Static aggregate constructors expose lanes but keep vector.from_elements as
// the explicit vector ABI boundary.
func.def @static_constant_poison() -> (vector<2xi32>, vector<2xf32>) {
  %c = vector.constant 7 : vector<2xi32>
  %p = vector.poison : vector<2xf32>
  func.return %c, %p : vector<2xi32>, vector<2xf32>
}

// ----
func.def @static_constant_poison() -> (vector<2xi32>, vector<2xf32>) {
  %7 = scalar.constant 7 : i32
  %8 = scalar.constant 7 : i32
  %c = vector.from_elements %7, %8 : vector<2xi32>
  %4 = scalar.poison : f32
  %5 = scalar.poison : f32
  %p = vector.from_elements %4, %5 : vector<2xf32>
  func.return %c, %p : vector<2xi32>, vector<2xf32>
}

// ====

// Empty vectors are already the canonical zero-lane aggregate boundary.
func.def @empty_boundary() -> (vector<0xf32>) {
  %r = vector.empty : vector<0xf32>
  func.return %r : vector<0xf32>
}

// ====

// Static register rearrangements become direct scalar lane selections.
func.def @static_rearrange(%a: vector<4xi32>, %b: vector<4xi32>, %x: i32) -> (vector<4xi32>) {
  %wide = vector.concat<0> %a, %b : vector<4xi32>, vector<4xi32> -> vector<8xi32>
  %slice = vector.slice %wide[2] : vector<8xi32> -> vector<4xi32>
  %shuffle = vector.shuffle<[3, 2, 1, 0]> %slice : vector<4xi32>
  %r = vector.insert %x into %shuffle[1] : i32, vector<4xi32>
  func.return %r : vector<4xi32>
}

// ----
func.def @static_rearrange(%a: vector<4xi32>, %b: vector<4xi32>, %x: i32) -> (vector<4xi32>) {
  %8 = vector.extract %b[1] : vector<4xi32> -> i32
  %9 = vector.extract %a[3] : vector<4xi32> -> i32
  %10 = vector.extract %a[2] : vector<4xi32> -> i32
  %r = vector.from_elements %8, %x, %9, %10 : vector<4xi32>
  func.return %r : vector<4xi32>
}

// ====

// Broadcast, transpose, and lane-compatible bitcast compose through the same
// lane-program path.
func.def @static_broadcast_transpose_bitcast(%v: vector<2xi32>) -> (vector<2x2xf32>) {
  %wide = vector.broadcast %v : vector<2xi32> -> vector<2x2xi32>
  %t = vector.transpose<[1, 0]> %wide : vector<2x2xi32> -> vector<2x2xi32>
  %r = vector.bitcast %t : vector<2x2xi32> to vector<2x2xf32>
  func.return %r : vector<2x2xf32>
}

// ----
func.def @static_broadcast_transpose_bitcast(%v: vector<2xi32>) -> (vector<2x2xf32>) {
  %5 = vector.extract %v[0] : vector<2xi32> -> i32
  %6 = scalar.bitcast %5 : i32 to f32
  %7 = vector.extract %v[0] : vector<2xi32> -> i32
  %8 = scalar.bitcast %7 : i32 to f32
  %9 = vector.extract %v[1] : vector<2xi32> -> i32
  %10 = scalar.bitcast %9 : i32 to f32
  %11 = vector.extract %v[1] : vector<2xi32> -> i32
  %12 = scalar.bitcast %11 : i32 to f32
  %r = vector.from_elements %6, %8, %10, %12 : vector<2x2xf32>
  func.return %r : vector<2x2xf32>
}

// ====

// Shape-changing bitcasts reinterpret the same linear register bitstream even
// when source and result lane widths differ.
func.def @static_shape_changing_bitcast(%bytes: vector<2xi8>, %half: vector<1xf16>) -> (vector<1xf16>, vector<2xi8>) {
  %to_half = vector.bitcast %bytes : vector<2xi8> to vector<1xf16>
  %to_bytes = vector.bitcast %half : vector<1xf16> to vector<2xi8>
  func.return %to_half, %to_bytes : vector<1xf16>, vector<2xi8>
}

// ----
func.def @static_shape_changing_bitcast(%bytes: vector<2xi8>, %half: vector<1xf16>) -> (vector<1xf16>, vector<2xi8>) {
  %19 = vector.extract %bytes[0] : vector<2xi8> -> i8
  %20 = scalar.extui %19 : i8 to i16
  %21 = vector.extract %bytes[1] : vector<2xi8> -> i8
  %22 = scalar.extui %21 : i8 to i16
  %23 = scalar.constant 8 : i16
  %24 = scalar.shli %22, %23 : i16
  %25 = scalar.ori %20, %24 : i16
  %26 = scalar.bitcast %25 : i16 to f16
  %to_half = vector.from_elements %26 : vector<1xf16>
  %6 = vector.extract %half[0] : vector<1xf16> -> f16
  %7 = scalar.bitcast %6 : f16 to i16
  %8 = scalar.constant 255 : i16
  %9 = scalar.andi %7, %8 : i16
  %10 = scalar.trunci %9 : i16 to i8
  %11 = vector.extract %half[0] : vector<1xf16> -> f16
  %12 = scalar.bitcast %11 : f16 to i16
  %13 = scalar.constant 8 : i16
  %14 = scalar.shrui %12, %13 : i16
  %15 = scalar.constant 255 : i16
  %16 = scalar.andi %14, %15 : i16
  %17 = scalar.trunci %16 : i16 to i8
  %to_bytes = vector.from_elements %10, %17 : vector<2xi8>
  func.return %to_half, %to_bytes : vector<1xf16>, vector<2xi8>
}

// ====

// Dynamic shape-changing bitcasts use the same linear bitstream model as the
// static aggregate path when symbolic total bit counts match.
func.def @dynamic_shape_changing_bitcast(%n: index, %bytes: vector<[%n]x2xi8>, %halves: vector<[%n]xf16>) -> (vector<[%n]xf16>, vector<[%n]x2xi8>) {
  %to_half = vector.bitcast %bytes : vector<[%n]x2xi8> to vector<[%n]xf16>
  %to_bytes = vector.bitcast %halves : vector<[%n]xf16> to vector<[%n]x2xi8>
  func.return %to_half, %to_bytes : vector<[%n]xf16>, vector<[%n]x2xi8>
}

// ----
func.def @dynamic_shape_changing_bitcast(%n: index, %bytes: vector<[%n]x2xi8>, %halves: vector<[%n]xf16>) -> (vector<[%n]xf16>, vector<[%n]x2xi8>) {
  %47 = vector.constant 0.0 : vector<[%n]xf16>
  %48 = index.constant 0 : index
  %49 = index.constant 1 : index
  %to_half = scf.for %50 = [%48 to %n step %49](%51 = %47 : vector<[%n]xf16>) -> (vector<[%n]xf16>) {
    %53 = index.constant 16 : index
    %54 = index.mul %50, %53 : index
    %55 = index.constant 0 : index
    %56 = index.constant 16 : index
    %57 = index.constant 1 : index
    %58 = scalar.constant 1 : i8
    %59 = scalar.constant 0 : i16
    %62 = scf.for %60 = [%55 to %56 step %57](%61 = %59 : i16) -> (i16) {
      %63 = index.add %54, %60 : index
      %64 = index.constant 8 : index
      %65 = index.div %63, %64 : index
      %66 = index.constant 8 : index
      %67 = index.rem %63, %66 : index
      %68 = index.constant 2 : index
      %69 = index.rem %65, %68 : index
      %70 = index.constant 2 : index
      %71 = index.div %65, %70 : index
      %72 = vector.extract %bytes[%71, %69] : vector<[%n]x2xi8> -> i8
      %73 = index.cast %67 : index to i8
      %74 = scalar.shrui %72, %73 : i8
      %75 = scalar.andi %74, %58 : i8
      %76 = scalar.extui %75 : i8 to i16
      %77 = index.cast %60 : index to i16
      %78 = scalar.shli %76, %77 : i16
      %79 = scalar.ori %61, %78 : i16
      scf.yield %79 : i16
    }
    %80 = scalar.bitcast %62 : i16 to f16
    %81 = vector.insert %80 into %51[%50] : f16, vector<[%n]xf16>
    scf.yield %81 : vector<[%n]xf16>
  }
  %7 = vector.constant 0 : vector<[%n]x2xi8>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %to_bytes = scf.for %10 = [%8 to %n step %9](%11 = %7 : vector<[%n]x2xi8>) -> (vector<[%n]x2xi8>) {
    %13 = index.constant 0 : index
    %14 = index.constant 1 : index
    %15 = index.constant 2 : index
    %18 = scf.for %16 = [%13 to %15 step %14](%17 = %11 : vector<[%n]x2xi8>) -> (vector<[%n]x2xi8>) {
      %19 = index.constant 2 : index
      %20 = index.mul %10, %19 : index
      %21 = index.add %20, %16 : index
      %22 = index.constant 8 : index
      %23 = index.mul %21, %22 : index
      %24 = index.constant 0 : index
      %25 = index.constant 8 : index
      %26 = index.constant 1 : index
      %27 = scalar.constant 1 : i16
      %28 = scalar.constant 0 : i8
      %31 = scf.for %29 = [%24 to %25 step %26](%30 = %28 : i8) -> (i8) {
        %32 = index.add %23, %29 : index
        %33 = index.constant 16 : index
        %34 = index.div %32, %33 : index
        %35 = index.constant 16 : index
        %36 = index.rem %32, %35 : index
        %37 = vector.extract %halves[%34] : vector<[%n]xf16> -> f16
        %38 = scalar.bitcast %37 : f16 to i16
        %39 = index.cast %36 : index to i16
        %40 = scalar.shrui %38, %39 : i16
        %41 = scalar.andi %40, %27 : i16
        %42 = scalar.trunci %41 : i16 to i8
        %43 = index.cast %29 : index to i8
        %44 = scalar.shli %42, %43 : i8
        %45 = scalar.ori %30, %44 : i8
        scf.yield %45 : i8
      }
      %46 = vector.insert %31 into %17[%10, %16] : i8, vector<[%n]x2xi8>
      scf.yield %46 : vector<[%n]x2xi8>
    }
    scf.yield %18 : vector<[%n]x2xi8>
  }
  func.return %to_half, %to_bytes : vector<[%n]xf16>, vector<[%n]x2xi8>
}

// ====

// Multi-result deinterleave lowers each result independently and can see
// through a static interleave producer.
func.def @static_interleave_deinterleave(%a: vector<2xi8>, %b: vector<2xi8>) -> (vector<4xi8>, vector<2xi8>, vector<2xi8>) {
  %paired = vector.interleave<0> %a, %b : vector<2xi8>, vector<2xi8> -> vector<4xi8>
  %even, %odd = vector.deinterleave<0> %paired : vector<4xi8> -> vector<2xi8>, vector<2xi8>
  func.return %paired, %even, %odd : vector<4xi8>, vector<2xi8>, vector<2xi8>
}

// ----
func.def @static_interleave_deinterleave(%a: vector<2xi8>, %b: vector<2xi8>) -> (vector<4xi8>, vector<2xi8>, vector<2xi8>) {
  %14 = vector.extract %a[0] : vector<2xi8> -> i8
  %15 = vector.extract %b[0] : vector<2xi8> -> i8
  %16 = vector.extract %a[1] : vector<2xi8> -> i8
  %17 = vector.extract %b[1] : vector<2xi8> -> i8
  %paired = vector.from_elements %14, %15, %16, %17 : vector<4xi8>
  %8 = vector.extract %a[0] : vector<2xi8> -> i8
  %9 = vector.extract %a[1] : vector<2xi8> -> i8
  %even = vector.from_elements %8, %9 : vector<2xi8>
  %11 = vector.extract %b[0] : vector<2xi8> -> i8
  %12 = vector.extract %b[1] : vector<2xi8> -> i8
  %odd = vector.from_elements %11, %12 : vector<2xi8>
  func.return %paired, %even, %odd : vector<4xi8>, vector<2xi8>, vector<2xi8>
}

// ====

// Dynamic slice offsets lower to index arithmetic feeding scalar lane extracts.
func.def @dynamic_slice(%n: index, %offset: index, %v: vector<[%n]xi32>) -> (vector<4xi32>) {
  %r = vector.slice %v[%offset] : vector<[%n]xi32> -> vector<4xi32>
  func.return %r : vector<4xi32>
}

// ----
func.def @dynamic_slice(%n: index, %offset: index, %v: vector<[%n]xi32>) -> (vector<4xi32>) {
  %5 = vector.extract %v[%offset] : vector<[%n]xi32> -> i32
  %6 = index.constant 1 : index
  %7 = index.add %offset, %6 : index
  %8 = vector.extract %v[%7] : vector<[%n]xi32> -> i32
  %9 = index.constant 2 : index
  %10 = index.add %offset, %9 : index
  %11 = vector.extract %v[%10] : vector<[%n]xi32> -> i32
  %12 = index.constant 3 : index
  %13 = index.add %offset, %12 : index
  %14 = vector.extract %v[%13] : vector<[%n]xi32> -> i32
  %r = vector.from_elements %5, %8, %11, %14 : vector<4xi32>
  func.return %r : vector<4xi32>
}

// ====

// Dynamic transpose uses loops over the result shape and swaps the source
// coordinates explicitly.
func.def @dynamic_transpose(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>) -> (vector<[%n]x[%m]xi32>) {
  %r = vector.transpose<[1, 0]> %v : vector<[%m]x[%n]xi32> -> vector<[%n]x[%m]xi32>
  func.return %r : vector<[%n]x[%m]xi32>
}

// ----
func.def @dynamic_transpose(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>) -> (vector<[%n]x[%m]xi32>) {
  %5 = vector.constant 0 : vector<[%n]x[%m]xi32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %n step %7](%9 = %5 : vector<[%n]x[%m]xi32>) -> (vector<[%n]x[%m]xi32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %m step %12](%14 = %9 : vector<[%n]x[%m]xi32>) -> (vector<[%n]x[%m]xi32>) {
      %16 = vector.extract %v[%13, %8] : vector<[%m]x[%n]xi32> -> i32
      %17 = vector.insert %16 into %14[%8, %13] : i32, vector<[%n]x[%m]xi32>
      scf.yield %17 : vector<[%n]x[%m]xi32>
    }
    scf.yield %15 : vector<[%n]x[%m]xi32>
  }
  func.return %r : vector<[%n]x[%m]xi32>
}

// ====

// Dynamic deinterleave only needs index multiply/add to map result coordinates
// to even and odd source coordinates.
func.def @dynamic_deinterleave(%full: index, %half: index, %v: vector<[%full]xi32>) -> (vector<[%half]xi32>, vector<[%half]xi32>) {
  %even, %odd = vector.deinterleave<0> %v : vector<[%full]xi32> -> vector<[%half]xi32>, vector<[%half]xi32>
  func.return %even, %odd : vector<[%half]xi32>, vector<[%half]xi32>
}

// ----
func.def @dynamic_deinterleave(%full: index, %half: index, %v: vector<[%full]xi32>) -> (vector<[%half]xi32>, vector<[%half]xi32>) {
  %7 = vector.constant 0 : vector<[%half]xi32>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %even = scf.for %10 = [%8 to %half step %9](%11 = %7 : vector<[%half]xi32>) -> (vector<[%half]xi32>) {
    %13 = index.constant 2 : index
    %14 = index.mul %10, %13 : index
    %15 = vector.extract %v[%14] : vector<[%full]xi32> -> i32
    %16 = vector.insert %15 into %11[%10] : i32, vector<[%half]xi32>
    scf.yield %16 : vector<[%half]xi32>
  }
  %17 = vector.constant 0 : vector<[%half]xi32>
  %18 = index.constant 0 : index
  %19 = index.constant 1 : index
  %odd = scf.for %20 = [%18 to %half step %19](%21 = %17 : vector<[%half]xi32>) -> (vector<[%half]xi32>) {
    %23 = index.constant 2 : index
    %24 = index.mul %20, %23 : index
    %25 = index.constant 1 : index
    %26 = index.add %24, %25 : index
    %27 = vector.extract %v[%26] : vector<[%full]xi32> -> i32
    %28 = vector.insert %27 into %21[%20] : i32, vector<[%half]xi32>
    scf.yield %28 : vector<[%half]xi32>
  }
  func.return %even, %odd : vector<[%half]xi32>, vector<[%half]xi32>
}

// ====

// Dynamic interleave uses quotient/remainder index ops to select the source
// vector and source lane for each result lane.
func.def @dynamic_interleave(%full: index, %half: index, %even: vector<[%half]xi32>, %odd: vector<[%half]xi32>) -> (vector<[%full]xi32>) {
  %r = vector.interleave<0> %even, %odd : vector<[%half]xi32>, vector<[%half]xi32> -> vector<[%full]xi32>
  func.return %r : vector<[%full]xi32>
}

// ----
func.def @dynamic_interleave(%full: index, %half: index, %even: vector<[%half]xi32>, %odd: vector<[%half]xi32>) -> (vector<[%full]xi32>) {
  %6 = vector.constant 0 : vector<[%full]xi32>
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %full step %8](%10 = %6 : vector<[%full]xi32>) -> (vector<[%full]xi32>) {
    %12 = index.constant 2 : index
    %13 = index.div %9, %12 : index
    %14 = vector.extract %even[%13] : vector<[%half]xi32> -> i32
    %15 = vector.extract %odd[%13] : vector<[%half]xi32> -> i32
    %16 = index.constant 2 : index
    %17 = index.rem %9, %16 : index
    %18 = index.constant 0 : index
    %19 = index.cmp eq, %17, %18 : index
    %20 = scf.select %19, %14, %15 : i32
    %21 = vector.insert %20 into %10[%9] : i32, vector<[%full]xi32>
    scf.yield %21 : vector<[%full]xi32>
  }
  func.return %r : vector<[%full]xi32>
}

// ====

// Dynamic insert can participate in another lane program: each result lane
// selects either the inserted scalar or the original destination lane.
func.def @dynamic_insert_consumed(%n: index, %lane: index, %dest: vector<[%n]xi32>, %value: i32) -> (vector<[%n]xi32>) {
  %updated = vector.insert %value into %dest[%lane] : i32, vector<[%n]xi32>
  %r = vector.negi %updated : vector<[%n]xi32>
  func.return %r : vector<[%n]xi32>
}

// ----
func.def @dynamic_insert_consumed(%n: index, %lane: index, %dest: vector<[%n]xi32>, %value: i32) -> (vector<[%n]xi32>) {
  %7 = vector.constant 0 : vector<[%n]xi32>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %r = scf.for %10 = [%8 to %n step %9](%11 = %7 : vector<[%n]xi32>) -> (vector<[%n]xi32>) {
    %13 = index.cmp eq, %10, %lane : index
    %14 = vector.extract %dest[%10] : vector<[%n]xi32> -> i32
    %15 = scf.select %13, %value, %14 : i32
    %16 = scalar.negi %15 : i32
    %17 = vector.insert %16 into %11[%10] : i32, vector<[%n]xi32>
    scf.yield %17 : vector<[%n]xi32>
  }
  func.return %r : vector<[%n]xi32>
}

// ====

// Dynamic concat uses structured control flow so non-selected inputs are not
// speculatively extracted with out-of-range coordinates.
func.def @dynamic_concat(%full: index, %left_n: index, %right_n: index, %left: vector<[%left_n]xi32>, %right: vector<[%right_n]xi32>) -> (vector<[%full]xi32>) {
  %r = vector.concat<0> %left, %right : vector<[%left_n]xi32>, vector<[%right_n]xi32> -> vector<[%full]xi32>
  func.return %r : vector<[%full]xi32>
}

// ----
func.def @dynamic_concat(%full: index, %left_n: index, %right_n: index, %left: vector<[%left_n]xi32>, %right: vector<[%right_n]xi32>) -> (vector<[%full]xi32>) {
  %7 = vector.constant 0 : vector<[%full]xi32>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %r = scf.for %10 = [%8 to %full step %9](%11 = %7 : vector<[%full]xi32>) -> (vector<[%full]xi32>) {
    %13 = index.cmp slt, %10, %left_n : index
    %14 = scf.if %13 -> (i32) {
      %15 = vector.extract %left[%10] : vector<[%left_n]xi32> -> i32
      scf.yield %15 : i32
    } else {
      %16 = index.add %left_n, %right_n : index
      %17 = index.cmp slt, %10, %16 : index
      %18 = index.sub %10, %left_n : index
      %19 = scf.if %17 -> (i32) {
        %20 = vector.extract %right[%18] : vector<[%right_n]xi32> -> i32
        scf.yield %20 : i32
      } else {
        %21 = scalar.poison : i32
        scf.yield %21 : i32
      }
      scf.yield %19 : i32
    }
    %22 = vector.insert %14 into %11[%10] : i32, vector<[%full]xi32>
    scf.yield %22 : vector<[%full]xi32>
  }
  func.return %r : vector<[%full]xi32>
}

// ====

// Bitfield extract/insert lower to explicit scalar shift, mask, and merge
// sequences so packed quantized registers have a target-independent oracle.
func.def @static_bitfields(%bytes: vector<2xi8>, %zero: vector<2xi8>) -> (vector<2xi8>) {
  %lo = vector.bitfield.extractu %bytes {offset = 0, width = 4} : vector<2xi8> -> vector<2xi8>
  %hi = vector.bitfield.extracts %bytes {offset = 4, width = 4} : vector<2xi8> -> vector<2xi32>
  test.use %hi : vector<2xi32>
  %r = vector.bitfield.insert %lo into %zero {offset = 0, width = 4} : vector<2xi8>, vector<2xi8>
  func.return %r : vector<2xi8>
}

// ----
func.def @static_bitfields(%bytes: vector<2xi8>, %zero: vector<2xi8>) -> (vector<2xi8>) {
  %29 = vector.extract %bytes[0] : vector<2xi8> -> i8
  %30 = scalar.constant 4 : i8
  %31 = scalar.shrsi %29, %30 : i8
  %32 = scalar.extsi %31 : i8 to i32
  %33 = vector.extract %bytes[1] : vector<2xi8> -> i8
  %34 = scalar.constant 4 : i8
  %35 = scalar.shrsi %33, %34 : i8
  %36 = scalar.extsi %35 : i8 to i32
  %hi = vector.from_elements %32, %36 : vector<2xi32>
  test.use %hi : vector<2xi32>
  %6 = vector.extract %bytes[0] : vector<2xi8> -> i8
  %7 = scalar.constant 15 : i8
  %8 = scalar.andi %6, %7 : i8
  %9 = vector.extract %zero[0] : vector<2xi8> -> i8
  %10 = scalar.constant 15 : i8
  %11 = scalar.andi %8, %10 : i8
  %12 = scalar.constant 15 : i8
  %13 = scalar.constant -1 : i8
  %14 = scalar.xori %12, %13 : i8
  %15 = scalar.andi %9, %14 : i8
  %16 = scalar.ori %15, %11 : i8
  %17 = vector.extract %bytes[1] : vector<2xi8> -> i8
  %18 = scalar.constant 15 : i8
  %19 = scalar.andi %17, %18 : i8
  %20 = vector.extract %zero[1] : vector<2xi8> -> i8
  %21 = scalar.constant 15 : i8
  %22 = scalar.andi %19, %21 : i8
  %23 = scalar.constant 15 : i8
  %24 = scalar.constant -1 : i8
  %25 = scalar.xori %23, %24 : i8
  %26 = scalar.andi %20, %25 : i8
  %27 = scalar.ori %26, %22 : i8
  %r = vector.from_elements %16, %27 : vector<2xi8>
  func.return %r : vector<2xi8>
}

// ====

// dot2f extends each f16/bf16 source lane to f32 before feeding scalar.fmaf,
// preserving the widened fused pair-dot semantics used by AMDGPU fdot2.
func.def @static_dot2f(%lhs: vector<2xf16>, %rhs: vector<2xf16>, %acc: vector<1xf32>) -> (vector<1xf32>) {
  %r = vector.dot2f %lhs, %rhs, %acc : vector<2xf16>, vector<2xf16>, vector<1xf32>
  func.return %r : vector<1xf32>
}

// ----
func.def @static_dot2f(%lhs: vector<2xf16>, %rhs: vector<2xf16>, %acc: vector<1xf32>) -> (vector<1xf32>) {
  %5 = vector.extract %acc[0] : vector<1xf32> -> f32
  %6 = vector.extract %lhs[0] : vector<2xf16> -> f16
  %7 = vector.extract %rhs[0] : vector<2xf16> -> f16
  %8 = scalar.extf %6 : f16 to f32
  %9 = scalar.extf %7 : f16 to f32
  %10 = scalar.fmaf %8, %9, %5 : f32
  %11 = vector.extract %lhs[1] : vector<2xf16> -> f16
  %12 = vector.extract %rhs[1] : vector<2xf16> -> f16
  %13 = scalar.extf %11 : f16 to f32
  %14 = scalar.extf %12 : f16 to f32
  %15 = scalar.fmaf %13, %14, %10 : f32
  %r = vector.from_elements %15 : vector<1xf32>
  func.return %r : vector<1xf32>
}

// ====

// Dynamic dot2f uses index arithmetic to map each result lane to the two
// source lanes in its group.
func.def @dynamic_dot2f(%n: index, %m: index, %lhs: vector<[%n]xbf16>, %rhs: vector<[%n]xbf16>, %acc: vector<[%m]xf32>) -> (vector<[%m]xf32>) {
  %r = vector.dot2f %lhs, %rhs, %acc : vector<[%n]xbf16>, vector<[%n]xbf16>, vector<[%m]xf32>
  func.return %r : vector<[%m]xf32>
}

// ----
func.def @dynamic_dot2f(%n: index, %m: index, %lhs: vector<[%n]xbf16>, %rhs: vector<[%n]xbf16>, %acc: vector<[%m]xf32>) -> (vector<[%m]xf32>) {
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %m step %8](%10 = %acc : vector<[%m]xf32>) -> (vector<[%m]xf32>) {
    %12 = vector.extract %acc[%9] : vector<[%m]xf32> -> f32
    %13 = index.constant 2 : index
    %14 = index.mul %9, %13 : index
    %15 = vector.extract %lhs[%14] : vector<[%n]xbf16> -> bf16
    %16 = vector.extract %rhs[%14] : vector<[%n]xbf16> -> bf16
    %17 = scalar.extf %15 : bf16 to f32
    %18 = scalar.extf %16 : bf16 to f32
    %19 = scalar.fmaf %17, %18, %12 : f32
    %20 = index.constant 1 : index
    %21 = index.add %14, %20 : index
    %22 = vector.extract %lhs[%21] : vector<[%n]xbf16> -> bf16
    %23 = vector.extract %rhs[%21] : vector<[%n]xbf16> -> bf16
    %24 = scalar.extf %22 : bf16 to f32
    %25 = scalar.extf %23 : bf16 to f32
    %26 = scalar.fmaf %24, %25, %19 : f32
    %27 = vector.insert %26 into %10[%9] : f32, vector<[%m]xf32>
    scf.yield %27 : vector<[%m]xf32>
  }
  func.return %r : vector<[%m]xf32>
}

// ====

// dot4i groups the last source axis into four-lane scalar multiply/add chains
// while preserving the signedness template at each scalar extension.
func.def @static_dot4i(%lhs: vector<4xi8>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %r = vector.dot4i<s8u8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %r : vector<1xi32>
}

// ----
func.def @static_dot4i(%lhs: vector<4xi8>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %5 = vector.extract %acc[0] : vector<1xi32> -> i32
  %6 = vector.extract %lhs[0] : vector<4xi8> -> i8
  %7 = vector.extract %rhs[0] : vector<4xi8> -> i8
  %8 = scalar.extsi %6 : i8 to i32
  %9 = scalar.extui %7 : i8 to i32
  %10 = scalar.muli %8, %9 : i32
  %11 = scalar.addi %5, %10 : i32
  %12 = vector.extract %lhs[1] : vector<4xi8> -> i8
  %13 = vector.extract %rhs[1] : vector<4xi8> -> i8
  %14 = scalar.extsi %12 : i8 to i32
  %15 = scalar.extui %13 : i8 to i32
  %16 = scalar.muli %14, %15 : i32
  %17 = scalar.addi %11, %16 : i32
  %18 = vector.extract %lhs[2] : vector<4xi8> -> i8
  %19 = vector.extract %rhs[2] : vector<4xi8> -> i8
  %20 = scalar.extsi %18 : i8 to i32
  %21 = scalar.extui %19 : i8 to i32
  %22 = scalar.muli %20, %21 : i32
  %23 = scalar.addi %17, %22 : i32
  %24 = vector.extract %lhs[3] : vector<4xi8> -> i8
  %25 = vector.extract %rhs[3] : vector<4xi8> -> i8
  %26 = scalar.extsi %24 : i8 to i32
  %27 = scalar.extui %25 : i8 to i32
  %28 = scalar.muli %26, %27 : i32
  %29 = scalar.addi %23, %28 : i32
  %r = vector.from_elements %29 : vector<1xi32>
  func.return %r : vector<1xi32>
}

// ====

// Dynamic dot4i uses index arithmetic to map each result lane to the four
// source lanes in its group.
func.def @dynamic_dot4i(%n: index, %m: index, %lhs: vector<[%n]xi8>, %rhs: vector<[%n]xi8>, %acc: vector<[%m]xi32>) -> (vector<[%m]xi32>) {
  %r = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<[%n]xi8>, vector<[%n]xi8>, vector<[%m]xi32>
  func.return %r : vector<[%m]xi32>
}

// ----
func.def @dynamic_dot4i(%n: index, %m: index, %lhs: vector<[%n]xi8>, %rhs: vector<[%n]xi8>, %acc: vector<[%m]xi32>) -> (vector<[%m]xi32>) {
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %m step %8](%10 = %acc : vector<[%m]xi32>) -> (vector<[%m]xi32>) {
    %12 = vector.extract %acc[%9] : vector<[%m]xi32> -> i32
    %13 = index.constant 4 : index
    %14 = index.mul %9, %13 : index
    %15 = vector.extract %lhs[%14] : vector<[%n]xi8> -> i8
    %16 = vector.extract %rhs[%14] : vector<[%n]xi8> -> i8
    %17 = scalar.extui %15 : i8 to i32
    %18 = scalar.extsi %16 : i8 to i32
    %19 = scalar.muli %17, %18 : i32
    %20 = scalar.addi %12, %19 : i32
    %21 = index.constant 1 : index
    %22 = index.add %14, %21 : index
    %23 = vector.extract %lhs[%22] : vector<[%n]xi8> -> i8
    %24 = vector.extract %rhs[%22] : vector<[%n]xi8> -> i8
    %25 = scalar.extui %23 : i8 to i32
    %26 = scalar.extsi %24 : i8 to i32
    %27 = scalar.muli %25, %26 : i32
    %28 = scalar.addi %20, %27 : i32
    %29 = index.constant 2 : index
    %30 = index.add %14, %29 : index
    %31 = vector.extract %lhs[%30] : vector<[%n]xi8> -> i8
    %32 = vector.extract %rhs[%30] : vector<[%n]xi8> -> i8
    %33 = scalar.extui %31 : i8 to i32
    %34 = scalar.extsi %32 : i8 to i32
    %35 = scalar.muli %33, %34 : i32
    %36 = scalar.addi %28, %35 : i32
    %37 = index.constant 3 : index
    %38 = index.add %14, %37 : index
    %39 = vector.extract %lhs[%38] : vector<[%n]xi8> -> i8
    %40 = vector.extract %rhs[%38] : vector<[%n]xi8> -> i8
    %41 = scalar.extui %39 : i8 to i32
    %42 = scalar.extsi %40 : i8 to i32
    %43 = scalar.muli %41, %42 : i32
    %44 = scalar.addi %36, %43 : i32
    %45 = vector.insert %44 into %10[%9] : i32, vector<[%m]xi32>
    scf.yield %45 : vector<[%m]xi32>
  }
  func.return %r : vector<[%m]xi32>
}

// ====

// dot8i4 consumes one packed i32 per result lane. Each i32 holds eight
// little-endian four-bit fields; the template controls signed extension.
func.def @static_dot8i4(%lhs: vector<1xi32>, %rhs: vector<1xi32>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %r = vector.dot8i4<u4s4> %lhs, %rhs, %acc : vector<1xi32>
