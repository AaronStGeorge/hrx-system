  %12 = scalar.mulf %10, %11 : f32
  %13 = vector.extract %v[0] : vector<4xf32> -> f32
  %14 = vector.extract %v[1] : vector<4xf32> -> f32
  %15 = scalar.negf %14 : f32
  %16 = scalar.addf %13, %15 : f32
