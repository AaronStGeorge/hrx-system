// RUN: pass vector-to-scalar

// Static lanewise ops become scalar lane programs and an explicit aggregate
// pack at the vector ABI boundary.
func.def @static_add_select_cast(%a: vector<4xi32>, %b: vector<4xi32>, %mask: vector<4xi1>) -> (vector<4xf32>) {
  %sum = vector.addi %a, %b : vector<4xi32>
  %chosen = vector.select %mask, %sum, %a : vector<4xi32>
  %r = vector.sitofp %chosen : vector<4xi32> to vector<4xf32>
  func.return %r : vector<4xf32>
}

// ----
func.def @static_add_select_cast(%a: vector<4xi32>, %b: vector<4xi32>, %mask: vector<4xi1>) -> (vector<4xf32>) {
  %7 = vector.extract %mask[0] : vector<4xi1> -> i1
  %8 = vector.extract %a[0] : vector<4xi32> -> i32
  %9 = vector.extract %b[0] : vector<4xi32> -> i32
  %10 = scalar.addi %8, %9 : i32
  %11 = vector.extract %a[0] : vector<4xi32> -> i32
  %12 = scalar.select %7, %10, %11 : i32
  %13 = scalar.sitofp %12 : i32 to f32
  %14 = vector.extract %mask[1] : vector<4xi1> -> i1
  %15 = vector.extract %a[1] : vector<4xi32> -> i32
  %16 = vector.extract %b[1] : vector<4xi32> -> i32
  %17 = scalar.addi %15, %16 : i32
  %18 = vector.extract %a[1] : vector<4xi32> -> i32
  %19 = scalar.select %14, %17, %18 : i32
  %20 = scalar.sitofp %19 : i32 to f32
  %21 = vector.extract %mask[2] : vector<4xi1> -> i1
  %22 = vector.extract %a[2] : vector<4xi32> -> i32
  %23 = vector.extract %b[2] : vector<4xi32> -> i32
  %24 = scalar.addi %22, %23 : i32
  %25 = vector.extract %a[2] : vector<4xi32> -> i32
  %26 = scalar.select %21, %24, %25 : i32
  %27 = scalar.sitofp %26 : i32 to f32
  %28 = vector.extract %mask[3] : vector<4xi1> -> i1
  %29 = vector.extract %a[3] : vector<4xi32> -> i32
  %30 = vector.extract %b[3] : vector<4xi32> -> i32
  %31 = scalar.addi %29, %30 : i32
  %32 = vector.extract %a[3] : vector<4xi32> -> i32
  %33 = scalar.select %28, %31, %32 : i32
  %34 = scalar.sitofp %33 : i32 to f32
  %r = vector.from_elements %13, %20, %27, %34 : f32, f32, f32, f32 -> vector<4xf32>
  func.return %r : vector<4xf32>
}

// ====

// Dynamic lanewise ops lower to an scf.for loop carrying the vector aggregate
// because the number of scalar lanes is not statically known.
func.def @dynamic_add(%n: index, %a: vector<[%n]xi32>, %b: vector<[%n]xi32>) -> (vector<[%n]xi32>) {
  %r = vector.addi %a, %b : vector<[%n]xi32>
  func.return %r : vector<[%n]xi32>
}

// ----
func.def @dynamic_add(%n: index, %a: vector<[%n]xi32>, %b: vector<[%n]xi32>) -> (vector<[%n]xi32>) {
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %a : vector<[%n]xi32>) -> (vector<[%n]xi32>) {
    %10 = vector.extract %a[%7] : vector<[%n]xi32> -> i32
    %11 = vector.extract %b[%7] : vector<[%n]xi32> -> i32
    %12 = scalar.addi %10, %11 : i32
    %13 = vector.insert %12 into %8[%7] : i32, vector<[%n]xi32> -> vector<[%n]xi32>
    scf.yield %13 : vector<[%n]xi32>
  }
  func.return %r : vector<[%n]xi32>
}

// ====

// Multi-axis dynamic vectors become nested scf.for loops over the logical
// row-major shape.
func.def @dynamic_2d_add(%m: index, %n: index, %a: vector<[%m]x[%n]xi32>, %b: vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
  %r = vector.addi %a, %b : vector<[%m]x[%n]xi32>
  func.return %r : vector<[%m]x[%n]xi32>
}

// ----
func.def @dynamic_2d_add(%m: index, %n: index, %a: vector<[%m]x[%n]xi32>, %b: vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %m step %7](%9 = %a : vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %n step %12](%14 = %9 : vector<[%m]x[%n]xi32>) -> (vector<[%m]x[%n]xi32>) {
      %16 = vector.extract %a[%8, %13] : vector<[%m]x[%n]xi32> -> i32
      %17 = vector.extract %b[%8, %13] : vector<[%m]x[%n]xi32> -> i32
      %18 = scalar.addi %16, %17 : i32
      %19 = vector.insert %18 into %14[%8, %13] : i32, vector<[%m]x[%n]xi32> -> vector<[%m]x[%n]xi32>
      scf.yield %19 : vector<[%m]x[%n]xi32>
    }
    scf.yield %15 : vector<[%m]x[%n]xi32>
  }
  func.return %r : vector<[%m]x[%n]xi32>
}

// ====

// Dynamic splats use loops too; no dynamic number of scalar SSA values is
// required.
func.def @dynamic_2d_splat(%m: index, %n: index, %x: f32) -> (vector<[%m]x[%n]xf32>) {
  %r = vector.splat %x : vector<[%m]x[%n]xf32>
  func.return %r : vector<[%m]x[%n]xf32>
}

// ----
func.def @dynamic_2d_splat(%m: index, %n: index, %x: f32) -> (vector<[%m]x[%n]xf32>) {
  %5 = vector.constant 0.0 : vector<[%m]x[%n]xf32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %m step %7](%9 = %5 : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %n step %12](%14 = %9 : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
      %16 = vector.insert %x into %14[%8, %13] : f32, vector<[%m]x[%n]xf32> -> vector<[%m]x[%n]xf32>
      scf.yield %16 : vector<[%m]x[%n]xf32>
    }
    scf.yield %15 : vector<[%m]x[%n]xf32>
  }
  func.return %r : vector<[%m]x[%n]xf32>
}

// ====

// New float/math lanewise ops use the same generic lane-program path as the
// original seed ops.
func.def @static_float_math(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %diff = vector.subf %a, %b : vector<2xf32>
  %exp = vector.expf %diff : vector<2xf32>
  %r = vector.maxnumf %exp, %a : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ----
func.def @static_float_math(%a: vector<2xf32>, %b: vector<2xf32>) -> (vector<2xf32>) {
  %6 = vector.extract %a[0] : vector<2xf32> -> f32
  %7 = vector.extract %b[0] : vector<2xf32> -> f32
  %8 = scalar.subf %6, %7 : f32
  %9 = scalar.expf %8 : f32
  %10 = vector.extract %a[0] : vector<2xf32> -> f32
  %11 = scalar.maxnumf %9, %10 : f32
  %12 = vector.extract %a[1] : vector<2xf32> -> f32
  %13 = vector.extract %b[1] : vector<2xf32> -> f32
  %14 = scalar.subf %12, %13 : f32
  %15 = scalar.expf %14 : f32
  %16 = vector.extract %a[1] : vector<2xf32> -> f32
  %17 = scalar.maxnumf %15, %16 : f32
  %r = vector.from_elements %11, %17 : f32, f32 -> vector<2xf32>
  func.return %r : vector<2xf32>
}

// ====

// Dynamic float/math ops lower to scalar work inside the aggregate loop.
func.def @dynamic_float_math(%n: index, %a: vector<[%n]xf32>, %b: vector<[%n]xf32>) -> (vector<[%n]xf32>) {
  %quotient = vector.divf %a, %b : vector<[%n]xf32>
  %r = vector.sqrtf %quotient : vector<[%n]xf32>
  func.return %r : vector<[%n]xf32>
}

// ----
func.def @dynamic_float_math(%n: index, %a: vector<[%n]xf32>, %b: vector<[%n]xf32>) -> (vector<[%n]xf32>) {
  %6 = vector.constant 0.0 : vector<[%n]xf32>
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %n step %8](%10 = %6 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %12 = vector.extract %a[%9] : vector<[%n]xf32> -> f32
    %13 = vector.extract %b[%9] : vector<[%n]xf32> -> f32
    %14 = scalar.divf %12, %13 : f32
    %15 = scalar.sqrtf %14 : f32
    %16 = vector.insert %15 into %10[%9] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %16 : vector<[%n]xf32>
  }
  func.return %r : vector<[%n]xf32>
}

// ====

// Integer wave-2 ops use the same descriptor-driven lane lowering path.
func.def @static_integer_wave2(%a: vector<2xi32>, %b: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>) {
  %sub = vector.subi<nuw> %a, %b : vector<2xi32>
  %divs = vector.divsi %sub, %c : vector<2xi32>
  %divu = vector.divui %a, %c : vector<2xi32>
  %rems = vector.remsi %sub, %c : vector<2xi32>
  %remu = vector.remui %a, %c : vector<2xi32>
  %ceilsi = vector.ceildivsi %sub, %c : vector<2xi32>
  %ceilui = vector.ceildivui %a, %c : vector<2xi32>
  %floorsi = vector.floordivsi %sub, %c : vector<2xi32>
  %neg = vector.negi %floorsi : vector<2xi32>
  %abs = vector.absi %neg : vector<2xi32>
  %minsi = vector.minsi %abs, %rems : vector<2xi32>
  %maxsi = vector.maxsi %minsi, %remu : vector<2xi32>
  %minui = vector.minui %maxsi, %divu : vector<2xi32>
  %maxui = vector.maxui %minui, %divs : vector<2xi32>
  %fma = vector.fmai<nsw> %maxui, %b, %ceilsi : vector<2xi32>
  %shl = vector.shli<nuw> %fma, %c : vector<2xi32>
  %shrs = vector.shrsi %shl, %c : vector<2xi32>
  %shru = vector.shrui %shl, %c : vector<2xi32>
  %rotl = vector.rotli %shrs, %c : vector<2xi32>
  %rotr = vector.rotri %shru, %c : vector<2xi32>
  %clz = vector.ctlzi %rotl : vector<2xi32>
  %ctz = vector.cttzi %rotr : vector<2xi32>
  %pop = vector.ctpopi %ctz : vector<2xi32>
  %r = vector.signi %pop : vector<2xi32>
  test.use %ceilui : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ----
func.def @static_integer_wave2(%a: vector<2xi32>, %b: vector<2xi32>, %c: vector<2xi32>) -> (vector<2xi32>) {
  %115 = vector.extract %a[0] : vector<2xi32> -> i32
  %116 = vector.extract %c[0] : vector<2xi32> -> i32
  %117 = scalar.ceildivui %115, %116 : i32
  %118 = vector.extract %a[1] : vector<2xi32> -> i32
  %119 = vector.extract %c[1] : vector<2xi32> -> i32
  %120 = scalar.ceildivui %118, %119 : i32
  %ceilui = vector.from_elements %117, %120 : i32, i32 -> vector<2xi32>
  %28 = vector.extract %a[0] : vector<2xi32> -> i32
  %29 = vector.extract %b[0] : vector<2xi32> -> i32
  %30 = scalar.subi<nuw> %28, %29 : i32
  %31 = vector.extract %c[0] : vector<2xi32> -> i32
  %32 = scalar.floordivsi %30, %31 : i32
  %33 = scalar.negi %32 : i32
  %34 = scalar.absi %33 : i32
  %35 = vector.extract %a[0] : vector<2xi32> -> i32
  %36 = vector.extract %b[0] : vector<2xi32> -> i32
  %37 = scalar.subi<nuw> %35, %36 : i32
  %38 = vector.extract %c[0] : vector<2xi32> -> i32
  %39 = scalar.remsi %37, %38 : i32
  %40 = scalar.minsi %34, %39 : i32
  %41 = vector.extract %a[0] : vector<2xi32> -> i32
  %42 = vector.extract %c[0] : vector<2xi32> -> i32
  %43 = scalar.remui %41, %42 : i32
  %44 = scalar.maxsi %40, %43 : i32
  %45 = vector.extract %a[0] : vector<2xi32> -> i32
  %46 = vector.extract %c[0] : vector<2xi32> -> i32
  %47 = scalar.divui %45, %46 : i32
  %48 = scalar.minui %44, %47 : i32
  %49 = vector.extract %a[0] : vector<2xi32> -> i32
  %50 = vector.extract %b[0] : vector<2xi32> -> i32
  %51 = scalar.subi<nuw> %49, %50 : i32
  %52 = vector.extract %c[0] : vector<2xi32> -> i32
  %53 = scalar.divsi %51, %52 : i32
  %54 = scalar.maxui %48, %53 : i32
  %55 = vector.extract %b[0] : vector<2xi32> -> i32
  %56 = vector.extract %a[0] : vector<2xi32> -> i32
  %57 = vector.extract %b[0] : vector<2xi32> -> i32
  %58 = scalar.subi<nuw> %56, %57 : i32
  %59 = vector.extract %c[0] : vector<2xi32> -> i32
  %60 = scalar.ceildivsi %58, %59 : i32
  %61 = scalar.fmai<nsw> %54, %55, %60 : i32
  %62 = vector.extract %c[0] : vector<2xi32> -> i32
  %63 = scalar.shli<nuw> %61, %62 : i32
  %64 = vector.extract %c[0] : vector<2xi32> -> i32
  %65 = scalar.shrui %63, %64 : i32
  %66 = vector.extract %c[0] : vector<2xi32> -> i32
  %67 = scalar.rotri %65, %66 : i32
  %68 = scalar.cttzi %67 : i32
  %69 = scalar.ctpopi %68 : i32
  %70 = scalar.signi %69 : i32
  %71 = vector.extract %a[1] : vector<2xi32> -> i32
  %72 = vector.extract %b[1] : vector<2xi32> -> i32
  %73 = scalar.subi<nuw> %71, %72 : i32
  %74 = vector.extract %c[1] : vector<2xi32> -> i32
  %75 = scalar.floordivsi %73, %74 : i32
  %76 = scalar.negi %75 : i32
  %77 = scalar.absi %76 : i32
  %78 = vector.extract %a[1] : vector<2xi32> -> i32
  %79 = vector.extract %b[1] : vector<2xi32> -> i32
  %80 = scalar.subi<nuw> %78, %79 : i32
  %81 = vector.extract %c[1] : vector<2xi32> -> i32
  %82 = scalar.remsi %80, %81 : i32
  %83 = scalar.minsi %77, %82 : i32
  %84 = vector.extract %a[1] : vector<2xi32> -> i32
  %85 = vector.extract %c[1] : vector<2xi32> -> i32
  %86 = scalar.remui %84, %85 : i32
  %87 = scalar.maxsi %83, %86 : i32
  %88 = vector.extract %a[1] : vector<2xi32> -> i32
  %89 = vector.extract %c[1] : vector<2xi32> -> i32
  %90 = scalar.divui %88, %89 : i32
  %91 = scalar.minui %87, %90 : i32
  %92 = vector.extract %a[1] : vector<2xi32> -> i32
  %93 = vector.extract %b[1] : vector<2xi32> -> i32
  %94 = scalar.subi<nuw> %92, %93 : i32
  %95 = vector.extract %c[1] : vector<2xi32> -> i32
  %96 = scalar.divsi %94, %95 : i32
  %97 = scalar.maxui %91, %96 : i32
  %98 = vector.extract %b[1] : vector<2xi32> -> i32
  %99 = vector.extract %a[1] : vector<2xi32> -> i32
  %100 = vector.extract %b[1] : vector<2xi32> -> i32
  %101 = scalar.subi<nuw> %99, %100 : i32
  %102 = vector.extract %c[1] : vector<2xi32> -> i32
  %103 = scalar.ceildivsi %101, %102 : i32
  %104 = scalar.fmai<nsw> %97, %98, %103 : i32
  %105 = vector.extract %c[1] : vector<2xi32> -> i32
  %106 = scalar.shli<nuw> %104, %105 : i32
  %107 = vector.extract %c[1] : vector<2xi32> -> i32
  %108 = scalar.shrui %106, %107 : i32
  %109 = vector.extract %c[1] : vector<2xi32> -> i32
  %110 = scalar.rotri %108, %109 : i32
  %111 = scalar.cttzi %110 : i32
  %112 = scalar.ctpopi %111 : i32
  %113 = scalar.signi %112 : i32
  %r = vector.from_elements %70, %113 : i32, i32 -> vector<2xi32>
  test.use %ceilui : vector<2xi32>
  func.return %r : vector<2xi32>
}

// ====

// Direct bit/rotate/count coverage keeps the descriptor test readable.
func.def @static_bit_count_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %shrs = vector.shrsi %a, %b : vector<2xi32>
  %rotl = vector.rotli %a, %b : vector<2xi32>
  %clz = vector.ctlzi %a : vector<2xi32>
  func.return %shrs, %rotl, %clz : vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ----
func.def @static_bit_count_wave2(%a: vector<2xi32>, %b: vector<2xi32>) -> (vector<2xi32>, vector<2xi32>, vector<2xi32>) {
  %20 = vector.extract %a[0] : vector<2xi32> -> i32
  %21 = vector.extract %b[0] : vector<2xi32> -> i32
  %22 = scalar.shrsi %20, %21 : i32
  %23 = vector.extract %a[1] : vector<2xi32> -> i32
  %24 = vector.extract %b[1] : vector<2xi32> -> i32
  %25 = scalar.shrsi %23, %24 : i32
  %shrs = vector.from_elements %22, %25 : i32, i32 -> vector<2xi32>
  %13 = vector.extract %a[0] : vector<2xi32> -> i32
  %14 = vector.extract %b[0] : vector<2xi32> -> i32
  %15 = scalar.rotli %13, %14 : i32
  %16 = vector.extract %a[1] : vector<2xi32> -> i32
  %17 = vector.extract %b[1] : vector<2xi32> -> i32
  %18 = scalar.rotli %16, %17 : i32
  %rotl = vector.from_elements %15, %18 : i32, i32 -> vector<2xi32>
  %8 = vector.extract %a[0] : vector<2xi32> -> i32
  %9 = scalar.ctlzi %8 : i32
  %10 = vector.extract %a[1] : vector<2xi32> -> i32
  %11 = scalar.ctlzi %10 : i32
  %clz = vector.from_elements %9, %11 : i32, i32 -> vector<2xi32>
  func.return %shrs, %rotl, %clz : vector<2xi32>, vector<2xi32>, vector<2xi32>
}

// ====

// Predicate and sign ops can change element type while preserving vector shape.
func.def @static_predicate_wave2(%a: vector<2xf32>, %i: vector<2xi32>) -> (vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>) {
  %is_nan = vector.isnanf %a : vector<2xf32> -> vector<2xi1>
  %is_inf = vector.isinff %a : vector<2xf32> -> vector<2xi1>
  %is_finite = vector.isfinitef %a : vector<2xf32> -> vector<2xi1>
  %fsign = vector.signf %a : vector<2xf32>
  %isign = vector.signi %i : vector<2xi32>
  func.return %is_nan, %is_inf, %is_finite, %fsign, %isign : vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>
}

// ----
func.def @static_predicate_wave2(%a: vector<2xf32>, %i: vector<2xi32>) -> (vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>) {
  %32 = vector.extract %a[0] : vector<2xf32> -> f32
  %33 = scalar.isnanf %32 : f32
  %34 = vector.extract %a[1] : vector<2xf32> -> f32
  %35 = scalar.isnanf %34 : f32
  %is_nan = vector.from_elements %33, %35 : i1, i1 -> vector<2xi1>
  %27 = vector.extract %a[0] : vector<2xf32> -> f32
  %28 = scalar.isinff %27 : f32
  %29 = vector.extract %a[1] : vector<2xf32> -> f32
  %30 = scalar.isinff %29 : f32
  %is_inf = vector.from_elements %28, %30 : i1, i1 -> vector<2xi1>
  %22 = vector.extract %a[0] : vector<2xf32> -> f32
  %23 = scalar.isfinitef %22 : f32
  %24 = vector.extract %a[1] : vector<2xf32> -> f32
  %25 = scalar.isfinitef %24 : f32
  %is_finite = vector.from_elements %23, %25 : i1, i1 -> vector<2xi1>
  %17 = vector.extract %a[0] : vector<2xf32> -> f32
  %18 = scalar.signf %17 : f32
  %19 = vector.extract %a[1] : vector<2xf32> -> f32
  %20 = scalar.signf %19 : f32
  %fsign = vector.from_elements %18, %20 : f32, f32 -> vector<2xf32>
  %12 = vector.extract %i[0] : vector<2xi32> -> i32
  %13 = scalar.signi %12 : i32
  %14 = vector.extract %i[1] : vector<2xi32> -> i32
  %15 = scalar.signi %14 : i32
  %isign = vector.from_elements %13, %15 : i32, i32 -> vector<2xi32>
  func.return %is_nan, %is_inf, %is_finite, %fsign, %isign : vector<2xi1>, vector<2xi1>, vector<2xi1>, vector<2xf32>, vector<2xi32>
}

// ====

// Dynamic predicate results initialize an i1 vector and update lanes in a loop.
func.def @dynamic_float_predicate(%n: index, %a: vector<[%n]xf32>) -> (vector<[%n]xi1>) {
  %r = vector.isfinitef %a : vector<[%n]xf32> -> vector<[%n]xi1>
  func.return %r : vector<[%n]xi1>
}

// ----
func.def @dynamic_float_predicate(%n: index, %a: vector<[%n]xf32>) -> (vector<[%n]xi1>) {
  %4 = vector.constant false : vector<[%n]xi1>
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %4 : vector<[%n]xi1>) -> (vector<[%n]xi1>) {
    %10 = vector.extract %a[%7] : vector<[%n]xf32> -> f32
    %11 = scalar.isfinitef %10 : f32
    %12 = vector.insert %11 into %8[%7] : i1, vector<[%n]xi1> -> vector<[%n]xi1>
    scf.yield %12 : vector<[%n]xi1>
  }
  func.return %r : vector<[%n]xi1>
}

// ====

// Reductions expose scalar accumulator order directly.
func.def @static_reduce(%v: vector<4xf32>, %zero: f32) -> (f32) {
  %r = vector.reduce<addf> %v, %zero : vector<4xf32> -> f32
  func.return %r : f32
}

// ----
func.def @static_reduce(%v: vector<4xf32>, %zero: f32) -> (f32) {
  %4 = vector.extract %v[0] : vector<4xf32> -> f32
  %5 = scalar.addf %zero, %4 : f32
  %6 = vector.extract %v[1] : vector<4xf32> -> f32
  %7 = scalar.addf %5, %6 : f32
  %8 = vector.extract %v[2] : vector<4xf32> -> f32
  %9 = scalar.addf %7, %8 : f32
  %10 = vector.extract %v[3] : vector<4xf32> -> f32
  %r = scalar.addf %9, %10 : f32
  func.return %r : f32
}

// ====

// Producer lanes feeding reductions are materialized directly instead of
// packing a temporary vector only to extract it again.
func.def @producer_reduce(%a: vector<4xi32>, %b: vector<4xi32>, %zero: i32) -> (i32) {
  %sum = vector.addi %a, %b : vector<4xi32>
  %r = vector.reduce<addi> %sum, %zero : vector<4xi32> -> i32
  func.return %r : i32
}

// ----
func.def @producer_reduce(%a: vector<4xi32>, %b: vector<4xi32>, %zero: i32) -> (i32) {
  %6 = vector.extract %a[0] : vector<4xi32> -> i32
  %7 = vector.extract %b[0] : vector<4xi32> -> i32
  %8 = scalar.addi %6, %7 : i32
  %9 = scalar.addi %zero, %8 : i32
  %10 = vector.extract %a[1] : vector<4xi32> -> i32
  %11 = vector.extract %b[1] : vector<4xi32> -> i32
  %12 = scalar.addi %10, %11 : i32
  %13 = scalar.addi %9, %12 : i32
  %14 = vector.extract %a[2] : vector<4xi32> -> i32
  %15 = vector.extract %b[2] : vector<4xi32> -> i32
  %16 = scalar.addi %14, %15 : i32
  %17 = scalar.addi %13, %16 : i32
  %18 = vector.extract %a[3] : vector<4xi32> -> i32
  %19 = vector.extract %b[3] : vector<4xi32> -> i32
  %20 = scalar.addi %18, %19 : i32
  %r = scalar.addi %17, %20 : i32
  func.return %r : i32
}

// ====

// Replacing a named result with a pre-existing value must not rename that
// replacement.
func.def @empty_reduce_preserves_init_name(%v: vector<0xi32>, %zero: i32) -> (i32) {
  %r = vector.reduce<addi> %v, %zero : vector<0xi32> -> i32
  func.return %r : i32
}

// ----
func.def @empty_reduce_preserves_init_name(%v: vector<0xi32>, %zero: i32) -> (i32) {
  func.return %zero : i32
}

// ====

// Dynamic reductions use scf.for with a scalar carried accumulator.
func.def @dynamic_reduce(%n: index, %v: vector<[%n]xi32>, %zero: i32) -> (i32) {
  %r = vector.reduce<addi> %v, %zero : vector<[%n]xi32> -> i32
  func.return %r : i32
}

// ----
func.def @dynamic_reduce(%n: index, %v: vector<[%n]xi32>, %zero: i32) -> (i32) {
  %5 = index.constant 0 : index
  %6 = index.constant 1 : index
  %r = scf.for %7 = [%5 to %n step %6](%8 = %zero : i32) -> (i32) {
    %10 = vector.extract %v[%7] : vector<[%n]xi32> -> i32
    %11 = scalar.addi %8, %10 : i32
    scf.yield %11 : i32
  }
  func.return %r : i32
}

// ====

// vector.dotf lowers through scalar.fmaf so the fused dot semantics survive.
func.def @dotf(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %r = vector.dotf %lhs, %rhs, %acc : vector<4xf32>, vector<4xf32> -> f32
  func.return %r : f32
}

// ----
func.def @dotf(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %5 = vector.extract %lhs[0] : vector<4xf32> -> f32
  %6 = vector.extract %rhs[0] : vector<4xf32> -> f32
  %7 = scalar.fmaf %5, %6, %acc : f32
  %8 = vector.extract %lhs[1] : vector<4xf32> -> f32
  %9 = vector.extract %rhs[1] : vector<4xf32> -> f32
  %10 = scalar.fmaf %8, %9, %7 : f32
  %11 = vector.extract %lhs[2] : vector<4xf32> -> f32
  %12 = vector.extract %rhs[2] : vector<4xf32> -> f32
  %13 = scalar.fmaf %11, %12, %10 : f32
  %14 = vector.extract %lhs[3] : vector<4xf32> -> f32
  %15 = vector.extract %rhs[3] : vector<4xf32> -> f32
  %r = scalar.fmaf %14, %15, %13 : f32
  func.return %r : f32
}

// ====

// Coordinate constructors lower to explicit scalar/index arithmetic.
func.def @coordinates(%n: index) -> (vector<4xindex>, vector<[%n]xi1>) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %lanes = vector.iota %c0 step %c1 : vector<4xindex>
  %mask = vector.mask.range [%c0 to %n step %c1] : index -> vector<[%n]xi1>
  func.return %lanes, %mask : vector<4xindex>, vector<[%n]xi1>
}

// ----
func.def @coordinates(%n: index) -> (vector<4xindex>, vector<[%n]xi1>) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %17 = index.constant 0 : index
  %18 = index.mul %17, %c1 : index
  %19 = index.add %c0, %18 : index
  %20 = index.constant 1 : index
  %21 = index.mul %20, %c1 : index
  %22 = index.add %c0, %21 : index
  %23 = index.constant 2 : index
  %24 = index.mul %23, %c1 : index
  %25 = index.add %c0, %24 : index
  %26 = index.constant 3 : index
  %27 = index.mul %26, %c1 : index
  %28 = index.add %c0, %27 : index
  %lanes = vector.from_elements %19, %22, %25, %28 : index, index, index, index -> vector<4xindex>
  %7 = vector.constant false : vector<[%n]xi1>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %mask = scf.for %10 = [%8 to %n step %9](%11 = %7 : vector<[%n]xi1>) -> (vector<[%n]xi1>) {
    %13 = index.mul %10, %c1 : index
    %14 = index.add %c0, %13 : index
    %15 = index.cmp slt, %14, %n : index
    %16 = vector.insert %15 into %11[%10] : i1, vector<[%n]xi1> -> vector<[%n]xi1>
    scf.yield %16 : vector<[%n]xi1>
  }
  func.return %lanes, %mask : vector<4xindex>, vector<[%n]xi1>
}

// ====

func.def @integer_coordinates(%limit: i32) -> (vector<4xi32>, vector<4xi1>) {
  %c0 = scalar.constant 0 : i32
  %c2 = scalar.constant 2 : i32
  %lanes = vector.iota %c0 step %c2 : vector<4xi32>
  %mask = vector.mask.range [%c0 to %limit step %c2] : i32 -> vector<4xi1>
  func.return %lanes, %mask : vector<4xi32>, vector<4xi1>
}

// ----
func.def @integer_coordinates(%limit: i32) -> (vector<4xi32>, vector<4xi1>) {
  %c0 = scalar.constant 0 : i32
  %c2 = scalar.constant 2 : i32
  %24 = scalar.constant 0 : i32
  %25 = scalar.muli %24, %c2 : i32
  %26 = scalar.addi %c0, %25 : i32
  %27 = scalar.constant 1 : i32
  %28 = scalar.muli %27, %c2 : i32
  %29 = scalar.addi %c0, %28 : i32
  %30 = scalar.constant 2 : i32
  %31 = scalar.muli %30, %c2 : i32
  %32 = scalar.addi %c0, %31 : i32
  %33 = scalar.constant 3 : i32
  %34 = scalar.muli %33, %c2 : i32
  %35 = scalar.addi %c0, %34 : i32
  %lanes = vector.from_elements %26, %29, %32, %35 : i32, i32, i32, i32 -> vector<4xi32>
  %7 = scalar.constant 0 : i32
  %8 = scalar.muli %7, %c2 : i32
  %9 = scalar.addi %c0, %8 : i32
  %10 = scalar.cmpi slt, %9, %limit : i32
  %11 = scalar.constant 1 : i32
  %12 = scalar.muli %11, %c2 : i32
  %13 = scalar.addi %c0, %12 : i32
  %14 = scalar.cmpi slt, %13, %limit : i32
  %15 = scalar.constant 2 : i32
  %16 = scalar.muli %15, %c2 : i32
  %17 = scalar.addi %c0, %16 : i32
  %18 = scalar.cmpi slt, %17, %limit : i32
  %19 = scalar.constant 3 : i32
  %20 = scalar.muli %19, %c2 : i32
  %21 = scalar.addi %c0, %20 : i32
  %22 = scalar.cmpi slt, %21, %limit : i32
  %mask = vector.from_elements %10, %14, %18, %22 : i1, i1, i1, i1 -> vector<4xi1>
  func.return %lanes, %mask : vector<4xi32>, vector<4xi1>
}

// ====

// Static aggregate constructors expose lanes but keep vector.from_elements as
// the explicit vector ABI boundary.
func.def @static_constant_poison() -> (vector<2xi32>, vector<2xf32>) {
  %c = vector.constant 7 : vector<2xi32>
  %p = vector.poison : vector<2xf32>
  func.return %c, %p : vector<2xi32>, vector<2xf32>
}

// ----
func.def @static_constant_poison() -> (vector<2xi32>, vector<2xf32>) {
  %7 = scalar.constant 7 : i32
  %8 = scalar.constant 7 : i32
  %c = vector.from_elements %7, %8 : i32, i32 -> vector<2xi32>
  %4 = scalar.poison : f32
  %5 = scalar.poison : f32
  %p = vector.from_elements %4, %5 : f32, f32 -> vector<2xf32>
  func.return %c, %p : vector<2xi32>, vector<2xf32>
}

// ====

// Empty vectors are already the canonical zero-lane aggregate boundary.
func.def @empty_boundary() -> (vector<0xf32>) {
  %r = vector.empty : vector<0xf32>
  func.return %r : vector<0xf32>
}

// ====

// Static register rearrangements become direct scalar lane selections.
func.def @static_rearrange(%a: vector<4xi32>, %b: vector<4xi32>, %x: i32) -> (vector<4xi32>) {
  %wide = vector.concat<0> %a, %b : vector<4xi32>, vector<4xi32> -> vector<8xi32>
  %slice = vector.slice %wide[2] : vector<8xi32> -> vector<4xi32>
  %shuffle = vector.shuffle<[3, 2, 1, 0]> %slice : vector<4xi32>
  %r = vector.insert %x into %shuffle[1] : i32, vector<4xi32> -> vector<4xi32>
  func.return %r : vector<4xi32>
}

// ----
func.def @static_rearrange(%a: vector<4xi32>, %b: vector<4xi32>, %x: i32) -> (vector<4xi32>) {
  %8 = vector.extract %b[1] : vector<4xi32> -> i32
  %9 = vector.extract %a[3] : vector<4xi32> -> i32
  %10 = vector.extract %a[2] : vector<4xi32> -> i32
  %r = vector.from_elements %8, %x, %9, %10 : i32, i32, i32, i32 -> vector<4xi32>
  func.return %r : vector<4xi32>
}

// ====

// Broadcast, transpose, and lane-compatible bitcast compose through the same
// lane-program path.
func.def @static_broadcast_transpose_bitcast(%v: vector<2xi32>) -> (vector<2x2xf32>) {
  %wide = vector.broadcast %v : vector<2xi32> -> vector<2x2xi32>
  %t = vector.transpose<[1, 0]> %wide : vector<2x2xi32> -> vector<2x2xi32>
  %r = vector.bitcast %t : vector<2x2xi32> to vector<2x2xf32>
  func.return %r : vector<2x2xf32>
}

// ----
func.def @static_broadcast_transpose_bitcast(%v: vector<2xi32>) -> (vector<2x2xf32>) {
  %5 = vector.extract %v[0] : vector<2xi32> -> i32
  %6 = scalar.bitcast %5 : i32 to f32
  %7 = vector.extract %v[0] : vector<2xi32> -> i32
  %8 = scalar.bitcast %7 : i32 to f32
  %9 = vector.extract %v[1] : vector<2xi32> -> i32
  %10 = scalar.bitcast %9 : i32 to f32
  %11 = vector.extract %v[1] : vector<2xi32> -> i32
  %12 = scalar.bitcast %11 : i32 to f32
  %r = vector.from_elements %6, %8, %10, %12 : f32, f32, f32, f32 -> vector<2x2xf32>
  func.return %r : vector<2x2xf32>
}

// ====

// Multi-result deinterleave lowers each result independently and can see
// through a static interleave producer.
func.def @static_interleave_deinterleave(%a: vector<2xi8>, %b: vector<2xi8>) -> (vector<4xi8>, vector<2xi8>, vector<2xi8>) {
  %paired = vector.interleave<0> %a, %b : vector<2xi8>, vector<2xi8> -> vector<4xi8>
  %even, %odd = vector.deinterleave<0> %paired : vector<4xi8> -> vector<2xi8>, vector<2xi8>
  func.return %paired, %even, %odd : vector<4xi8>, vector<2xi8>, vector<2xi8>
}

// ----
func.def @static_interleave_deinterleave(%a: vector<2xi8>, %b: vector<2xi8>) -> (vector<4xi8>, vector<2xi8>, vector<2xi8>) {
  %14 = vector.extract %a[0] : vector<2xi8> -> i8
  %15 = vector.extract %b[0] : vector<2xi8> -> i8
  %16 = vector.extract %a[1] : vector<2xi8> -> i8
  %17 = vector.extract %b[1] : vector<2xi8> -> i8
  %paired = vector.from_elements %14, %15, %16, %17 : i8, i8, i8, i8 -> vector<4xi8>
  %8 = vector.extract %a[0] : vector<2xi8> -> i8
  %9 = vector.extract %a[1] : vector<2xi8> -> i8
  %even = vector.from_elements %8, %9 : i8, i8 -> vector<2xi8>
  %11 = vector.extract %b[0] : vector<2xi8> -> i8
  %12 = vector.extract %b[1] : vector<2xi8> -> i8
  %odd = vector.from_elements %11, %12 : i8, i8 -> vector<2xi8>
  func.return %paired, %even, %odd : vector<4xi8>, vector<2xi8>, vector<2xi8>
}

// ====

// Dynamic slice offsets lower to index arithmetic feeding scalar lane extracts.
func.def @dynamic_slice(%n: index, %offset: index, %v: vector<[%n]xi32>) -> (vector<4xi32>) {
  %r = vector.slice %v[%offset] : vector<[%n]xi32> -> vector<4xi32>
  func.return %r : vector<4xi32>
}

// ----
func.def @dynamic_slice(%n: index, %offset: index, %v: vector<[%n]xi32>) -> (vector<4xi32>) {
  %5 = vector.extract %v[%offset] : vector<[%n]xi32> -> i32
  %6 = index.constant 1 : index
  %7 = index.add %offset, %6 : index
  %8 = vector.extract %v[%7] : vector<[%n]xi32> -> i32
  %9 = index.constant 2 : index
  %10 = index.add %offset, %9 : index
  %11 = vector.extract %v[%10] : vector<[%n]xi32> -> i32
  %12 = index.constant 3 : index
  %13 = index.add %offset, %12 : index
  %14 = vector.extract %v[%13] : vector<[%n]xi32> -> i32
  %r = vector.from_elements %5, %8, %11, %14 : i32, i32, i32, i32 -> vector<4xi32>
  func.return %r : vector<4xi32>
}

// ====

// Dynamic transpose uses loops over the result shape and swaps the source
// coordinates explicitly.
func.def @dynamic_transpose(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>) -> (vector<[%n]x[%m]xi32>) {
  %r = vector.transpose<[1, 0]> %v : vector<[%m]x[%n]xi32> -> vector<[%n]x[%m]xi32>
  func.return %r : vector<[%n]x[%m]xi32>
}

// ----
func.def @dynamic_transpose(%m: index, %n: index, %v: vector<[%m]x[%n]xi32>) -> (vector<[%n]x[%m]xi32>) {
  %5 = vector.constant 0 : vector<[%n]x[%m]xi32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %n step %7](%9 = %5 : vector<[%n]x[%m]xi32>) -> (vector<[%n]x[%m]xi32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %15 = scf.for %13 = [%11 to %m step %12](%14 = %9 : vector<[%n]x[%m]xi32>) -> (vector<[%n]x[%m]xi32>) {
      %16 = vector.extract %v[%13, %8] : vector<[%m]x[%n]xi32> -> i32
      %17 = vector.insert %16 into %14[%8, %13] : i32, vector<[%n]x[%m]xi32> -> vector<[%n]x[%m]xi32>
      scf.yield %17 : vector<[%n]x[%m]xi32>
    }
    scf.yield %15 : vector<[%n]x[%m]xi32>
  }
  func.return %r : vector<[%n]x[%m]xi32>
}

// ====

// Dynamic deinterleave only needs index multiply/add to map result coordinates
// to even and odd source coordinates.
func.def @dynamic_deinterleave(%full: index, %half: index, %v: vector<[%full]xi32>) -> (vector<[%half]xi32>, vector<[%half]xi32>) {
  %even, %odd = vector.deinterleave<0> %v : vector<[%full]xi32> -> vector<[%half]xi32>, vector<[%half]xi32>
  func.return %even, %odd : vector<[%half]xi32>, vector<[%half]xi32>
}

// ----
func.def @dynamic_deinterleave(%full: index, %half: index, %v: vector<[%full]xi32>) -> (vector<[%half]xi32>, vector<[%half]xi32>) {
  %7 = vector.constant 0 : vector<[%half]xi32>
  %8 = index.constant 0 : index
  %9 = index.constant 1 : index
  %even = scf.for %10 = [%8 to %half step %9](%11 = %7 : vector<[%half]xi32>) -> (vector<[%half]xi32>) {
    %13 = index.constant 2 : index
    %14 = index.mul %10, %13 : index
    %15 = vector.extract %v[%14] : vector<[%full]xi32> -> i32
    %16 = vector.insert %15 into %11[%10] : i32, vector<[%half]xi32> -> vector<[%half]xi32>
    scf.yield %16 : vector<[%half]xi32>
  }
  %17 = vector.constant 0 : vector<[%half]xi32>
  %18 = index.constant 0 : index
  %19 = index.constant 1 : index
  %odd = scf.for %20 = [%18 to %half step %19](%21 = %17 : vector<[%half]xi32>) -> (vector<[%half]xi32>) {
    %23 = index.constant 2 : index
    %24 = index.mul %20, %23 : index
    %25 = index.constant 1 : index
    %26 = index.add %24, %25 : index
    %27 = vector.extract %v[%26] : vector<[%full]xi32> -> i32
    %28 = vector.insert %27 into %21[%20] : i32, vector<[%half]xi32> -> vector<[%half]xi32>
    scf.yield %28 : vector<[%half]xi32>
  }
  func.return %even, %odd : vector<[%half]xi32>, vector<[%half]xi32>
}
