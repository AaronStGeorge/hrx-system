// RUN: pass vector-to-scalar

func.def @dynamic_leading_transform_hadamard(%n: index, %v: vector<[%n]x2xf32>) -> (vector<[%n]x2xf32>) {
  %xf = encoding.define #numeric_transform<family="hadamard", input_elems=2, output_elems=2> : encoding<transform>
  %r = vector.transform %v, %xf : vector<[%n]x2xf32>, encoding<transform> -> vector<[%n]x2xf32>
  func.return %r : vector<[%n]x2xf32>
}

// ----
func.def @dynamic_leading_transform_hadamard(%n: index, %v: vector<[%n]x2xf32>) -> (vector<[%n]x2xf32>) {
  %5 = vector.constant 0.0 : vector<[%n]x2xf32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %n step %7](%9 = %5 : vector<[%n]x2xf32>) -> (vector<[%n]x2xf32>) {
    %11 = index.constant 0 : index
    %12 = index.constant 1 : index
    %13 = index.constant 2 : index
    %16 = scf.for %14 = [%11 to %13 step %12](%15 = %9 : vector<[%n]x2xf32>) -> (vector<[%n]x2xf32>) {
      %17 = index.constant 0 : index
      %18 = vector.extract %v[%8, %17] : vector<[%n]x2xf32> -> f32
      %19 = index.constant 1 : index
      %20 = vector.extract %v[%8, %19] : vector<[%n]x2xf32> -> f32
      %21 = index.cast %14 : index to i64
      %22 = scalar.constant 1 : i64
      %23 = scalar.andi %21, %22 : i64
      %24 = scalar.constant 0 : i64
      %25 = scalar.cmpi ne, %23, %24 : i64
      %26 = scalar.negf %20 : f32
      %27 = scf.select %25, %26, %20 : f32
      %28 = scalar.addf %18, %27 : f32
      %29 = vector.insert %28 into %15[%8, %14] : f32, vector<[%n]x2xf32>
      scf.yield %29 : vector<[%n]x2xf32>
    }
    scf.yield %16 : vector<[%n]x2xf32>
  }
  func.return %r : vector<[%n]x2xf32>
}

