// ----
func.def @transform_hadamard(%v: vector<4xf32>) -> (vector<4xf32>) {
  %4 = vector.extract %v[0] : vector<4xf32> -> f32
  %5 = vector.extract %v[1] : vector<4xf32> -> f32
  %6 = scalar.addf %4, %5 : f32
  %7 = vector.extract %v[2] : vector<4xf32> -> f32
  %8 = scalar.addf %6, %7 : f32
  %9 = vector.extract %v[3] : vector<4xf32> -> f32
  %10 = scalar.addf %8, %9 : f32
  %11 = vector.extract %v[0] : vector<4xf32> -> f32
  %12 = vector.extract %v[1] : vector<4xf32> -> f32
  %13 = scalar.negf %12 : f32
  %14 = scalar.addf %11, %13 : f32
  %15 = vector.extract %v[2] : vector<4xf32> -> f32
  %16 = scalar.addf %14, %15 : f32
  %17 = vector.extract %v[3] : vector<4xf32> -> f32
  %18 = scalar.negf %17 : f32
  %19 = scalar.addf %16, %18 : f32
  %20 = vector.extract %v[0] : vector<4xf32> -> f32
  %21 = vector.extract %v[1] : vector<4xf32> -> f32
  %22 = scalar.addf %20, %21 : f32
  %23 = vector.extract %v[2] : vector<4xf32> -> f32
  %24 = scalar.negf %23 : f32
  %25 = scalar.addf %22, %24 : f32
  %26 = vector.extract %v[3] : vector<4xf32> -> f32
  %27 = scalar.negf %26 : f32
  %28 = scalar.addf %25, %27 : f32
  %29 = vector.extract %v[0] : vector<4xf32> -> f32
  %30 = vector.extract %v[1] : vector<4xf32> -> f32
  %31 = scalar.negf %30 : f32
  %32 = scalar.addf %29, %31 : f32
  %33 = vector.extract %v[2] : vector<4xf32> -> f32
  %34 = scalar.negf %33 : f32
  %35 = scalar.addf %32, %34 : f32
  %36 = vector.extract %v[3] : vector<4xf32> -> f32
  %37 = scalar.addf %35, %36 : f32
  %r = vector.from_elements %10, %19, %28, %37 : vector<4xf32>
  func.return %r : vector<4xf32>
}

