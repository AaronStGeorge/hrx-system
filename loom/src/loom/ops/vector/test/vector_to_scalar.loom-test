// ====

// Dynamic q4 pack/unpack uses the divisible-width path: each byte contains two
// four-bit logical fields.
func.def @dynamic_bitpack_q4(%n: index, %m: index, %codes: vector<[%n]xi8>, %packed: vector<[%m]xi8>) -> (vector<[%m]xi8>, vector<[%n]xi8>) {
  %stream = vector.bitpack<4> %codes : vector<[%n]xi8> -> vector<[%m]xi8>
  %unpacked = vector.bitunpacku<4> %packed : vector<[%m]xi8> -> vector<[%n]xi8>
  func.return %stream, %unpacked : vector<[%m]xi8>, vector<[%n]xi8>
}

// ----
func.def @dynamic_bitpack_q4(%n: index, %m: index, %codes: vector<[%n]xi8>, %packed: vector<[%m]xi8>) -> (vector<[%m]xi8>, vector<[%n]xi8>) {
  %26 = vector.constant 0 : vector<[%m]xi8>
  %27 = index.constant 0 : index
  %28 = index.constant 1 : index
  %stream = scf.for %29 = [%27 to %m step %28](%30 = %26 : vector<[%m]xi8>) -> (vector<[%m]xi8>) {
    %32 = index.constant 2 : index
    %33 = index.mul %29, %32 : index
    %34 = scalar.constant 0 : i8
    %35 = vector.extract %codes[%33] : vector<[%n]xi8> -> i8
    %36 = scalar.constant 15 : i8
    %37 = scalar.andi %35, %36 : i8
    %38 = scalar.ori %34, %37 : i8
    %39 = index.constant 1 : index
    %40 = index.add %33, %39 : index
    %41 = vector.extract %codes[%40] : vector<[%n]xi8> -> i8
    %42 = scalar.constant 15 : i8
    %43 = scalar.andi %41, %42 : i8
    %44 = scalar.constant 4 : i8
    %45 = scalar.shli %43, %44 : i8
    %46 = scalar.ori %38, %45 : i8
    %47 = vector.insert %46 into %30[%29] : i8, vector<[%m]xi8>
    scf.yield %47 : vector<[%m]xi8>
  }
  %8 = vector.constant 0 : vector<[%n]xi8>
  %9 = index.constant 0 : index
  %10 = index.constant 1 : index
  %unpacked = scf.for %11 = [%9 to %n step %10](%12 = %8 : vector<[%n]xi8>) -> (vector<[%n]xi8>) {
    %14 = index.constant 2 : index
    %15 = index.div %11, %14 : index
    %16 = index.constant 2 : index
    %17 = index.rem %11, %16 : index
    %18 = vector.extract %packed[%15] : vector<[%m]xi8> -> i8
    %19 = index.constant 4 : index
    %20 = index.mul %17, %19 : index
    %21 = index.cast %20 : index to i8
    %22 = scalar.shrui %18, %21 : i8
    %23 = scalar.constant 15 : i8
    %24 = scalar.andi %22, %23 : i8
    %25 = vector.insert %24 into %12[%11] : i8, vector<[%n]xi8>
    scf.yield %25 : vector<[%n]xi8>
  }
  func.return %stream, %unpacked : vector<[%m]xi8>, vector<[%n]xi8>
}

// ====

// Dynamic q3 streams force the bit-addressed fallback: fields cross byte
// boundaries, and the crossing pattern depends on the dynamic lane ordinal.
func.def @dynamic_bitpack_q3(%n: index, %m: index, %codes: vector<[%n]xi8>, %packed: vector<[%m]xi8>) -> (vector<[%m]xi8>, vector<[%n]xi8>, vector<[%n]xi8>) {
  %stream = vector.bitpack<3> %codes : vector<[%n]xi8> -> vector<[%m]xi8>
  %unpacked_u = vector.bitunpacku<3> %packed : vector<[%m]xi8> -> vector<[%n]xi8>
  %unpacked_s = vector.bitunpacks<3> %packed : vector<[%m]xi8> -> vector<[%n]xi8>
  func.return %stream, %unpacked_u, %unpacked_s : vector<[%m]xi8>, vector<[%n]xi8>, vector<[%n]xi8>
}

// ----
func.def @dynamic_bitpack_q3(%n: index, %m: index, %codes: vector<[%n]xi8>, %packed: vector<[%m]xi8>) -> (vector<[%m]xi8>, vector<[%n]xi8>, vector<[%n]xi8>) {
  %72 = vector.constant 0 : vector<[%m]xi8>
  %73 = index.constant 0 : index
  %74 = index.constant 1 : index
  %stream = scf.for %75 = [%73 to %m step %74](%76 = %72 : vector<[%m]xi8>) -> (vector<[%m]xi8>) {
    %78 = index.constant 8 : index
    %79 = index.mul %75, %78 : index
    %80 = index.constant 0 : index
    %81 = index.constant 8 : index
    %82 = index.constant 1 : index
    %83 = scalar.constant 1 : i8
    %84 = scalar.constant 0 : i8
    %87 = scf.for %85 = [%80 to %81 step %82](%86 = %84 : i8) -> (i8) {
      %88 = index.add %79, %85 : index
      %89 = index.constant 3 : index
      %90 = index.div %88, %89 : index
      %91 = index.constant 3 : index
      %92 = index.rem %88, %91 : index
      %93 = vector.extract %codes[%90] : vector<[%n]xi8> -> i8
      %94 = index.cast %92 : index to i8
      %95 = scalar.shrui %93, %94 : i8
      %96 = scalar.andi %95, %83 : i8
      %97 = index.cast %85 : index to i8
      %98 = scalar.shli %96, %97 : i8
      %99 = scalar.ori %86, %98 : i8
      scf.yield %99 : i8
    }
    %100 = vector.insert %87 into %76[%75] : i8, vector<[%m]xi8>
    scf.yield %100 : vector<[%m]xi8>
  }
  %43 = vector.constant 0 : vector<[%n]xi8>
  %44 = index.constant 0 : index
  %45 = index.constant 1 : index
  %unpacked_u = scf.for %46 = [%44 to %n step %45](%47 = %43 : vector<[%n]xi8>) -> (vector<[%n]xi8>) {
    %49 = index.constant 3 : index
    %50 = index.mul %46, %49 : index
    %51 = index.constant 0 : index
    %52 = index.constant 3 : index
    %53 = index.constant 1 : index
    %54 = scalar.constant 1 : i8
    %55 = scalar.constant 0 : i8
    %58 = scf.for %56 = [%51 to %52 step %53](%57 = %55 : i8) -> (i8) {
      %59 = index.add %50, %56 : index
      %60 = index.constant 8 : index
      %61 = index.div %59, %60 : index
      %62 = index.constant 8 : index
      %63 = index.rem %59, %62 : index
      %64 = vector.extract %packed[%61] : vector<[%m]xi8> -> i8
      %65 = index.cast %63 : index to i8
      %66 = scalar.shrui %64, %65 : i8
      %67 = scalar.andi %66, %54 : i8
      %68 = index.cast %56 : index to i8
      %69 = scalar.shli %67, %68 : i8
      %70 = scalar.ori %57, %69 : i8
      scf.yield %70 : i8
    }
    %71 = vector.insert %58 into %47[%46] : i8, vector<[%n]xi8>
    scf.yield %71 : vector<[%n]xi8>
  }
  %10 = vector.constant 0 : vector<[%n]xi8>
  %11 = index.constant 0 : index
  %12 = index.constant 1 : index
  %unpacked_s = scf.for %13 = [%11 to %n step %12](%14 = %10 : vector<[%n]xi8>) -> (vector<[%n]xi8>) {
    %16 = index.constant 3 : index
    %17 = index.mul %13, %16 : index
    %18 = index.constant 0 : index
    %19 = index.constant 3 : index
    %20 = index.constant 1 : index
    %21 = scalar.constant 1 : i8
    %22 = scalar.constant 0 : i8
    %25 = scf.for %23 = [%18 to %19 step %20](%24 = %22 : i8) -> (i8) {
      %26 = index.add %17, %23 : index
      %27 = index.constant 8 : index
      %28 = index.div %26, %27 : index
      %29 = index.constant 8 : index
      %30 = index.rem %26, %29 : index
      %31 = vector.extract %packed[%28] : vector<[%m]xi8> -> i8
      %32 = index.cast %30 : index to i8
      %33 = scalar.shrui %31, %32 : i8
      %34 = scalar.andi %33, %21 : i8
      %35 = index.cast %23 : index to i8
      %36 = scalar.shli %34, %35 : i8
      %37 = scalar.ori %24, %36 : i8
      scf.yield %37 : i8
    }
    %38 = scalar.constant 5 : i8
    %39 = scalar.shli %25, %38 : i8
    %40 = scalar.constant 5 : i8
    %41 = scalar.shrsi %39, %40 : i8
    %42 = vector.insert %41 into %14[%13] : i8, vector<[%n]xi8>
    scf.yield %42 : vector<[%n]xi8>
  }
  func.return %stream, %unpacked_u, %unpacked_s : vector<[%m]xi8>, vector<[%n]xi8>, vector<[%n]xi8>
}

// ====

// Table lookup keeps the register table explicit while exposing the per-lane
// integer-to-index boundary used to select decoded values.
func.def @static_table_lookup(%table: vector<4xf32>) -> (vector<2xf32>) {
  %i0 = scalar.constant 3 : i8
  %i1 = scalar.constant 0 : i8
  %codes = vector.from_elements %i0, %i1 : vector<2xi8>
  %r = vector.table.lookup %table[%codes] : vector<4xf32>, vector<2xi8> -> vector<2xf32>
  func.return %r : vector<2xf32>
}

// ----
func.def @static_table_lookup(%table: vector<4xf32>) -> (vector<2xf32>) {
  %i0 = scalar.constant 3 : i8
  %i1 = scalar.constant 0 : i8
  %6 = index.cast %i0 : i8 to index
  %7 = vector.extract %table[%6] : vector<4xf32> -> f32
  %8 = index.cast %i1 : i8 to index
  %9 = vector.extract %table[%8] : vector<4xf32> -> f32
  %r = vector.from_elements %7, %9 : vector<2xf32>
  func.return %r : vector<2xf32>
}

// ====

// Dynamic table lookup uses the same aggregate loop shape as lanewise ops and
// performs the code-lane cast inside the loop body.
func.def @dynamic_table_lookup(%n: index, %table: vector<4xf32>, %codes: vector<[%n]xi8>) -> (vector<[%n]xf32>) {
  %r = vector.table.lookup %table[%codes] : vector<4xf32>, vector<[%n]xi8> -> vector<[%n]xf32>
  func.return %r : vector<[%n]xf32>
}

// ----
func.def @dynamic_table_lookup(%n: index, %table: vector<4xf32>, %codes: vector<[%n]xi8>) -> (vector<[%n]xf32>) {
  %5 = vector.constant 0.0 : vector<[%n]xf32>
  %6 = index.constant 0 : index
  %7 = index.constant 1 : index
  %r = scf.for %8 = [%6 to %n step %7](%9 = %5 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %11 = vector.extract %codes[%8] : vector<[%n]xi8> -> i8
    %12 = index.cast %11 : i8 to index
    %13 = vector.extract %table[%12] : vector<4xf32> -> f32
    %14 = vector.insert %13 into %9[%8] : f32, vector<[%n]xf32>
    scf.yield %14 : vector<[%n]xf32>
  }
  func.return %r : vector<[%n]xf32>
}

// ====

// Static table quantize spells out compare-and-count semantics. tie=upper
// counts thresholds equal to the value, and nan=max selects the top code.
func.def @static_table_quantize(%values: vector<2xf32>) -> (vector<2xi8>) {
  %t0 = scalar.constant -1.0 : f32
  %t1 = scalar.constant 0.0 : f32
  %t2 = scalar.constant 1.0 : f32
  %thresholds = vector.from_elements %t0, %t1, %t2 : vector<3xf32>
  %r = vector.table.quantize %values, %thresholds {nan = max, tie = upper} : vector<2xf32>, vector<3xf32> -> vector<2xi8>
  func.return %r : vector<2xi8>
}

// ----
func.def @static_table_quantize(%values: vector<2xf32>) -> (vector<2xi8>) {
  %t0 = scalar.constant -1.0 : f32
  %t1 = scalar.constant 0.0 : f32
  %t2 = scalar.constant 1.0 : f32
  %7 = vector.extract %values[0] : vector<2xf32> -> f32
  %8 = scalar.constant 0 : i8
  %9 = scalar.cmpf ole, %t0, %7 : f32
  %10 = scalar.constant 1 : i8
  %11 = scalar.addi %8, %10 : i8
  %12 = scf.select %9, %11, %8 : i8
  %13 = scalar.cmpf ole, %t1, %7 : f32
  %14 = scalar.constant 1 : i8
  %15 = scalar.addi %12, %14 : i8
  %16 = scf.select %13, %15, %12 : i8
  %17 = scalar.cmpf ole, %t2, %7 : f32
  %18 = scalar.constant 1 : i8
  %19 = scalar.addi %16, %18 : i8
  %20 = scf.select %17, %19, %16 : i8
  %21 = scalar.constant 3 : i8
  %22 = scalar.isnanf %7 : f32
  %23 = scf.select %22, %21, %20 : i8
  %24 = vector.extract %values[1] : vector<2xf32> -> f32
  %25 = scalar.constant 0 : i8
  %26 = scalar.cmpf ole, %t0, %24 : f32
  %27 = scalar.constant 1 : i8
  %28 = scalar.addi %25, %27 : i8
  %29 = scf.select %26, %28, %25 : i8
  %30 = scalar.cmpf ole, %t1, %24 : f32
  %31 = scalar.constant 1 : i8
  %32 = scalar.addi %29, %31 : i8
  %33 = scf.select %30, %32, %29 : i8
  %34 = scalar.cmpf ole, %t2, %24 : f32
  %35 = scalar.constant 1 : i8
  %36 = scalar.addi %33, %35 : i8
  %37 = scf.select %34, %36, %33 : i8
  %38 = scalar.constant 3 : i8
  %39 = scalar.isnanf %24 : f32
  %40 = scf.select %39, %38, %37 : i8
  %r = vector.from_elements %23, %40 : vector<2xi8>
  func.return %r : vector<2xi8>
}

// ====

// Dynamic table quantize nests a scalar threshold loop inside the result-lane
// aggregate loop, giving the portable reference path for runtime threshold
// tables.
func.def @dynamic_table_quantize(%n: index, %k: index, %values: vector<[%n]xf32>, %thresholds: vector<[%k]xf32>) -> (vector<[%n]xi8>) {
  %r = vector.table.quantize %values, %thresholds {nan = max, tie = lower} : vector<[%n]xf32>, vector<[%k]xf32> -> vector<[%n]xi8>
  func.return %r : vector<[%n]xi8>
}

// ----
func.def @dynamic_table_quantize(%n: index, %k: index, %values: vector<[%n]xf32>, %thresholds: vector<[%k]xf32>) -> (vector<[%n]xi8>) {
  %6 = vector.constant 0 : vector<[%n]xi8>
  %7 = index.constant 0 : index
  %8 = index.constant 1 : index
  %r = scf.for %9 = [%7 to %n step %8](%10 = %6 : vector<[%n]xi8>) -> (vector<[%n]xi8>) {
    %12 = vector.extract %values[%9] : vector<[%n]xf32> -> f32
    %13 = index.constant 0 : index
    %14 = index.constant 1 : index
    %15 = scalar.constant 0 : i8
    %18 = scf.for %16 = [%13 to %k step %14](%17 = %15 : i8) -> (i8) {
      %19 = vector.extract %thresholds[%16] : vector<[%k]xf32> -> f32
      %20 = scalar.cmpf olt, %19, %12 : f32
      %21 = scalar.constant 1 : i8
      %22 = scalar.addi %17, %21 : i8
      %23 = scf.select %20, %22, %17 : i8
      scf.yield %23 : i8
    }
    %24 = index.cast %k : index to i8
    %25 = scalar.isnanf %12 : f32
    %26 = scf.select %25, %24, %18 : i8
    %27 = vector.insert %26 into %10[%9] : i8, vector<[%n]xi8>
    scf.yield %27 : vector<[%n]xi8>
  }
  func.return %r : vector<[%n]xi8>
}

