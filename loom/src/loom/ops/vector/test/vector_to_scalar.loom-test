  %21 = scalar.addi %7, %20 : i32
  %22 = scalar.shrui %5, %9 : i32
  %23 = scalar.andi %22, %8 : i32
  %24 = scalar.shrui %6, %9 : i32
  %25 = scalar.andi %24, %8 : i32
  %26 = scalar.shli %25, %15 : i32
  %27 = scalar.shrsi %26, %15 : i32
  %28 = scalar.muli %23, %27 : i32
  %29 = scalar.addi %21, %28 : i32
  %30 = scalar.shrui %5, %10 : i32
  %31 = scalar.andi %30, %8 : i32
  %32 = scalar.shrui %6, %10 : i32
  %33 = scalar.andi %32, %8 : i32
  %34 = scalar.shli %33, %15 : i32
  %35 = scalar.shrsi %34, %15 : i32
  %36 = scalar.muli %31, %35 : i32
  %37 = scalar.addi %29, %36 : i32
  %38 = scalar.shrui %5, %11 : i32
  %39 = scalar.andi %38, %8 : i32
  %40 = scalar.shrui %6, %11 : i32
  %41 = scalar.andi %40, %8 : i32
  %42 = scalar.shli %41, %15 : i32
  %43 = scalar.shrsi %42, %15 : i32
  %44 = scalar.muli %39, %43 : i32
  %45 = scalar.addi %37, %44 : i32
  %46 = scalar.shrui %5, %12 : i32
  %47 = scalar.andi %46, %8 : i32
  %48 = scalar.shrui %6, %12 : i32
  %49 = scalar.andi %48, %8 : i32
  %50 = scalar.shli %49, %15 : i32
  %51 = scalar.shrsi %50, %15 : i32
  %52 = scalar.muli %47, %51 : i32
  %53 = scalar.addi %45, %52 : i32
  %54 = scalar.shrui %5, %13 : i32
  %55 = scalar.andi %54, %8 : i32
  %56 = scalar.shrui %6, %13 : i32
  %57 = scalar.andi %56, %8 : i32
  %58 = scalar.shli %57, %15 : i32
  %59 = scalar.shrsi %58, %15 : i32
  %60 = scalar.muli %55, %59 : i32
  %61 = scalar.addi %53, %60 : i32
  %62 = scalar.shrui %5, %14 : i32
  %63 = scalar.andi %62, %8 : i32
  %64 = scalar.shrui %6, %14 : i32
  %65 = scalar.andi %64, %8 : i32
  %66 = scalar.shli %65, %15 : i32
  %67 = scalar.shrsi %66, %15 : i32
  %68 = scalar.muli %63, %67 : i32
  %69 = scalar.addi %61, %68 : i32
  %70 = scalar.shrui %5, %15 : i32
  %71 = scalar.andi %70, %8 : i32
  %72 = scalar.shrui %6, %15 : i32
  %73 = scalar.andi %72, %8 : i32
  %74 = scalar.shli %73, %15 : i32
  %75 = scalar.shrsi %74, %15 : i32
  %76 = scalar.muli %71, %75 : i32
  %77 = scalar.addi %69, %76 : i32
  %r = vector.from_elements %77 : vector<1xi32>
