    %11 = vector.extract %lhs[%8] : vector<[%n]xi32> -> i32
    %12 = vector.extract %rhs[%8] : vector<[%n]xi32> -> i32
    %13 = vector.extract %acc[%8] : vector<[%n]xi32> -> i32
    %14 = scalar.constant 15 : i32
    %15 = scalar.constant 4 : i32
    %16 = scalar.constant 8 : i32
    %17 = scalar.constant 12 : i32
    %18 = scalar.constant 16 : i32
    %19 = scalar.constant 20 : i32
    %20 = scalar.constant 24 : i32
    %21 = scalar.constant 28 : i32
    %22 = scalar.andi %11, %14 : i32
    %23 = scalar.andi %12, %14 : i32
