    %40 = scalar.shrui %12, %17 : i32
    %41 = scalar.andi %40, %14 : i32
    %42 = scalar.muli %39, %41 : i32
    %43 = scalar.addi %37, %42 : i32
    %44 = scalar.shrui %11, %18 : i32
    %45 = scalar.andi %44, %14 : i32
    %46 = scalar.shrui %12, %18 : i32
    %47 = scalar.andi %46, %14 : i32
    %48 = scalar.muli %45, %47 : i32
    %49 = scalar.addi %43, %48 : i32
    %50 = scalar.shrui %11, %19 : i32
    %51 = scalar.andi %50, %14 : i32
    %52 = scalar.shrui %12, %19 : i32
    %53 = scalar.andi %52, %14 : i32
    %54 = scalar.muli %51, %53 : i32
