  %23 = vector.extract %v[0] : vector<2xf32> -> f32
  %24 = vector.extract %signs[0] : vector<2xi1> -> i1
  %25 = scalar.negf %23 : f32
  %26 = scf.select %24, %25, %23 : f32
  %27 = scalar.negf %26 : f32
  %28 = scalar.addf %22, %27 : f32
