  %13 = scalar.addf %8, %12 : f32
  %14 = vector.extract %v[0] : vector<2xf32> -> f32
  %15 = vector.extract %signs[0] : vector<2xi1> -> i1
  %16 = scalar.negf %14 : f32
  %17 = scf.select %15, %16, %14 : f32
  %18 = vector.extract %v[1] : vector<2xf32> -> f32
  %19 = vector.extract %signs[1] : vector<2xi1> -> i1
  %20 = scalar.negf %18 : f32
  %21 = scf.select %19, %20, %18 : f32
  %22 = scalar.negf %21 : f32
  %23 = scalar.addf %17, %22 : f32
