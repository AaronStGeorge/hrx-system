// ====

// Dynamic dot8i4 carries the accumulator aggregate through the loop while each
// lane updates one packed i32 word.
func.def @dynamic_dot8i4(%n: index, %lhs: vector<[%n]xi32>, %rhs: vector<[%n]xi32>, %acc: vector<[%n]xi32>) -> (vector<[%n]xi32>) {
  %r = vector.dot8i4<u4u4> %lhs, %rhs, %acc : vector<[%n]xi32>
