  %8 = scalar.addi %6, %7 : i64
  %9 = scalar.constant 30 : i64
  %10 = scalar.shrui %8, %9 : i64
  %11 = scalar.xori %8, %10 : i64
  %12 = scalar.constant -4658895280553007687 : i64
  %13 = scalar.muli %11, %12 : i64
  %14 = scalar.constant 27 : i64
  %15 = scalar.shrui %13, %14 : i64
  %16 = scalar.xori %13, %15 : i64
  %17 = scalar.constant -7723592293110705685 : i64
  %18 = scalar.muli %16, %17 : i64
  %19 = scalar.constant 31 : i64
  %20 = scalar.shrui %18, %19 : i64
  %21 = scalar.xori %18, %20 : i64
  %22 = scalar.constant 1 : i64
  %23 = scalar.andi %21, %22 : i64
  %24 = scalar.constant 0 : i64
  %25 = scalar.cmpi ne, %23, %24 : i64
  %26 = scalar.negf %5 : f32
  %27 = scf.select %25, %26, %5 : f32
  %r = vector.from_elements %27 : vector<1xf32>
  func.return %r : vector<1xf32>
}

