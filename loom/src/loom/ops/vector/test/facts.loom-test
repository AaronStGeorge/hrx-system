// RUN: pass canonicalize

// Uniform vector.constant facts let reductions fold to scalar constants without
// materializing vector constants.
func.def @reduce_uniform_constant_addi() -> (i32) {
  %v = vector.constant 2 : vector<4xi32>
  %init = scalar.constant 7 : i32
  %r = vector.reduce<addi> %v, %init : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @reduce_uniform_constant_addi() -> (i32) {
  %r = scalar.constant 15 : i32
  func.return %r : i32
}

// ====

// Uniform facts survive vector.splat and mechanical lanewise integer ops.
func.def @reduce_uniform_splat_addi() -> (i32) {
  %a = scalar.constant 3 : i32
  %b = scalar.constant 4 : i32
  %va = vector.splat %a : vector<4xi32>
  %vb = vector.splat %b : vector<4xi32>
  %sum = vector.addi %va, %vb : vector<4xi32>
  %init = scalar.constant 1 : i32
  %r = vector.reduce<addi> %sum, %init : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @reduce_uniform_splat_addi() -> (i32) {
  %r = scalar.constant 29 : i32
  func.return %r : i32
}

// ====

// Representative lanewise float facts preserve uniform summaries through the
// expanded math surface.
func.def @reduce_uniform_float_math() -> (f32) {
  %nine = vector.constant 9.0 : vector<4xf32>
  %four = vector.constant 4.0 : vector<4xf32>
  %rem = vector.remf %nine, %four : vector<4xf32>
  %root = vector.sqrtf %nine : vector<4xf32>
  %sum = vector.addf %rem, %root : vector<4xf32>
  %init = scalar.constant 1.0 : f32
  %r = vector.reduce<addf> %sum, %init : vector<4xf32>, f32
  func.return %r : f32
}
// ----
func.def @reduce_uniform_float_math() -> (f32) {
  %r = scalar.constant 17.0 : f32
  func.return %r : f32
}

// ====

// Small per-lane float facts compose through new lanewise unary and binary ops.
func.def @small_static_float_math_extract() -> (f32) {
  %one = scalar.constant 1.0 : f32
  %four = scalar.constant 4.0 : f32
  %v = vector.from_elements %one, %four : vector<2xf32>
  %root = vector.sqrtf %v : vector<2xf32>
  %max = vector.maximumf %v, %root : vector<2xf32>
  %r = vector.extract %max[1] : vector<2xf32> -> f32
  func.return %r : f32
}
// ----
func.def @small_static_float_math_extract() -> (f32) {
  %r = scalar.constant 4.0 : f32
  func.return %r : f32
}

// ====

// Vector minimumf mirrors scalar IEEE NaN propagation instead of minnumf.
func.def @vector_minimumf_propagates_uniform_nan() -> (i1) {
  %neg = vector.constant -1.0 : vector<4xf32>
  %nan = vector.logf %neg : vector<4xf32>
  %three = vector.constant 3.0 : vector<4xf32>
  %min = vector.minimumf %nan, %three : vector<4xf32>
  %lane = vector.extract %min[0] : vector<4xf32> -> f32
  %r = scalar.isnanf %lane : f32
  func.return %r : i1
}
// ----
func.def @vector_minimumf_propagates_uniform_nan() -> (i1) {
  %r = scalar.constant true : i1
  func.return %r : i1
}

// ====

// Vector minnumf keeps the explicit NaN-skipping behavior.
func.def @vector_minnumf_skips_uniform_nan() -> (i1) {
  %neg = vector.constant -1.0 : vector<4xf32>
  %nan = vector.logf %neg : vector<4xf32>
  %three = vector.constant 3.0 : vector<4xf32>
  %min = vector.minnumf %nan, %three : vector<4xf32>
  %lane = vector.extract %min[0] : vector<4xf32> -> f32
  %r = scalar.isnanf %lane : f32
  func.return %r : i1
}
// ----
func.def @vector_minnumf_skips_uniform_nan() -> (i1) {
  %r = scalar.constant false : i1
  func.return %r : i1
}

// ====

// Identity elements can fold reductions over dynamic extents when the explicit
// accumulator is itself exact.
func.def @reduce_dynamic_zero_splat_addi(%n: index) -> (i32) {
  %zero = scalar.constant 0 : i32
  %init = scalar.constant 5 : i32
  %v = vector.splat %zero : vector<[%n]xi32>
  %r = vector.reduce<addi> %v, %init : vector<[%n]xi32>, i32
  func.return %r : i32
}
// ----
func.def @reduce_dynamic_zero_splat_addi(%n: index) -> (i32) {
  %r = scalar.constant 5 : i32
  func.return %r : i32
}

// ====

// Uniform floating-point dot products fold through fused multiply-add facts.
func.def @dotf_uniform_constants() -> (f32) {
  %lhs = vector.constant 2.0 : vector<4xf32>
  %rhs = vector.constant 3.0 : vector<4xf32>
  %init = scalar.constant 1.0 : f32
  %r = vector.dotf %lhs, %rhs, %init : vector<4xf32>, vector<4xf32>, f32
  func.return %r : f32
}
// ----
func.def @dotf_uniform_constants() -> (f32) {
  %r = scalar.constant 25.0 : f32
  func.return %r : f32
}

// ====

// Uniform mask facts let vector.select choose a whole vector fact summary.
func.def @select_uniform_true_then_reduce() -> (i32) {
  %mask = vector.constant true : vector<4xi1>
  %a = vector.constant 5 : vector<4xi32>
  %b = vector.constant 9 : vector<4xi32>
  %selected = vector.select %mask, %a, %b : vector<4xi32>
  %zero = scalar.constant 0 : i32
  %r = vector.reduce<addi> %selected, %zero : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @select_uniform_true_then_reduce() -> (i32) {
  %r = scalar.constant 20 : i32
  func.return %r : i32
}

// ====

// Per-lane facts for small static vectors let vector.from_elements feed scalar
// reductions without first materializing a vector constant.
func.def @reduce_from_elements_addi() -> (i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4 : vector<4xi32>
  %zero = scalar.constant 0 : i32
  %r = vector.reduce<addi> %v, %zero : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @reduce_from_elements_addi() -> (i32) {
  %r = scalar.constant 10 : i32
  func.return %r : i32
}

// ====

// Structural vector ops preserve uniform summaries when their lane mapping does
// not change the scalar element fact.
func.def @structural_uniform_facts() -> (i32, i32, i32, i32) {
  %seven = vector.constant 7 : vector<2xi32>
  %wide = vector.broadcast %seven : vector<2xi32> -> vector<3x2xi32>
  %r0 = vector.extract %wide[2, 1] : vector<3x2xi32> -> i32
  %four = vector.constant 4 : vector<2x3xi32>
  %transposed = vector.transpose<[1, 0]> %four : vector<2x3xi32> -> vector<3x2xi32>
  %r1 = vector.extract %transposed[1, 0] : vector<3x2xi32> -> i32
  %three = scalar.constant 3 : i32
  %threes = vector.constant 3 : vector<4xi32>
  %inserted = vector.insert %three into %threes[2] : i32, vector<4xi32>
  %r2 = vector.extract %inserted[0] : vector<4xi32> -> i32
  %one = vector.constant 1.0 : vector<4xf32>
  %bits = vector.bitcast %one : vector<4xf32> to vector<4xi32>
  %r3 = vector.extract %bits[3] : vector<4xi32> -> i32
  func.return %r0, %r1, %r2, %r3 : i32, i32, i32, i32
}
// ----
func.def @structural_uniform_facts() -> (i32, i32, i32, i32) {
  %r0 = scalar.constant 7 : i32
  %r1 = scalar.constant 4 : i32
  %r2 = scalar.constant 3 : i32
  %r3 = scalar.constant 1065353216 : i32
  func.return %r0, %r1, %r2, %r3 : i32, i32, i32, i32
}

// ====

// Broadcast facts remap trailing source axes into each result lane.
func.def @broadcast_small_static_lanes() -> (i32, i32) {
  %five = scalar.constant 5 : i32
  %six = scalar.constant 6 : i32
  %v = vector.from_elements %five, %six : vector<2xi32>
  %wide = vector.broadcast %v : vector<2xi32> -> vector<3x2xi32>
  %r0 = vector.extract %wide[1, 0] : vector<3x2xi32> -> i32
  %r1 = vector.extract %wide[2, 1] : vector<3x2xi32> -> i32
  func.return %r0, %r1 : i32, i32
}
// ----
func.def @broadcast_small_static_lanes() -> (i32, i32) {
  %r0 = scalar.constant 5 : i32
  %r1 = scalar.constant 6 : i32
  func.return %r0, %r1 : i32, i32
}

// ====

// Insert facts overwrite only the static inserted lane.
func.def @insert_scalar_small_static_lane() -> (i32, i32) {
  %one = scalar.constant 1 : i32
  %two = scalar.constant 2 : i32
  %three = scalar.constant 3 : i32
  %four = scalar.constant 4 : i32
  %nine = scalar.constant 9 : i32
  %v = vector.from_elements %one, %two, %three, %four : vector<4xi32>
  %updated = vector.insert %nine into %v[2] : i32, vector<4xi32>
  %r0 = vector.extract %updated[1] : vector<4xi32> -> i32
  %r1 = vector.extract %updated[2] : vector<4xi32> -> i32
  func.return %r0, %r1 : i32, i32
}
// ----
func.def @insert_scalar_small_static_lane() -> (i32, i32) {
  %r0 = scalar.constant 2 : i32
  %r1 = scalar.constant 9 : i32
  func.return %r0, %r1 : i32, i32
}

// ====

// Transpose facts use the same result-axis to source-axis permutation as the
// op verifier and type transfer.
func.def @transpose_small_static_lanes() -> (i32, i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %c5 = scalar.constant 5 : i32
  %c6 = scalar.constant 6 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4, %c5, %c6 : vector<2x3xi32>
  %t = vector.transpose<[1, 0]> %v : vector<2x3xi32> -> vector<3x2xi32>
  %r0 = vector.extract %t[0, 1] : vector<3x2xi32> -> i32
  %r1 = vector.extract %t[2, 1] : vector<3x2xi32> -> i32
  func.return %r0, %r1 : i32, i32
}
// ----
func.def @transpose_small_static_lanes() -> (i32, i32) {
  %r0 = scalar.constant 4 : i32
  %r1 = scalar.constant 6 : i32
  func.return %r0, %r1 : i32, i32
}

// ====

// Bitcast facts reinterpret exact same-width lanes without handling wider
// byte-pack reshapes.
func.def @bitcast_same_lane_raw_bits() -> (f32, i32) {
  %one_bits = scalar.constant 0x3f800000 : i32
  %two_bits = scalar.constant 0x40000000 : i32
  %bits = vector.from_elements %one_bits, %two_bits : vector<2xi32>
  %floats = vector.bitcast %bits : vector<2xi32> to vector<2xf32>
  %one = scalar.constant 1.0 : f32
  %two = scalar.constant 2.0 : f32
  %float_values = vector.from_elements %one, %two : vector<2xf32>
  %roundtrip = vector.bitcast %float_values : vector<2xf32> to vector<2xi32>
  %r0 = vector.extract %floats[0] : vector<2xf32> -> f32
  %r1 = vector.extract %roundtrip[1] : vector<2xi32> -> i32
  func.return %r0, %r1 : f32, i32
}
// ----
func.def @bitcast_same_lane_raw_bits() -> (f32, i32) {
  %r0 = scalar.constant 1.0 : f32
  %r1 = scalar.constant 1073741824 : i32
  func.return %r0, %r1 : f32, i32
}

// ====

// Small per-lane facts compose with uniform facts through lanewise integer ops.
func.def @small_lanewise_with_uniform_then_reduce() -> (i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %ten = scalar.constant 10 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4 : vector<4xi32>
  %offset = vector.splat %ten : vector<4xi32>
  %sum = vector.addi %v, %offset : vector<4xi32>
  %zero = scalar.constant 0 : i32
  %r = vector.reduce<addi> %sum, %zero : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @small_lanewise_with_uniform_then_reduce() -> (i32) {
  %r = scalar.constant 50 : i32
  func.return %r : i32
}

// ====

// Wave-2 integer ops preserve uniform summaries through arithmetic, min/max,
// shifts, and sign.
func.def @wave2_integer_uniform_facts() -> (i32, i32, i32, i32, i32) {
  %eighteen = vector.constant 18 : vector<4xi32>
  %five = vector.constant 5 : vector<4xi32>
  %one = vector.constant 1 : vector<4xi32>
  %sub = vector.subi %eighteen, %five : vector<4xi32>
  %div = vector.divsi %eighteen, %five : vector<4xi32>
  %rem = vector.remui %eighteen, %five : vector<4xi32>
  %min = vector.minsi %sub, %div : vector<4xi32>
  %shl = vector.shli %min, %one : vector<4xi32>
  %sign = vector.signi %sub : vector<4xi32>
  %r0 = vector.extract %sub[0] : vector<4xi32> -> i32
  %r1 = vector.extract %div[0] : vector<4xi32> -> i32
  %r2 = vector.extract %rem[0] : vector<4xi32> -> i32
  %r3 = vector.extract %shl[0] : vector<4xi32> -> i32
  %r4 = vector.extract %sign[0] : vector<4xi32> -> i32
  func.return %r0, %r1, %r2, %r3, %r4 : i32, i32, i32, i32, i32
}
// ----
func.def @wave2_integer_uniform_facts() -> (i32, i32, i32, i32, i32) {
  %r0 = scalar.constant 13 : i32
  %r1 = scalar.constant 3 : i32
  %r2 = scalar.constant 3 : i32
  %r3 = scalar.constant 6 : i32
  %r4 = scalar.constant 1 : i32
  func.return %r0, %r1, %r2, %r3, %r4 : i32, i32, i32, i32, i32
}

// ====

// Bit-count vector facts use the declared integer element width for each lane.
func.def @wave2_bit_count_small_lanes() -> (i32, i32, i32) {
  %one = scalar.constant 1 : i32
  %eight = scalar.constant 8 : i32
  %minus_one = scalar.constant -1 : i32
  %v = vector.from_elements %one, %eight, %minus_one : vector<3xi32>
  %clz = vector.ctlzi %v : vector<3xi32>
  %ctz = vector.cttzi %v : vector<3xi32>
  %pop = vector.ctpopi %v : vector<3xi32>
  %r0 = vector.extract %clz[0] : vector<3xi32> -> i32
  %r1 = vector.extract %ctz[1] : vector<3xi32> -> i32
  %r2 = vector.extract %pop[2] : vector<3xi32> -> i32
  func.return %r0, %r1, %r2 : i32, i32, i32
}
// ----
func.def @wave2_bit_count_small_lanes() -> (i32, i32, i32) {
  %r0 = scalar.constant 31 : i32
  %r1 = scalar.constant 3 : i32
  %r2 = scalar.constant 32 : i32
  func.return %r0, %r1, %r2 : i32, i32, i32
}

// ====

// Bitfield facts interpret exact lane payloads as raw typed bits, so both
// unsigned and signed field extraction can fold through scalar extracts.
func.def @bitfield_extract_small_lanes() -> (i32, i32) {
  %a0 = scalar.constant 0x1f : i16
  %a1 = scalar.constant 0xf0 : i16
  %v = vector.from_elements %a0, %a1 : vector<2xi16>
  %lo = vector.bitfield.extractu %v {offset = 0, width = 4} : vector<2xi16> -> vector<2xi32>
  %hi = vector.bitfield.extracts %v {offset = 4, width = 4} : vector<2xi16> -> vector<2xi32>
  %r0 = vector.extract %lo[0] : vector<2xi32> -> i32
  %r1 = vector.extract %hi[1] : vector<2xi32> -> i32
  func.return %r0, %r1 : i32, i32
}
// ----
func.def @bitfield_extract_small_lanes() -> (i32, i32) {
  %r0 = scalar.constant 15 : i32
  %r1 = scalar.constant -1 : i32
  func.return %r0, %r1 : i32, i32
}

// ====

// Bitpack and bitunpack facts follow the same little-endian bitstream order as
// vector-to-scalar lowering, including fields that share one storage lane.
func.def @bitpack_bitunpack_q4_round_trip() -> (i8, i8, i8) {
  %c0 = scalar.constant 0 : i8
  %c1 = scalar.constant 1 : i8
  %c2 = scalar.constant 2 : i8
  %c3 = scalar.constant 3 : i8
  %codes = vector.from_elements %c0, %c1, %c2, %c3 : vector<4xi8>
  %packed = vector.bitpack<4> %codes : vector<4xi8> -> vector<2xi8>
  %unpacked = vector.bitunpacku<4> %packed : vector<2xi8> -> vector<4xi8>
  %signed = vector.bitunpacks<4> %packed : vector<2xi8> -> vector<4xi8>
  %p1 = vector.extract %packed[1] : vector<2xi8> -> i8
  %u3 = vector.extract %unpacked[3] : vector<4xi8> -> i8
  %s3 = vector.extract %signed[3] : vector<4xi8> -> i8
  func.return %p1, %u3, %s3 : i8, i8, i8
}
// ----
func.def @bitpack_bitunpack_q4_round_trip() -> (i8, i8, i8) {
  %p1 = scalar.constant 50 : i8
  %u3 = scalar.constant 3 : i8
  %s3 = scalar.constant 3 : i8
  func.return %p1, %u3, %s3 : i8, i8, i8
}

// ====

// Table lookup facts compose exact code lanes with explicit register tables.
func.def @table_lookup_small_lanes() -> (f16, f16) {
  %g0 = scalar.constant -1.0 : f16
  %g1 = scalar.constant -0.5 : f16
  %g2 = scalar.constant 0.5 : f16
  %g3 = scalar.constant 1.0 : f16
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf16>
  %i0 = scalar.constant 3 : i8
  %i1 = scalar.constant 1 : i8
  %indices = vector.from_elements %i0, %i1 : vector<2xi8>
  %values = vector.table.lookup %grid[%indices] : vector<4xf16>, vector<2xi8> -> vector<2xf16>
  %r0 = vector.extract %values[0] : vector<2xf16> -> f16
  %r1 = vector.extract %values[1] : vector<2xf16> -> f16
  func.return %r0, %r1 : f16, f16
}
// ----
func.def @table_lookup_small_lanes() -> (f16, f16) {
  %r0 = scalar.constant 1.0 : f16
  %r1 = scalar.constant -0.5 : f16
  func.return %r0, %r1 : f16, f16
}

// ====

// Table quantization facts count ordered threshold comparisons directly.
func.def @table_quantize_small_lanes() -> (i8, i8, i8) {
  %t0 = scalar.constant -1.0 : f16
  %t1 = scalar.constant 0.0 : f16
  %t2 = scalar.constant 1.0 : f16
  %thresholds = vector.from_elements %t0, %t1, %t2 : vector<3xf16>
  %v0 = scalar.constant -2.0 : f16
  %v1 = scalar.constant 0.0 : f16
  %v2 = scalar.constant 2.0 : f16
  %values = vector.from_elements %v0, %v1, %v2 : vector<3xf16>
  %codes = vector.table.quantize %values, %thresholds {nan = zero, tie = upper} : vector<3xf16>, vector<3xf16> -> vector<3xi8>
  %r0 = vector.extract %codes[0] : vector<3xi8> -> i8
  %r1 = vector.extract %codes[1] : vector<3xi8> -> i8
  %r2 = vector.extract %codes[2] : vector<3xi8> -> i8
  func.return %r0, %r1, %r2 : i8, i8, i8
}
// ----
func.def @table_quantize_small_lanes() -> (i8, i8, i8) {
  %r0 = scalar.constant 0 : i8
  %r1 = scalar.constant 2 : i8
  %r2 = scalar.constant 3 : i8
  func.return %r0, %r1, %r2 : i8, i8, i8
}

// ====

// Numeric transform facts follow the same Hadamard lane parity as
// vector-to-scalar lowering, so exact small vectors can fold before reference
// expansion.
func.def @transform_hadamard_small_static_lanes() -> (f32, f32, f32, f32) {
  %c0 = scalar.constant 1.0 : f32
  %c1 = scalar.constant 2.0 : f32
  %c2 = scalar.constant 3.0 : f32
  %c3 = scalar.constant 4.0 : f32
  %v = vector.from_elements %c0, %c1, %c2, %c3 : vector<4xf32>
  %xf = encoding.define #numeric_transform<family="hadamard", input_elems=4, output_elems=4> : encoding<transform>
  %r = vector.transform %v, %xf : vector<4xf32>, encoding<transform> -> vector<4xf32>
  %r0 = vector.extract %r[0] : vector<4xf32> -> f32
  %r1 = vector.extract %r[1] : vector<4xf32> -> f32
  %r2 = vector.extract %r[2] : vector<4xf32> -> f32
  %r3 = vector.extract %r[3] : vector<4xf32> -> f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}
// ----
func.def @transform_hadamard_small_static_lanes() -> (f32, f32, f32, f32) {
  %r0 = scalar.constant 10.0 : f32
  %r1 = scalar.constant -2.0 : f32
  %r2 = scalar.constant -4.0 : f32
  %r3 = scalar.constant 0.0 : f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}

// ====

// TurboQuant-style explicit sign vectors participate in exact Hadamard facts
// when the sign table is itself known.
func.def @transform_hadamard_sign_small_static_lanes() -> (f32, f32, f32, f32) {
  %c0 = scalar.constant 1.0 : f32
  %c1 = scalar.constant 2.0 : f32
  %c2 = scalar.constant 3.0 : f32
  %c3 = scalar.constant 4.0 : f32
  %false = scalar.constant false : i1
  %true = scalar.constant true : i1
  %v = vector.from_elements %c0, %c1, %c2, %c3 : vector<4xf32>
  %signs = vector.from_elements %false, %true, %false, %true : vector<4xi1>
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=4, output_elems=4> {signs = %signs : vector<4xi1>} : encoding<transform>
  %r = vector.transform %v, %xf : vector<4xf32>, encoding<transform> -> vector<4xf32>
  %r0 = vector.extract %r[0] : vector<4xf32> -> f32
  %r1 = vector.extract %r[1] : vector<4xf32> -> f32
  %r2 = vector.extract %r[2] : vector<4xf32> -> f32
  %r3 = vector.extract %r[3] : vector<4xf32> -> f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}
// ----
func.def @transform_hadamard_sign_small_static_lanes() -> (f32, f32, f32, f32) {
  %r0 = scalar.constant -2.0 : f32
  %r1 = scalar.constant 10.0 : f32
  %r2 = scalar.constant 0.0 : f32
  %r3 = scalar.constant -4.0 : f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}

// ====

// Exact seeds use the same SplitMix64 low-bit signs as vector-to-scalar
// lowering.
func.def @transform_hadamard_sign_exact_seed_small_static_lanes() -> (f32, f32, f32, f32) {
  %seed = index.constant 0 : index
  %c0 = scalar.constant 1.0 : f32
  %c1 = scalar.constant 2.0 : f32
  %c2 = scalar.constant 3.0 : f32
  %c3 = scalar.constant 4.0 : f32
  %v = vector.from_elements %c0, %c1, %c2, %c3 : vector<4xf32>
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=4, output_elems=4> {seed = %seed : index} : encoding<transform>
  %r = vector.transform %v, %xf : vector<4xf32>, encoding<transform> -> vector<4xf32>
  %r0 = vector.extract %r[0] : vector<4xf32> -> f32
  %r1 = vector.extract %r[1] : vector<4xf32> -> f32
  %r2 = vector.extract %r[2] : vector<4xf32> -> f32
  %r3 = vector.extract %r[3] : vector<4xf32> -> f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}
// ----
func.def @transform_hadamard_sign_exact_seed_small_static_lanes() -> (f32, f32, f32, f32) {
  %r0 = scalar.constant -4.0 : f32
  %r1 = scalar.constant 8.0 : f32
  %r2 = scalar.constant -2.0 : f32
  %r3 = scalar.constant -6.0 : f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}

// ====

// Dynamic seeds remain conservative; without an exact seed fact, the transform
// result should not collapse to a guessed lane value.
func.def @transform_hadamard_sign_dynamic_seed_keeps_transform(%seed: index) -> (f32) {
  %c0 = scalar.constant 1.0 : f32
  %c1 = scalar.constant 2.0 : f32
  %v = vector.from_elements %c0, %c1 : vector<2xf32>
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=2, output_elems=2> {seed = %seed : index} : encoding<transform>
  %r = vector.transform %v, %xf : vector<2xf32>, encoding<transform> -> vector<2xf32>
  %r0 = vector.extract %r[0] : vector<2xf32> -> f32
  func.return %r0 : f32
}
// ----
func.def @transform_hadamard_sign_dynamic_seed_keeps_transform(%seed: index) -> (f32) {
  %c0 = scalar.constant 1.0 : f32
  %c1 = scalar.constant 2.0 : f32
  %v = vector.from_elements %c0, %c1 : vector<2xf32>
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=2, output_elems=2> {seed = %seed : index} : encoding<transform>
  %r = vector.transform %v, %xf : vector<2xf32>, encoding<transform> -> vector<2xf32>
  %r0 = vector.extract %r[0] : vector<2xf32> -> f32
  func.return %r0 : f32
}

// ====

// Explicit sign/permutation transforms use the permutation table for the source
// lane but still use the loop input lane for Hadamard phase selection.
func.def @transform_sign_permute_hadamard_small_static_lanes() -> (f32, f32) {
  %c0 = scalar.constant 10.0 : f32
  %c1 = scalar.constant 20.0 : f32
  %false = scalar.constant false : i1
  %true = scalar.constant true : i1
  %p1 = index.constant 1 : index
  %p0 = index.constant 0 : index
  %v = vector.from_elements %c0, %c1 : vector<2xf32>
  %signs = vector.from_elements %false, %true : vector<2xi1>
  %permutation = vector.from_elements %p1, %p0 : vector<2xindex>
  %xf = encoding.define #numeric_transform<family="sign_permute_hadamard", input_elems=2, output_elems=2> {permutation = %permutation : vector<2xindex>, signs = %signs : vector<2xi1>} : encoding<transform>
  %r = vector.transform %v, %xf : vector<2xf32>, encoding<transform> -> vector<2xf32>
  %r0 = vector.extract %r[0] : vector<2xf32> -> f32
  %r1 = vector.extract %r[1] : vector<2xf32> -> f32
  func.return %r0, %r1 : f32, f32
}
// ----
func.def @transform_sign_permute_hadamard_small_static_lanes() -> (f32, f32) {
  %r0 = scalar.constant -10.0 : f32
  %r1 = scalar.constant -30.0 : f32
  func.return %r0, %r1 : f32, f32
}

// ====

// QJL-style dense projection facts compute the explicit matrix dot for small
// static operands.
func.def @transform_jl_dense_small_static_lanes() -> (f32, f32, f32) {
  %v0 = scalar.constant 2.0 : f32
  %v1 = scalar.constant 3.0 : f32
  %m00 = scalar.constant 1.0 : f32
  %m01 = scalar.constant 0.0 : f32
  %m10 = scalar.constant 0.0 : f32
  %m11 = scalar.constant 1.0 : f32
  %m20 = scalar.constant 1.0 : f32
  %m21 = scalar.constant 1.0 : f32
  %v = vector.from_elements %v0, %v1 : vector<2xf32>
  %matrix = vector.from_elements %m00, %m01, %m10, %m11, %m20, %m21 : vector<3x2xf32>
  %xf = encoding.define #numeric_transform<family="jl_dense", input_elems=2, output_elems=3> {matrix = %matrix : vector<3x2xf32>} : encoding<transform>
  %r = vector.transform %v, %xf : vector<2xf32>, encoding<transform> -> vector<3xf32>
  %r0 = vector.extract %r[0] : vector<3xf32> -> f32
  %r1 = vector.extract %r[1] : vector<3xf32> -> f32
  %r2 = vector.extract %r[2] : vector<3xf32> -> f32
  func.return %r0, %r1, %r2 : f32, f32, f32
}
// ----
func.def @transform_jl_dense_small_static_lanes() -> (f32, f32, f32) {
  %r0 = scalar.constant 2.0 : f32
  %r1 = scalar.constant 3.0 : f32
  %r2 = scalar.constant 5.0 : f32
  func.return %r0, %r1, %r2 : f32, f32, f32
}

// ====

// Float predicate and sign facts can produce exact i1/float lane summaries.
func.def @wave2_float_predicate_facts() -> (i1, i1, i1, f32) {
  %neg = vector.constant -1.0 : vector<4xf32>
  %zero = vector.constant 0.0 : vector<4xf32>
  %nan = vector.logf %neg : vector<4xf32>
  %inf = vector.divf %neg, %zero : vector<4xf32>
  %finite = vector.constant 2.0 : vector<4xf32>
  %is_nan = vector.isnanf %nan : vector<4xf32> -> vector<4xi1>
  %is_inf = vector.isinff %inf : vector<4xf32> -> vector<4xi1>
  %is_finite = vector.isfinitef %finite : vector<4xf32> -> vector<4xi1>
  %sign = vector.signf %neg : vector<4xf32>
  %r0 = vector.extract %is_nan[0] : vector<4xi1> -> i1
  %r1 = vector.extract %is_inf[0] : vector<4xi1> -> i1
  %r2 = vector.extract %is_finite[0] : vector<4xi1> -> i1
  %r3 = vector.extract %sign[0] : vector<4xf32> -> f32
  func.return %r0, %r1, %r2, %r3 : i1, i1, i1, f32
}
// ----
func.def @wave2_float_predicate_facts() -> (i1, i1, i1, f32) {
  %r0 = scalar.constant true : i1
  %r1 = scalar.constant true : i1
  %r2 = scalar.constant true : i1
  %r3 = scalar.constant -1.0 : f32
  func.return %r0, %r1, %r2, %r3 : i1, i1, i1, f32
}

// ====

// Static extracts from small vector summaries are scalar facts immediately.
func.def @extract_from_small_static_lanes() -> (i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4 : vector<4xi32>
  %r = vector.extract %v[2] : vector<4xi32> -> i32
  func.return %r : i32
}
// ----
func.def @extract_from_small_static_lanes() -> (i32) {
  %r = scalar.constant 3 : i32
  func.return %r : i32
}

// ====

// Multi-axis extracts use row-major logical lane order and partial extracts
// preserve the tail-vector fact summary.
func.def @extract_rank2_small_static_lanes() -> (i32, i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %c5 = scalar.constant 5 : i32
  %c6 = scalar.constant 6 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4, %c5, %c6 : vector<2x3xi32>
  %element = vector.extract %v[1, 2] : vector<2x3xi32> -> i32
  %row = vector.extract %v[1] : vector<2x3xi32> -> vector<3xi32>
  %zero = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %row, %zero : vector<3xi32>, i32
  func.return %element, %sum : i32, i32
}
// ----
func.def @extract_rank2_small_static_lanes() -> (i32, i32) {
  %element = scalar.constant 6 : i32
  %sum = scalar.constant 15 : i32
  func.return %element, %sum : i32, i32
}

// ====

// Shuffle remaps small per-lane summaries instead of dropping them.
func.def @shuffle_small_static_lanes_then_extract() -> (i32) {
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %v = vector.from_elements %c1, %c2, %c3, %c4 : vector<4xi32>
  %reversed = vector.shuffle<[3, 2, 1, 0]> %v : vector<4xi32>
  %r = vector.extract %reversed[0] : vector<4xi32> -> i32
  func.return %r : i32
}
// ----
func.def @shuffle_small_static_lanes_then_extract() -> (i32) {
  %r = scalar.constant 4 : i32
  func.return %r : i32
}

// ====

// Small mask summaries let vector.select keep lane-specific facts when the
// selected values also have lane-queryable summaries.
func.def @select_small_mask_then_reduce() -> (i32) {
  %true = scalar.constant true : i1
  %false = scalar.constant false : i1
  %c1 = scalar.constant 1 : i32
  %c2 = scalar.constant 2 : i32
  %c3 = scalar.constant 3 : i32
  %c4 = scalar.constant 4 : i32
  %ten = scalar.constant 10 : i32
  %mask = vector.from_elements %true, %false, %true, %false : vector<4xi1>
  %a = vector.splat %ten : vector<4xi32>
  %b = vector.from_elements %c1, %c2, %c3, %c4 : vector<4xi32>
  %selected = vector.select %mask, %a, %b : vector<4xi32>
  %zero = scalar.constant 0 : i32
  %r = vector.reduce<addi> %selected, %zero : vector<4xi32>, i32
  func.return %r : i32
}
// ----
func.def @select_small_mask_then_reduce() -> (i32) {
  %r = scalar.constant 26 : i32
  func.return %r : i32
}

// ====

// Dot products can fold small explicit lane vectors.
func.def @dotf_small_static_lanes() -> (f32) {
  %a0 = scalar.constant 1.0 : f32
  %a1 = scalar.constant 2.0 : f32
  %b0 = scalar.constant 3.0 : f32
  %b1 = scalar.constant 4.0 : f32
  %init = scalar.constant 5.0 : f32
  %a = vector.from_elements %a0, %a1 : vector<2xf32>
  %b = vector.from_elements %b0, %b1 : vector<2xf32>
  %r = vector.dotf %a, %b, %init : vector<2xf32>, vector<2xf32>, f32
  func.return %r : f32
}
// ----
func.def @dotf_small_static_lanes() -> (f32) {
  %r = scalar.constant 16.0 : f32
  func.return %r : f32
}

// ====

// Grouped f16 dot facts follow the same last-axis pairing as vector.dot2f
// lowering: each result lane consumes two adjacent source lanes.
func.def @dot2f_small_static_lanes() -> (f32, f32) {
  %a0 = scalar.constant 1.0 : f16
  %a1 = scalar.constant 2.0 : f16
  %a2 = scalar.constant 3.0 : f16
  %a3 = scalar.constant 4.0 : f16
  %b0 = scalar.constant 5.0 : f16
  %b1 = scalar.constant 6.0 : f16
  %b2 = scalar.constant 7.0 : f16
  %b3 = scalar.constant 8.0 : f16
  %acc0 = scalar.constant 10.0 : f32
  %acc1 = scalar.constant 20.0 : f32
  %a = vector.from_elements %a0, %a1, %a2, %a3 : vector<4xf16>
  %b = vector.from_elements %b0, %b1, %b2, %b3 : vector<4xf16>
  %acc = vector.from_elements %acc0, %acc1 : vector<2xf32>
  %r = vector.dot2f %a, %b, %acc : vector<4xf16>, vector<4xf16>, vector<2xf32>
  %r0 = vector.extract %r[0] : vector<2xf32> -> f32
  %r1 = vector.extract %r[1] : vector<2xf32> -> f32
  func.return %r0, %r1 : f32, f32
}
// ----
func.def @dot2f_small_static_lanes() -> (f32, f32) {
  %r0 = scalar.constant 27.0 : f32
  %r1 = scalar.constant 73.0 : f32
  func.return %r0, %r1 : f32, f32
}

// ====

// Grouped i8 dot facts preserve signedness choices from the template kind.
func.def @dot4i_small_static_lanes() -> (i32) {
  %a0 = scalar.constant -1 : i8
  %a1 = scalar.constant 2 : i8
  %a2 = scalar.constant -3 : i8
  %a3 = scalar.constant 4 : i8
  %b0 = scalar.constant -1 : i8
  %b1 = scalar.constant 6 : i8
  %b2 = scalar.constant 7 : i8
  %b3 = scalar.constant 8 : i8
  %acc0 = scalar.constant 100 : i32
  %a = vector.from_elements %a0, %a1, %a2, %a3 : vector<4xi8>
  %b = vector.from_elements %b0, %b1, %b2, %b3 : vector<4xi8>
  %acc = vector.from_elements %acc0 : vector<1xi32>
  %r = vector.dot4i<s8u8> %a, %b, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  %r0 = vector.extract %r[0] : vector<1xi32> -> i32
  func.return %r0 : i32
}
// ----
func.def @dot4i_small_static_lanes() -> (i32) {
  %r0 = scalar.constant -132 : i32
  func.return %r0 : i32
}

// ====

// Packed i4 dot facts unpack little-endian nibbles with per-side signedness.
func.def @dot8i4_small_static_lanes() -> (i32) {
  %lhs0 = scalar.constant 124076833 : i32
  %rhs0 = scalar.constant 158027055 : i32
  %acc0 = scalar.constant 100 : i32
  %lhs = vector.from_elements %lhs0 : vector<1xi32>
  %rhs = vector.from_elements %rhs0 : vector<1xi32>
  %acc = vector.from_elements %acc0 : vector<1xi32>
  %r = vector.dot8i4<u4s4> %lhs, %rhs, %acc : vector<1xi32>
  %r0 = vector.extract %r[0] : vector<1xi32> -> i32
  func.return %r0 : i32
}
// ----
func.def @dot8i4_small_static_lanes() -> (i32) {
  %r0 = scalar.constant 72 : i32
  func.return %r0 : i32
}

// ====

// Uniform packed-dot facts remain useful for dynamic vectors when a later
// consumer can exploit a shape-independent identity.
func.def @dot8i4_uniform_dynamic_identity(%n: index) -> (i32) {
  %zero = scalar.constant 0 : i32
  %lhs = vector.splat %zero : vector<[%n]xi32>
  %rhs = vector.splat %zero : vector<[%n]xi32>
  %acc = vector.splat %zero : vector<[%n]xi32>
  %dot = vector.dot8i4<u4u4> %lhs, %rhs, %acc : vector<[%n]xi32>
  %init = scalar.constant 7 : i32
  %r = vector.reduce<addi> %dot, %init : vector<[%n]xi32>, i32
  func.return %r : i32
}
// ----
func.def @dot8i4_uniform_dynamic_identity(%n: index) -> (i32) {
  %r = scalar.constant 7 : i32
  func.return %r : i32
}

// ====

// Packed fp8/bf8 dot facts decode little-endian bytes according to the
// template kind. 0x38 is fp8(E4M3) 1.0, and 0x3c is bf8(E5M2) 1.0.
func.def @dot4f8_small_static_lanes() -> (f32, f32) {
  %lhs0 = scalar.constant 0x38383838 : i32
  %rhs0 = scalar.constant 0x3c3c3c3c : i32
  %lhs1 = scalar.constant 0 : i32
  %rhs1 = scalar.constant 0 : i32
  %acc0 = scalar.constant 5.0 : f32
  %acc1 = scalar.constant -3.0 : f32
  %lhs = vector.from_elements %lhs0, %lhs1 : vector<2xi32>
  %rhs = vector.from_elements %rhs0, %rhs1 : vector<2xi32>
  %acc = vector.from_elements %acc0, %acc1 : vector<2xf32>
  %r = vector.dot4f8<fp8bf8> %lhs, %rhs, %acc : vector<2xi32>, vector<2xf32>
  %r0 = vector.extract %r[0] : vector<2xf32> -> f32
  %r1 = vector.extract %r[1] : vector<2xf32> -> f32
  func.return %r0, %r1 : f32, f32
}
// ----
func.def @dot4f8_small_static_lanes() -> (f32, f32) {
  %r0 = scalar.constant 9.0 : f32
  %r1 = scalar.constant -3.0 : f32
  func.return %r0, %r1 : f32, f32
}

// ====

// All template spellings decode the selected lhs/rhs field formats.
func.def @dot4f8_all_kind_ones() -> (f32, f32, f32, f32) {
  %fp8_ones = scalar.constant 0x38383838 : i32
  %bf8_ones = scalar.constant 0x3c3c3c3c : i32
  %zero = scalar.constant 0.0 : f32
  %fp8 = vector.from_elements %fp8_ones : vector<1xi32>
  %bf8 = vector.from_elements %bf8_ones : vector<1xi32>
  %acc = vector.from_elements %zero : vector<1xf32>
  %r0v = vector.dot4f8<fp8bf8> %fp8, %bf8, %acc : vector<1xi32>, vector<1xf32>
  %r1v = vector.dot4f8<bf8fp8> %bf8, %fp8, %acc : vector<1xi32>, vector<1xf32>
  %r2v = vector.dot4f8<fp8fp8> %fp8, %fp8, %acc : vector<1xi32>, vector<1xf32>
  %r3v = vector.dot4f8<bf8bf8> %bf8, %bf8, %acc : vector<1xi32>, vector<1xf32>
  %r0 = vector.extract %r0v[0] : vector<1xf32> -> f32
  %r1 = vector.extract %r1v[0] : vector<1xf32> -> f32
  %r2 = vector.extract %r2v[0] : vector<1xf32> -> f32
  %r3 = vector.extract %r3v[0] : vector<1xf32> -> f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}
// ----
func.def @dot4f8_all_kind_ones() -> (f32, f32, f32, f32) {
  %r0 = scalar.constant 4.0 : f32
  %r1 = scalar.constant 4.0 : f32
  %r2 = scalar.constant 4.0 : f32
  %r3 = scalar.constant 4.0 : f32
  func.return %r0, %r1, %r2, %r3 : f32, f32, f32, f32
}

// ====

// Uniform packed fp8/bf8 facts stay shape-independent on dynamic vectors.
func.def @dot4f8_uniform_dynamic_extract(%n: index) -> (f32) {
  %lhs0 = scalar.constant 0x38383838 : i32
  %rhs0 = scalar.constant 0x3c3c3c3c : i32
  %zero = scalar.constant 0.0 : f32
  %lhs = vector.splat %lhs0 : vector<[%n]xi32>
  %rhs = vector.splat %rhs0 : vector<[%n]xi32>
  %acc = vector.splat %zero : vector<[%n]xf32>
  %dot = vector.dot4f8<fp8bf8> %lhs, %rhs, %acc : vector<[%n]xi32>, vector<[%n]xf32>
  %r = vector.extract %dot[0] : vector<[%n]xf32> -> f32
  func.return %r : f32
}
// ----
func.def @dot4f8_uniform_dynamic_extract(%n: index) -> (f32) {
  %r = scalar.constant 4.0 : f32
  func.return %r : f32
}

// ====

// Oversized explicit vectors deliberately degrade to unknown facts instead of
// allocating unbounded per-lane analysis payloads.
func.def @oversized_from_elements_degrades_to_unknown() -> (i64) {
  %zero = scalar.constant 0 : i32
  %v = vector.from_elements %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero, %zero : vector<17xi32>
  %r = vector.reduce<addi> %v, %zero : vector<17xi32>, i32
  %lo = test.fact_range_lo %r : i32 -> i64
  func.return %lo : i64
}
// ----
func.def @oversized_from_elements_degrades_to_unknown() -> (i64) {
  %lo = scalar.constant -9223372036854775808 : i64
  func.return %lo : i64
}

// ====

// Structural summaries for vector.iota remain queryable on dynamic vectors.
func.def @iota_summary_fact(%n: index) -> (i1) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %v = vector.iota %c0 step %c1 : vector<[%n]xindex>
  %is = test.fact_is_vector_iota %v : vector<[%n]xindex> -> i1
  func.return %is : i1
}
// ----
func.def @iota_summary_fact(%n: index) -> (i1) {
  %is = scalar.constant true : i1
  func.return %is : i1
}

// ====

// Non-empty mask.range summaries stay structural until a consumer needs them.
func.def @prefix_mask_summary_fact(%n: index) -> (i1) {
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %mask = vector.mask.range [%c0 to %n step %c1] : index -> vector<[%n]xi1>
  %is = test.fact_is_vector_prefix_mask %mask : vector<[%n]xi1> -> i1
  func.return %is : i1
}
// ----
func.def @prefix_mask_summary_fact(%n: index) -> (i1) {
  %is = scalar.constant true : i1
  func.return %is : i1
}
