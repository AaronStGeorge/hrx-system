// RUN: verify

// ====

// Floating-point lanewise ops require floating-point vector elements.
func.def @addf_integer(%a: vector<4xi32>, %b: vector<4xi32>) {
  // ERROR@+1: TYPE/004 "float_element"
  %r = vector.addf %a, %b : vector<4xi32>
  func.return
}

// ====

// Floating-point comparisons require floating-point vector inputs.
func.def @cmpf_integer(%a: vector<4xi32>, %b: vector<4xi32>) {
  // ERROR@+1: TYPE/003 "float_element"
  %m = vector.cmpf olt, %a, %b : vector<4xi32> -> vector<4xi1>
  func.return
}

// ====

// Comparison masks must have i1 elements.
func.def @cmpf_result_not_i1(%a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: TYPE/004 "i1_element"
  %m = vector.cmpf olt, %a, %b : vector<4xf32> -> vector<4xi32>
  func.return
}

// ====

// Select masks must have i1 elements.
func.def @select_mask_not_i1(%mask: vector<4xi32>, %a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: TYPE/003 "i1_element"
  %r = vector.select %mask, %a, %b : vector<4xf32>
  func.return
}

// ====

// Select masks must have the same vector shape as the selected values.
func.def @select_shape_mismatch(%mask: vector<8xi1>, %a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: SHAPE/002
  %r = vector.select %mask, %a, %b : vector<4xf32>
  func.return
}

// ====

// Reductions keep the vector element type tied to the scalar accumulator/result.
func.def @reduce_element_mismatch(%v: vector<4xf32>, %zero: i32) {
  // ERROR@+1: TYPE/002
  %r = vector.reduce<addf> %v, %zero : vector<4xf32> -> i32
  func.return
}

// ====

// Vector constants use a scalar literal payload matching the vector element type.
func.def @constant_payload_mismatch() {
  // ERROR@+1: TYPE/005 "value"
  %r = vector.constant 0 : vector<4xf32>
  func.return
}

// ====

// Vector broadcast rejects statically provable shape mismatches.
func.def @broadcast_static_mismatch(%v: vector<4xf32>) {
  // ERROR@+1: SHAPE/004
  %r = vector.broadcast %v : vector<4xf32> -> vector<8xf32>
  func.return
}

// ====

// Vector broadcast cannot drop source dimensions.
func.def @broadcast_rank_mismatch(%v: vector<4x4xf32>) {
  // ERROR@+1: SHAPE/001
  %r = vector.broadcast %v : vector<4x4xf32> -> vector<4xf32>
  func.return
}

// ====

// Vector construction from scalars must provide every static lane.
func.def @from_elements_count_mismatch(%x: f32) {
  // ERROR@+1: STRUCTURE/013 "elements"
  %r = vector.from_elements %x, %x, %x : f32, f32, f32 -> vector<4xf32>
  func.return
}

// ====

// Vector construction from scalars needs an all-static lane count.
func.def @from_elements_dynamic_result(%x: f32, %n: index) {
  // ERROR@+1: TYPE/004 "all-static vector shape"
  %r = vector.from_elements %x, %x, %x, %x : f32, f32, f32, f32 -> vector<[%n]xf32>
  func.return
}

// ====

// Vector memory ops require one logical origin index per view rank.
func.def @load_index_count_mismatch(%buffer: buffer, %offset: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: SUBRANGE/001 "view" "1" "2"
  %r = vector.load %view[0] : view<4x4xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

// The vector lane footprint rank cannot exceed the view rank.
func.def @load_vector_rank_too_large(%buffer: buffer, %offset: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: TYPE/004 "rank no greater than view rank"
  %r = vector.load %view[0] : view<4xf32, %layout> -> vector<2x2xf32>
  func.return
}

// ====

// Static vector memory footprints must fit inside statically known view bounds.
func.def @load_static_footprint_out_of_bounds(%buffer: buffer, %offset: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: SUBRANGE/004
  %r = vector.load %view[2, 1] : view<4x4xf32, %layout> -> vector<3x4xf32>
  func.return
}

// ====

// A static origin past a static view bound is invalid even if the vector
// footprint has dynamic extent.
func.def @load_static_offset_past_bound(%buffer: buffer, %offset: index, %n: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: SUBRANGE/004
  %r = vector.load %view[5] : view<4xf32, %layout> -> vector<[%n]xf32>
  func.return
}

// ====

// Vector memory element types match the view element type.
func.def @load_element_mismatch(%buffer: buffer, %offset: index) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: TYPE/002
  %r = vector.load %view[0] : view<4xf32, %layout> -> vector<4xi32>
  func.return
}

// ====

// Masked vector loads require an i1 mask vector.
func.def @load_mask_not_i1(%buffer: buffer, %offset: index, %mask: vector<4xi32>, %old: vector<4xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: TYPE/003 "i1_element"
  %r = vector.load.mask %view[0], %mask, %old : view<4xf32, %layout>, vector<4xi32>, vector<4xf32> -> vector<4xf32>
  func.return
}

// ====

// Masked vector stores require mask and value shapes to match.
func.def @store_mask_shape_mismatch(%buffer: buffer, %offset: index, %mask: vector<8xi1>, %value: vector<4xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: SHAPE/002
  vector.store.mask %value, %view[0], %mask : vector<4xf32>, view<4xf32, %layout>, vector<8xi1>
  func.return
}

// ====

// Expand loads are rank-1: the mask selects a compact memory run, not a
// multi-dimensional register footprint.
func.def @load_expand_rank_mismatch(%buffer: buffer, %offset: index, %mask: vector<2x2xi1>, %old: vector<2x2xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: TYPE/004 "rank-1 vector"
  %r = vector.load.expand %view[0, 0], %mask, %old : view<4x4xf32, %layout>, vector<2x2xi1>, vector<2x2xf32> -> vector<2x2xf32>
  func.return
}

// ====

// Compress stores are rank-1 for the same active-lane memory cursor reason.
func.def @store_compress_rank_mismatch(%buffer: buffer, %offset: index, %mask: vector<2x2xi1>, %value: vector<2x2xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: TYPE/003 "rank-1 vector"
  vector.store.compress %value, %view[0, 0], %mask : vector<2x2xf32>, view<4x4xf32, %layout>, vector<2x2xi1>
  func.return
}

// ====

// Expand-load mask and passthrough shapes follow the result shape.
func.def @load_expand_mask_shape_mismatch(%buffer: buffer, %offset: index, %mask: vector<8xi1>, %old: vector<4xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, %layout>
  // ERROR@+1: SHAPE/002
  %r = vector.load.expand %view[0], %mask, %old : view<16xf32, %layout>, vector<8xi1>, vector<4xf32> -> vector<4xf32>
  func.return
}

// ====

// Until mask facts prove a smaller popcount, static checks conservatively use
// the full rank-1 vector length as the maximum compact memory footprint.
func.def @store_compress_static_footprint_out_of_bounds(%buffer: buffer, %offset: index, %mask: vector<4xi1>, %value: vector<4xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: SUBRANGE/004
  vector.store.compress %value, %view[2], %mask : vector<4xf32>, view<4xf32, %layout>, vector<4xi1>
  func.return
}

// ====

// Vector gathers require one logical origin index per view rank.
func.def @gather_index_count_mismatch(%buffer: buffer, %offset: index, %offsets: vector<4xindex>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4x4xf32, %layout>
  // ERROR@+1: SUBRANGE/001 "view" "1" "2"
  %r = vector.gather %view[0][%offsets] : view<4x4xf32, %layout>, vector<4xindex> -> vector<4xf32>
  func.return
}

// ====

// Gather/scatter offset lanes must be address-sized indices or explicit
// non-i1 integers, not masks or floating-point data.
func.def @gather_offsets_i1(%buffer: buffer, %offset: index, %offsets: vector<4xi1>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: TYPE/003 "offsets" "vector<...>" "vector with index or non-i1 integer elements"
  %r = vector.gather %view[0][%offsets] : view<4xf32, %layout>, vector<4xi1> -> vector<4xf32>
  func.return
}

// ====

// Gather offset vector shape follows the gathered value shape.
func.def @gather_offsets_shape_mismatch(%buffer: buffer, %offset: index, %offsets: vector<8xindex>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, %layout>
  // ERROR@+1: SHAPE/002
  %r = vector.gather %view[0][%offsets] : view<16xf32, %layout>, vector<8xindex> -> vector<4xf32>
  func.return
}

// ====

// Static gather base origins must be inside static view bounds.
func.def @gather_static_origin_out_of_bounds(%buffer: buffer, %offset: index, %offsets: vector<4xindex>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  // ERROR@+1: SUBRANGE/004
  %r = vector.gather %view[5][%offsets] : view<4xf32, %layout>, vector<4xindex> -> vector<4xf32>
  func.return
}

// ====

// Masked scatters require mask and value shapes to match; masked-off lanes
// leave memory unchanged, and active non-atomic scatter lanes must be distinct.
func.def @scatter_mask_shape_mismatch(%buffer: buffer, %offset: index, %offsets: vector<4xindex>, %mask: vector<8xi1>, %value: vector<4xf32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, %layout>
  // ERROR@+1: SHAPE/002
  vector.scatter.mask %value, %view[0][%offsets], %mask : vector<4xf32>, view<16xf32, %layout>, vector<4xindex>, vector<8xi1>
  func.return
}

// ====

// Vector extract cannot index more dimensions than the source has.
func.def @extract_too_many_indices(%v: vector<4xf32>) {
  // ERROR@+1: STRUCTURE/013 "static_indices"
  %r = vector.extract %v[0, 0] : vector<4xf32> -> f32
  func.return
}

// ====

// Partial vector extract returns the unindexed vector tail, not a scalar.
func.def @extract_tail_type_mismatch(%v: vector<4x4xf32>) {
  // ERROR@+1: TYPE/004 "vector tail value"
  %r = vector.extract %v[0] : vector<4x4xf32> -> f32
  func.return
}

// ====

// Partial vector insert expects the inserted value to match the unindexed tail.
func.def @insert_tail_type_mismatch(%x: f32, %v: vector<4x4xf32>) {
  // ERROR@+1: TYPE/003 "vector tail value"
  %r = vector.insert %x into %v[0] : f32, vector<4x4xf32> -> vector<4x4xf32>
  func.return
}

// ====

// Static vector indices must be within statically known bounds.
func.def @extract_static_index_out_of_bounds(%v: vector<4xf32>) {
  // ERROR@+1: SUBRANGE/004
  %r = vector.extract %v[5] : vector<4xf32> -> f32
  func.return
}

// ====

// Register slices preserve rank.
func.def @slice_rank_mismatch(%v: vector<4x4xf32>) {
  // ERROR@+1: SHAPE/001
  %r = vector.slice %v[0, 0] : vector<4x4xf32> -> vector<4xf32>
  func.return
}

// ====

// Register slices require one offset per source rank.
func.def @slice_offset_count_mismatch(%v: vector<4x4xf32>) {
  // ERROR@+1: SUBRANGE/001 "source" "1" "2"
  %r = vector.slice %v[0] : vector<4x4xf32> -> vector<2x2xf32>
  func.return
}

// ====

// Static register slices must fit inside statically known source bounds.
func.def @slice_static_out_of_bounds(%v: vector<4xf32>) {
  // ERROR@+1: SUBRANGE/004
  %r = vector.slice %v[3] : vector<4xf32> -> vector<2xf32>
  func.return
}

// ====

// A static slice offset past a static source bound is invalid even if the result
// extent is dynamic.
func.def @slice_offset_past_bound(%v: vector<4xf32>, %n: index) {
  // ERROR@+1: SUBRANGE/004
  %r = vector.slice %v[5] : vector<4xf32> -> vector<[%n]xf32>
  func.return
}

// ====

// Concat axes must refer to an existing result dimension.
func.def @concat_axis_out_of_range(%a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: SUBRANGE/002 "1" "1"
  %r = vector.concat<1> %a, %b : vector<4xf32>, vector<4xf32> -> vector<8xf32>
  func.return
}

// ====

// Concat inputs match result shape on every non-concatenated axis.
func.def @concat_non_axis_shape_mismatch(%a: vector<2x4xf32>, %b: vector<2x8xf32>) {
  // ERROR@+1: SHAPE/002
  %r = vector.concat<0> %a, %b : vector<2x4xf32>, vector<2x8xf32> -> vector<4x4xf32>
  func.return
}

// ====

// Static concat axis extents must sum to the result axis extent.
func.def @concat_axis_sum_mismatch(%a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: TYPE/004 "concat axis extent"
  %r = vector.concat<0> %a, %b : vector<4xf32>, vector<4xf32> -> vector<7xf32>
  func.return
}

// ====

// Transpose permutations must have one entry per source rank.
func.def @transpose_permutation_count_mismatch(%v: vector<4x8xf32>) {
  // ERROR@+1: STRUCTURE/013 "permutation"
  %r = vector.transpose<[1]> %v : vector<4x8xf32> -> vector<8x4xf32>
  func.return
}

// ====

// Transpose permutations name each source axis exactly once.
func.def @transpose_duplicate_axis(%v: vector<4x8xf32>) {
  // ERROR@+1: STRUCTURE/014 "permutation"
  %r = vector.transpose<[0, 0]> %v : vector<4x8xf32> -> vector<4x4xf32>
  func.return
}

// ====

// Transpose result shape follows the explicit result-axis to source-axis map.
func.def @transpose_result_shape_mismatch(%v: vector<4x8xf32>) {
  // ERROR@+1: SHAPE/002
  %r = vector.transpose<[1, 0]> %v : vector<4x8xf32> -> vector<4x8xf32>
  func.return
}

// ====

// Static shuffle is a rank-1 lane remap.
func.def @shuffle_rank_mismatch(%v: vector<2x2xf32>) {
  // ERROR@+1: TYPE/003 "all-static rank-1 vector"
  %r = vector.shuffle<[0, 1, 2, 3]> %v : vector<2x2xf32>
  func.return
}

// ====

// Static shuffle needs one source lane entry per result/source lane.
func.def @shuffle_lane_count_mismatch(%v: vector<4xf32>) {
  // ERROR@+1: STRUCTURE/013 "source_lanes"
  %r = vector.shuffle<[0, 1, 2]> %v : vector<4xf32>
  func.return
}

// ====

// Static shuffle lane references must be in bounds; duplicate lanes are allowed.
func.def @shuffle_lane_out_of_bounds(%v: vector<4xf32>) {
  // ERROR@+1: SUBRANGE/004
  %r = vector.shuffle<[0, 4, 2, 3]> %v : vector<4xf32>
  func.return
}

// ====

// Static shuffle cannot prove a complete lane remap for dynamic vector extents.
func.def @shuffle_dynamic_shape(%n: index, %v: vector<[%n]xf32>) {
  // ERROR@+1: TYPE/003 "all-static rank-1 vector"
  %r = vector.shuffle<[0]> %v : vector<[%n]xf32>
  func.return
}

// ====

// Extension and truncation ops encode their width direction in the op name.
func.def @extf_wrong_width(%v: vector<4xf32>) {
  // ERROR@+1: TYPE/004 "wider floating-point element type"
  %r = vector.extf %v : vector<4xf32> to vector<4xf16>
  func.return
}

// ====

// Integer truncation must narrow, not widen.
func.def @trunci_wrong_width(%v: vector<4xi8>) {
  // ERROR@+1: TYPE/004 "narrower integer element type"
  %r = vector.trunci %v : vector<4xi8> to vector<4xi32>
  func.return
}

// ====

// Bitcasts preserve shape and per-lane bitwidth.
func.def @bitcast_width_mismatch(%v: vector<4xf32>) {
  // ERROR@+1: TYPE/004 "same element bitwidth as input"
  %r = vector.bitcast %v : vector<4xf32> to vector<4xi16>
  func.return
}

// ====

// Bitfield extraction requires positive field widths.
func.def @bitfield_extract_zero_width(%v: vector<4xi8>) {
  // ERROR@+1: STRUCTURE/014 "width" "0" "positive bitfield width"
  %r = vector.bitfield.extractu %v {offset = 0, width = 0} : vector<4xi8> -> vector<4xi32>
  func.return
}

// ====

// Bitfield offsets are least-significant bit positions and cannot be negative.
func.def @bitfield_extract_negative_offset(%v: vector<4xi8>) {
  // ERROR@+1: STRUCTURE/014 "offset" "-1" "non-negative bit offset"
  %r = vector.bitfield.extractu %v {offset = -1, width = 4} : vector<4xi8> -> vector<4xi32>
  func.return
}

// ====

// Bitfield ranges must fit inside each source lane.
func.def @bitfield_extract_range_overflow(%v: vector<4xi8>) {
  // ERROR@+1: STRUCTURE/014 "width" "4" "bitfield range within storage element width"
  %r = vector.bitfield.extracts %v {offset = 6, width = 4} : vector<4xi8> -> vector<4xi32>
  func.return
}

// ====

// Extract result lanes must be wide enough to hold the selected field.
func.def @bitfield_extract_result_too_narrow(%v: vector<4xi8>) {
  // ERROR@+1: TYPE/004 "integer element type at least bitfield width"
  %r = vector.bitfield.extractu %v {offset = 0, width = 4} : vector<4xi8> -> vector<4xi1>
  func.return
}

// ====

// Insert source field lanes must be wide enough to provide the selected bits.
func.def @bitfield_insert_field_too_narrow(%field: vector<4xi1>, %base: vector<4xi8>) {
  // ERROR@+1: TYPE/003 "integer element type at least bitfield width"
  %r = vector.bitfield.insert %field into %base {offset = 0, width = 4} : vector<4xi1>, vector<4xi8> -> vector<4xi8>
  func.return
}

// ====

// Insert ranges must fit inside each base lane.
func.def @bitfield_insert_range_overflow(%field: vector<4xi32>, %base: vector<4xi8>) {
  // ERROR@+1: STRUCTURE/014 "width" "4" "bitfield range within storage element width"
  %r = vector.bitfield.insert %field into %base {offset = 6, width = 4} : vector<4xi32>, vector<4xi8> -> vector<4xi8>
  func.return
}

// ====

// Reduce template parameters are tied to the vector element family.
func.def @reduce_kind_mismatch(%v: vector<4xi32>, %zero: i32) {
  // ERROR@+1: TYPE/003 "floating-point element type for reduce kind"
  %r = vector.reduce<minimumf> %v, %zero : vector<4xi32> -> i32
  func.return
}

// ====

// Atomic memory order and scope are required explicit attributes.
func.def @atomic_missing_ordering_and_scope(%buffer: buffer, %base: index, %row: index, %col: index, %offsets: vector<4xindex>, %v: vector<4xi32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%base] : buffer -> view<8x8xi32, %layout>
  // ERROR@+2: TYPE/005 "ordering"
  // ERROR@+1: TYPE/005 "scope"
  vector.atomic.reduce<addi> %v, %view[%row, %col][%offsets] : vector<4xi32>, view<8x8xi32, %layout>, vector<4xindex>
  func.return
}

// ====

// Atomic ordering values are parsed as a typed enum, not arbitrary strings.
func.def @atomic_invalid_ordering(%buffer: buffer, %base: index, %row: index, %col: index, %offsets: vector<4xindex>, %v: vector<4xi32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%base] : buffer -> view<8x8xi32, %layout>
  // ERROR@+1: PARSE/017 "ordering"
  vector.atomic.reduce<addi> %v, %view[%row, %col][%offsets] {ordering = unordered, scope = workgroup} : vector<4xi32>, view<8x8xi32, %layout>, vector<4xindex>
  func.return
}

// ====

// Atomic kind spelling is tied to the vector element family.
func.def @atomic_kind_mismatch(%buffer: buffer, %base: index, %row: index, %col: index, %offsets: vector<4xindex>, %v: vector<4xi32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%base] : buffer -> view<8x8xi32, %layout>
  // ERROR@+1: TYPE/003 "floating-point element type for atomic kind"
  vector.atomic.reduce<addf> %v, %view[%row, %col][%offsets] {ordering = relaxed, scope = workgroup} : vector<4xi32>, view<8x8xi32, %layout>, vector<4xindex>
  func.return
}

// ====

// Exchange is an RMW operation, not a no-result reduction/update.
func.def @atomic_reduce_rejects_exchange(%buffer: buffer, %base: index, %row: index, %col: index, %offsets: vector<4xindex>, %v: vector<4xi32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%base] : buffer -> view<8x8xi32, %layout>
  // ERROR@+1: STRUCTURE/014 "non-exchange atomic reduce kind"
  vector.atomic.reduce<xchgi> %v, %view[%row, %col][%offsets] {ordering = relaxed, scope = workgroup} : vector<4xi32>, view<8x8xi32, %layout>, vector<4xindex>
  func.return
}

// ====

// Atomic offset vectors accept index or non-i1 integer elements.
func.def @atomic_offsets_reject_i1(%buffer: buffer, %base: index, %row: index, %col: index, %offsets: vector<4xi1>, %v: vector<4xi32>) {
  %layout = view.layout.dense : encoding
  %view = buffer.view %buffer[%base] : buffer -> view<8x8xi32, %layout>
  // ERROR@+1: TYPE/003 "vector with index or non-i1 integer elements"
  %old = vector.atomic.rmw<addi> %v, %view[%row, %col][%offsets] {ordering = relaxed, scope = workgroup} : vector<4xi32>, view<8x8xi32, %layout>, vector<4xi1> -> vector<4xi32>
  func.return
}

// ====

// Lanewise vector float flags are value assumptions, not generic fast-math flags.
func.def @mulf_contract_is_not_a_flag(%a: vector<4xf32>, %b: vector<4xf32>) {
  // ERROR@+1: PARSE/018 "contract"
  %r = vector.mulf<contract> %a, %b : vector<4xf32>
  func.return
}
