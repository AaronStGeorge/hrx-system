// RUN: format bytecode

// Fragment movement uses keyed attributes, dynamic shape operands, dynamic view
// origins, cache attrs, and a trailing store without a result. Keep bytecode
// coverage separate from the larger text roundtrip corpus so wire-format gaps
// are easy to localize.
func.def @fragment_memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %m: index, %n: index, %k: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %a = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%k]xf16, %layout>
  %b = buffer.view %buffer[%offset] : buffer -> view<[%k]x[%n]xf16, %layout>
  %c = buffer.view %buffer[%offset] : buffer -> view<[%m]x[%n]xf32, %layout>
  %lhs = vector.fragment.load<lhs> %a[%row, 0] shape [%m, %k] {cache_scope = device, cache_temporal = high_temporal} : view<[%m]x[%k]xf16, %layout> -> vector<16xf16>
  %rhs = vector.fragment.load<rhs> %b[0, %col] shape [%k, %n] {cache_scope = device, cache_temporal = non_temporal} : view<[%k]x[%n]xf16, %layout> -> vector<16xf16>
  %init = vector.fragment.load<init> %c[%row, %col] shape [%m, %n] : view<[%m]x[%n]xf32, %layout> -> vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xf16>, vector<16xf16>, vector<8xf32>
  vector.fragment.store<result> %result, %c[%row, %col] shape [%m, %n] {cache_scope = system, cache_temporal = writeback} : vector<8xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}
