    view.store %53, %view[24] : f32, view<32xf32, %layout>
    scf.yield
  } else {
    scf.yield
  }
  %54 = vector.extract %mask[0] : vector<4xi1> -> i1
  %55 = index.constant 0 : index
  %56 = index.constant 1 : index
  %57 = scalar.select %54, %56, %55 : index
  %58 = vector.extract %mask[1] : vector<4xi1> -> i1
  scf.if %58 {
    %59 = vector.extract %value[1] : vector<4xf32> -> f32
    %60 = index.constant 24 : index
    %61 = index.add %60, %57 : index
