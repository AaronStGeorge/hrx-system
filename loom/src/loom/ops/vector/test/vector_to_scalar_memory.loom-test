  %77 = index.constant 1 : index
  %78 = scalar.select %75, %77, %76 : index
  %79 = vector.extract %mask[1] : vector<4xi1> -> i1
  %80 = index.constant 0 : index
  %81 = index.constant 1 : index
  %82 = scalar.select %79, %81, %80 : index
  %83 = index.add %78, %82 : index
  %84 = vector.extract %mask[2] : vector<4xi1> -> i1
  %85 = index.constant 0 : index
  %86 = index.constant 1 : index
  %87 = scalar.select %84, %86, %85 : index
  %88 = index.add %83, %87 : index
  %89 = vector.extract %mask[3] : vector<4xi1> -> i1
