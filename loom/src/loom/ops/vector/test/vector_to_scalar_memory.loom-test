// ====

func.def @dynamic_memory_ops(%n: index, %buffer: buffer, %byte_offset: offset, %origin: index, %mask: vector<[%n]xi1>, %old: vector<[%n]xf32>, %offsets: vector<[%n]xindex>, %value: vector<[%n]xf32>) -> (vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<[%n]xf32, %layout>
  %load = vector.load %view[%origin] : view<[%n]xf32, %layout> -> vector<[%n]xf32>
  %masked = vector.load.mask %view[%origin], %mask, %old : view<[%n]xf32, %layout>, vector<[%n]xi1>, vector<[%n]xf32> -> vector<[%n]xf32>
  %expanded = vector.load.expand %view[%origin], %mask, %old : view<[%n]xf32, %layout>, vector<[%n]xi1>, vector<[%n]xf32> -> vector<[%n]xf32>
  %gathered = vector.gather %view[%origin][%offsets] : view<[%n]xf32, %layout>, vector<[%n]xindex> -> vector<[%n]xf32>
  vector.store %value, %view[%origin] : vector<[%n]xf32>, view<[%n]xf32, %layout>
  vector.store.mask %value, %view[%origin], %mask : vector<[%n]xf32>, view<[%n]xf32, %layout>, vector<[%n]xi1>
  vector.store.compress %value, %view[%origin], %mask : vector<[%n]xf32>, view<[%n]xf32, %layout>, vector<[%n]xi1>
  vector.scatter %value, %view[%origin][%offsets] : vector<[%n]xf32>, view<[%n]xf32, %layout>, vector<[%n]xindex>
  vector.scatter.mask %value, %view[%origin][%offsets], %mask : vector<[%n]xf32>, view<[%n]xf32, %layout>, vector<[%n]xindex>, vector<[%n]xi1>
  func.return %load, %masked, %expanded, %gathered : vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>
}

// ----
func.def @dynamic_memory_ops(%n: index, %buffer: buffer, %byte_offset: offset, %origin: index, %mask: vector<[%n]xi1>, %old: vector<[%n]xf32>, %offsets: vector<[%n]xindex>, %value: vector<[%n]xf32>) -> (vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<[%n]xf32, %layout>
  %100 = vector.constant 0.0 : vector<[%n]xf32>
  %101 = index.constant 0 : index
  %102 = index.constant 1 : index
  %load = scf.for %103 = [%101 to %n step %102](%104 = %100 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %106 = index.add %origin, %103 : index
    %107 = view.load %view[%106] : view<[%n]xf32, %layout> -> f32
    %108 = vector.insert %107 into %104[%103] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %108 : vector<[%n]xf32>
  }
  %89 = index.constant 0 : index
  %90 = index.constant 1 : index
  %masked = scf.for %91 = [%89 to %n step %90](%92 = %old : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %94 = vector.extract %mask[%91] : vector<[%n]xi1> -> i1
    %95 = scf.if %94 -> (f32) {
      %96 = index.add %origin, %91 : index
      %97 = view.load %view[%96] : view<[%n]xf32, %layout> -> f32
      scf.yield %97 : f32
    } else {
      %98 = vector.extract %old[%91] : vector<[%n]xf32> -> f32
      scf.yield %98 : f32
    }
    %99 = vector.insert %95 into %92[%91] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %99 : vector<[%n]xf32>
  }
  %68 = index.constant 0 : index
  %69 = index.constant 1 : index
  %expanded = scf.for %70 = [%68 to %n step %69](%71 = %old : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %73 = index.constant 0 : index
    %74 = index.constant 1 : index
    %77 = scf.for %75 = [%73 to %70 step %74](%76 = %73 : index) -> (index) {
      %78 = vector.extract %mask[%75] : vector<[%n]xi1> -> i1
      %79 = index.constant 0 : index
      %80 = index.constant 1 : index
      %81 = scalar.select %78, %80, %79 : index
      %82 = index.add %76, %81 : index
      scf.yield %82 : index
    }
    %83 = vector.extract %mask[%70] : vector<[%n]xi1> -> i1
    %84 = scf.if %83 -> (f32) {
      %85 = index.add %origin, %77 : index
      %86 = view.load %view[%85] : view<[%n]xf32, %layout> -> f32
      scf.yield %86 : f32
    } else {
      %87 = vector.extract %old[%70] : vector<[%n]xf32> -> f32
      scf.yield %87 : f32
    }
    %88 = vector.insert %84 into %71[%70] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %88 : vector<[%n]xf32>
  }
  %58 = vector.constant 0.0 : vector<[%n]xf32>
  %59 = index.constant 0 : index
  %60 = index.constant 1 : index
  %gathered = scf.for %61 = [%59 to %n step %60](%62 = %58 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %64 = vector.extract %offsets[%61] : vector<[%n]xindex> -> index
    %65 = index.add %origin, %64 : index
    %66 = view.load %view[%65] : view<[%n]xf32, %layout> -> f32
    %67 = vector.insert %66 into %62[%61] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %67 : vector<[%n]xf32>
  }
  %53 = index.constant 0 : index
  %54 = index.constant 1 : index
  scf.for %55 = [%53 to %n step %54] {
    %56 = vector.extract %value[%55] : vector<[%n]xf32> -> f32
    %57 = index.add %origin, %55 : index
    view.store %56, %view[%57] : f32, view<[%n]xf32, %layout>
    scf.yield
  }
  %47 = index.constant 0 : index
  %48 = index.constant 1 : index
  scf.for %49 = [%47 to %n step %48] {
    %50 = vector.extract %mask[%49] : vector<[%n]xi1> -> i1
    scf.if %50 {
      %51 = vector.extract %value[%49] : vector<[%n]xf32> -> f32
      %52 = index.add %origin, %49 : index
      view.store %51, %view[%52] : f32, view<[%n]xf32, %layout>
      scf.yield
    } else {
      scf.yield
    }
    scf.yield
  }
  %31 = index.constant 0 : index
  %32 = index.constant 1 : index
  scf.for %33 = [%31 to %n step %32] {
    %34 = index.constant 0 : index
    %35 = index.constant 1 : index
    %38 = scf.for %36 = [%34 to %33 step %35](%37 = %34 : index) -> (index) {
      %39 = vector.extract %mask[%36] : vector<[%n]xi1> -> i1
      %40 = index.constant 0 : index
      %41 = index.constant 1 : index
      %42 = scalar.select %39, %41, %40 : index
      %43 = index.add %37, %42 : index
      scf.yield %43 : index
    }
    %44 = vector.extract %mask[%33] : vector<[%n]xi1> -> i1
    scf.if %44 {
      %45 = vector.extract %value[%33] : vector<[%n]xf32> -> f32
      %46 = index.add %origin, %38 : index
      view.store %45, %view[%46] : f32, view<[%n]xf32, %layout>
      scf.yield
    } else {
      scf.yield
    }
    scf.yield
  }
  %25 = index.constant 0 : index
  %26 = index.constant 1 : index
  scf.for %27 = [%25 to %n step %26] {
    %28 = vector.extract %value[%27] : vector<[%n]xf32> -> f32
    %29 = vector.extract %offsets[%27] : vector<[%n]xindex> -> index
    %30 = index.add %origin, %29 : index
    view.store %28, %view[%30] : f32, view<[%n]xf32, %layout>
    scf.yield
  }
  %18 = index.constant 0 : index
  %19 = index.constant 1 : index
  scf.for %20 = [%18 to %n step %19] {
    %21 = vector.extract %mask[%20] : vector<[%n]xi1> -> i1
    scf.if %21 {
      %22 = vector.extract %value[%20] : vector<[%n]xf32> -> f32
      %23 = vector.extract %offsets[%20] : vector<[%n]xindex> -> index
      %24 = index.add %origin, %23 : index
      view.store %22, %view[%24] : f32, view<[%n]xf32, %layout>
      scf.yield
    } else {
      scf.yield
    }
    scf.yield
  }
  func.return %load, %masked, %expanded, %gathered : vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>, vector<[%n]xf32>
}
