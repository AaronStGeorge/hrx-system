  %116 = view.load %view[%115] : view<32xf32, %layout> -> f32
  %117 = vector.extract %offsets[3] : vector<4xindex> -> index
  %118 = index.constant 12 : index
  %119 = index.add %118, %117 : index
  %120 = view.load %view[%119] : view<32xf32, %layout> -> f32
  %gathered = vector.from_elements %108, %112, %116, %120 : f32, f32, f32, f32 -> vector<4xf32>
  %101 = vector.extract %value[0] : vector<4xf32> -> f32
  view.store %101, %view[16] : f32, view<32xf32, %layout>
  %102 = vector.extract %value[1] : vector<4xf32> -> f32
  view.store %102, %view[17] : f32, view<32xf32, %layout>
  %103 = vector.extract %value[2] : vector<4xf32> -> f32
