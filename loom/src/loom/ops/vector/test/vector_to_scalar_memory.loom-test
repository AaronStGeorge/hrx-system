func.def @load_mask_static(%buffer: buffer, %byte_offset: offset, %mask: vector<2xi1>, %old: vector<2xf32>) -> (vector<2xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<8xf32, %layout>
  %8 = vector.extract %mask[0] : vector<2xi1> -> i1
  %9 = scf.if %8 -> (f32) {
    %10 = view.load %view[3] : view<8xf32, %layout> -> f32
    scf.yield %10 : f32
  } else {
    %11 = vector.extract %old[0] : vector<2xf32> -> f32
    scf.yield %11 : f32
  }
  %12 = vector.extract %mask[1] : vector<2xi1> -> i1
  %13 = scf.if %12 -> (f32) {
    %14 = view.load %view[4] : view<8xf32, %layout> -> f32
    scf.yield %14 : f32
  } else {
    %15 = vector.extract %old[1] : vector<2xf32> -> f32
    scf.yield %15 : f32
  }
  %loaded = vector.from_elements %9, %13 : f32, f32 -> vector<2xf32>
  func.return %loaded : vector<2xf32>
}

