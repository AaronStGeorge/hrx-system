// RUN: pass vector-to-scalar

func.def @static_memory_ops(%buffer: buffer, %byte_offset: offset, %mask: vector<4xi1>, %old: vector<4xf32>, %offsets: vector<4xindex>, %value: vector<4xf32>) -> (vector<4xf32>, vector<4xf32>, vector<4xf32>, vector<4xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<32xf32, %layout>
  %load = vector.load %view[0] : view<32xf32, %layout> -> vector<4xf32>
  %masked = vector.load.mask %view[4], %mask, %old : view<32xf32, %layout>, vector<4xi1>, vector<4xf32> -> vector<4xf32>
  %expanded = vector.load.expand %view[8], %mask, %old : view<32xf32, %layout>, vector<4xi1>, vector<4xf32> -> vector<4xf32>
  %gathered = vector.gather %view[12][%offsets] : view<32xf32, %layout>, vector<4xindex> -> vector<4xf32>
  vector.store %value, %view[16] : vector<4xf32>, view<32xf32, %layout>
  vector.store.mask %value, %view[20], %mask : vector<4xf32>, view<32xf32, %layout>, vector<4xi1>
  vector.store.compress %value, %view[24], %mask : vector<4xf32>, view<32xf32, %layout>, vector<4xi1>
  vector.scatter %value, %view[28][%offsets] : vector<4xf32>, view<32xf32, %layout>, vector<4xindex>
  vector.scatter.mask %value, %view[28][%offsets], %mask : vector<4xf32>, view<32xf32, %layout>, vector<4xindex>, vector<4xi1>
  func.return %load, %masked, %expanded, %gathered : vector<4xf32>, vector<4xf32>, vector<4xf32>, vector<4xf32>
}

