// ----
func.def @load_dynamic(%n: index, %buffer: buffer, %byte_offset: offset, %origin: index) -> (vector<[%n]xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<[%n]xf32, %layout>
  %8 = vector.constant 0.0 : vector<[%n]xf32>
  %9 = index.constant 0 : index
  %10 = index.constant 1 : index
  %loaded = scf.for %11 = [%9 to %n step %10](%12 = %8 : vector<[%n]xf32>) -> (vector<[%n]xf32>) {
    %14 = index.add %origin, %11 : index
    %15 = view.load %view[%14] : view<[%n]xf32, %layout> -> f32
    %16 = vector.insert %15 into %12[%11] : f32, vector<[%n]xf32> -> vector<[%n]xf32>
    scf.yield %16 : vector<[%n]xf32>
  }
  func.return %loaded : vector<[%n]xf32>
}

