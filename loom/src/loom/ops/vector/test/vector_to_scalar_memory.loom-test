// RUN: pass vector-to-scalar

func.def @load_static(%buffer: buffer, %byte_offset: offset) -> (vector<2xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<8xf32, %layout>
  %loaded = vector.load %view[3] : view<8xf32, %layout> -> vector<2xf32>
  func.return %loaded : vector<2xf32>
}

// ----
func.def @load_static(%buffer: buffer, %byte_offset: offset) -> (vector<2xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<8xf32, %layout>
  %6 = view.load %view[3] : view<8xf32, %layout> -> f32
  %7 = view.load %view[4] : view<8xf32, %layout> -> f32
  %loaded = vector.from_elements %6, %7 : f32, f32 -> vector<2xf32>
  func.return %loaded : vector<2xf32>
}

