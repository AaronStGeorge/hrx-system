    scf.yield %10 : f32
  } else {
    %11 = vector.extract %old[0] : vector<3xf32> -> f32
    scf.yield %11 : f32
  }
  %12 = vector.extract %mask[0] : vector<3xi1> -> i1
  %13 = index.constant 0 : index
  %14 = index.constant 1 : index
  %15 = scf.select %12, %14, %13 : index
  %16 = vector.extract %mask[1] : vector<3xi1> -> i1
  %17 = scf.if %16 -> (f32) {
    %18 = index.constant 3 : index
    %19 = index.add %18, %15 : index
    %20 = view.load %view[%19] : view<8xf32, %layout> -> f32
    scf.yield %20 : f32
  } else {
    %21 = vector.extract %old[1] : vector<3xf32> -> f32
    scf.yield %21 : f32
  }
  %22 = vector.extract %mask[0] : vector<3xi1> -> i1
  %23 = index.constant 0 : index
  %24 = index.constant 1 : index
  %25 = scf.select %22, %24, %23 : index
  %26 = vector.extract %mask[1] : vector<3xi1> -> i1
  %27 = index.constant 0 : index
  %28 = index.constant 1 : index
  %29 = scf.select %26, %28, %27 : index
  %30 = index.add %25, %29 : index
  %31 = vector.extract %mask[2] : vector<3xi1> -> i1
  %32 = scf.if %31 -> (f32) {
    %33 = index.constant 3 : index
    %34 = index.add %33, %30 : index
    %35 = view.load %view[%34] : view<8xf32, %layout> -> f32
    scf.yield %35 : f32
  } else {
    %36 = vector.extract %old[2] : vector<3xf32> -> f32
    scf.yield %36 : f32
  }
  %loaded = vector.from_elements %9, %17, %32 : f32, f32, f32 -> vector<3xf32>
  func.return %loaded : vector<3xf32>
