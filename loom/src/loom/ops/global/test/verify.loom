// RUN: verify

// ====

// Undefined global reference.
func.def @undefined_load() {
  // ERROR@+1: SYMBOL/002 "missing"
  %v = global.load @missing : f32
  func.return
}

// ====

// Loading from a function symbol is a kind mismatch.
func.def @callee(%x: f32) -> (f32) {
  func.return %x : f32
}

func.def @load_from_function() {
  // ERROR@+1: SYMBOL/003 "expected global"
  %v = global.load @callee : f32
  func.return
}

// ====

// Extra co-results that are not referenced by the loaded value type are invalid.
global.constant @pi : f32

func.def @load_extra_result() {
  // ERROR@+1: STRUCTURE/002
  %v, %extra = global.load @pi : f32
  func.return
}

// ====

// Global structural equality must survive at the load site.
global.variable @square : tile<[%n]x[%n]xf32>

func.def @load_square_mismatch() {
  // ERROR@+1: TYPE/001 "loaded value"
  %tile, %m, %k = global.load @square : tile<[%m]x[%k]xf32>
  func.return
}

// ====

// Equal dim refs count as one co-result.
global.variable @square_ok : tile<[%n]x[%n]xf32>

func.def @load_square_ok() {
  %tile, %n = global.load @square_ok : tile<[%n]x[%n]xf32>
  func.return
}

// ====

// Storing a rectangular value to a square global is invalid.
global.variable @square_store : tile<[%n]x[%n]xf32>

func.def @store_square_mismatch(%value: tile<[%m]x[%k]xf32>) {
  // ERROR@+1: TYPE/001 "stored value"
  global.store %value, @square_store : tile<[%m]x[%k]xf32>
  func.return
}
