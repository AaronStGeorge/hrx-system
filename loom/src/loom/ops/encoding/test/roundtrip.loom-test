// RUN: roundtrip

// ====

// Dynamic encoding parameters are named SSA operands on encoding.define.
func.def @dynamic_encoding_params(%group_size: index, %scale: f32) {
  %enc = encoding.define #q8_0<block=32> {group_size = %group_size : index, scale = %scale : f32} : encoding
  test.use %enc : encoding
  func.return
}

// ====

// The resulting encoding value is attached explicitly in shaped types.
func.def @dynamic_encoding_attachment(%group_size: index) {
  %enc = encoding.define #q8_0<block=32> {group_size = %group_size : index} : encoding
  %tile = test.constant 0 : tile<256xi8, %enc>
  test.use %tile : tile<256xi8, %enc>
  func.return
}
