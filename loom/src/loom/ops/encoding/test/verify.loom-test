// RUN: verify

// ====

// Static encoding attrs and dynamic encoding operands are two views of one
// parameter namespace; a name can appear in only one place.
func.def @static_dynamic_duplicate(%block: index) {
  // ERROR@+1: ENCODING/006 "block"
  %enc = encoding.define #q8_0<block=32> {block = %block : index} : encoding<schema>
  func.return
}

// ====

// SSA values never appear inside static #family<...> parameter attributes.
func.def @static_param_ssa_value(%group_size: index) {
  // ERROR@+1: PARSE/028 "group_size"
  %enc = encoding.define #q8_0<group_size=%group_size> : encoding<schema>
  func.return
}

// ====

// A known encoding family must declare the precise role-qualified result type
// at the definition site; generic `encoding` would push role discovery to
// later consumers.
func.def @encoding_define_generic_result_role() {
  // ERROR@+1: ENCODING/012 "q8_0" "encoding" "encoding<schema>"
  %enc = encoding.define #q8_0<block=32> : encoding
  func.return
}

// ====

func.def @encoding_isa_result_must_be_i1(%enc: encoding<schema>) {
  // ERROR@+1: TYPE/004 "i1"
  %is = encoding.isa %enc, "quantized" : i32
  func.return
}

// ====

func.def @layout_assume_strided_rejects_negative_rank(%layout: encoding<layout>) {
  // ERROR@+1: STRUCTURE/014 "rank" "-1" "rank in [0, 255]"
  %strided = encoding.layout.assume.strided %layout {rank = -1} : encoding<layout>
  func.return
}

// ====

func.def @layout_strided_rejects_negative_static_stride() {
  // ERROR@+1: STRUCTURE/014 "static_strides" "-1" "stride >= 0 or dynamic sentinel"
  %strided = encoding.layout.strided [-1, 1] : encoding<layout>
  func.return
}

// ====

func.def @assume_spec_rejects_role_mismatch(%schema: encoding<schema>) {
  // ERROR@+1: ENCODING/012 "dense" "encoding<schema>" "encoding<layout>"
  %bad = encoding.assume.spec %schema, #dense : encoding<schema>
  func.return
}

// ====

// Numeric transform descriptors are verified when declared, even before a
// vector.transform use site sees them.
func.def @numeric_transform_unknown_family_define_only() {
  // ERROR@+1: ENCODING/013 "numeric_transform" "family" "mystery"
  %xf = encoding.define #numeric_transform<family="mystery", input_elems=128, output_elems=128> : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_hadamard_rejects_signs() {
  %signs = vector.constant false : vector<128xi1>
  // ERROR@+1: ENCODING/008 "numeric_transform" "signs"
  %xf = encoding.define #numeric_transform<family="hadamard", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_hadamard_sign_requires_signs_or_seed() {
  // ERROR@+1: ENCODING/007 "numeric_transform" "signs or seed"
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_hadamard_sign_rejects_signs_and_seed(%seed: index) {
  %signs = vector.constant false : vector<128xi1>
  // ERROR@+1: ENCODING/014 "numeric_transform" "signs" "seed"
  %xf = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {seed = %seed : index, signs = %signs : vector<128xi1>} : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_sign_permute_requires_permutation() {
  %signs = vector.constant false : vector<128xi1>
  // ERROR@+1: ENCODING/007 "numeric_transform" "permutation"
  %xf = encoding.define #numeric_transform<family="sign_permute_hadamard", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_jl_dense_requires_matrix() {
  // ERROR@+1: ENCODING/007 "numeric_transform" "matrix"
  %xf = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> : encoding<transform>
  func.return
}

// ====

func.def @numeric_transform_jl_dense_rejects_orthonormal() {
  %matrix = vector.constant 0.0 : vector<64x128xf32>
  // ERROR@+1: ENCODING/013 "numeric_transform" "normalization" "orthonormal"
  %xf = encoding.define #numeric_transform<family="jl_dense", input_elems=128, normalization="orthonormal", output_elems=64> {matrix = %matrix : vector<64x128xf32>} : encoding<transform>
  func.return
}

// ====

func.def @amdgpu_matrix_rejects_unknown_format() {
  // ERROR@+1: ENCODING/013 "amdgpu_matrix_operand" "format" "tf32"
  %schema = encoding.define #amdgpu_matrix_operand<format="tf32", packed_elements=32, packed_registers=6, scale="none", scale_conversion="none", scale_format="none", scale_placement="none", zero_scale_fallback=false> : encoding<schema>
  func.return
}

// ====

func.def @amdgpu_matrix_rejects_dynamic_params(%format: index) {
  // ERROR@+1: ENCODING/008 "amdgpu_matrix_operand" "format"
  %schema = encoding.define #amdgpu_matrix_operand<packed_elements=32, packed_registers=6, scale="none", scale_conversion="none", scale_format="none", scale_placement="none", zero_scale_fallback=false> {format = %format : index} : encoding<schema>
  func.return
}

// ====

func.def @amdgpu_matrix_requires_explicit_zero_scale_fallback() {
  // ERROR@+1: ENCODING/007 "amdgpu_matrix_operand" "zero_scale_fallback"
  %schema = encoding.define #amdgpu_matrix_operand<format="fp6", packed_elements=32, packed_registers=6, scale="scale32", scale_conversion="convergent", scale_format="none", scale_placement="explicit"> : encoding<schema>
  func.return
}

// ====

func.def @amdgpu_matrix_rejects_scale_format_without_scale() {
  // ERROR@+1: ENCODING/013 "amdgpu_matrix_operand" "scale_format" "e4m3"
  %schema = encoding.define #amdgpu_matrix_operand<format="fp4", packed_elements=128, packed_registers=16, scale="none", scale_conversion="none", scale_format="e4m3", scale_placement="none", zero_scale_fallback=false> : encoding<schema>
  func.return
}

// ====

func.def @amdgpu_matrix_rejects_scaled_conversion_none() {
  // ERROR@+1: ENCODING/013 "amdgpu_matrix_operand" "scale_conversion" "none"
  %schema = encoding.define #amdgpu_matrix_operand<format="fp6", packed_elements=32, packed_registers=6, scale="scale32", scale_conversion="none", scale_format="none", scale_placement="explicit", zero_scale_fallback=true> : encoding<schema>
  func.return
}

// ====

func.def @amdgpu_matrix_rejects_zero_packed_registers() {
  // ERROR@+1: STRUCTURE/014 "packed_registers" "0"
  %schema = encoding.define #amdgpu_matrix_operand<format="fp6", packed_elements=32, packed_registers=0, scale="none", scale_conversion="none", scale_format="none", scale_placement="none", zero_scale_fallback=false> : encoding<schema>
  func.return
}

// ====

func.def @turboquant_missing_static_param(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/007 "turboquant_kv" "logical_element"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_wrong_static_kind(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/010 "turboquant_kv" "first_stage_bits"
  %schema = encoding.define #turboquant_kv<first_stage_bits="2", logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_unsupported_pack_order(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/013 "turboquant_kv" "pack_order" "msb0"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="msb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_record_too_small(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: STRUCTURE/014 "record_bytes" "39"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=39, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_threshold_count_mismatch(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<4xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: STRUCTURE/014 "thresholds" "4"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<4xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_centroids_wrong_type(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xi32, %dense>
  %signs = vector.constant false : vector<128xi1>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/009 "turboquant_kv" "centroids"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xi32, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_transform_role_mismatch(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %schema_param = encoding.define #q8_0<block=32> : encoding<schema>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/011 "turboquant_kv" "transform" "a numeric transform encoding"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %schema_param : encoding<schema>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_transform_family_mismatch(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %transform = encoding.define #numeric_transform<family="hadamard", input_elems=128, output_elems=128> : encoding<transform>
  %qjl_matrix = vector.constant 0.0 : vector<64x128xf32>
  %qjl_transform = encoding.define #numeric_transform<family="jl_dense", input_elems=128, output_elems=64> {matrix = %qjl_matrix : vector<64x128xf32>} : encoding<transform>
  // ERROR@+1: ENCODING/013 "turboquant_kv" "transform" "hadamard"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}

// ====

func.def @turboquant_qjl_transform_family_mismatch(%params: buffer, %thresholds_offset: offset, %centroids_offset: offset) {
  %dense = encoding.layout.dense : encoding<layout>
  %thresholds = buffer.view %params[%thresholds_offset] : buffer -> view<3xf32, %dense>
  %centroids = buffer.view %params[%centroids_offset] : buffer -> view<4xf16, %dense>
  %signs = vector.constant false : vector<128xi1>
  %transform = encoding.define #numeric_transform<family="hadamard_sign", input_elems=128, output_elems=128> {signs = %signs : vector<128xi1>} : encoding<transform>
  %qjl_transform = encoding.define #numeric_transform<family="hadamard", input_elems=128, output_elems=64> : encoding<transform>
  // ERROR@+1: ENCODING/013 "turboquant_kv" "qjl_transform" "hadamard"
  %schema = encoding.define #turboquant_kv<first_stage_bits=2, logical_element="f16", logical_elems=128, pack_order="lsb0", qjl_rows=64, record_bytes=40, residual_bits=1, scalar_quantizer="lloyd_max", transform_family="hadamard_sign"> {centroids = %centroids : view<4xf16, %dense>, qjl_transform = %qjl_transform : encoding<transform>, thresholds = %thresholds : view<3xf32, %dense>, transform = %transform : encoding<transform>} : encoding<schema>
  func.return
}
