load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_test", "loom_generated_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_generated_cc_library(
    name = "encoding",
    srcs = [
        "facts.c",
        "families.c",
        "matrix_operand.c",
        "numeric_transform.c",
        "roles.c",
        "storage.c",
        "verify.c",
    ],
    hdrs = [
        "families.h",
        "matrix_operand.h",
        "numeric_transform.h",
        "ops.h",
        "params.h",
        "roles.h",
        "storage.h",
    ],
    args = ["--dialect=encoding"],
    generated_src_flags = [
        "--builders",
        "--tables",
    ],
    generated_srcs = [
        "builders.c",
        "tables.c",
    ],
    generator = "//loom/py/loom/gen:c_tables_generator",
    deps = [
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:stable_id",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "format_test",
    srcs = ["format_test.cc"],
    deps = [
        ":encoding",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/format/text:printer",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "facts_test",
    srcs = ["facts_test.cc"],
    deps = [
        ":encoding",
        "//loom/src/loom/ir",
        "//loom/src/loom/util:fact_table",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "verify_test",
    srcs = ["verify_test.cc"],
    deps = [
        ":encoding",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/func",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//loom/src/loom/verify",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
