// RUN: pass dce

// Assertions with unused checked results still execute and must not be dropped.
func.def @unused_assertion_survives_dce(%n: index) {
  %checked = sanitizer.assert.value %n [ge(%n, 0)] : index
  func.return
}

// ====

// Identical assertions represent distinct report/trap sites and are not CSE
// candidates.
// RUN: pass cse
func.def @assertions_do_not_cse(%n: index) -> (index, index) {
  %lhs = sanitizer.assert.value %n [ge(%n, 0)] : index
  %rhs = sanitizer.assert.value %n [ge(%n, 0)] : index
  func.return %lhs, %rhs : index, index
}
