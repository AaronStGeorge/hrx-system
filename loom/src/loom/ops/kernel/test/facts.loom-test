// RUN: pass canonicalize

kernel.def @fixed_workgroup_query_facts() {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c8, %c1) : index
} launch {
  %tid_x = kernel.workitem.id<x> : index
  %size_x = kernel.workgroup.size<x> : index
  %lane = kernel.subgroup.lane.id : index
  %subgroup_count = kernel.subgroup.count : index
  %byte_count = index.constant 4 : index
  %byte_offset = index.mul %tid_x, %byte_count : index
  %tid_hi = test.fact_range_hi %tid_x : index -> i64
  %size_lo = test.fact_range_lo %size_x : index -> i64
  %size_hi = test.fact_range_hi %size_x : index -> i64
  %size_divisor = test.fact_divisor %size_x : index -> i64
  %size_power_of_two = test.fact_power_of_two %size_x : index -> i1
  %lane_hi = test.fact_range_hi %lane : index -> i64
  %subgroup_count_lo = test.fact_range_lo %subgroup_count : index -> i64
  %subgroup_count_hi = test.fact_range_hi %subgroup_count : index -> i64
  %subgroup_count_positive = test.fact_positive %subgroup_count : index -> i1
  %byte_offset_divisor = test.fact_divisor %byte_offset : index -> i64
  %byte_offset_hi = test.fact_range_hi %byte_offset : index -> i64
  test.use %tid_hi, %size_lo, %size_hi, %size_divisor, %size_power_of_two, %lane_hi, %subgroup_count_lo, %subgroup_count_hi, %subgroup_count_positive, %byte_offset_divisor, %byte_offset_hi : i64, i64, i64, i64, i1, i64, i64, i64, i1, i64, i64
  kernel.return
}

// ----
kernel.def @fixed_workgroup_query_facts() {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c8, %c1) : index
} launch {
  %tid_hi = scalar.constant 63 : i64
  %size_lo = scalar.constant 64 : i64
  %size_hi = scalar.constant 64 : i64
  %size_divisor = scalar.constant 64 : i64
  %size_power_of_two = scalar.constant true : i1
  %lane_hi = scalar.constant 127 : i64
  %subgroup_count_lo = scalar.constant 4 : i64
  %subgroup_count_hi = scalar.constant 512 : i64
  %subgroup_count_positive = scalar.constant true : i1
  %byte_offset_divisor = scalar.constant 4 : i64
  %byte_offset_hi = scalar.constant 252 : i64
  test.use %tid_hi, %size_lo, %size_hi, %size_divisor, %size_power_of_two, %lane_hi, %subgroup_count_lo, %subgroup_count_hi, %subgroup_count_positive, %byte_offset_divisor, %byte_offset_hi : i64, i64, i64, i64, i1, i64, i64, i64, i1, i64, i64
  kernel.return
}

