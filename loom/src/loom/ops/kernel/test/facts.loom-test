kernel.def @default_hal_query_facts() {
  %workgroup_size = kernel.workgroup.size<y> : index
  %workgroup_count = kernel.workgroup.count<z> : index
  %dispatch_id = kernel.workitem.dispatch.id<x> : index
  %subgroup_size = kernel.subgroup.size : index
  %workgroup_size_lo = test.fact_range_lo %workgroup_size : index -> i64
  %workgroup_size_hi = test.fact_range_hi %workgroup_size : index -> i64
  %workgroup_count_lo = test.fact_range_lo %workgroup_count : index -> i64
  %workgroup_count_hi = test.fact_range_hi %workgroup_count : index -> i64
  %dispatch_id_lo = test.fact_range_lo %dispatch_id : index -> i64
  %dispatch_id_hi = test.fact_range_hi %dispatch_id : index -> i64
  %subgroup_size_lo = test.fact_range_lo %subgroup_size : index -> i64
  %subgroup_size_hi = test.fact_range_hi %subgroup_size : index -> i64
  %workgroup_size_positive = test.fact_positive %workgroup_size : index -> i1
  %workgroup_count_positive = test.fact_positive %workgroup_count : index -> i1
  %subgroup_size_positive = test.fact_positive %subgroup_size : index -> i1
  test.use %workgroup_size_lo, %workgroup_size_hi, %workgroup_count_lo, %workgroup_count_hi, %dispatch_id_lo, %dispatch_id_hi, %subgroup_size_lo, %subgroup_size_hi, %workgroup_size_positive, %workgroup_count_positive, %subgroup_size_positive : i64, i64, i64, i64, i64, i64, i64, i64, i1, i1, i1
  kernel.return
}

