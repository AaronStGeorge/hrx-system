kernel.def @subgroup_mask_distribution_facts() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch(%arg: i32) {
  %lane = kernel.subgroup.lane.id : index
  %lane_i32 = index.cast %lane : index to i32
  %predicate = scalar.cmpi eq, %lane_i32, %arg : i32
  %any = kernel.subgroup.vote.any %predicate : i1
  %all = kernel.subgroup.vote.all %predicate : i1
  %ballot = kernel.subgroup.vote.ballot %predicate : i1 -> i64
  %active = kernel.subgroup.active.mask : i64
  %match_any = kernel.subgroup.match.any %lane_i32 : i32 -> i64
  %match_all_mask, %match_all = kernel.subgroup.match.all %lane_i32 : i32 -> i64, i1
  %predicate_is_lane = test.fact_lane_predicate %predicate : i1 -> i1
  %any_is_uniform = test.fact_uniform %any : i1 -> i1
  %any_is_lane = test.fact_lane_predicate %any : i1 -> i1
  %all_is_uniform = test.fact_uniform %all : i1 -> i1
  %ballot_is_mask = test.fact_subgroup_lane_mask %ballot : i64 -> i1
  %ballot_is_uniform = test.fact_uniform %ballot : i64 -> i1
  %ballot_is_varying = test.fact_lane_varying %ballot : i64 -> i1
  %active_is_mask = test.fact_subgroup_lane_mask %active : i64 -> i1
  %active_is_uniform = test.fact_uniform %active : i64 -> i1
  %match_any_is_mask = test.fact_subgroup_lane_mask %match_any : i64 -> i1
  %match_any_is_varying = test.fact_lane_varying %match_any : i64 -> i1
  %match_all_mask_is_mask = test.fact_subgroup_lane_mask %match_all_mask : i64 -> i1
  %match_all_mask_is_uniform = test.fact_uniform %match_all_mask : i64 -> i1
  %match_all_is_uniform = test.fact_uniform %match_all : i1 -> i1
  test.use %predicate_is_lane, %any_is_uniform, %any_is_lane, %all_is_uniform, %ballot_is_mask, %ballot_is_uniform, %ballot_is_varying, %active_is_mask, %active_is_uniform, %match_any_is_mask, %match_any_is_varying, %match_all_mask_is_mask, %match_all_mask_is_uniform, %match_all_is_uniform : i1, i1, i1, i1, i1, i1, i1, i1, i1, i1, i1, i1, i1, i1
  kernel.return
}

