kernel.def workgroup_size(8, 1, 1) @small_workgroup_lane_facts() {
  %lane_lo = scalar.constant 0 : i64
  %lane_hi = scalar.constant 7 : i64
  test.use %lane_lo, %lane_hi : i64, i64
  kernel.return
}

