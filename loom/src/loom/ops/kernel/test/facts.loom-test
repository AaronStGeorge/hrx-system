kernel.def workgroup_size(8, 1, 1) @small_workgroup_lane_facts() {
  %lane = kernel.subgroup.lane.id : index
  %lane_lo = test.fact_range_lo %lane : index -> i64
  %lane_hi = test.fact_range_hi %lane : index -> i64
  test.use %lane_lo, %lane_hi : i64, i64
  kernel.return
}

