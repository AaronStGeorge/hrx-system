kernel.def @computed_launch_config_facts_seed_body() {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c64 = index.constant 64 : index
  %size_x = index.mul %c8, %c8 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%size_x, %c1, %c1) : index
} launch {
  %tid_x = kernel.workitem.id<x> : index
  %tid_hi = test.fact_range_hi %tid_x : index -> i64
  test.use %tid_hi : i64
  kernel.return
}

