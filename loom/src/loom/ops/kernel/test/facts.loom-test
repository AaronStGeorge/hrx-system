kernel.def @default_hal_query_facts() {
  %workgroup_size_lo = scalar.constant 1 : i64
  %workgroup_size_hi = scalar.constant 4294967295 : i64
  %workgroup_count_lo = scalar.constant 1 : i64
  %workgroup_count_hi = scalar.constant 4294967295 : i64
  %dispatch_id_lo = scalar.constant 0 : i64
  %dispatch_id_hi = scalar.constant 4294967295 : i64
  %subgroup_size_lo = scalar.constant 1 : i64
  %subgroup_size_hi = scalar.constant 128 : i64
  %workgroup_size_positive = scalar.constant true : i1
  %workgroup_count_positive = scalar.constant true : i1
  %subgroup_size_positive = scalar.constant true : i1
  test.use %workgroup_size_lo, %workgroup_size_hi, %workgroup_count_lo, %workgroup_count_hi, %dispatch_id_lo, %dispatch_id_hi, %subgroup_size_lo, %subgroup_size_hi, %workgroup_size_positive, %workgroup_count_positive, %subgroup_size_positive : i64, i64, i64, i64, i64, i64, i64, i64, i1, i1, i1
  kernel.return
}
