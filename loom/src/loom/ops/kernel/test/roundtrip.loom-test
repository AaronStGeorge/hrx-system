// ====

test.target<low_core> @test_target

kernel.def @subgroup_collectives(%value: f32, %vector: vector<4xf32>, %predicate: i1, %lane: i32, %offset: i32, %width: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %shuffle, %valid = kernel.subgroup.shuffle<xor> %value, %offset, %width : f32, i32, i32
  %shuffle_vector, %valid_vector = kernel.subgroup.shuffle<down> %vector, %offset, %width : vector<4xf32>, i32, i32
  %broadcast = kernel.subgroup.broadcast %value from %lane : f32, i32
  %first = kernel.subgroup.broadcast.first %value : f32
  %sum = kernel.subgroup.reduce<addf> %value : f32
  %clustered_sum = kernel.subgroup.reduce<addf> %value {cluster_size = 4, cluster_stride = 2} : f32
  %prefix = kernel.subgroup.scan<addf> %value {direction = forward, mode = inclusive} : f32
  %reverse_prefix = kernel.subgroup.scan<addf> %value {cluster_size = 4, direction = reverse, mode = exclusive} : f32
  %any = kernel.subgroup.vote.any %predicate : i1
  %all = kernel.subgroup.vote.all %predicate : i1
  %ballot = kernel.subgroup.vote.ballot %predicate : i1 -> i64
  %active = kernel.subgroup.active.mask : i64
  %match_any = kernel.subgroup.match.any %lane : i32 -> i64
  %match_mask, %match_all = kernel.subgroup.match.all %lane : i32 -> i64, i1
  kernel.return
}

