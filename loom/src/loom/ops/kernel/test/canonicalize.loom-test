// RUN: pass canonicalize

kernel.def @exit_moves_tail_to_false_path(%done: i1, %value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  kernel.exit %done : i1
  test.use %value : i32
  kernel.return
}

// ----
kernel.def @exit_moves_tail_to_false_path(%done: i1, %value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  scf.if %done {
    scf.yield
  } else {
    test.use %value : i32
    scf.yield
  }
  kernel.return
}

// ====

kernel.def @exit_body_moves_to_true_path(%done: i1, %value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  kernel.exit %done : i1 {
    test.use %value : i32
    kernel.return
  }
  kernel.return
}

// ----
kernel.def @exit_body_moves_to_true_path(%done: i1, %value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  scf.if %done {
    test.use %value : i32
    scf.yield
  } else {
    scf.yield
  }
  kernel.return
}

// ====

kernel.def @false_exit_erases(%value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %done = scalar.constant false : i1
  kernel.exit %done : i1
  test.use %value : i32
  kernel.return
}

// ----
kernel.def @false_exit_erases(%value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  test.use %value : i32
  kernel.return
}

// ====

kernel.def @true_exit_erases(%value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %done = scalar.constant true : i1
  kernel.exit %done : i1
  test.use %value : i32
  kernel.return
}

// ----
kernel.def @true_exit_erases(%value: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  kernel.return
}

// ====

kernel.def @true_exit_inlines_body(%value: i32, %dead: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %done = scalar.constant true : i1
  kernel.exit %done : i1 {
    test.use %value : i32
    kernel.return
  }
  test.use %dead : i32
  kernel.return
}

// ----
kernel.def @true_exit_inlines_body(%value: i32, %dead: i32) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
