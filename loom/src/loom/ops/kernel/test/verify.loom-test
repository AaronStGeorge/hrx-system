// RUN: verify

test.target<low_core> @test_target

target.artifact @test_artifact target(@test_target) {abi = hal_executable, artifact_format = elf}

// ERROR@+1: STRUCTURE/014 "export" "0" "present when artifact, ordinal, or linkage is present"
kernel.def target(@test_target) artifact(@test_artifact) @kernel_artifact_requires_export() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  kernel.return
}

// ====

test.target<low_core> @test_target

kernel.def @launch_config_requires_index_operands() {
  %c1 = index.constant 1 : index
  %bad = scalar.constant 0 : i32
  // ERROR@+1: TYPE/003 "workgroup_size_x" "i32" "index"
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%bad, %c1, %c1) : index
} launch {
  kernel.return
}

// ====

test.target<low_core> @test_target

func.def @workitem_id_requires_kernel_def() {
  // ERROR@+1: STRUCTURE/029 "kernel.workitem.id" "required" "kernel.def" "func.def"
  %tid = kernel.workitem.id<x> : index
  func.return
}

// ====

test.target<low_core> @test_target

kernel.def @exit_requires_direct_kernel_body(%cond: i1) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  scf.if %cond {
    // ERROR@+1: STRUCTURE/029 "kernel.exit" "parent" "kernel.def" "scf.if"
    kernel.exit %cond : i1
    scf.yield
  }
  kernel.return
}

