func.def @async_group_rejects_group_operand_as_token() {
  %empty = kernel.async.group -> kernel.async.group
  // ERROR@+1: TYPE/003 "tokens" "kernel.async.group" "kernel.async.token"
  %bad = kernel.async.group %empty : kernel.async.group -> kernel.async.group
  kernel.async.wait %empty {newer_groups = 0} : kernel.async.group
  kernel.async.wait %bad {newer_groups = 0} : kernel.async.group
  func.return
}

