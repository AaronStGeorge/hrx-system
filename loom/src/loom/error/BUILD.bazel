load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test", "loom_generated_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "emitter",
    hdrs = ["emitter.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "diagnostic",
    srcs = ["diagnostic.c"],
    hdrs = ["diagnostic.h"],
    deps = [
        ":emitter",
        ":error_defs",
        ":renderer",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "diagnostic_test",
    srcs = ["diagnostic_test.cc"],
    deps = [
        ":diagnostic",
        ":error_defs",
        ":renderer",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_generated_cc_library(
    name = "error_defs",
    hdrs = [
        "error_defs.h",
    ],
    args = [
        "--catalog-symbol=loom_error_catalog_core",
        "--public-header=loom/error/error_catalog.h",
        "--shard=core",
    ],
    extra_output_flags = [
        "--catalog",
    ],
    extra_outputs = [
        "error_catalog.json",
    ],
    generated_hdr_flags = [
        "--header",
    ],
    generated_hdrs = [
        "error_catalog.h",
    ],
    generator = "//loom/py/loom/gen/error:c_errors",
    source = "error_catalog.c",
    deps = [
        ":emitter",
        "//loom/src/loom/ir",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "error_defs_test",
    srcs = ["error_defs_test.cc"],
    deps = [
        ":error_defs",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_library(
    name = "json_sink",
    srcs = ["json_sink.c"],
    hdrs = ["json_sink.h"],
    deps = [
        ":diagnostic",
        ":error_defs",
        ":renderer",
        "//loom/src/loom/util:json",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "json_sink_test",
    srcs = ["json_sink_test.cc"],
    deps = [
        ":error_defs",
        ":json_sink",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_library(
    name = "renderer",
    srcs = ["renderer.c"],
    hdrs = ["renderer.h"],
    deps = [
        ":error_defs",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "renderer_test",
    srcs = ["renderer_test.cc"],
    deps = [
        ":error_defs",
        ":renderer",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
