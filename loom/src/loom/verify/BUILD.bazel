load("//loom/build_tools/bazel:build_defs.bzl", "loom_assert_no_dependencies", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_assert_no_dependencies(
    name = "core_verify_no_func_dialect_dep",
    dependencies = ["//loom/src/loom/ops/func"],
    targets = [":verify"],
)

loom_cc_library(
    name = "verify",
    srcs = [
        "verify.c",
        "verify_constraints.c",
        "verify_diagnostics.c",
        "verify_ownership.c",
        "verify_state.c",
        "verify_structure.c",
    ],
    hdrs = [
        "verify.h",
        "verify_constraints.h",
        "verify_diagnostics.h",
        "verify_ownership.h",
        "verify_state.h",
        "verify_structure.h",
    ],
    deps = [
        "//loom/src/loom/analysis:consumption",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/error:renderer",
        "//loom/src/loom/format/text:printer",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops:special_values",
        "//loom/src/loom/target:registers",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/base/internal:unicode",
    ],
)

loom_cc_test(
    name = "verify_test",
    srcs = ["verify_test.cc"],
    deps = [
        ":verify",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/error:json_sink",
        "//loom/src/loom/error:renderer",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
