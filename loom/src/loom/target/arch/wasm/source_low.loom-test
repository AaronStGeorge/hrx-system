// RUN: emit source-low @wasm_arith output=low
target.profile @wasm_target preset("wasm-simd128")

func.def target(@wasm_target) @wasm_arith(%lhs: vector<4xi32>, %rhs: vector<4xi32>) -> (vector<4xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %diff = vector.subi %sum, %rhs : vector<4xi32>
  func.return %diff : vector<4xi32>
}
// ----
low.func.def target(@wasm_target) abi(wasm_function) @wasm_arith__low(%lhs: reg<wasm.v128>, %rhs: reg<wasm.v128>) -> (reg<wasm.v128>) {
  %sum = low.op<wasm.i32x4.add>(%lhs, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  %diff = low.op<wasm.i32x4.sub>(%sum, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  low.return %diff : reg<wasm.v128>
}

// ====
// RUN: emit source-low @wasm_f32_arith output=low
target.profile @wasm_f32_target preset("wasm-simd128")

func.def target(@wasm_f32_target) @wasm_f32_arith(%lhs: vector<4xf32>, %rhs: vector<4xf32>) -> (vector<4xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<4xf32>
  %product = vector.mulf %sum, %rhs : vector<4xf32>
  func.return %product : vector<4xf32>
}

// ----
low.func.def target(@wasm_f32_target) abi(wasm_function) @wasm_f32_arith__low(%lhs: reg<wasm.v128>, %rhs: reg<wasm.v128>) -> (reg<wasm.v128>) {
  %sum = low.op<wasm.f32x4.add>(%lhs, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  %product = low.op<wasm.f32x4.mul>(%sum, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  low.return %product : reg<wasm.v128>
}

// ====
// RUN: emit source-low @wasm_splat output=low
target.profile @wasm_splat_target preset("wasm-simd128")

func.def target(@wasm_splat_target) @wasm_splat(%value: i32, %rhs: vector<4xi32>) -> (vector<4xi32>) {
  %splat = vector.splat %value : vector<4xi32>
  %sum = vector.addi %splat, %rhs : vector<4xi32>
  func.return %sum : vector<4xi32>
}

// ----
low.func.def target(@wasm_splat_target) abi(wasm_function) @wasm_splat__low(%value: reg<wasm.i32>, %rhs: reg<wasm.v128>) -> (reg<wasm.v128>) {
  %splat = low.op<wasm.i32x4.splat>(%value) : (reg<wasm.i32>) -> reg<wasm.v128>
  %sum = low.op<wasm.i32x4.add>(%splat, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  low.return %sum : reg<wasm.v128>
}
