  low.scf.if %condition {
  }
  return
}

// ====
// RUN: pass source-to-low{control-flow=structured-low}

wasm.target<simd128> @target

func.def target(@target) @rejects_unsupported_structured_region_op(%selector: index, %a: vector<4xi32>, %b: vector<4xi32>) -> (vector<4xi32>) {
  // ERROR@+1: TARGET/030 {op_name="scf.switch", region_count="2"}
  %result = scf.switch %selector -> (vector<4xi32>) {
    case 0 {
      scf.yield %a : vector<4xi32>
    }
    default {
      scf.yield %b : vector<4xi32>
    }
  }
  func.return %result : vector<4xi32>
}
