// RUN: emit low-allocation-json @nested_if_allocates fixed=%then:target_id:9:1 fixed=%else:target_id:10:1

wasm.target<simd128> @target

low.func.def target(@target) abi(wasm_function) @nested_if_allocates(%cond: reg<wasm.i32>, %lhs: reg<wasm.v128>, %rhs: reg<wasm.v128>, %fallback: reg<wasm.v128>) -> (reg<wasm.v128>) asm<wasm.core.simd128> {
  %result = low.scf.if %cond -> (reg<wasm.v128>) {
    %then = i32x4.add %lhs, %rhs
    low.scf.yield %then : reg<wasm.v128>
  } else {
    %else = i32x4.sub %fallback, %rhs
    low.scf.yield %else : reg<wasm.v128>
  }
  return %result
}

