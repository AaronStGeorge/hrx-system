// RUN: emit low-allocation-json @nested_for_allocates fixed=%iv:target_id:20:1 fixed=%acc:target_id:21:1 fixed=%copy:target_id:22:1 fixed=%next:target_id:23:1

wasm.target<simd128> @target

low.func.def target(@target) abi(wasm_function) @nested_for_allocates(%lo: reg<wasm.i32>, %hi: reg<wasm.i32>, %step: reg<wasm.i32>, %seed: reg<wasm.v128>, %rhs: reg<wasm.v128>) -> (reg<wasm.v128>) asm<wasm.core.simd128> {
  %result = low.scf.for [%lo to %hi step %step] iter_args(%seed: reg<wasm.v128>) -> (reg<wasm.v128>) do(%iv: reg<wasm.i32>, %acc: reg<wasm.v128>) {
    %copy = copy %acc : reg<wasm.v128> -> reg<wasm.v128>
    %next = i32x4.add %copy, %rhs
    low.scf.yield %next : reg<wasm.v128>
  }
  return %result
}

