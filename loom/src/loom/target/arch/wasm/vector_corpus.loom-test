// RUN: emit source-low @wasm_i32_mix4 output=none
target.profile @wasm_i32_mix_target preset("wasm-simd128")

func.def target(@wasm_i32_mix_target) @wasm_i32_mix4(%lhs: vector<4xi32>, %rhs: vector<4xi32>) -> (vector<4xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %product = vector.muli %sum, %rhs : vector<4xi32>
  %result = vector.subi %product, %lhs : vector<4xi32>
  func.return %result : vector<4xi32>
}

// ====
// RUN: emit source-low @wasm_f32_mix4 output=none
target.profile @wasm_f32_mix_target preset("wasm-simd128")

func.def target(@wasm_f32_mix_target) @wasm_f32_mix4(%lhs: vector<4xf32>, %rhs: vector<4xf32>) -> (vector<4xf32>) {
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %result = vector.addf %product, %rhs : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====
// RUN: emit source-low @wasm_memory_copy output=none
target.profile @wasm_memory_copy_target preset("wasm-simd128")

func.def target(@wasm_memory_copy_target) @wasm_memory_copy(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @wasm_dot_gap output=none
// XFAIL: Wasm SIMD128 source-to-low does not yet lower vector dot/reduction forms.
target.profile @wasm_dot_gap_target preset("wasm-simd128")

func.def target(@wasm_dot_gap_target) @wasm_dot_gap(%lhs: vector<4xi8>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}
