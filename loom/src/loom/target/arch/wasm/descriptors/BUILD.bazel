load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_low_descriptor_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_WASM_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/wasm:__pkg__"]

_WASM_DESCRIPTOR_VISIBILITY = [
    "//loom/src/loom/target/emit/wasm:__pkg__",
    "//loom/src/loom/target/emit/wasm/contracts:__pkg__",
] + _WASM_ROOT_VISIBILITY

_WASM_DESCRIPTOR_IDS_VISIBILITY = (
    _WASM_DESCRIPTOR_VISIBILITY + [
        "//loom/src/loom/target/emit/wasm/lower:__pkg__",
    ]
)

loom_low_descriptor_cc_library(
    name = "descriptors",
    args = ["--descriptor-set=wasm_core_simd128"],
    generator = "//loom/py/loom/gen:wasm_low_descriptor_shard",
    ids_visibility = _WASM_DESCRIPTOR_IDS_VISIBILITY,
    visibility = _WASM_DESCRIPTOR_VISIBILITY,
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    visibility = _WASM_ROOT_VISIBILITY,
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:types",
        "//loom/src/loom/target/arch/wasm/records:target_records",
        "//runtime/src/iree/base",
    ],
)
