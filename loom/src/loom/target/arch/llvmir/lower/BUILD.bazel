load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_LLVMIR_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/llvmir:__pkg__"]

loom_cc_library(
    name = "lower",
    srcs = ["registry.c"],
    hdrs = ["lower.h"],
    visibility = _LLVMIR_ROOT_VISIBILITY,
    deps = [
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/target/arch/llvmir/contracts",
        "//loom/src/loom/target/arch/llvmir/descriptors:descriptors_ids",
        "//runtime/src/iree/base",
    ],
)
