// TEMPLATE: loom/src/loom/test/corpus/source_low/vector_bitcast.loom-test
// RUN: emit source-low output=low

// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_to_i8x4_bitcast(%word: vector<1xi32>) -> (vector<4xi8>) {
  %bytes = vector.bitcast %word : vector<1xi32> to vector<4xi8>
  func.return %bytes : vector<4xi8>
}

