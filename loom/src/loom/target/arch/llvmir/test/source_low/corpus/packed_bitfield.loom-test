llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_bitfield_insert(%field_buffer: buffer, %base_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %field_view = buffer.view %field_buffer[%zero] : buffer -> view<1xi32, #dense>
  %base_view = buffer.view %base_buffer[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %field = vector.load %field_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %base = vector.load %base_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %inserted = vector.bitfield.insert %field into %base {offset = 8, width = 4} : vector<1xi32>, vector<1xi32>
  vector.store %inserted, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @i32_bitfield_insert(%field_view: reg<llvmir.ptr>, %base_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %27 = load.i32 %field_view, 0
  %28 = load.i32 %base_view, 0
  %29 = const.i32 15
  %30 = and.i32 %27, %29
  %31 = const.i32 8
  %32 = shl.i32 %30, %31
  %33 = const.i32 -3841
  %34 = and.i32 %28, %33
  %inserted = or.i32 %34, %32
  store.i32 %inserted, %output_view, 0
  return
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_bitfield_b128_shape(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %low = vector.bitfield.extractu %loaded {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high = vector.bitfield.extractu %loaded {offset = 4, width = 2} : vector<4xi32> -> vector<4xi32>
  %merged = vector.bitfield.insert %high into %low {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %result = vector.subi %merged, %bias : vector<4xi32>
  vector.store %result, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @i32_bitfield_b128_shape(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %86 = load.i32 %input_view, 0
  %87 = const.i32 4
  %88 = lshr.i32 %86, %87
  %89 = const.i32 3
  %90 = and.i32 %88, %89
  %91 = const.i32 15
  %92 = and.i32 %86, %91
  %93 = shl.i32 %90, %87
  %94 = const.i32 -49
  %95 = and.i32 %92, %94
  %96 = or.i32 %95, %93
  %97 = load.i32 %input_view, 4
  %98 = lshr.i32 %97, %87
  %99 = and.i32 %98, %89
  %100 = and.i32 %97, %91
  %101 = shl.i32 %99, %87
  %102 = and.i32 %100, %94
  %103 = or.i32 %102, %101
  %104 = load.i32 %input_view, 8
  %105 = lshr.i32 %104, %87
  %106 = and.i32 %105, %89
  %107 = and.i32 %104, %91
  %108 = shl.i32 %106, %87
  %109 = and.i32 %107, %94
  %110 = or.i32 %109, %108
  %111 = load.i32 %input_view, 12
  %112 = lshr.i32 %111, %87
  %113 = and.i32 %112, %89
  %114 = and.i32 %111, %91
  %115 = shl.i32 %113, %87
  %116 = and.i32 %114, %94
  %117 = or.i32 %116, %115
  %merged = from_elements.v4i32 %96, %103, %110, %117
  %bias = const.v4i32 32
  %result = sub.v4i32 %merged, %bias
  store.v4i32 %result, %output_view, 0
  return
}
