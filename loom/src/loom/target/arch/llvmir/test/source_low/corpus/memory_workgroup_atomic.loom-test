low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_atomic_bitwise_i32() asm<llvmir.generic.core> {
  %bytes = const.i64 256
  %scratch_view = alloca.workgroup.i8 %bytes, 4
  %mask = const.i32 255
  atomic.reduce.and.i32 %mask, %scratch_view, 0, 0, 2
  atomic.reduce.or.i32 %mask, %scratch_view, 0, 0, 2
  atomic.reduce.xor.i32 %mask, %scratch_view, 0, 0, 2
  %old_and = atomic.rmw.and.i32 %mask, %scratch_view, 0, 0, 2
  %old_or = atomic.rmw.or.i32 %mask, %scratch_view, 0, 0, 2
  %old_xor = atomic.rmw.xor.i32 %mask, %scratch_view, 0, 0, 2
  return
}

