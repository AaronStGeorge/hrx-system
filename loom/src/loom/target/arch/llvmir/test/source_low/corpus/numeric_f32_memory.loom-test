llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32_uniform_vector_binary(%lhs_buffer: buffer, %rhs_buffer: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %lhs_global = buffer.assume.memory_space<global> %lhs_buffer : buffer
  %rhs_global = buffer.assume.memory_space<global> %rhs_buffer : buffer
  %lhs_noalias, %rhs_noalias = buffer.assume.noalias %lhs_global, %rhs_global : buffer, buffer
  %lhs_view = buffer.view %lhs_noalias[%base] : buffer -> view<4xf32, #dense>
  %rhs_view = buffer.view %rhs_noalias[%base] : buffer -> view<4xf32, #dense>
  %lhs = vector.load %lhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %sum = vector.addf %lhs, %rhs : vector<4xf32>
  %difference = vector.subf %lhs, %rhs : vector<4xf32>
  %combined = vector.addf %product, %sum : vector<4xf32>
  %two = vector.constant 2.0 : vector<4xf32>
  %scaled = vector.mulf %lhs, %two : vector<4xf32>
  %with_difference = vector.addf %combined, %difference : vector<4xf32>
  %result = vector.addf %with_difference, %scaled : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
low.func.def target(@target) abi(object_function) @f32_uniform_vector_binary(%lhs_view: reg<llvmir.ptr>, %rhs_view: reg<llvmir.ptr>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %lhs = load.v4f32 %lhs_view, 0
  %rhs = load.v4f32 %rhs_view, 0
  %product = mul.v4f32 %lhs, %rhs
  %sum = add.v4f32 %lhs, %rhs
  %difference = sub.v4f32 %lhs, %rhs
  %combined = add.v4f32 %product, %sum
  %two = const.v4f32 1073741824
  %scaled = mul.v4f32 %lhs, %two
  %with_difference = add.v4f32 %combined, %difference
  %result = add.v4f32 %with_difference, %scaled
  return %result
}

