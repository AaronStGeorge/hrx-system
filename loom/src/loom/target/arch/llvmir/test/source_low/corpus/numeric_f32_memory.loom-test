// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_f32_memory.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}
kernel.def target(@target) @f32_arith() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %sum = vector.addf %lhs, %rhs : vector<1xf32>
  %product = vector.mulf %sum, %rhs : vector<1xf32>
  %negated = vector.negf %product : vector<1xf32>
  %absolute = vector.absf %negated : vector<1xf32>
  vector.store %absolute, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @f32_arith() asm<llvmir.generic.core> {
  %lhs_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %rhs_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer} : reg<llvmir.ptr>
  %lhs = load.f32 %lhs_view, 0
  %rhs = load.f32 %rhs_view, 0
  %sum = add.f32 %lhs, %rhs
  %product = mul.f32 %sum, %rhs
  %negated = neg.f32 %product
  %absolute = abs.f32 %negated
  store.f32 %absolute, %output_view, 0
  return
}

