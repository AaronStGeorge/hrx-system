// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_b128.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}
kernel.def target(@target) @lds_b128_roundtrip() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_b128_roundtrip() asm<llvmir.generic.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %bytes = const.i64 1024
  %scratch_view = alloca.workgroup.i8 %bytes, 16
  %loaded = load.v4i32 %input_view, 0
  store.v4i32 %loaded, %scratch_view, 0
  %roundtrip = load.v4i32 %scratch_view, 0
  store.v4i32 %roundtrip, %output_view, 0
  return
}

// ====

llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}
kernel.def target(@target) @lds_b128_xor_swizzle_roundtrip() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %shift = index.constant 4 : index
  %shifted = index.shrui %tid, %shift : index
  %mask = index.constant 3 : index
  %swizzle_bits = index.andi %shifted, %mask : index
  %swizzled = index.xori %tid, %swizzle_bits : index
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%swizzled, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%swizzled, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @lds_b128_xor_swizzle_roundtrip() asm<llvmir.generic.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %tid = kernel.workitem_id.x
  %bytes = const.i64 1024
  %scratch_view = alloca.workgroup.i8 %bytes, 16
  %shift = const.i64 4
  %shifted = lshr.i64 %tid, %shift
  %mask = const.i64 3
  %swizzle_bits = and.i64 %shifted, %mask
  %swizzled = xor.i64 %tid, %swizzle_bits
  %50 = const.i64 2
  %51 = shl.i64 %tid, %50
  %loaded = load.indexed.v4i32 %input_view, %51, 0, 16
  %53 = shl.i64 %swizzled, %50
  store.indexed.v4i32 %loaded, %scratch_view, %53, 0, 16
  %roundtrip = load.indexed.v4i32 %scratch_view, %53, 0, 16
  store.indexed.v4i32 %roundtrip, %output_view, %51, 0, 16
  return
}

