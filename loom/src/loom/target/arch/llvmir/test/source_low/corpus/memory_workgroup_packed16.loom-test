low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_f16x8_b128_extract_scalar_stores() asm<llvmir.generic.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %bytes = const.i64 16
  %scratch_view = alloca.workgroup.i8 %bytes, 16
  %loaded = load.v8f16 %input_view, 0
  %lane0 = extract.v8f16 %loaded, 0
  store.f16 %lane0, %scratch_view, 0
  %lane1 = extract.v8f16 %loaded, 1
  store.f16 %lane1, %scratch_view, 2
  %lane2 = extract.v8f16 %loaded, 2
  store.f16 %lane2, %scratch_view, 4
  %lane3 = extract.v8f16 %loaded, 3
  store.f16 %lane3, %scratch_view, 6
  %lane4 = extract.v8f16 %loaded, 4
  store.f16 %lane4, %scratch_view, 8
  %lane5 = extract.v8f16 %loaded, 5
  store.f16 %lane5, %scratch_view, 10
  %lane6 = extract.v8f16 %loaded, 6
  store.f16 %lane6, %scratch_view, 12
  %lane7 = extract.v8f16 %loaded, 7
  store.f16 %lane7, %scratch_view, 14
  %roundtrip = load.v8f16 %scratch_view, 0
  store.v8f16 %roundtrip, %output_view, 0
  return
}

