// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}
kernel.def target(@target) @lds_f16_strided_scalar_roundtrip() {
  %unit = index.constant 1 : index
  %tile = index.constant 16 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%tile, %tile, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %row0 = kernel.workitem.id<x> : index
  %col0 = kernel.workitem.id<y> : index
  %row = index.assume %row0 [range(%row0, 0, 15)] : index
  %col = index.assume %col0 [range(%col0, 0, 15)] : index
  %base = index.constant 0 : offset
  %bytes = index.constant 512 : offset
  %rhs_layout = encoding.layout.strided [1, 16] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 2, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%base] : buffer -> view<16x16xf16, #dense>
  %scratch_view = buffer.view %scratch[%base] : buffer -> view<16x16xf16, %rhs_layout>
  %output_view = buffer.view %output[%base] : buffer -> view<16x16xf16, #dense>
  %loaded = view.load %input_view[%row, %col] : view<16x16xf16, #dense> -> f16
  view.store %loaded, %scratch_view[%row, %col] : f16, view<16x16xf16, %rhs_layout>
  %roundtrip = view.load %scratch_view[%row, %col] : view<16x16xf16, %rhs_layout> -> f16
  view.store %roundtrip, %output_view[%row, %col] : f16, view<16x16xf16, #dense>
  kernel.return
}
