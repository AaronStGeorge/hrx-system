llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_cmpi_select(%lhs: vector<2xi32>, %rhs: vector<2xi32>, %true_value: vector<2xi32>, %false_value: vector<2xi32>) -> (vector<2xi32>) {
  %mask = vector.cmpi slt, %lhs, %rhs : vector<2xi32> -> vector<2xi1>
  %selected = vector.select %mask, %true_value, %false_value : vector<2xi32>
  func.return %selected : vector<2xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32_cmpi_select(%lhs: reg<llvmir.i32 x2>, %rhs: reg<llvmir.i32 x2>, %true_value: reg<llvmir.i32 x2>, %false_value: reg<llvmir.i32 x2>) -> (reg<llvmir.i32 x2>) asm<llvmir.generic.core> {
  %mask = cmp.slt.v2i32 %lhs, %rhs
  %selected = select.v2i32 %mask, %true_value, %false_value
  return %selected
}

