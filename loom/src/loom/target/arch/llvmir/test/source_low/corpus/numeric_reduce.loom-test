// ----
low.func.def target(@target) abi(object_function) @f32_reduce_add(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %init = const.f32 0
  %21 = load.f32 %input_view, 0
