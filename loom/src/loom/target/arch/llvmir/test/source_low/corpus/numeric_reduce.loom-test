  %23 = load.f32 %input_view, 4
  %24 = add.f32 %22, %23
  %25 = load.f32 %input_view, 8
  %26 = add.f32 %24, %25
  %27 = load.f32 %input_view, 12
  %stored = add.f32 %26, %27
  store.f32 %stored, %output_view, 0
