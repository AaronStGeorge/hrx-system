// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_reduce.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %init = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %loaded, %init : vector<4xi32>, i32
  %stored = vector.from_elements %sum : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @i32_reduce_add(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %20 = load.i32 %input_view, 0
  %21 = load.i32 %input_view, 4
  %22 = add.i32 %20, %21
  %23 = load.i32 %input_view, 8
  %24 = add.i32 %22, %23
  %25 = load.i32 %input_view, 12
  %stored = add.i32 %24, %25
  store.i32 %stored, %output_view, 0
  return
}

