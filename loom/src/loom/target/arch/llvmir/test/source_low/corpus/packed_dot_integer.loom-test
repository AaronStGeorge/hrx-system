// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_dot_integer.loom-test
// RUN: emit source-low output=low

// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @dot4i_s8s8(%lhs: vector<4xi8>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}

