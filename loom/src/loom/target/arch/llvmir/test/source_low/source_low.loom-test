llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_i32x4_compare_select(%lhs: vector<4xi32>, %rhs: vector<4xi32>, %fallback: vector<4xi32>) -> (vector<4xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %predicate = vector.cmpi slt, %sum, %rhs : vector<4xi32> -> vector<4xi1>
  %selected = vector.select %predicate, %sum, %fallback : vector<4xi32>
  func.return %selected : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_i32x4_compare_select(%lhs: reg<llvmir.i32 x4>, %rhs: reg<llvmir.i32 x4>, %fallback: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %sum = add.v4i32 %lhs, %rhs
  %predicate = cmp.slt.v4i32 %sum, %rhs
  %selected = select.v4i32 %predicate, %sum, %fallback
  return %selected
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_i32x16_vector_ops(%lhs: vector<16xi32>, %rhs: vector<16xi32>, %fallback: vector<16xi32>) -> (vector<16xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<16xi32>
  %shifted = vector.shli %sum, %rhs : vector<16xi32>
  %signed = vector.cmpi sgt, %shifted, %rhs : vector<16xi32> -> vector<16xi1>
  %unsigned = vector.cmpi ugt, %shifted, %lhs : vector<16xi32> -> vector<16xi1>
  %mask = vector.ori %signed, %unsigned : vector<16xi1>
  %selected = vector.select %mask, %shifted, %fallback : vector<16xi32>
  func.return %selected : vector<16xi32>
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_i32x16_vector_ops(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>, %fallback: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %sum = add.v16i32 %lhs, %rhs
  %shifted = shl.v16i32 %sum, %rhs
  %signed = cmp.sgt.v16i32 %shifted, %rhs
  %unsigned = cmp.ugt.v16i32 %shifted, %lhs
  %mask = or.v16i1 %signed, %unsigned
  %selected = select.v16i32 %mask, %shifted, %fallback
  return %selected
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_f32x16_unordered_select(%lhs: vector<16xf32>, %rhs: vector<16xf32>, %fallback: vector<16xf32>) -> (vector<16xf32>) {
  %ordered = vector.cmpf olt, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %unordered = vector.cmpf une, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %selected = vector.select %ordered, %lhs, %rhs : vector<16xf32>
  %result = vector.select %unordered, %selected, %fallback : vector<16xf32>
  func.return %result : vector<16xf32>
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_f32x16_unordered_select(%lhs: reg<llvmir.f32 x16>, %rhs: reg<llvmir.f32 x16>, %fallback: reg<llvmir.f32 x16>) -> (reg<llvmir.f32 x16>) asm<llvmir.generic.core> {
  %ordered = cmp.olt.v16f32 %lhs, %rhs
  %unordered = cmp.une.v16f32 %lhs, %rhs
  %selected = select.v16f32 %ordered, %lhs, %rhs
  %result = select.v16f32 %unordered, %selected, %fallback
  return %result
}

