func.def target(@target) @llvmir_f64_unordered_compare_select(%lhs: f64, %rhs: f64, %true_value: f64, %false_value: f64) -> (f64) {
  %predicate = scalar.cmpf uno, %lhs, %rhs : f64
  %selected = scf.select %predicate, %true_value, %false_value : f64
  func.return %selected : f64
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_f64_unordered_compare_select(%lhs: reg<llvmir.f64>, %rhs: reg<llvmir.f64>, %true_value: reg<llvmir.f64>, %false_value: reg<llvmir.f64>) -> (reg<llvmir.f64>) asm<llvmir.generic.core> {
