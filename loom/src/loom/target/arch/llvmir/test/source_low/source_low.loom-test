// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_scalar_arithmetic(%lhs: i32, %rhs: i32, %x: f32, %y: f32) -> (i32, f32) {
  %sum = scalar.addi %lhs, %rhs : i32
  %product = scalar.mulf %x, %y : f32
  func.return %sum, %product : i32, f32
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_scalar_arithmetic(%lhs: reg<llvmir.i32>, %rhs: reg<llvmir.i32>, %x: reg<llvmir.f32>, %y: reg<llvmir.f32>) -> (reg<llvmir.i32>, reg<llvmir.f32>) asm<llvmir.generic.core> {
  %sum = add.i32 %lhs, %rhs
  %product = mul.f32 %x, %y
  return %sum, %product
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_i64_compare_select(%lhs: i64, %rhs: i64, %true_value: i64, %false_value: i64) -> (i64) {
  %predicate = scalar.cmpi sgt, %lhs, %rhs : i64
  %selected = scf.select %predicate, %true_value, %false_value : i64
  func.return %selected : i64
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_i64_compare_select(%lhs: reg<llvmir.i64>, %rhs: reg<llvmir.i64>, %true_value: reg<llvmir.i64>, %false_value: reg<llvmir.i64>) -> (reg<llvmir.i64>) asm<llvmir.generic.core> {
  %predicate = cmp.sgt.i64 %lhs, %rhs
  %selected = select.i64 %predicate, %true_value, %false_value
  return %selected
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_i32x4_compare_select(%lhs: vector<4xi32>, %rhs: vector<4xi32>, %fallback: vector<4xi32>) -> (vector<4xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %predicate = vector.cmpi slt, %sum, %rhs : vector<4xi32> -> vector<4xi1>
  %selected = vector.select %predicate, %sum, %fallback : vector<4xi32>
  func.return %selected : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_i32x4_compare_select(%lhs: reg<llvmir.i32 x4>, %rhs: reg<llvmir.i32 x4>, %fallback: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %sum = add.v4i32 %lhs, %rhs
  %predicate = cmp.slt.v4i32 %sum, %rhs
  %selected = select.v4i32 %predicate, %sum, %fallback
  return %selected
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @llvmir_i32_dynamic_memory(%input: buffer, %output: buffer, %i: index) -> (i32) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %bounded_i = index.assume %i [range(%i, 0, 16)] : index
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xi32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xi32, #dense>
  %loaded = view.load %input_view[%bounded_i] : view<32xi32, #dense> -> i32
  view.store %loaded, %output_view[%bounded_i] : i32, view<32xi32, #dense>
  func.return %loaded : i32
}

// ----
low.func.def target(@target) abi(object_function) @llvmir_i32_dynamic_memory(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %bounded_i: reg<llvmir.i64>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %loaded = load.indexed.i32 %input_view, %bounded_i, 16, 4
  store.indexed.i32 %loaded, %output_view, %bounded_i, 32, 4
  return %loaded
}

// ====

llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}

kernel.def target(@target) @llvmir_hal_buffer_resources() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = view.load %input_view[0] : view<1xi32, #dense> -> i32
  view.store %loaded, %output_view[0] : i32, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @llvmir_hal_buffer_resources() asm<llvmir.generic.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %loaded = load.i32 %input_view, 0
  store.i32 %loaded, %output_view, 0
  return
}
