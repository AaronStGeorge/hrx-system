// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_dot_float8.loom-test
// RUN: emit source-low output=low

// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @dot4f8_fp8bf8(%lhs: vector<1xi32>, %rhs: vector<1xi32>, %acc: vector<1xf32>) -> (vector<1xf32>) {
  %dot = vector.dot4f8<fp8bf8> %lhs, %rhs, %acc : vector<1xi32>, vector<1xf32>
  func.return %dot : vector<1xf32>
}

