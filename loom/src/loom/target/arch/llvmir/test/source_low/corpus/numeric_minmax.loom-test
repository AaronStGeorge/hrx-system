llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32_reduce_minnum_maxnum(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<2xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %min_init = scalar.constant 1000.0 : f32
  %min = vector.reduce<minnumf, reassoc|nnan|nsz> %loaded, %min_init : vector<4xf32>, f32
  %max_init = scalar.constant -1000.0 : f32
  %max = vector.reduce<maxnumf, reassoc|nnan|nsz> %loaded, %max_init : vector<4xf32>, f32
  %stored = vector.from_elements %min, %max : vector<2xf32>
  vector.store %stored, %output_view[0] : vector<2xf32>, view<2xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @f32_reduce_minnum_maxnum(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %min_init = const.f32 1148846080
  %30 = load.f32 %input_view, 0
  %31 = load.f32 %input_view, 4
  %32 = minnum.f32 %30, %31
  %33 = load.f32 %input_view, 8
  %34 = load.f32 %input_view, 12
  %35 = minnum.f32 %33, %34
  %36 = minnum.f32 %32, %35
  %min = minnum.f32 %min_init, %36
  %max_init = const.f32 3296329728
  %39 = maxnum.f32 %30, %31
  %40 = maxnum.f32 %33, %34
  %41 = maxnum.f32 %39, %40
  %max = maxnum.f32 %max_init, %41
  %stored = from_elements.v2f32 %min, %max
  store.v2f32 %stored, %output_view, 0
  return
}
