  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @scalar_f32_minnum_maxnum(%lhs: f32, %rhs: f32) -> (f32) {
  %min = scalar.minnumf %lhs, %rhs : f32
  %max = scalar.maxnumf %lhs, %rhs : f32
  %sum = scalar.addf %min, %max : f32
  func.return %sum : f32
}

// ----
low.func.def target(@target) abi(object_function) @scalar_f32_minnum_maxnum(%lhs: reg<llvmir.f32>, %rhs: reg<llvmir.f32>) -> (reg<llvmir.f32>) asm<llvmir.generic.core> {
  %min = minnum.f32 %lhs, %rhs
  %max = maxnum.f32 %lhs, %rhs
  %sum = add.f32 %min, %max
  return %sum
}

