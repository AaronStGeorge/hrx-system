// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @scalar_f32_minnum_maxnum(%lhs: f32, %rhs: f32) -> (f32) {
  %min = scalar.minnumf %lhs, %rhs : f32
  %max = scalar.maxnumf %lhs, %rhs : f32
  %sum = scalar.addf %min, %max : f32
  func.return %sum : f32
}

