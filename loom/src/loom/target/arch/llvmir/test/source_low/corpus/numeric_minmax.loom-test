func.def target(@target) @scf_select_sgpr(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  %selected = scf.select %cond, %a, %b : i32
  func.return %selected : i32
}

// ----
low.func.def target(@target) abi(object_function) @scf_select_sgpr(%lhs: reg<llvmir.i32>, %rhs: reg<llvmir.i32>, %a: reg<llvmir.i32>, %b: reg<llvmir.i32>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %cond = cmp.slt.i32 %lhs, %rhs
  %selected = select.i32 %cond, %a, %b
  return %selected
}

