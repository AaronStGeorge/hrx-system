llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @scf_select_chained_vgpr_i32(%values: vector<2xi32>, %limit: i32, %fallback: i32) -> (i32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %is_lane = scalar.cmpi slt, %lane, %limit : i32
  %selected = scf.select %is_lane, %lane, %fallback : i32
  %is_selected = scalar.cmpi ne, %selected, %fallback : i32
  %result = scf.select %is_selected, %selected, %fallback : i32
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(object_function) @scf_select_chained_vgpr_i32(%values: reg<llvmir.i32 x2>, %limit: reg<llvmir.i32>, %fallback: reg<llvmir.i32>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %lane = extract.v2i32 %values, 0
  %is_lane = cmp.slt.i32 %lane, %limit
  %selected = select.i32 %is_lane, %lane, %fallback
  %is_selected = cmp.ne.i32 %selected, %fallback
  %result = select.i32 %is_selected, %selected, %fallback
  return %result
}

