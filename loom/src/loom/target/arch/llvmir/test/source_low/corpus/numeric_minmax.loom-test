func.def target(@target) @index_minmax_sgpr(%lhs0: index, %rhs0: index) -> (index) {
  %lhs = index.assume %lhs0 [range(%lhs0, 0, 1024)] : index
  %rhs = index.assume %rhs0 [range(%rhs0, 0, 1024)] : index
  %min = index.min %lhs, %rhs : index
  %max = index.max %lhs, %rhs : index
  %sum = index.add %min, %max : index
  func.return %sum : index
}

// ----
low.func.def target(@target) abi(object_function) @index_minmax_sgpr(%lhs: reg<llvmir.i64>, %rhs: reg<llvmir.i64>) -> (reg<llvmir.i64>) asm<llvmir.generic.core> {
  %11 = cmp.slt.i64 %lhs, %rhs
  %min = select.i64 %11, %lhs, %rhs
  %13 = cmp.sgt.i64 %lhs, %rhs
  %max = select.i64 %13, %lhs, %rhs
  %sum = add.i64 %min, %max
  return %sum
}

