// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_bitunpack.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_to_u8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32_to_u8x4_bitunpack(%packed: reg<llvmir.i32>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %32 = const.i32 255
  %33 = and.i32 %packed, %32
  %34 = const.i32 8
  %35 = lshr.i32 %packed, %34
  %36 = and.i32 %35, %32
  %37 = const.i32 16
  %38 = lshr.i32 %packed, %37
  %39 = and.i32 %38, %32
  %40 = const.i32 24
  %41 = lshr.i32 %packed, %40
  %42 = and.i32 %41, %32
  %unpacked = from_elements.v4i32 %33, %36, %39, %42
  return %unpacked
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32_to_s8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacks<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32_to_s8x4_bitunpack(%packed: reg<llvmir.i32>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %48 = const.i32 255
  %49 = and.i32 %packed, %48
  %50 = const.i32 24
  %51 = shl.i32 %49, %50
  %52 = ashr.i32 %51, %50
  %53 = const.i32 8
  %54 = lshr.i32 %packed, %53
  %55 = and.i32 %54, %48
  %56 = shl.i32 %55, %50
  %57 = ashr.i32 %56, %50
  %58 = const.i32 16
  %59 = lshr.i32 %packed, %58
  %60 = and.i32 %59, %48
  %61 = shl.i32 %60, %50
  %62 = ashr.i32 %61, %50
  %63 = lshr.i32 %packed, %50
  %64 = and.i32 %63, %48
  %65 = shl.i32 %64, %50
  %66 = ashr.i32 %65, %50
  %unpacked = from_elements.v4i32 %52, %57, %62, %66
  return %unpacked
}

