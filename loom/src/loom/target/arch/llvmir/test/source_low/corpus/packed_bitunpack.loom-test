llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i8x2_to_u2x8_bitunpack(%packed: vector<2xi8>) -> (vector<8xi32>) {
  %unpacked = vector.bitunpacku<2> %packed : vector<2xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i8x2_to_u2x8_bitunpack(%packed: reg<llvmir.i8 x2>) -> (reg<llvmir.i32 x8>) asm<llvmir.generic.core> {
  %66 = extract.v2i8 %packed, 0
  %67 = zext.i8.i32 %66
  %68 = const.i32 3
  %69 = and.i32 %67, %68
  %70 = const.i32 2
  %71 = lshr.i32 %67, %70
  %72 = and.i32 %71, %68
  %73 = const.i32 4
  %74 = lshr.i32 %67, %73
  %75 = and.i32 %74, %68
  %76 = const.i32 6
  %77 = lshr.i32 %67, %76
  %78 = and.i32 %77, %68
  %79 = extract.v2i8 %packed, 1
  %80 = zext.i8.i32 %79
  %81 = and.i32 %80, %68
  %82 = lshr.i32 %80, %70
  %83 = and.i32 %82, %68
  %84 = lshr.i32 %80, %73
  %85 = and.i32 %84, %68
  %86 = lshr.i32 %80, %76
  %87 = and.i32 %86, %68
  %unpacked = from_elements.v8i32 %69, %72, %75, %78, %81, %83, %85, %87
  return %unpacked
}

