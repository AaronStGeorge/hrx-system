  %58 = shl.i32 %57, %47
  %59 = ashr.i32 %58, %47
  %60 = lshr.i32 %packed, %47
  %61 = and.i32 %60, %45
  %62 = shl.i32 %61, %47
  %63 = ashr.i32 %62, %47
  %unpacked = from_elements.v4i32 %49, %54, %59, %63
  return %unpacked
}

