llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i8x2_to_u2x8_bitunpack(%packed: vector<2xi8>) -> (vector<8xi32>) {
  %unpacked = vector.bitunpacku<2> %packed : vector<2xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i8x2_to_u2x8_bitunpack(%packed: reg<llvmir.i8 x2>) -> (reg<llvmir.i32 x8>) asm<llvmir.generic.core> {
  %66 = extract.v2i8 %packed, 0
  %67 = const.i8 3
  %68 = and.i8 %66, %67
  %69 = zext.i8.i32 %68
  %70 = const.i8 2
  %71 = lshr.i8 %66, %70
  %72 = and.i8 %71, %67
  %73 = zext.i8.i32 %72
  %74 = const.i8 4
  %75 = lshr.i8 %66, %74
  %76 = and.i8 %75, %67
  %77 = zext.i8.i32 %76
  %78 = const.i8 6
  %79 = lshr.i8 %66, %78
  %80 = and.i8 %79, %67
  %81 = zext.i8.i32 %80
  %82 = extract.v2i8 %packed, 1
  %83 = and.i8 %82, %67
  %84 = zext.i8.i32 %83
  %85 = lshr.i8 %82, %70
  %86 = and.i8 %85, %67
  %87 = zext.i8.i32 %86
  %88 = lshr.i8 %82, %74
  %89 = and.i8 %88, %67
  %90 = zext.i8.i32 %89
  %91 = lshr.i8 %82, %78
  %92 = and.i8 %91, %67
  %93 = zext.i8.i32 %92
  %unpacked = from_elements.v8i32 %69, %73, %77, %81, %84, %87, %90, %93
  return %unpacked
}
