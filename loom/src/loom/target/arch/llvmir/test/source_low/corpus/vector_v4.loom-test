  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x4_select(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %true_value: vector<4xf32>, %false_value: vector<4xf32>) -> (vector<4xf32>) {
  %mask = vector.cmpf olt, %lhs, %rhs : vector<4xf32> -> vector<4xi1>
  %selected = vector.select %mask, %true_value, %false_value : vector<4xf32>
  func.return %selected : vector<4xf32>
}

// ----
low.func.def target(@target) abi(object_function) @f32x4_select(%lhs: reg<llvmir.f32 x4>, %rhs: reg<llvmir.f32 x4>, %true_value: reg<llvmir.f32 x4>, %false_value: reg<llvmir.f32 x4>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %mask = cmp.olt.v4f32 %lhs, %rhs
  %selected = select.v4f32 %mask, %true_value, %false_value
  return %selected
}

