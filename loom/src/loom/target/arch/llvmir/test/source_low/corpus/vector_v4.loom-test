func.def target(@target) @f32x4_lane_edit(%v: vector<4xf32>, %x: f32) -> (vector<4xf32>) {
  %lane = vector.extract %v[1] : vector<4xf32> -> f32
  %sum = scalar.addf %lane, %x : f32
  %updated = vector.insert %sum into %v[2] : f32, vector<4xf32>
  func.return %updated : vector<4xf32>
}

