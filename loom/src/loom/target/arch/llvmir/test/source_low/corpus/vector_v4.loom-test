// TEMPLATE: loom/src/loom/test/corpus/source_low/vector_v4.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x4_arith(%lhs: vector<4xi32>, %rhs: vector<4xi32>) -> (vector<4xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %diff = vector.subi %sum, %rhs : vector<4xi32>
  func.return %diff : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x4_arith(%lhs: reg<llvmir.i32 x4>, %rhs: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %sum = add.v4i32 %lhs, %rhs
  %diff = sub.v4i32 %sum, %rhs
  return %diff
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x4_arith(%lhs: vector<4xf32>, %rhs: vector<4xf32>) -> (vector<4xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<4xf32>
  %product = vector.mulf %sum, %rhs : vector<4xf32>
  func.return %product : vector<4xf32>
}

// ----
low.func.def target(@target) abi(object_function) @f32x4_arith(%lhs: reg<llvmir.f32 x4>, %rhs: reg<llvmir.f32 x4>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %sum = add.v4f32 %lhs, %rhs
  %product = mul.v4f32 %sum, %rhs
  return %product
}

