llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x4_select(%lhs: vector<4xi32>, %rhs: vector<4xi32>, %true_value: vector<4xi32>, %false_value: vector<4xi32>) -> (vector<4xi32>) {
  %mask = vector.cmpi slt, %lhs, %rhs : vector<4xi32> -> vector<4xi1>
  %selected = vector.select %mask, %true_value, %false_value : vector<4xi32>
  func.return %selected : vector<4xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x4_select(%lhs: reg<llvmir.i32 x4>, %rhs: reg<llvmir.i32 x4>, %true_value: reg<llvmir.i32 x4>, %false_value: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %mask = cmp.slt.v4i32 %lhs, %rhs
  %selected = select.v4i32 %mask, %true_value, %false_value
  return %selected
}

