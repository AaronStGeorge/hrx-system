  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %x = kernel.workitem_id.x
  %y = kernel.workitem_id.y
  %row_stride = const.i64 4
  %19 = mul.i64 %y, %row_stride
  %linear = add.i64 %19, %x
  %loaded = load.indexed.i32 %input_view, %linear, 0, 4
  store.indexed.i32 %loaded, %output_view, %linear, 0, 4
  return
}

