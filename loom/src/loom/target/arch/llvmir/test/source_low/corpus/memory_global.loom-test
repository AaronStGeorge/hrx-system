low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_readonly_uniform_smem_loop_bound() asm<llvmir.generic.core> {
  %control_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %input_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<llvmir.ptr>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer} : reg<llvmir.ptr>
  %start = const.i64 0
  %step = const.i64 1
  %zero = const.f32 0
  %limit_i32 = load.i32 %control_view, 0
  %limit = sext.i32.i64 %limit_i32
  low.br ^_bb1(%start: reg<llvmir.i64>, %zero: reg<llvmir.f32>)
^_bb1(%position: reg<llvmir.i64>, %current_sum: reg<llvmir.f32>):
  %39 = cmp.slt.i64 %position, %limit
  low.cond_br %39, ^_bb2, ^_bb3 : reg<llvmir.i1>
^_bb2:
  %loaded = load.indexed.f32 %input_view, %position, 0, 4
  %next_sum = add.f32 %current_sum, %loaded
  %42 = add.i64 %position, %step
  low.br ^_bb1(%42: reg<llvmir.i64>, %next_sum: reg<llvmir.f32>)
^_bb3:
  store.f32 %current_sum, %output_view, 0
  return
}

