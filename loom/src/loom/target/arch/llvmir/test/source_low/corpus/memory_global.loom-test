llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @global_saddr_fallback(%input: buffer, %output: buffer) {
  %base = index.constant 4 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @global_saddr_fallback(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %loaded = load.v4i32 %input_view, 4
  store.v4i32 %loaded, %output_view, 4
  return
}

