// TEMPLATE: loom/src/loom/test/corpus/source_low/vector_slice.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x4_slice_middle(%values: vector<4xi32>) -> (vector<2xi32>) {
  %middle = vector.slice %values[1] : vector<4xi32> -> vector<2xi32>
  func.return %middle : vector<2xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x4_slice_middle(%values: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x2>) asm<llvmir.generic.core> {
  %middle = slice.v4i32.v2i32 %values, 1
  return %middle
}

