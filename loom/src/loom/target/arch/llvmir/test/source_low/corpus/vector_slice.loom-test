llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x4_insert_static(%values: vector<4xf32>, %value: f32) -> (vector<4xf32>) {
  %updated = vector.insert %value into %values[2] : f32, vector<4xf32>
  func.return %updated : vector<4xf32>
}

// ----
low.func.def target(@target) abi(object_function) @f32x4_insert_static(%values: reg<llvmir.f32 x4>, %value: reg<llvmir.f32>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %updated = insert.v4f32 %values, %value, 2
  return %updated
}

