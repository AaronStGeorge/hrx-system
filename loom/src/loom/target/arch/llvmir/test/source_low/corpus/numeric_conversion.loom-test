// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_conversion.loom-test
// RUN: emit source-low output=low

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @vector_sitofp_i32x2(%input: vector<2xi32>, %scale: vector<2xf32>) -> (vector<2xf32>) {
  %converted = vector.sitofp %input : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  func.return %scaled : vector<2xf32>
}

// ----
low.func.def target(@target) abi(object_function) @vector_sitofp_i32x2(%input: reg<llvmir.i32 x2>, %scale: reg<llvmir.f32 x2>) -> (reg<llvmir.f32 x2>) asm<llvmir.generic.core> {
  %converted = sitofp.v2i32.v2f32 %input
  %scaled = mul.v2f32 %converted, %scale
  return %scaled
}

