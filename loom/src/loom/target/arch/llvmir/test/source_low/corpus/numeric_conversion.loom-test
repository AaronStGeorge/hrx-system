// XFAIL: llvmir source-low coverage gap
llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @vector_sitofp_i32x2(%input: vector<2xi32>, %scale: vector<2xf32>) -> (vector<2xf32>) {
  %converted = vector.sitofp %input : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  func.return %scaled : vector<2xf32>
}

