  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @bf16_dot2_256(%lhs: vector<16xbf16>, %rhs: vector<16xbf16>, %acc: vector<8xf32>) -> (vector<8xf32>) {
