low.func.def target(@target) abi(object_function) @bf16_dot2f(%lhs: reg<llvmir.bf16 x8>, %rhs: reg<llvmir.bf16 x8>, %acc: reg<llvmir.f32 x4>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %54 = extract.v4f32 %acc, 0
  %55 = extract.v8bf16 %lhs, 0
  %56 = extract.v8bf16 %rhs, 0
  %57 = fpext.bf16.f32 %55
  %58 = fpext.bf16.f32 %56
  %59 = fma.f32 %57, %58, %54
  %60 = extract.v8bf16 %lhs, 1
  %61 = extract.v8bf16 %rhs, 1
  %62 = fpext.bf16.f32 %60
  %63 = fpext.bf16.f32 %61
  %64 = fma.f32 %62, %63, %59
  %65 = extract.v4f32 %acc, 1
  %66 = extract.v8bf16 %lhs, 2
  %67 = extract.v8bf16 %rhs, 2
  %68 = fpext.bf16.f32 %66
  %69 = fpext.bf16.f32 %67
  %70 = fma.f32 %68, %69, %65
  %71 = extract.v8bf16 %lhs, 3
  %72 = extract.v8bf16 %rhs, 3
  %73 = fpext.bf16.f32 %71
  %74 = fpext.bf16.f32 %72
  %75 = fma.f32 %73, %74, %70
  %76 = extract.v4f32 %acc, 2
  %77 = extract.v8bf16 %lhs, 4
  %78 = extract.v8bf16 %rhs, 4
  %79 = fpext.bf16.f32 %77
  %80 = fpext.bf16.f32 %78
  %81 = fma.f32 %79, %80, %76
  %82 = extract.v8bf16 %lhs, 5
  %83 = extract.v8bf16 %rhs, 5
  %84 = fpext.bf16.f32 %82
  %85 = fpext.bf16.f32 %83
  %86 = fma.f32 %84, %85, %81
  %87 = extract.v4f32 %acc, 3
  %88 = extract.v8bf16 %lhs, 6
  %89 = extract.v8bf16 %rhs, 6
  %90 = fpext.bf16.f32 %88
  %91 = fpext.bf16.f32 %89
  %92 = fma.f32 %90, %91, %87
  %93 = extract.v8bf16 %lhs, 7
  %94 = extract.v8bf16 %rhs, 7
  %95 = fpext.bf16.f32 %93
  %96 = fpext.bf16.f32 %94
  %97 = fma.f32 %95, %96, %92
