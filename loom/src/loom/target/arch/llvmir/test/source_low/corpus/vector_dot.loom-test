llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32_exact_product_reduce(%lhs: vector<4xf32>, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %dot = vector.reduce<addf> %product, %acc : vector<4xf32>, f32
  func.return %dot : f32
}

// ----
low.func.def target(@target) abi(object_function) @f32_exact_product_reduce(%lhs: reg<llvmir.f32 x4>, %rhs: reg<llvmir.f32 x4>, %acc: reg<llvmir.f32>) -> (reg<llvmir.f32>) asm<llvmir.generic.core> {
  %26 = extract.v4f32 %lhs, 0
  %27 = extract.v4f32 %rhs, 0
  %28 = mul.f32 %26, %27
  %29 = add.f32 %acc, %28
  %30 = extract.v4f32 %lhs, 1
  %31 = extract.v4f32 %rhs, 1
  %32 = mul.f32 %30, %31
  %33 = add.f32 %29, %32
  %34 = extract.v4f32 %lhs, 2
  %35 = extract.v4f32 %rhs, 2
  %36 = mul.f32 %34, %35
  %37 = add.f32 %33, %36
  %38 = extract.v4f32 %lhs, 3
  %39 = extract.v4f32 %rhs, 3
  %40 = mul.f32 %38, %39
  %dot = add.f32 %37, %40
  return %dot
}

