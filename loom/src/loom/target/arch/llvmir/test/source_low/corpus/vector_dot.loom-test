}
func.def target(@target) @f32_dotf_zero_seed(%lhs: vector<4xf32>, %rhs: vector<4xf32>) -> (f32) {
  %zero = scalar.constant 0.0 : f32
  %dot = vector.dotf %lhs, %rhs, %zero : vector<4xf32>, vector<4xf32>, f32
  func.return %dot : f32
}

// ----
low.func.def target(@target) abi(object_function) @f32_dotf_zero_seed(%lhs: reg<llvmir.f32 x4>, %rhs: reg<llvmir.f32 x4>) -> (reg<llvmir.f32>) asm<llvmir.generic.core> {
  %zero = const.f32 0
  %21 = extract.v4f32 %lhs, 0
  %22 = extract.v4f32 %rhs, 0
  %23 = fma.f32 %21, %22, %zero
  %24 = extract.v4f32 %lhs, 1
  %25 = extract.v4f32 %rhs, 1
  %26 = fma.f32 %24, %25, %23
  %27 = extract.v4f32 %lhs, 2
  %28 = extract.v4f32 %rhs, 2
  %29 = fma.f32 %27, %28, %26
  %30 = extract.v4f32 %lhs, 3
  %31 = extract.v4f32 %rhs, 3
  %dot = fma.f32 %30, %31, %29
  return %dot
}

