llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32_contract_product_reduce(%lhs: vector<8xf32>, %rhs: vector<8xf32>, %acc: f32) -> (f32) {
  %product = vector.mulf<reassoc|nnan|ninf|nsz|contract> %lhs, %rhs : vector<8xf32>
  %dot = vector.reduce<addf, reassoc|nnan|ninf|nsz|contract> %product, %acc : vector<8xf32>, f32
  func.return %dot : f32
}

// ----
low.func.def target(@target) abi(object_function) @f32_contract_product_reduce(%lhs: reg<llvmir.f32 x8>, %rhs: reg<llvmir.f32 x8>, %acc: reg<llvmir.f32>) -> (reg<llvmir.f32>) asm<llvmir.generic.core> {
  %35 = extract.v8f32 %lhs, 0
  %36 = extract.v8f32 %rhs, 0
  %37 = fma.f32 %35, %36, %acc
  %38 = extract.v8f32 %lhs, 1
  %39 = extract.v8f32 %rhs, 1
  %40 = fma.f32 %38, %39, %37
  %41 = extract.v8f32 %lhs, 2
  %42 = extract.v8f32 %rhs, 2
  %43 = fma.f32 %41, %42, %40
  %44 = extract.v8f32 %lhs, 3
  %45 = extract.v8f32 %rhs, 3
  %46 = fma.f32 %44, %45, %43
  %47 = extract.v8f32 %lhs, 4
  %48 = extract.v8f32 %rhs, 4
  %49 = fma.f32 %47, %48, %46
  %50 = extract.v8f32 %lhs, 5
  %51 = extract.v8f32 %rhs, 5
  %52 = fma.f32 %50, %51, %49
  %53 = extract.v8f32 %lhs, 6
  %54 = extract.v8f32 %rhs, 6
  %55 = fma.f32 %53, %54, %52
  %56 = extract.v8f32 %lhs, 7
  %57 = extract.v8f32 %rhs, 7
  %dot = fma.f32 %56, %57, %55
  return %dot
}

