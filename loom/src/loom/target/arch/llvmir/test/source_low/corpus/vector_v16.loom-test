}
func.def target(@target) @f32x16_arith(%lhs: vector<16xf32>, %rhs: vector<16xf32>) -> (vector<16xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<16xf32>
  %difference = vector.subf %sum, %lhs : vector<16xf32>
  %product = vector.mulf %difference, %rhs : vector<16xf32>
  %fma = vector.fmaf %lhs, %rhs, %product : vector<16xf32>
  func.return %fma : vector<16xf32>
}

