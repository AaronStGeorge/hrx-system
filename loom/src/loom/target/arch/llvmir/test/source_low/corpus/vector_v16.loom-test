llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x16_static_memory(%input: buffer, %output: buffer) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[4] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[8] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @f32x16_static_memory(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>) asm<llvmir.generic.core> {
  %loaded = load.v16f32 %input_view, 32
  store.v16f32 %loaded, %output_view, 64
  return
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x16_dynamic_memory(%input: buffer, %output: buffer, %i: index) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %bounded_i = index.assume %i [range(%i, 0, 16)] : index
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%bounded_i] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%bounded_i] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @f32x16_dynamic_memory(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %bounded_i: reg<llvmir.i64>) asm<llvmir.generic.core> {
  %loaded = load.indexed.v16f32 %input_view, %bounded_i, 16, 4
  store.indexed.v16f32 %loaded, %output_view, %bounded_i, 32, 4
  return
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x16_index_add_memory(%input: buffer, %output: buffer, %i: index, %j: index) {
  %zero = index.constant 0 : offset
  %sum = index.add %i, %j : index
  %bounded_sum = index.assume %sum [range(%sum, 0, 16)] : index
  %input_view = buffer.view %input[%zero] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%bounded_sum] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%bounded_sum] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(object_function) @f32x16_index_add_memory(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %i: reg<llvmir.i64>, %j: reg<llvmir.i64>) asm<llvmir.generic.core> {
  %bounded_sum = add.i64 %i, %j
  %loaded = load.indexed.v16f32 %input_view, %bounded_sum, 0, 4
  store.indexed.v16f32 %loaded, %output_view, %bounded_sum, 0, 4
  return
}

