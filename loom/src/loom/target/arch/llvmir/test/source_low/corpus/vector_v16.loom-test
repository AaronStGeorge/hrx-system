}
func.def target(@target) @i32x16_minmax_logic(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %min_s = vector.minsi %lhs, %rhs : vector<16xi32>
  %max_s = vector.maxsi %lhs, %rhs : vector<16xi32>
  %min_u = vector.minui %lhs, %rhs : vector<16xi32>
  %max_u = vector.maxui %lhs, %rhs : vector<16xi32>
  %mask = vector.andi %min_s, %max_s : vector<16xi32>
  %mixed = vector.xori %mask, %min_u : vector<16xi32>
  %result = vector.ori %mixed, %max_u : vector<16xi32>
  func.return %result : vector<16xi32>
}

