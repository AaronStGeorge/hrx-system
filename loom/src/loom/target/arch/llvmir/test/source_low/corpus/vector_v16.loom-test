llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x16_arith(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<16xi32>
  %diff = vector.subi %sum, %rhs : vector<16xi32>
  func.return %diff : vector<16xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x16_arith(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %sum = add.v16i32 %lhs, %rhs
  %diff = sub.v16i32 %sum, %rhs
  return %diff
}

