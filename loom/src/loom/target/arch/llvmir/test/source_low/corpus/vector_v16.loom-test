llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @f32x16_compare_select(%lhs: vector<16xf32>, %rhs: vector<16xf32>, %fallback: vector<16xf32>) -> (vector<16xf32>) {
  %ordered_lt = vector.cmpf olt, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %unordered_ne = vector.cmpf une, %lhs, %rhs : vector<16xf32> -> vector<16xi1>
  %selected = vector.select %ordered_lt, %lhs, %rhs : vector<16xf32>
  %result = vector.select %unordered_ne, %selected, %fallback : vector<16xf32>
  func.return %result : vector<16xf32>
}

// ----
low.func.def target(@target) abi(object_function) @f32x16_compare_select(%lhs: reg<llvmir.f32 x16>, %rhs: reg<llvmir.f32 x16>, %fallback: reg<llvmir.f32 x16>) -> (reg<llvmir.f32 x16>) asm<llvmir.generic.core> {
  %ordered_lt = cmp.olt.v16f32 %lhs, %rhs
  %unordered_ne = cmp.une.v16f32 %lhs, %rhs
  %selected = select.v16f32 %ordered_lt, %lhs, %rhs
  %result = select.v16f32 %unordered_ne, %selected, %fallback
  return %result
}

