llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x16_compare_select(%lhs: vector<16xi32>, %rhs: vector<16xi32>, %fallback: vector<16xi32>) -> (vector<16xi32>) {
  %signed = vector.cmpi sgt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %unsigned = vector.cmpi ugt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %selected = vector.select %signed, %lhs, %rhs : vector<16xi32>
  %result = vector.select %unsigned, %selected, %fallback : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x16_compare_select(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>, %fallback: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %signed = cmp.sgt.v16i32 %lhs, %rhs
  %unsigned = cmp.ugt.v16i32 %lhs, %rhs
  %selected = select.v16i32 %signed, %lhs, %rhs
  %result = select.v16i32 %unsigned, %selected, %fallback
  return %result
}

// ====

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x16_mask_and_select(%lhs: vector<16xi32>, %rhs: vector<16xi32>, %fallback: vector<16xi32>) -> (vector<16xi32>) {
  %greater = vector.cmpi sgt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %less = vector.cmpi slt, %lhs, %rhs : vector<16xi32> -> vector<16xi1>
  %either = vector.ori %greater, %less : vector<16xi1>
  %greater_again = vector.andi %either, %greater : vector<16xi1>
  %condition = vector.xori %greater_again, %less : vector<16xi1>
  %result = vector.select %condition, %lhs, %fallback : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x16_mask_and_select(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>, %fallback: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %greater = cmp.sgt.v16i32 %lhs, %rhs
  %less = cmp.slt.v16i32 %lhs, %rhs
  %either = or.v16i1 %greater, %less
  %greater_again = and.v16i1 %either, %greater
  %condition = xor.v16i1 %greater_again, %less
  %result = select.v16i32 %condition, %lhs, %fallback
  return %result
}

