llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}
func.def target(@target) @i32x16_variable_shift(%value: vector<16xi32>, %amount: vector<16xi32>) -> (vector<16xi32>) {
  %left = vector.shli %value, %amount : vector<16xi32>
  %signed = vector.shrsi %left, %amount : vector<16xi32>
  %result = vector.shrui %signed, %amount : vector<16xi32>
  func.return %result : vector<16xi32>
}

// ----
low.func.def target(@target) abi(object_function) @i32x16_variable_shift(%value: reg<llvmir.i32 x16>, %amount: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %left = shl.v16i32 %value, %amount
  %signed = ashr.v16i32 %left, %amount
  %result = lshr.v16i32 %signed, %amount
  return %result
}

