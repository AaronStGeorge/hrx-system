load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_target_table_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_target_table_cc_library(
    name = "generic_core",
    args = ["--contract-fragment=llvmir.generic.core"],
    generator = "//loom/py/loom/gen/target/contracts:llvmir_contract_fragment",
    deps = ["//loom/src/loom/target:contract"],
)

loom_target_table_cc_library(
    name = "generic_core_lower_rules",
    args = ["--contract-fragment=llvmir.generic.core"],
    generator = "//loom/py/loom/gen/target/contracts:llvmir_lower_rule_shard",
    deps = [
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/ops/buffer",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/scf",
        "//loom/src/loom/ops/vector",
        "//loom/src/loom/ops/view",
        "//loom/src/loom/target/arch/llvmir/descriptors:descriptors_ids",
    ],
)

loom_cc_library(
    name = "contracts",
    hdrs = [
        "generic_core.h",
        "generic_core_lower_rules.h",
    ],
    deps = [
        ":generic_core",
        ":generic_core_lower_rules",
    ],
)
