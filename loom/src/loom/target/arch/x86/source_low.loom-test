// RUN: emit source-low @x86_arith output=low
target.profile @x86_target preset("x86-avx512")

func.def target(@x86_target) @x86_arith(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<16xi32>
  %diff = vector.subi %sum, %rhs : vector<16xi32>
  func.return %diff : vector<16xi32>
}
// ----
low.func.def target(@x86_target) abi(object_function) @x86_arith__low(%lhs: reg<x86.zmm>, %rhs: reg<x86.zmm>) -> (reg<x86.zmm>) {
  %sum = low.op<x86.avx512.vpaddd.zmm>(%lhs, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  %diff = low.op<x86.avx512.vpsubd.zmm>(%sum, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  low.return %diff : reg<x86.zmm>
}

// ====
// RUN: emit source-low @x86_f32_arith output=low
target.profile @x86_f32_target preset("x86-avx512")

func.def target(@x86_f32_target) @x86_f32_arith(%lhs: vector<16xf32>, %rhs: vector<16xf32>) -> (vector<16xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<16xf32>
  %difference = vector.subf %sum, %lhs : vector<16xf32>
  %product = vector.mulf %difference, %rhs : vector<16xf32>
  %fma = vector.fmaf %lhs, %rhs, %product : vector<16xf32>
  func.return %fma : vector<16xf32>
}

// ----
low.func.def target(@x86_f32_target) abi(object_function) @x86_f32_arith__low(%lhs: reg<x86.zmm>, %rhs: reg<x86.zmm>) -> (reg<x86.zmm>) {
  %sum = low.op<x86.avx512.vaddps.zmm>(%lhs, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  %difference = low.op<x86.avx512.vsubps.zmm>(%sum, %lhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  %product = low.op<x86.avx512.vmulps.zmm>(%difference, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  %13 = low.copy %product : reg<x86.zmm> -> reg<x86.zmm>
  %fma = low.op<x86.avx512.vfmadd231ps.zmm>(%13, %lhs, %rhs) : (reg<x86.zmm>, reg<x86.zmm>, reg<x86.zmm>) -> %13 as reg<x86.zmm>
  low.return %fma : reg<x86.zmm>
}

// ====
// RUN: emit source-low @x86_static_memory output=low
target.profile @x86_static_memory_target preset("x86-avx512")

func.def target(@x86_static_memory_target) @x86_static_memory(%input: buffer, %output: buffer) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[4] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[8] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_static_memory_target) abi(object_function) @x86_static_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>) {
  %input_base = low.const<x86.avx512.movimm.gpr64> {imm64 = 16} : reg<x86.gpr64>
  %output_base = low.const<x86.avx512.movimm.gpr64> {imm64 = 32} : reg<x86.gpr64>
  %loaded = low.op<x86.avx512.vmovdqu32.load.zmm>(%input_view) {disp32 = 32} : (reg<x86.gpr64>) -> reg<x86.zmm>
  low.op<x86.avx512.vmovdqu32.store.zmm>(%loaded, %output_view) {disp32 = 64} : (reg<x86.zmm>, reg<x86.gpr64>)
  low.return
}

// ====
// RUN: emit source-low @x86_dynamic_memory output=low
target.profile @x86_dynamic_memory_target preset("x86-avx512")

func.def target(@x86_dynamic_memory_target) @x86_dynamic_memory(%input: buffer, %output: buffer, %i: index) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%i] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%i] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_dynamic_memory_target) abi(object_function) @x86_dynamic_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>, %i: reg<x86.gpr64>) {
  %input_base = low.const<x86.avx512.movimm.gpr64> {imm64 = 16} : reg<x86.gpr64>
  %output_base = low.const<x86.avx512.movimm.gpr64> {imm64 = 32} : reg<x86.gpr64>
  %loaded = low.op<x86.avx512.vmovdqu32.load.indexed.zmm>(%input_view, %i) {disp32 = 16, scale = 4} : (reg<x86.gpr64>, reg<x86.gpr64>) -> reg<x86.zmm>
  low.op<x86.avx512.vmovdqu32.store.indexed.zmm>(%loaded, %output_view, %i) {disp32 = 32, scale = 4} : (reg<x86.zmm>, reg<x86.gpr64>, reg<x86.gpr64>)
  low.return
}
