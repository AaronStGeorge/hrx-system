// RUN: emit source-low @x86_arith output=low
target.profile @x86_target preset("x86-avx512")

func.def target(@x86_target) @x86_arith(%lhs: vector<16xi32>, %rhs: vector<16xi32>) -> (vector<16xi32>) {
  %sum = vector.addi %lhs, %rhs : vector<16xi32>
  %diff = vector.subi %sum, %rhs : vector<16xi32>
  func.return %diff : vector<16xi32>
}
// ----
low.func.def target(@x86_target) abi(object_function) @x86_arith__low(%lhs: reg<x86.zmm>, %rhs: reg<x86.zmm>) -> (reg<x86.zmm>) asm<x86.avx512.core> {
  %sum = vpaddd %lhs, %rhs
  %diff = vpsubd %sum, %rhs
  return %diff
}

// ====
// RUN: emit source-low @x86_f32_arith output=low
target.profile @x86_f32_target preset("x86-avx512")

func.def target(@x86_f32_target) @x86_f32_arith(%lhs: vector<16xf32>, %rhs: vector<16xf32>) -> (vector<16xf32>) {
  %sum = vector.addf %lhs, %rhs : vector<16xf32>
  %difference = vector.subf %sum, %lhs : vector<16xf32>
  %product = vector.mulf %difference, %rhs : vector<16xf32>
  %fma = vector.fmaf %lhs, %rhs, %product : vector<16xf32>
  func.return %fma : vector<16xf32>
}

// ----
low.func.def target(@x86_f32_target) abi(object_function) @x86_f32_arith__low(%lhs: reg<x86.zmm>, %rhs: reg<x86.zmm>) -> (reg<x86.zmm>) asm<x86.avx512.core> {
  %sum = vaddps %lhs, %rhs
  %difference = vsubps %sum, %lhs
  %product = vmulps %difference, %rhs
  %13 = copy %product : reg<x86.zmm> -> reg<x86.zmm>
  %fma = vfmadd231ps %13, %lhs, %rhs
  return %fma
}

// ====
// RUN: emit source-low @x86_static_memory output=low
target.profile @x86_static_memory_target preset("x86-avx512")

func.def target(@x86_static_memory_target) @x86_static_memory(%input: buffer, %output: buffer) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[4] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[8] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_static_memory_target) abi(object_function) @x86_static_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>) asm<x86.avx512.core> {
  %input_base = mov.imm64 16
  %output_base = mov.imm64 32
  %loaded = vmovdqu32.load %input_view {disp32 = 32}
  vmovdqu32.store %loaded, %output_view {disp32 = 64}
  return
}

// ====
// RUN: emit source-low @x86_dynamic_memory output=low
target.profile @x86_dynamic_memory_target preset("x86-avx512")

func.def target(@x86_dynamic_memory_target) @x86_dynamic_memory(%input: buffer, %output: buffer, %i: index) {
  %input_base = index.constant 16 : offset
  %output_base = index.constant 32 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%output_base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%i] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%i] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_dynamic_memory_target) abi(object_function) @x86_dynamic_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>, %i: reg<x86.gpr64>) asm<x86.avx512.core> {
  %input_base = mov.imm64 16
  %output_base = mov.imm64 32
  %loaded = vmovdqu32.load.indexed %input_view, %i {disp32 = 16, scale = 4}
  vmovdqu32.store.indexed %loaded, %output_view, %i {disp32 = 32, scale = 4}
  return
}

// ====
// RUN: emit source-low @x86_index_add_memory output=low
target.profile @x86_index_add_memory_target preset("x86-avx512")

func.def target(@x86_index_add_memory_target) @x86_index_add_memory(%input: buffer, %output: buffer, %i: index, %j: index) {
  %zero = index.constant 0 : offset
  %sum = index.add %i, %j : index
  %input_view = buffer.view %input[%zero] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%sum] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%sum] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_index_add_memory_target) abi(object_function) @x86_index_add_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>, %i: reg<x86.gpr64>, %j: reg<x86.gpr64>) asm<x86.avx512.core> {
  %zero = mov.imm64 0
  %sum = lea %i, %j
  %loaded = vmovdqu32.load.indexed %input_view, %sum {disp32 = 0, scale = 4}
  vmovdqu32.store.indexed %loaded, %output_view, %sum {disp32 = 0, scale = 4}
  return
}

// ====
// RUN: emit source-low @x86_index_madd_memory output=low
target.profile @x86_index_madd_memory_target preset("x86-avx512")

func.def target(@x86_index_madd_memory_target) @x86_index_madd_memory(%input: buffer, %output: buffer, %row: index, %stride: index, %col: index) {
  %zero = index.constant 0 : offset
  %linear = index.madd %row, %stride, %col : index
  %input_view = buffer.view %input[%zero] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%linear] : view<32xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[%linear] : vector<16xf32>, view<32xf32, #dense>
  func.return
}

// ----
low.func.def target(@x86_index_madd_memory_target) abi(object_function) @x86_index_madd_memory__low(%input_view: reg<x86.gpr64>, %output_view: reg<x86.gpr64>, %row: reg<x86.gpr64>, %stride: reg<x86.gpr64>, %col: reg<x86.gpr64>) asm<x86.avx512.core> {
  %zero = mov.imm64 0
  %16 = copy %row : reg<x86.gpr64> -> reg<x86.gpr64>
  %17 = imul %16, %stride
  %linear = lea %17, %col
  %loaded = vmovdqu32.load.indexed %input_view, %linear {disp32 = 0, scale = 4}
  vmovdqu32.store.indexed %loaded, %output_view, %linear {disp32 = 0, scale = 4}
  return
}
