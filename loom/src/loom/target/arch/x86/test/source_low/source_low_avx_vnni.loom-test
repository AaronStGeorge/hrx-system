// RUN: emit source-low output=low

x86.target<packed_dot> @target {contract_set_key = "x86.avx_vnni.core", contract_feature_bits = 4}

func.def target(@target) @dot4i_u8s8_256(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
low.func.def target(@target) abi(object_function) @dot4i_u8s8_256(%lhs: reg<x86.ymm>, %rhs: reg<x86.ymm>, %acc: reg<x86.ymm>) -> (reg<x86.ymm>) asm<x86.avx_vnni.core> {
  %9 = copy %acc : reg<x86.ymm> -> reg<x86.ymm>
  %dot = vpdpbusd.ymm %9, %lhs, %rhs
  return %dot
}

// ====

x86.target<packed_dot> @target {contract_set_key = "x86.avx_vnni_int8.core", contract_feature_bits = 8}

func.def target(@target) @dot8i4_u4s4_rejected(%lhs: vector<8xi32>, %rhs: vector<8xi32>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  // ERROR@+1: TARGET/001 {op_name="vector.dot8i4"}
  %dot = vector.dot8i4<u4s4> %lhs, %rhs, %acc : vector<8xi32>
  func.return %dot : vector<8xi32>
}
