// RUN: emit source-low output=low

x86.target<scalar> @target

func.def target(@target) @scalar_i32_arithmetic(%lhs: i32, %rhs: i32, %factor: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  %difference = scalar.subi %sum, %factor : i32
  %result = scalar.muli %difference, %rhs : i32
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(object_function) @scalar_i32_arithmetic(%lhs: reg<x86.gpr32>, %rhs: reg<x86.gpr32>, %factor: reg<x86.gpr32>) -> (reg<x86.gpr32>) asm<x86.scalar.core> {
  %11 = copy %lhs : reg<x86.gpr32> -> reg<x86.gpr32>
  %sum = add.gpr32 %11, %rhs
  %13 = copy %sum : reg<x86.gpr32> -> reg<x86.gpr32>
  %difference = sub.gpr32 %13, %factor
  %15 = copy %difference : reg<x86.gpr32> -> reg<x86.gpr32>
  %result = imul.gpr32 %15, %rhs
  return %result
}
