// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_scalar_f32.loom-test
// RUN: emit source-low target-preset=x86-avx512 output=low

func.def @scalar_f32_arith(%lhs: f32, %rhs: f32, %bias: f32) -> (f32) {
  %sum = scalar.addf %lhs, %rhs : f32
  %difference = scalar.subf %sum, %bias : f32
  %product = scalar.mulf %difference, %rhs : f32
  %result = scalar.fmaf %product, %rhs, %bias : f32
  func.return %result : f32
}

// ----
low.func.def target(@target) @scalar_f32_arith(%lhs: reg<x86.xmm>, %rhs: reg<x86.xmm>, %bias: reg<x86.xmm>) -> (reg<x86.xmm>) asm<x86.avx512.core> {
  %sum = vaddss.xmm %lhs, %rhs
  %difference = vsubss.xmm %sum, %bias
  %product = vmulss.xmm %difference, %rhs
  %15 = copy %bias : reg<x86.xmm> -> reg<x86.xmm>
  %result = vfmadd231ss.xmm %15, %product, %rhs
  return %result
}
