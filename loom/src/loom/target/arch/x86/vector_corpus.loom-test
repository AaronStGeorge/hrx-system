// RUN: emit source-low @x86_axpy16 output=none
target.profile @x86_avx512_axpy_target preset("x86-avx512")

func.def target(@x86_avx512_axpy_target) @x86_axpy16(%lhs: vector<16xf32>, %rhs: vector<16xf32>, %acc: vector<16xf32>) -> (vector<16xf32>) {
  %product = vector.mulf %lhs, %rhs : vector<16xf32>
  %sum = vector.addf %product, %acc : vector<16xf32>
  %result = vector.fmaf %lhs, %rhs, %sum : vector<16xf32>
  func.return %result : vector<16xf32>
}

// ====
// RUN: emit source-low @x86_dot4i_gemv_step output=none
target.profile @x86_packed_dot_target preset("x86-packed-dot")

func.def target(@x86_packed_dot_target) @x86_dot4i_gemv_step(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  // REMARK@+1: BACKEND/002 "selected x86 packed-dot descriptor"
  %dot = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ====
// RUN: emit source-low @x86_memory_copy output=none
target.profile @x86_memory_copy_target preset("x86-avx512")

func.def target(@x86_memory_copy_target) @x86_memory_copy(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<16xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<16xf32, #dense>
  %loaded = vector.load %input_view[0] : view<16xf32, #dense> -> vector<16xf32>
  vector.store %loaded, %output_view[0] : vector<16xf32>, view<16xf32, #dense>
  func.return
}
