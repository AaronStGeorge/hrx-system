#===------------------------------------------------------------------------===#
# x86 low descriptors
#===------------------------------------------------------------------------===#

loom_cc_library(
    name = "feature_bits",
    hdrs = ["feature_bits.h"],
    deps = ["//runtime/src/iree/base"],
)

loom_low_descriptor_cc_library(
    name = "avx512_descriptors",
    args = ["--descriptor-set=x86_avx512_core"],
    cmake_generator = "//loom/py/loom:gen/low_descriptor_shard.py",
    cmake_generator_deps = [
        "//loom/py/loom:gen/low_descriptors.py",
        "//loom/py/loom:target/arch/x86/descriptors.py",
        "//loom/py/loom:target/arch/x86/packed_dot_data.py",
        "//loom/py/loom:target/descriptor_sets.py",
        "//loom/py/loom:target/low_descriptors.py",
    ],
    generator = "//loom/py/loom:x86_low_descriptor_shard",
    header = "avx512_descriptors.h",
    source = "avx512_descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_test(
    name = "avx512_descriptors_test",
    srcs = ["avx512_descriptors_test.cc"],
    deps = [
        ":avx512_descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:text_asm_roundtrip_test_util",
        "//loom/src/loom/codegen/low:text_asm_test_util",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_low_descriptor_cc_library(
