        "//loom/py/loom:target/low_descriptors.py",
    ],
    generator = "//loom/py/loom:x86_low_descriptor_shard",
    header = "packed_dot_descriptors.h",
    source = "packed_dot_descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

