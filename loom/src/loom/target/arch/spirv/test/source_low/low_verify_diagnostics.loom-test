  low.br ^loop(%initial: reg<spirv.id>)
^loop(%carried: reg<spirv.id>):
  low.cond_br %condition, ^body, ^done : reg<spirv.id>
^body:
  // ERROR@+1: SPIRV/020 {function_name="loop_payload_type_mismatch", source_value_name="wrong", target_value_name="carried", expected_value_type="s32", actual_value_type="f32"}
  low.br ^loop(%wrong: reg<spirv.id>)
^done:
  return
}

