low.func.def target(@target) abi_layout({spirv_arg_value_types = [23, 23], spirv_result_value_types = [23]}) @spirv_iadd_ids_allocate_logical_ids(%lhs: reg<spirv.id>, %rhs: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %sum = OpIAdd %lhs, %rhs
  return %sum
}

