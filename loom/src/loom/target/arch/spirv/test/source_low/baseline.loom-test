// RUN: emit low-allocation @spirv_storage_buffer_load_store

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi_layout({spirv_result_value_types = [23]}) @spirv_storage_buffer_load_store(%base: reg<spirv.ptr.storage_buffer>, %byte_offset: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %ptr = OpPtrAccessChain.storage_buffer.i32.byte_offset %base, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %ptr
  OpStore.storage_buffer.i32 %ptr, %loaded
  return %loaded
}

