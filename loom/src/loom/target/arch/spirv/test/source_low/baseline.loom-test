low.func.def target(@target) abi_layout({spirv_result_value_types = [23]}) @spirv_storage_buffer_bda_addressing(%base: reg<spirv.ptr.storage_buffer>, %row: reg<spirv.offset64>, %column: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %byte_offset = OpIAdd.offset64 %row, %column
  %ptr = OpPtrAccessChain.storage_buffer.i32.byte_offset %base, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %ptr
  return %loaded
}

