// RUN: emit source-low output=low

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_i32_arithmetic(%lhs: i32, %rhs: i32) -> (i32) {
  %bias = scalar.constant 7 : i32
  %sum = scalar.addi %lhs, %rhs : i32
  %difference = scalar.subi %lhs, %rhs : i32
  %product = scalar.muli %difference, %sum : i32
  %signed_quotient = scalar.divsi %product, %bias : i32
  %signed_remainder = scalar.remsi %signed_quotient, %bias : i32
  %result = scalar.addi %signed_remainder, %bias : i32
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_i32_arithmetic(%lhs: reg<spirv.id>, %rhs: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %bias = OpConstant.i32 7
  %sum = OpIAdd %lhs, %rhs
  %difference = OpISub %lhs, %rhs
  %product = OpIMul %difference, %sum
  %signed_quotient = OpSDiv %product, %bias
  %signed_remainder = OpSRem %signed_quotient, %bias
  %result = OpIAdd %signed_remainder, %bias
  return %result
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_i32_compare_select(%lhs: i32, %rhs: i32) -> (i32) {
  %less = scalar.cmpi slt, %lhs, %rhs : i32
  %selected = scf.select %less, %lhs, %rhs : i32
  func.return %selected : i32
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_i32_compare_select(%lhs: reg<spirv.id>, %rhs: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %less = OpSLessThan %lhs, %rhs
  %selected = OpSelect %less, %lhs, %rhs
  return %selected
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_index_arithmetic(%index: index, %factor: index) -> (index) {
  %one = index.constant 1 : index
  %previous = index.sub %index, %one : index
  %scaled = index.mul %previous, %factor : index
  %next = index.madd %scaled, %factor, %one : index
  func.return %next : index
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_index_arithmetic(%index: reg<spirv.id>, %factor: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %one = OpConstant.i32 1
  %previous = OpISub %index, %one
  %scaled = OpIMul %previous, %factor
  %next = OpIMulAdd %scaled, %factor, %one
  return %next
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_offset_compare_select(%byte_offset: offset, %limit: offset) -> (offset) {
  %zero = index.constant 0 : offset
  %inside = index.cmp ule, %byte_offset, %limit : offset
  %selected = scf.select %inside, %byte_offset, %zero : offset
  func.return %selected : offset
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_offset_compare_select(%byte_offset: reg<spirv.offset64>, %limit: reg<spirv.offset64>) -> (reg<spirv.offset64>) asm<spirv.logical.core> {
  %zero = OpConstant.offset64 0
  %inside = OpULessThanEqual.offset64 %byte_offset, %limit
  %selected = OpSelect.offset64 %inside, %byte_offset, %zero
  return %selected
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_offset_addressing(%base: buffer, %row: offset) -> (i32) {
  %column = index.constant 4 : offset
  %byte_offset = index.add %row, %column : offset
  %view = buffer.view %base[%byte_offset] : buffer -> view<1xi32, #dense>
  %loaded = view.load %view[0] : view<1xi32, #dense> -> i32
  func.return %loaded : i32
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_offset_addressing(%base: reg<spirv.ptr.storage_buffer>, %row: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %column = OpConstant.offset64 4
  %byte_offset = OpIAdd.offset64 %row, %column
  %view = OpPtrAccessChain.storage_buffer.i32.byte_offset %base, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %view
  return %loaded
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_storage_buffer_i32_roundtrip(%input: buffer, %output: buffer, %byte_offset: offset) -> (i32) {
  %input_view = buffer.view %input[%byte_offset] : buffer -> view<1xi32, #dense>
  %loaded = view.load %input_view[0] : view<1xi32, #dense> -> i32
  %incremented = scalar.addi %loaded, %loaded : i32
  %output_view = buffer.view %output[%byte_offset] : buffer -> view<1xi32, #dense>
  view.store %incremented, %output_view[0] : i32, view<1xi32, #dense>
  func.return %loaded : i32
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_storage_buffer_i32_roundtrip(%input: reg<spirv.ptr.storage_buffer>, %output: reg<spirv.ptr.storage_buffer>, %byte_offset: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %incremented = OpIAdd %loaded, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output, %byte_offset
  OpStore.storage_buffer.i32 %output_view, %incremented
  return %loaded
}

// ====

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_i32(%input: buffer, %output: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %input_view = buffer.view %input[%byte_offset] : buffer -> view<1xi32, #dense>
  %loaded = view.load %input_view[0] : view<1xi32, #dense> -> i32
  %incremented = scalar.addi %loaded, %loaded : i32
  %output_view = buffer.view %output[%byte_offset] : buffer -> view<1xi32, #dense>
  view.store %incremented, %output_view[0] : i32, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_i32(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %incremented = OpIAdd %loaded, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output, %byte_offset
  OpStore.storage_buffer.i32 %output_view, %incremented
  return
}

// ====

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_f32(%input: buffer, %output: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %input_view = buffer.view %input[%byte_offset] : buffer -> view<1xf32, #dense>
  %loaded = view.load %input_view[0] : view<1xf32, #dense> -> f32
  %sum = scalar.addf %loaded, %loaded : f32
  %product = scalar.mulf %sum, %loaded : f32
  %quotient = scalar.divf %product, %loaded : f32
  %remainder = scalar.remf %quotient, %loaded : f32
  %output_view = buffer.view %output[%byte_offset] : buffer -> view<1xf32, #dense>
  view.store %remainder, %output_view[0] : f32, view<1xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_f32(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.f32 %input_view
  %sum = OpFAdd.f32 %loaded, %loaded
  %product = OpFMul.f32 %sum, %loaded
  %quotient = OpFDiv.f32 %product, %loaded
  %remainder = OpFRem.f32 %quotient, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %output, %byte_offset
  OpStore.storage_buffer.f32 %output_view, %remainder
  return
}

// ====

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_i64(%input: buffer, %output: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %input_view = buffer.view %input[%byte_offset] : buffer -> view<1xi64, #dense>
  %loaded = view.load %input_view[0] : view<1xi64, #dense> -> i64
  %sum = scalar.addi %loaded, %loaded : i64
  %larger = scalar.cmpi sgt, %sum, %loaded : i64
  %selected = scf.select %larger, %sum, %loaded : i64
  %output_view = buffer.view %output[%byte_offset] : buffer -> view<1xi64, #dense>
  view.store %selected, %output_view[0] : i64, view<1xi64, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_i64(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_view = OpPtrAccessChain.storage_buffer.i64.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.i64 %input_view
  %sum = OpIAdd.i64 %loaded, %loaded
  %larger = OpSGreaterThan.i64 %sum, %loaded
  %selected = OpSelect.i64 %larger, %sum, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.i64.byte_offset %output, %byte_offset
  OpStore.storage_buffer.i64 %output_view, %selected
  return
}

// ====

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel, contract_feature_bits = 37374}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_feature_widths(%input_i8: buffer, %output_i8: buffer, %input_i16: buffer, %output_i16: buffer, %input_f16: buffer, %output_f16: buffer, %input_bf16: buffer, %output_bf16: buffer, %input_f64: buffer, %output_f64: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %input_i8_view = buffer.view %input_i8[%byte_offset] : buffer -> view<1xi8, #dense>
  %loaded_i8 = view.load %input_i8_view[0] : view<1xi8, #dense> -> i8
  %sum_i8 = scalar.addi %loaded_i8, %loaded_i8 : i8
  %output_i8_view = buffer.view %output_i8[%byte_offset] : buffer -> view<1xi8, #dense>
  view.store %sum_i8, %output_i8_view[0] : i8, view<1xi8, #dense>
  %input_i16_view = buffer.view %input_i16[%byte_offset] : buffer -> view<1xi16, #dense>
  %loaded_i16 = view.load %input_i16_view[0] : view<1xi16, #dense> -> i16
  %sum_i16 = scalar.addi %loaded_i16, %loaded_i16 : i16
  %output_i16_view = buffer.view %output_i16[%byte_offset] : buffer -> view<1xi16, #dense>
  view.store %sum_i16, %output_i16_view[0] : i16, view<1xi16, #dense>
  %input_f16_view = buffer.view %input_f16[%byte_offset] : buffer -> view<1xf16, #dense>
  %loaded_f16 = view.load %input_f16_view[0] : view<1xf16, #dense> -> f16
  %sum_f16 = scalar.addf %loaded_f16, %loaded_f16 : f16
  %output_f16_view = buffer.view %output_f16[%byte_offset] : buffer -> view<1xf16, #dense>
  view.store %sum_f16, %output_f16_view[0] : f16, view<1xf16, #dense>
  %input_bf16_view = buffer.view %input_bf16[%byte_offset] : buffer -> view<1xbf16, #dense>
  %loaded_bf16 = view.load %input_bf16_view[0] : view<1xbf16, #dense> -> bf16
  %output_bf16_view = buffer.view %output_bf16[%byte_offset] : buffer -> view<1xbf16, #dense>
  view.store %loaded_bf16, %output_bf16_view[0] : bf16, view<1xbf16, #dense>
  %input_f64_view = buffer.view %input_f64[%byte_offset] : buffer -> view<1xf64, #dense>
  %loaded_f64 = view.load %input_f64_view[0] : view<1xf64, #dense> -> f64
  %sum_f64 = scalar.addf %loaded_f64, %loaded_f64 : f64
  %output_f64_view = buffer.view %output_f64[%byte_offset] : buffer -> view<1xf64, #dense>
  view.store %sum_f64, %output_f64_view[0] : f64, view<1xf64, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_feature_widths(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input_i8 = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_i8 = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_i16 = resource<hal_binding> {index = 2, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_i16 = resource<hal_binding> {index = 3, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_f16 = resource<hal_binding> {index = 4, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_f16 = resource<hal_binding> {index = 5, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_bf16 = resource<hal_binding> {index = 6, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_bf16 = resource<hal_binding> {index = 7, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_f64 = resource<hal_binding> {index = 8, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_f64 = resource<hal_binding> {index = 9, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_i8_view = OpPtrAccessChain.storage_buffer.i8.byte_offset %input_i8, %byte_offset
  %loaded_i8 = OpLoad.storage_buffer.i8 %input_i8_view
  %sum_i8 = OpIAdd.i8 %loaded_i8, %loaded_i8
  %output_i8_view = OpPtrAccessChain.storage_buffer.i8.byte_offset %output_i8, %byte_offset
  OpStore.storage_buffer.i8 %output_i8_view, %sum_i8
  %input_i16_view = OpPtrAccessChain.storage_buffer.i16.byte_offset %input_i16, %byte_offset
  %loaded_i16 = OpLoad.storage_buffer.i16 %input_i16_view
  %sum_i16 = OpIAdd.i16 %loaded_i16, %loaded_i16
  %output_i16_view = OpPtrAccessChain.storage_buffer.i16.byte_offset %output_i16, %byte_offset
  OpStore.storage_buffer.i16 %output_i16_view, %sum_i16
  %input_f16_view = OpPtrAccessChain.storage_buffer.f16.byte_offset %input_f16, %byte_offset
  %loaded_f16 = OpLoad.storage_buffer.f16 %input_f16_view
  %sum_f16 = OpFAdd.f16 %loaded_f16, %loaded_f16
  %output_f16_view = OpPtrAccessChain.storage_buffer.f16.byte_offset %output_f16, %byte_offset
  OpStore.storage_buffer.f16 %output_f16_view, %sum_f16
  %input_bf16_view = OpPtrAccessChain.storage_buffer.bf16.byte_offset %input_bf16, %byte_offset
  %loaded_bf16 = OpLoad.storage_buffer.bf16 %input_bf16_view
  %output_bf16_view = OpPtrAccessChain.storage_buffer.bf16.byte_offset %output_bf16, %byte_offset
  OpStore.storage_buffer.bf16 %output_bf16_view, %loaded_bf16
  %input_f64_view = OpPtrAccessChain.storage_buffer.f64.byte_offset %input_f64, %byte_offset
  %loaded_f64 = OpLoad.storage_buffer.f64 %input_f64_view
  %sum_f64 = OpFAdd.f64 %loaded_f64, %loaded_f64
  %output_f64_view = OpPtrAccessChain.storage_buffer.f64.byte_offset %output_f64, %byte_offset
  OpStore.storage_buffer.f64 %output_f64_view, %sum_f64
  return
}
