spirv.target<vulkan1_3> @target_scalar_payloads {contract_feature_bits = 37374}

func.def target(@target_scalar_payloads) @spirv_scalar_payload_abi(%flag: i1, %i8: i8, %i16: i16, %i32: i32, %i64: i64, %f16: f16, %bf16: bf16, %f32: f32, %f64: f64) -> (i1, i8, i16, i32, i64, f16, bf16, f32, f64) {
  func.return %flag, %i8, %i16, %i32, %i64, %f16, %bf16, %f32, %f64 : i1, i8, i16, i32, i64, f16, bf16, f32, f64
}

// ----
low.func.def target(@target_scalar_payloads) abi(shader_entry_point) abi_layout({spirv_arg_value_types = [1, 21, 22, 23, 24, 17, 20, 18, 19], spirv_result_value_types = [1, 21, 22, 23, 24, 17, 20, 18, 19]}) @spirv_scalar_payload_abi(%flag: reg<spirv.id>, %i8: reg<spirv.id>, %i16: reg<spirv.id>, %i32: reg<spirv.id>, %i64: reg<spirv.id>, %f16: reg<spirv.id>, %bf16: reg<spirv.id>, %f32: reg<spirv.id>, %f64: reg<spirv.id>) -> (reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>, reg<spirv.id>) asm<spirv.logical.core> {
  return %flag, %i8, %i16, %i32, %i64, %f16, %bf16, %f32, %f64
}

// ====

spirv.target<vulkan1_3> @hal_target_scalar_payloads {abi = hal_kernel, contract_feature_bits = 37374}

kernel.def target(@hal_target_scalar_payloads) @spirv_hal_direct_scalar_payload_abi(%i8: i8, %output: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %byte_offset_aligned = index.assume %byte_offset [mul(%byte_offset, 1)] : offset
  %output_aligned = buffer.assume.alignment %output {minimum_alignment = 1} : buffer
  %output_view = buffer.view %output_aligned[%byte_offset_aligned] : buffer -> view<1xi8, #dense>
  view.store %i8, %output_view[0] : i8, view<1xi8, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target_scalar_payloads) abi_layout({spirv_arg_value_types = [21, 0]}) workgroup_size(1, 1, 1) @spirv_hal_direct_scalar_payload_abi(%i8: reg<spirv.id>, %byte_offset_aligned: reg<spirv.offset64>) asm<spirv.logical.core> {
  %output_aligned = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_view = OpPtrAccessChain.storage_buffer.i8.byte_offset %output_aligned, %byte_offset_aligned
  OpStore.storage_buffer.i8 %output_view, %i8
  return
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_index_arithmetic(%index: index, %factor: index) -> (index) {
  %one = index.constant 1 : index
  %previous = index.sub %index, %one : index
  %scaled = index.mul %previous, %factor : index
  %next = index.madd %scaled, %factor, %one : index
  func.return %next : index
}

// ----
low.func.def target(@target) abi(shader_entry_point) abi_layout({spirv_arg_value_types = [23, 23], spirv_result_value_types = [23]}) @spirv_index_arithmetic(%index: reg<spirv.id>, %factor: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %one = OpConstant.i32 1
  %previous = OpISub %index, %one
  %scaled = OpIMul %previous, %factor
  %next = OpIMulAdd %scaled, %factor, %one
  return %next
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_offset_compare_select(%byte_offset: offset, %limit: offset) -> (offset) {
  %zero = index.constant 0 : offset
  %inside = index.cmp ule, %byte_offset, %limit : offset
  %selected = scf.select %inside, %byte_offset, %zero : offset
  func.return %selected : offset
}

// ----
low.func.def target(@target) abi(shader_entry_point) @spirv_offset_compare_select(%byte_offset: reg<spirv.offset64>, %limit: reg<spirv.offset64>) -> (reg<spirv.offset64>) asm<spirv.logical.core> {
  %zero = OpConstant.offset64 0
  %inside = OpULessThanEqual.offset64 %byte_offset, %limit
  %selected = OpSelect.offset64 %inside, %byte_offset, %zero
  return %selected
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @spirv_offset_addressing(%base: buffer, %row: offset) -> (i32) {
  %column = index.constant 4 : offset
  %row_aligned = index.assume %row [mul(%row, 4)] : offset
  %base_aligned = buffer.assume.alignment %base {minimum_alignment = 4} : buffer
  %byte_offset = index.add %row_aligned, %column : offset
  %view = buffer.view %base_aligned[%byte_offset] : buffer -> view<1xi32, #dense>
  %loaded = view.load %view[0] : view<1xi32, #dense> -> i32
  func.return %loaded : i32
}

// ----
low.func.def target(@target) abi(shader_entry_point) abi_layout({spirv_result_value_types = [23]}) @spirv_offset_addressing(%base_aligned: reg<spirv.ptr.storage_buffer>, %row_aligned: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %column = OpConstant.offset64 4
  %byte_offset = OpIAdd.offset64 %row_aligned, %column
  %view = OpPtrAccessChain.storage_buffer.i32.byte_offset %base_aligned, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %view
  return %loaded
}

// ====

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_dynamic_builtin_storage_buffer_i32(%input: buffer, %output: buffer) {
  %groups_x = index.constant 4 : index
  %groups_z = index.constant 3 : index
  %one = index.constant 1 : index
  %two = index.constant 2 : index
  kernel.launch.config workgroups(%groups_x, %one, %groups_z) workgroup_size(%one, %two, %one) : index
} launch {
  %workgroup_x = kernel.workgroup.id<x> : index
  %local_y = kernel.workitem.id<y> : index
  %global_z = kernel.workitem.dispatch.id<z> : index
  %sum = index.add %workgroup_x, %local_y : index
  %linear = index.add %sum, %global_z : index
  %scale = index.constant 4 : index
  %byte_index = index.mul %linear, %scale : index
  %byte_offset = index.cast %byte_index : index to offset
  %byte_offset_aligned = index.assume %byte_offset [mul(%byte_offset, 4)] : offset
  %input_aligned = buffer.assume.alignment %input {minimum_alignment = 4} : buffer
  %output_aligned = buffer.assume.alignment %output {minimum_alignment = 4} : buffer
  %input_view = buffer.view %input_aligned[%byte_offset_aligned] : buffer -> view<1xi32, #dense>
  %loaded = view.load %input_view[0] : view<1xi32, #dense> -> i32
  %output_view = buffer.view %output_aligned[%byte_offset_aligned] : buffer -> view<1xi32, #dense>
  view.store %loaded, %output_view[0] : i32, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 2, 1) @spirv_dynamic_builtin_storage_buffer_i32() asm<spirv.logical.core> {
  %input_aligned = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_aligned = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %workgroup_x = OpLoadBuiltin.workgroup_id.x
  %local_y = OpLoadBuiltin.local_invocation_id.y
  %global_z = OpLoadBuiltin.global_invocation_id.z
  %sum = OpIAdd %workgroup_x, %local_y
  %linear = OpIAdd %sum, %global_z
  %31 = OpConstant.i32 2
  %byte_index = OpShiftLeftLogical %linear, %31
  %byte_offset_aligned = OpUConvert.i32.offset64 %byte_index
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input_aligned, %byte_offset_aligned
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output_aligned, %byte_offset_aligned
  OpStore.storage_buffer.i32 %output_view, %loaded
  return
}

