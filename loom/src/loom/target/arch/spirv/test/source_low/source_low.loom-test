spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_f32(%input: buffer, %output: buffer, %byte_offset: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %byte_offset_aligned = index.assume %byte_offset [mul(%byte_offset, 4)] : offset
  %input_aligned = buffer.assume.alignment %input {minimum_alignment = 4} : buffer
  %output_aligned = buffer.assume.alignment %output {minimum_alignment = 4} : buffer
  %input_view = buffer.view %input_aligned[%byte_offset_aligned] : buffer -> view<1xf32, #dense>
  %loaded = view.load %input_view[0] : view<1xf32, #dense> -> f32
  %sum = scalar.addf %loaded, %loaded : f32
  %product = scalar.mulf %sum, %loaded : f32
  %quotient = scalar.divf %product, %loaded : f32
  %remainder = scalar.remf %quotient, %loaded : f32
  %output_view = buffer.view %output_aligned[%byte_offset_aligned] : buffer -> view<1xf32, #dense>
  view.store %remainder, %output_view[0] : f32, view<1xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_f32(%byte_offset_aligned: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input_aligned = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_aligned = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %input_aligned, %byte_offset_aligned
  %loaded = OpLoad.storage_buffer.f32 %input_view
  %sum = OpFAdd.f32 %loaded, %loaded
  %product = OpFMul.f32 %sum, %loaded
  %quotient = OpFDiv.f32 %product, %loaded
  %remainder = OpFRem.f32 %quotient, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %output_aligned, %byte_offset_aligned
  OpStore.storage_buffer.f32 %output_view, %remainder
  return
}

