spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

kernel.def target(@hal_target) @spirv_hal_resource_storage_buffer_i32_guard(%input: buffer, %output: buffer, %byte_offset: offset, %limit: offset) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %byte_offset_aligned = index.assume %byte_offset [mul(%byte_offset, 4)] : offset
  %inside = index.cmp ult, %byte_offset_aligned, %limit : offset
  cfg.cond_br %inside, ^in_bounds, ^done
^in_bounds:
  %input_aligned = buffer.assume.alignment %input {minimum_alignment = 4} : buffer
  %output_aligned = buffer.assume.alignment %output {minimum_alignment = 4} : buffer
  %input_view = buffer.view %input_aligned[%byte_offset_aligned] : buffer -> view<1xi32, #dense>
  %loaded = view.load %input_view[0] : view<1xi32, #dense> -> i32
  %incremented = scalar.addi %loaded, %loaded : i32
  %output_view = buffer.view %output_aligned[%byte_offset_aligned] : buffer -> view<1xi32, #dense>
  view.store %incremented, %output_view[0] : i32, view<1xi32, #dense>
  cfg.br ^done
^done:
  kernel.return
}

// ----
low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_hal_resource_storage_buffer_i32_guard(%byte_offset_aligned: reg<spirv.offset64>, %limit: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input_aligned = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_aligned = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %inside = OpULessThan.offset64 %byte_offset_aligned, %limit
  low.cond_br %inside, ^in_bounds, ^done : reg<spirv.id>
^in_bounds:
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input_aligned, %byte_offset_aligned
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %incremented = OpIAdd %loaded, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output_aligned, %byte_offset_aligned
  OpStore.storage_buffer.i32 %output_view, %incremented
  low.br ^done
^done:
  return
}

