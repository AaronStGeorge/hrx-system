spirv.target<vulkan1_3> @target

func.def target(@target) @unsupported_source_type(%value: f8E4M3) {
  // ERROR@-1: TARGET/031 {target_key="target", export_name="unsupported_source_type", config_key="target", op_name="func.def", function_name="unsupported_source_type", actual_type="f8E4M3", type_constraint="scalar.fp8_decode_or_contract"}
