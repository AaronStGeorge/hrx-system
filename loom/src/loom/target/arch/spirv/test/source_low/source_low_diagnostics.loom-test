// RUN: emit source-low output=low

spirv.target<vulkan1_3> @target

func.def target(@target) @unsupported_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  // ERROR@+1: TARGET/001 {op_name="scalar.ceildivui"}
  %quotient = scalar.ceildivui %lhs, %rhs : i32
  func.return %quotient : i32
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @unsigned_i16_requires_target_features(%lhs: i16, %rhs: i16) -> (i16) {
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_udiv.u16", constraint_key="descriptor_available"}
  %quotient = scalar.divui %lhs, %rhs : i16
  func.return %quotient : i16
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @unsigned_i16_conversion_requires_target_features(%lhs: i16) -> (i32) {
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_u_convert.u16.u32", constraint_key="descriptor_available"}
  %wide = scalar.extui %lhs : i16 to i32
  func.return %wide : i32
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @unsupported_semantic_math(%input: f32) -> (f32) {
  // ERROR@+1: LOWERING/036 {op_name="scalar.logisticf", phase_name="legalize-math", policy_name="spirv-math", math_op="logisticf", lane_domain="scalar", element_type="f32", constraint_key="math.op.native_arithmetic"}
  %result = scalar.logisticf %input : f32
  func.return %result : f32
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @unsupported_source_type(%value: f32) {
  // ERROR@-1: TARGET/033 {field_name="source", actual_type="f32"}
  func.return
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @storage_buffer_f16_requires_target_features(%input: buffer, %output: buffer, %byte_offset: offset) {
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_ptr_access_chain.storage_buffer.f16.byte_offset", constraint_key="descriptor_available"}
  %input_view = buffer.view %input[%byte_offset] : buffer -> view<1xf16, #dense>
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_load.storage_buffer.f16", constraint_key="descriptor_available"}
  %loaded = view.load %input_view[0] : view<1xf16, #dense> -> f16
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_ptr_access_chain.storage_buffer.f16.byte_offset", constraint_key="descriptor_available"}
  %output_view = buffer.view %output[%byte_offset] : buffer -> view<1xf16, #dense>
  // ERROR@+1: TARGET/003 {subject_kind="descriptor", subject_name="spirv.op_store.storage_buffer.f16", constraint_key="descriptor_available"}
  view.store %loaded, %output_view[0] : f16, view<1xf16, #dense>
  func.return
}
