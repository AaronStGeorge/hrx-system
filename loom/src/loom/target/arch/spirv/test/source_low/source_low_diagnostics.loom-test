// RUN: emit source-low output=low

spirv.target<vulkan1_3> @target

func.def target(@target) @unsupported_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  // ERROR@+1: TARGET/001 {op_name="scalar.ceildivui"}
  %quotient = scalar.ceildivui %lhs, %rhs : i32
  func.return %quotient : i32
}

// ====

spirv.target<vulkan1_3> @target

func.def target(@target) @unresolved_apply_rejected_at_source_low(%value: i32) -> (i32) {
  // ERROR@+1: LOWERING/045 {op_name="func.apply", phase_name="select-func-apply", contract_key="demo.missing", reason="no provider implements the requested contract"}
  %result = func.apply<demo.missing>(%value) : (i32) -> (i32)
  func.return %result : i32
}

