// RUN: roundtrip

// IREE VM import declarations are ordinary function-like symbols. Source IR
// keeps using func.call instead of target-private call ops.
ireevm.target<core> @vm_target

ireevm.import.decl target(@vm_target) symbol("hal.buffer.length") @hal_buffer_length(%buffer: i32) -> (i64)

func.def target(@vm_target) @call_import(%buffer: i32) -> (i64) {
  %length = func.call @hal_buffer_length(%buffer) : (i32) -> (i64)
  func.return %length : i64
}

// ====

// Generic func-like declaration modifiers remain available for linker contracts
// and call analyses.
ireevm.target<core> @vm_target

ireevm.import.decl public target(@vm_target) symbol("hal.buffer.map") pure @hal_buffer_map(%buffer: i32, %access: i32) -> (i64)
