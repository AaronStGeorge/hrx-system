// RUN: emit source-low output=low

ireevm.target<core> @target

func.def target(@target) @unsupported_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  // ERROR@+1: TARGET/001 {op_name="scalar.ceildivsi"}
  %quotient = scalar.ceildivsi %lhs, %rhs : i32
  func.return %quotient : i32
}

// ====

ireevm.target<core> @target

func.def target(@target) @unsupported_source_type(%value: f16) {
  // ERROR@-1: TARGET/033 {field_name="source", actual_type="f16"}
  func.return
}

// ====

ireevm.target<core> @target

// ERROR@+1: TARGET/022 {constraint_key="abi.hal_kernel"}
kernel.def target(@target) @kernel_workgroup_size_requires_hal_abi() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  kernel.return
}
