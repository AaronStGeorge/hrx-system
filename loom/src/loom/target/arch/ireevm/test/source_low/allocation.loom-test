// RUN: emit low-allocation-json @vm_i64_block_arguments_allocate_two_slots

ireevm.target<core> @vm_target

low.func.def target(@vm_target) @vm_i64_block_arguments_allocate_two_slots(%start: reg<ireevm.i64 x2>, %limit: reg<ireevm.i64 x2>, %step: reg<ireevm.i64 x2>) -> (reg<ireevm.i64 x2>) asm<ireevm.core> {
  low.br ^loop(%start: reg<ireevm.i64 x2>)
^loop(%current: reg<ireevm.i64 x2>):
  %keep_going = ireevm.cmp.lt.s.i64 %current, %limit
  low.cond_br %keep_going, ^body, ^exit : reg<ireevm.i32>
^body:
  %next = ireevm.add.i64 %current, %step
  low.br ^loop(%next: reg<ireevm.i64 x2>)
^exit:
  return %current
}

