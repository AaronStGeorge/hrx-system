// RUN: emit low-allocation-json @vm_i32_values_allocate_one_scalar_slot

ireevm.target<core> @vm_target

low.func.def target(@vm_target) @vm_i32_values_allocate_one_scalar_slot(%lhs: reg<ireevm.i32>, %rhs: reg<ireevm.i32>) -> (reg<ireevm.i32>) asm<ireevm.core> {
  %sum = ireevm.add.i32 %lhs, %rhs
  return %sum
}

