load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_target_table_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_target_table_cc_library(
    name = "core",
    args = ["--contract-fragment=ireevm.core"],
    generator = "//loom/py/loom/gen:ireevm_contract_fragment",
    deps = ["//loom/src/loom/target:contract"],
)

loom_target_table_cc_library(
    name = "core_lower_rules",
    args = ["--contract-fragment=ireevm.core"],
    generator = "//loom/py/loom/gen:ireevm_lower_rule_shard",
    deps = [
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/target/arch/ireevm:descriptors_ids",
    ],
)

loom_cc_library(
    name = "contracts",
    hdrs = [
        "core.h",
        "core_lower_rules.h",
    ],
    deps = [
        ":core",
        ":core_lower_rules",
    ],
)
