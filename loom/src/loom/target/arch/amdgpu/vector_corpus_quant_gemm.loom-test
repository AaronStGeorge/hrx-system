// RUN: emit source-low @amdgpu_q6_high2_scaled_gemm2x2_shape output=none
target.profile @gfx11_q6_high2_scaled_gemm2x2_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_high2_scaled_gemm2x2_shape_target) @amdgpu_q6_high2_scaled_gemm2x2_shape(%low_buffer: buffer, %high_buffer: buffer, %rhs_buffer: buffer, %scale_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %two = index.constant 2 : index
  %four = index.constant 4 : index
  %rhs_base = index.madd %x, %two, %zero : index
  %output_base = index.madd %y, %four, %rhs_base : index
  %low_view = buffer.view %low_buffer[%zero_offset] : buffer -> view<2xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero_offset] : buffer -> view<2xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %scale_view = buffer.view %scale_buffer[%zero_offset] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<8xf32, #dense>
  %low_packed = vector.load %low_view[%y] : view<2xi32, #dense> -> vector<1xi32>
  %high_word = vector.load %high_view[%y] : view<2xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[%rhs_base] : view<4xi32, #dense> -> vector<2xi32>
  %scale = vector.load %scale_view[%rhs_base] : view<4xf32, #dense> -> vector<2xf32>
  %low4 = vector.bitunpacku<4> %low_packed : vector<1xi32> -> vector<8xi32>
  %high_bytes = vector.bitcast %high_word : vector<1xi32> to vector<4xi8>
  %high_packed = vector.slice %high_bytes[2] : vector<4xi8> -> vector<2xi8>
  %high2 = vector.bitunpacku<2> %high_packed : vector<2xi8> -> vector<8xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<8xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<8xi32> -> vector<8xi8>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<2xi32> -> vector<8xi32>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<8xi32> -> vector<8xi8>
  %acc = vector.constant 0 : vector<2xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  %converted = vector.sitofp %dot : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  vector.store %scaled, %output_view[%output_base] : vector<2xf32>, view<8xf32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_high2_scaled_gemm2x2_k16_shape output=none
target.profile @gfx11_q6_high2_scaled_gemm2x2_k16_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_high2_scaled_gemm2x2_k16_shape_target) @amdgpu_q6_high2_scaled_gemm2x2_k16_shape(%low_buffer: buffer, %high_buffer: buffer, %rhs_buffer: buffer, %scale_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %two = index.constant 2 : index
  %four = index.constant 4 : index
  %row_base = index.madd %y, %two, %zero : index
  %row_next = index.add %row_base, %one : index
  %column_base = index.madd %x, %two, %zero : index
  %rhs_base = index.madd %x, %four, %zero : index
  %rhs_next = index.add %rhs_base, %two : index
  %output_base = index.madd %y, %four, %column_base : index
  %low_view = buffer.view %low_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<8xi32, #dense>
  %scale_view = buffer.view %scale_buffer[%zero_offset] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<8xf32, #dense>
  %low_packed0 = vector.load %low_view[%row_base] : view<4xi32, #dense> -> vector<1xi32>
  %high_word0 = vector.load %high_view[%row_base] : view<4xi32, #dense> -> vector<1xi32>
  %rhs_packed0 = vector.load %rhs_view[%rhs_base] : view<8xi32, #dense> -> vector<2xi32>
  %low40 = vector.bitunpacku<4> %low_packed0 : vector<1xi32> -> vector<8xi32>
  %high_bytes0 = vector.bitcast %high_word0 : vector<1xi32> to vector<4xi8>
  %high_packed0 = vector.slice %high_bytes0[2] : vector<4xi8> -> vector<2xi8>
  %high20 = vector.bitunpacku<2> %high_packed0 : vector<2xi8> -> vector<8xi32>
  %q60 = vector.bitfield.insert %high20 into %low40 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q60 = vector.subi %q60, %bias : vector<8xi32>
  %lhs0 = vector.bitpack<8> %signed_q60 : vector<8xi32> -> vector<8xi8>
  %rhs_i320 = vector.bitunpacku<8> %rhs_packed0 : vector<2xi32> -> vector<8xi32>
  %rhs0 = vector.bitpack<8> %rhs_i320 : vector<8xi32> -> vector<8xi8>
  %zero_acc = vector.constant 0 : vector<2xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot0 = vector.dot4i<s8s8> %lhs0, %rhs0, %zero_acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  %low_packed1 = vector.load %low_view[%row_next] : view<4xi32, #dense> -> vector<1xi32>
  %high_word1 = vector.load %high_view[%row_next] : view<4xi32, #dense> -> vector<1xi32>
  %rhs_packed1 = vector.load %rhs_view[%rhs_next] : view<8xi32, #dense> -> vector<2xi32>
  %low41 = vector.bitunpacku<4> %low_packed1 : vector<1xi32> -> vector<8xi32>
  %high_bytes1 = vector.bitcast %high_word1 : vector<1xi32> to vector<4xi8>
  %high_packed1 = vector.slice %high_bytes1[2] : vector<4xi8> -> vector<2xi8>
  %high21 = vector.bitunpacku<2> %high_packed1 : vector<2xi8> -> vector<8xi32>
  %q61 = vector.bitfield.insert %high21 into %low41 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %signed_q61 = vector.subi %q61, %bias : vector<8xi32>
  %lhs1 = vector.bitpack<8> %signed_q61 : vector<8xi32> -> vector<8xi8>
  %rhs_i321 = vector.bitunpacku<8> %rhs_packed1 : vector<2xi32> -> vector<8xi32>
  %rhs1 = vector.bitpack<8> %rhs_i321 : vector<8xi32> -> vector<8xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot1 = vector.dot4i<s8s8> %lhs1, %rhs1, %dot0 : vector<8xi8>, vector<8xi8>, vector<2xi32>
  %scale = vector.load %scale_view[%column_base] : view<4xf32, #dense> -> vector<2xf32>
  %converted = vector.sitofp %dot1 : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  vector.store %scaled, %output_view[%output_base] : vector<2xf32>, view<8xf32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_k_scaled_gemm2x2_k16_shape output=none
target.profile @gfx11_q6_k_scaled_gemm2x2_k16_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_k_scaled_gemm2x2_k16_shape_target) @amdgpu_q6_k_scaled_gemm2x2_k16_shape(%low_buffer: buffer, %high_buffer: buffer, %rhs_buffer: buffer, %scale_buffer: buffer, %d_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %two = index.constant 2 : index
  %four = index.constant 4 : index
  %eight = index.constant 8 : index
  %row_base = index.madd %y, %two, %zero : index
  %column_base = index.madd %x, %two, %zero : index
  %rhs_base = index.madd %x, %four, %zero : index
  %output_base = index.madd %y, %four, %column_base : index
  %low_byte_base = index.mul %row_base, %four : index
  %low_byte_next = index.add %low_byte_base, %four : index
  %rhs_byte_base = index.mul %rhs_base, %four : index
  %rhs_byte_next = index.add %rhs_byte_base, %eight : index
  %scale_byte_base = index.mul %y, %four : index
  %low_view = buffer.view %low_buffer[%zero_offset] : buffer -> view<16xi8, #dense>
  %high_view = buffer.view %high_buffer[%zero_offset] : buffer -> view<16xi8, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<32xi8, #dense>
  %scale_view = buffer.view %scale_buffer[%zero_offset] : buffer -> view<8xi8, #dense>
  %d_view = buffer.view %d_buffer[%zero_offset] : buffer -> view<2xf32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<8xf32, #dense>
  %scale_bytes = vector.load %scale_view[%scale_byte_base] : view<8xi8, #dense> -> vector<4xi8>
  %scale_i32 = vector.bitunpacks<8> %scale_bytes : vector<4xi8> -> vector<4xi32>
  %scale_i320 = vector.extract %scale_i32[0] : vector<4xi32> -> i32
  %scale_i321 = vector.extract %scale_i32[1] : vector<4xi32> -> i32
  %scale_f320 = scalar.sitofp %scale_i320 : i32 to f32
  %scale_f321 = scalar.sitofp %scale_i321 : i32 to f32
  %d_loaded = vector.load %d_view[%y] : view<2xf32, #dense> -> vector<1xf32>
  %d = vector.extract %d_loaded[0] : vector<1xf32> -> f32
  %factor0 = scalar.mulf %scale_f320, %d : f32
  %factor1 = scalar.mulf %scale_f321, %d : f32
  %factor_vec0 = vector.from_elements %factor0, %factor0 : vector<2xf32>
  %factor_vec1 = vector.from_elements %factor1, %factor1 : vector<2xf32>
  %low_packed0 = vector.load %low_view[%low_byte_base] : view<16xi8, #dense> -> vector<4xi8>
  %high_bytes0 = vector.load %high_view[%low_byte_base] : view<16xi8, #dense> -> vector<4xi8>
  %rhs0 = vector.load %rhs_view[%rhs_byte_base] : view<32xi8, #dense> -> vector<8xi8>
  %low40 = vector.bitunpacku<4> %low_packed0 : vector<4xi8> -> vector<8xi32>
  %high_packed0 = vector.slice %high_bytes0[0] : vector<4xi8> -> vector<2xi8>
  %high20 = vector.bitunpacku<2> %high_packed0 : vector<2xi8> -> vector<8xi32>
  %q60 = vector.bitfield.insert %high20 into %low40 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q60 = vector.subi %q60, %bias : vector<8xi32>
  %lhs0 = vector.bitpack<8> %signed_q60 : vector<8xi32> -> vector<8xi8>
  %zero_acc = vector.constant 0 : vector<2xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot0 = vector.dot4i<s8s8> %lhs0, %rhs0, %zero_acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  %converted0 = vector.sitofp %dot0 : vector<2xi32> to vector<2xf32>
  %scaled0 = vector.mulf %converted0, %factor_vec0 : vector<2xf32>
  %low_packed1 = vector.load %low_view[%low_byte_next] : view<16xi8, #dense> -> vector<4xi8>
  %high_bytes1 = vector.load %high_view[%low_byte_next] : view<16xi8, #dense> -> vector<4xi8>
  %rhs1 = vector.load %rhs_view[%rhs_byte_next] : view<32xi8, #dense> -> vector<8xi8>
  %low41 = vector.bitunpacku<4> %low_packed1 : vector<4xi8> -> vector<8xi32>
  %high_packed1 = vector.slice %high_bytes1[0] : vector<4xi8> -> vector<2xi8>
  %high21 = vector.bitunpacku<2> %high_packed1 : vector<2xi8> -> vector<8xi32>
  %q61 = vector.bitfield.insert %high21 into %low41 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %signed_q61 = vector.subi %q61, %bias : vector<8xi32>
  %lhs1 = vector.bitpack<8> %signed_q61 : vector<8xi32> -> vector<8xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot1 = vector.dot4i<s8s8> %lhs1, %rhs1, %zero_acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  %converted1 = vector.sitofp %dot1 : vector<2xi32> to vector<2xf32>
  %scaled1 = vector.mulf %converted1, %factor_vec1 : vector<2xf32>
  %sum = vector.addf %scaled0, %scaled1 : vector<2xf32>
  vector.store %sum, %output_view[%output_base] : vector<2xf32>, view<8xf32, #dense>
  func.return
}
