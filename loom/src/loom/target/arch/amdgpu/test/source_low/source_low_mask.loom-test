low.func.def target(@target) abi(hal_kernel) @i64_splat(%value: reg<amdgpu.sgpr x2>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %5 = slice %value[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %6 = v_mov_b32_copy %5
  %7 = slice %value[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %8 = v_mov_b32_copy %7
  %9 = concat(%6, %8) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %splat = concat(%9, %9) : (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>) -> reg<amdgpu.vgpr x4>
  return %splat
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f64_splat(%value: f64) -> (vector<2xf64>) {
  %splat = vector.splat %value : vector<2xf64>
  func.return %splat : vector<2xf64>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f64_splat(%value: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %splat = concat(%value, %value) : (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>) -> reg<amdgpu.vgpr x4>
  return %splat
}
