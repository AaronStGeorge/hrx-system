// RUN: emit source-low output=pipeline

amdgpu.target<gfx1100> @target

func.def target(@target) @pipeline_probe(%value: i32) -> (i32) {
  func.return %value : i32
}

// ----
pass.pipeline<module> @__loom_check_source_low pipeline {
  for func {
    where target {
      legalize-math
      normalize-kernel-resources
      promote-private-fragments
    }
  }
  select-templates(mode = "final")
  inline-callables
  target-legalize(mode = "eager")
  for func {
    where target {
      vector-gather-to-scalar
      linearize-view-accesses
      canonicalize
      cse
      unroll-scf-for
      canonicalize
      cse
      scf-to-cfg
      cfg-simplify
      canonicalize
      cse
      branch-sink
    }
  }
  target-legalize(mode = "eager")
  source-to-low
  for func {
    where target {
      cfg-simplify
      canonicalize
      cse
      low-dce
    }
  }
}

// ====
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @gfx11
amdgpu.target<gfx1200> @gfx12

func.template<demo.target_prune> target(@gfx12) priority(20) @gfx12_provider(%codes: vector<8xi32>) -> (vector<4xi8>) {
  %packed = vector.bitpack<4> %codes : vector<8xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

func.template<demo.target_prune> target(@gfx11) priority(10) @gfx11_provider(%codes: vector<4xi32>) -> (vector<4xi8>) {
  %packed = vector.bitpack<8> %codes : vector<4xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

func.template<demo.target_prune> priority(1) @fallback_provider(%codes: vector<4xi32>) -> (vector<4xi8>) {
  %packed = vector.bitpack<8> %codes : vector<4xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

func.def target(@gfx11) @target_template_prunes_nonmatching_provider(%codes: vector<4xi32>) -> (vector<4xi8>) {
  %packed = func.apply<demo.target_prune>(%codes) : (vector<4xi32>) -> (vector<4xi8>)
  func.return %packed : vector<4xi8>
}

// ----
low.func.def target(@gfx11) abi(hal_kernel) @target_template_prunes_nonmatching_provider(%codes: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %15 = slice %codes[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = v_and_b32_lit %15, 255
  %17 = slice %codes[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_and_b32_lit %17, 255
  %19 = v_lshlrev_b32_src0_inline %18, 8
  %20 = v_or_b32 %16, %19
  %21 = slice %codes[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = v_and_b32_lit %21, 255
  %23 = v_lshlrev_b32_src0_inline %22, 16
  %24 = v_or_b32 %20, %23
  %25 = slice %codes[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %26 = v_and_b32_lit %25, 255
  %27 = v_lshlrev_b32_src0_inline %26, 24
  %packed = v_or_b32 %24, %27
  return %packed
}

// ====
// RUN: emit source-low output=prepared-pipeline

amdgpu.target<gfx1100> @target

kernel.def target(@target) @prepared_pipeline_probe() {
  %one = index.constant 1 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%one, %one, %one) : index
} launch(%arg: buffer) {
  kernel.return
}

// ----
pass.pipeline<module> @__loom_check_prepared_low pipeline {
  for func {
    where target {
      legalize-math
      normalize-kernel-resources
      promote-private-fragments
    }
  }
  select-templates(mode = "final")
  inline-callables
  target-legalize(mode = "eager")
  for func {
    where target {
      vector-gather-to-scalar
      linearize-view-accesses
      canonicalize
      cse
      unroll-scf-for
      canonicalize
      cse
      scf-to-cfg
      cfg-simplify
      canonicalize
      cse
      branch-sink
    }
  }
  target-legalize(mode = "eager")
  source-to-low
  for func {
    where target {
      cfg-simplify
      canonicalize
      cse
      low-dce
    }
  }
  for func {
    where target {
      where target(abi = "hal_kernel", codegen = "low_native", target_op = "amdgpu.target") {
        amdgpu-materialize-hal-kernel-abi
      }
      canonicalize
      cse
      cse
      low-select-operand-forms
      low-dce
    }
  }
}
