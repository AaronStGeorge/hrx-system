amdgpu.target<gfx1100> @gfx11_target
kernel.def target(@gfx11_target) @packed_f16_affine_epilogue_kernel() {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 64 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%input: buffer, %scale_buffer: buffer, %bias_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xf16, #dense>
  %scale_view = buffer.view %scale_buffer[%zero] : buffer -> view<64x4xf16, #dense>
  %bias_view = buffer.view %bias_buffer[%zero] : buffer -> view<64x4xf16, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf16, #dense>
  %x = vector.load %input_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  %scale = vector.load %scale_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  %bias = vector.load %bias_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  %result = vector.fmaf %x, %scale, %bias : vector<4xf16>
  vector.store %result, %output_view[%tid, 0] : vector<4xf16>, view<64x4xf16, #dense>
  kernel.return
}

// ----
low.kernel.def target(@gfx11_target) workgroup_size(64, 1, 1) @packed_f16_affine_epilogue_kernel() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %scale_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %bias_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 3, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %22 = v_lshlrev_b32_src0_inline %tid, 3
  %x = global_load_b64_saddr %22, %input_view
  %24 = v_lshlrev_b32_src0_inline %tid, 3
  %scale = global_load_b64_saddr %24, %scale_view
  %26 = v_lshlrev_b32_src0_inline %tid, 3
  %bias = global_load_b64_saddr %26, %bias_view
  %28 = slice %bias[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %29 = slice %x[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %30 = slice %scale[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %31 = v_pk_fmac_f16 %28, %29, %30
  %32 = slice %bias[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %33 = slice %x[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %34 = slice %scale[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %35 = v_pk_fmac_f16 %32, %33, %34
  %result = concat(%31, %35) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %37 = v_lshlrev_b32_src0_inline %tid, 3
  global_store_b64_saddr %37, %result, %output_view
  return
}

