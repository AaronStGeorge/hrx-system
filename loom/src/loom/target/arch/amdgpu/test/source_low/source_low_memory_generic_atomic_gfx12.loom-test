low.func.def target(@target) abi(hal_kernel) @generic_atomic_cmpxchg_i32_static() asm<amdgpu.rdna4.core> {
  %view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %10 = slice %view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %11 = slice %view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %12 = v_mov_b32_copy %10
  %13 = v_mov_b32_copy %11
  %14 = concat(%12, %13) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %15 = v_mov_b32 7
  %16 = v_mov_b32 9
  %17 = concat(%15, %16) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %old_cmpxchg = flat_atomic_cmpswap_b32_rtn %14, %17 {scope = 2}
  return
}
