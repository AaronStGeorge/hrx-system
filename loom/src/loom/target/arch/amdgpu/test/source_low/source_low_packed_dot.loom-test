// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_dot_integer.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @dot4i_s8s8(%lhs: vector<4xi8>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}

// ----
low.func.def target(@target) @dot4i_s8s8(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>, %acc: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %dot = v_dot4_i32_i8 %lhs, %rhs, %acc
  return %dot
}

// ====

