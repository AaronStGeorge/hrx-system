// RUN: emit source-low output=low sanitizer=race

amdgpu.target<gfx1200> @target {processor = "gfx1201"}

kernel.def target(@target) @race_sync_direct_gfx1201() {
  %one = index.constant 1 : index
  %threads = index.constant 64 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%threads, %one, %one) : index
} launch() {
  sanitizer.race.sync<workgroup> {ordering = acq_rel, scope = workgroup}
  kernel.return
}

