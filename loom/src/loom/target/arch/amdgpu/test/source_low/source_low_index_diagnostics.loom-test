// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_scale_byte_offset_width_rejected(%lane: index) -> (offset) {
  %stride = index.constant 4294967296 : offset
  // ERROR@+1: TARGET/003 {subject_role="byte-offset-width", subject_name="u32", constraint_key="amdgpu.byte_offset.u32"}
