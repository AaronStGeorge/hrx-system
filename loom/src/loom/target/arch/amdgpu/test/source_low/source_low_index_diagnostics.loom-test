// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i64_index_cast_unknown_range_rejected(%value: i64) -> (index) {
  // ERROR@+1: AMDGPU/033 {source_type="i64", result_type="index", index_bitwidth="32", required_range_lo="-2147483648", required_range_hi="2147483647", accepted_proof_sources="[scalar.assume on the integer source before index.cast, config or kernel boundary facts on the integer source]"}
  %index = index.cast %value : i64 to index
  func.return %index : index
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @i64_index_cast_too_wide_range_rejected(%value: i64) -> (index) {
  %bounded = scalar.assume %value [range(%value, 0, 2147483648)] : i64
