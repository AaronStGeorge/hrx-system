// RUN: emit amdgpu-wait-counter-plan-json @concat_forwards_lds_wait

amdgpu.target<gfx1100> @target {subgroup_size = 64}
low.func.def target(@target) @concat_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr x8>, %acc: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %lhs0 = ds_read_b128 %addr
  %lhs1 = ds_read_b128 %addr {offset = 16}
  %lhs = concat(%lhs0, %lhs1) : (reg<amdgpu.vgpr x4>, reg<amdgpu.vgpr x4>) -> reg<amdgpu.vgpr x8>
  %result = v_wmma_f16_16x16x16_f16_w64 %lhs, %rhs, %acc
  return %result
}

// ----
// Nodes 0 and 1 are the LDS reads, node 2 is the transparent concat, and node 3
// is the WMMA consumer. The planned wait must attach to node 3, not node 2.
{"format":"loom.low.packet_hazard_plan.v1","function":"concat_forwards_lds_wait","target":"target","descriptor_set":"amdgpu.rdna3.core","progress_count":2,"hazard_count":1,"progress":[{"index":0,"packet":0,"node":0,"block":0,"scheduled_ordinal":0,"class_id":3,"class_name":"amdgpu.lds","action":"advance","units":1},{"index":1,"packet":1,"node":1,"block":0,"scheduled_ordinal":1,"class_id":3,"class_name":"amdgpu.lds","action":"advance","units":1}],"hazards":[{"index":0,"kind":"action","action_id":1,"action_name":"amdgpu.wait_packet","reason_id":2,"reason_name":"amdgpu.ssa_use","producer_node":1,"producer_packet":1,"producer_scheduled_ordinal":1,"consumer_node":3,"insertion_packet":3,"block":0,"scheduled_ordinal":3,"progress_class_id":3,"progress_class_name":"amdgpu.lds","required":2,"observed":0,"residual":2}]}

// ====
// RUN: emit amdgpu-wait-counter-plan-json @slice_forwards_lds_wait

amdgpu.target<gfx1100> @target
low.func.def target(@target) @slice_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %loaded = ds_read_b128 %addr
  %lane0 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %result = v_add_f32 %lane0, %rhs
  return %result
}

// ----
// Node 1 is the transparent slice. The wait must be planned at node 2, where
// the sliced LDS payload is actually consumed by VALU.
{"format":"loom.low.packet_hazard_plan.v1","function":"slice_forwards_lds_wait","target":"target","descriptor_set":"amdgpu.rdna3.core","progress_count":1,"hazard_count":1,"progress":[{"index":0,"packet":0,"node":0,"block":0,"scheduled_ordinal":0,"class_id":3,"class_name":"amdgpu.lds","action":"advance","units":1}],"hazards":[{"index":0,"kind":"action","action_id":1,"action_name":"amdgpu.wait_packet","reason_id":2,"reason_name":"amdgpu.ssa_use","producer_node":0,"producer_packet":0,"producer_scheduled_ordinal":0,"consumer_node":2,"insertion_packet":2,"block":0,"scheduled_ordinal":2,"progress_class_id":3,"progress_class_name":"amdgpu.lds","required":1,"observed":0,"residual":1}]}

// ====
// RUN: emit amdgpu-wait-counter-plan-json @copy_forwards_lds_wait

amdgpu.target<gfx1100> @target
low.func.def target(@target) @copy_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %loaded = ds_read_b32 %addr
  %copied = copy %loaded : reg<amdgpu.vgpr> -> reg<amdgpu.vgpr>
  %result = v_add_f32 %copied, %rhs
  return %result
}

// ----
// Node 1 is the coalesced copy. The wait must be planned at node 2, where the
// copied LDS payload is actually consumed by VALU.
{"format":"loom.low.packet_hazard_plan.v1","function":"copy_forwards_lds_wait","target":"target","descriptor_set":"amdgpu.rdna3.core","progress_count":1,"hazard_count":1,"progress":[{"index":0,"packet":0,"node":0,"block":0,"scheduled_ordinal":0,"class_id":3,"class_name":"amdgpu.lds","action":"advance","units":1}],"hazards":[{"index":0,"kind":"action","action_id":1,"action_name":"amdgpu.wait_packet","reason_id":2,"reason_name":"amdgpu.ssa_use","producer_node":0,"producer_packet":0,"producer_scheduled_ordinal":0,"consumer_node":2,"insertion_packet":2,"block":0,"scheduled_ordinal":2,"progress_class_id":3,"progress_class_name":"amdgpu.lds","required":1,"observed":0,"residual":1}]}
