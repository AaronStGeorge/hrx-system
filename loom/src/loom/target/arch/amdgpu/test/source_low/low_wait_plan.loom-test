// ====
// RUN: emit amdgpu-wait-counter-plan-json @smem_load_address_dependency strategy=source

amdgpu.target<gfx1100> @target
low.func.def target(@target) @smem_load_address_dependency(%kernarg: reg<amdgpu.sgpr x2>) -> (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %zero = s_mov_b32 0
  %base = s_load_dwordx2 %kernarg, %zero {offset = 16}
  %noise0 = s_load_dword %kernarg, %zero {offset = 0}
  %noise1 = s_load_dword %kernarg, %zero {offset = 8}
  %noise2 = s_load_dword %kernarg, %zero {offset = 12}
  %value = s_load_dword %base, %zero
  return %value, %noise0, %noise1, %noise2 : reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>
}

// ----
// The pointer-producing scalar load is oldest among four outstanding SMEM
// packets, but dependent SMEM consumers must still request a full SMEM drain.
