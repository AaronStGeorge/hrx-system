// ====
// RUN: emit amdgpu-wait-counter-plan-json @slice_forwards_lds_wait

amdgpu.target<gfx1100> @target
low.func.def target(@target) @slice_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %loaded = ds_read_b128 %addr
  %lane0 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %result = v_add_f32 %lane0, %rhs
  return %result
}

// ----
// Node 1 is the transparent slice. The wait must be planned at node 2, where
// the sliced LDS payload is actually consumed by VALU.
