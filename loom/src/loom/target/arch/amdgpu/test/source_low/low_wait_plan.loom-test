// ====
// RUN: emit amdgpu-assembly @smem_load_address_dependency_assembly strategy=source

amdgpu.target<gfx1100> @target
low.func.def target(@target) @smem_load_address_dependency_assembly(%kernarg: reg<amdgpu.sgpr x2>, %output: reg<amdgpu.sgpr x2>) asm<amdgpu.rdna3.core> {
  %zero = s_mov_b32 0
  %zero_v = v_mov_b32 0
  %base = s_load_dwordx2 %kernarg, %zero {offset = 16}
  %noise0 = s_load_dword %kernarg, %zero {offset = 0}
  %noise1 = s_load_dword %kernarg, %zero {offset = 8}
  %noise2 = s_load_dword %kernarg, %zero {offset = 12}
  %value = s_load_dword %base, %zero
  %sum0 = s_add_u32 %value, %noise0
  %sum1 = s_add_u32 %sum0, %noise1
  %sum2 = s_add_u32 %sum1, %noise2
  %sum_v = v_mov_b32_copy %sum2
  global_store_b32_saddr %zero_v, %sum_v, %output
  return
}

