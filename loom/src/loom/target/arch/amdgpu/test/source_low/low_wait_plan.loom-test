// RUN: emit amdgpu-wait-counter-plan-json @concat_forwards_lds_wait

amdgpu.target<gfx1100> @target {subgroup_size = 64}
low.func.def target(@target) @concat_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr x8>, %acc: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %lhs0 = ds_read_b128 %addr
  %lhs1 = ds_read_b128 %addr {offset = 16}
  %lhs = concat(%lhs0, %lhs1) : (reg<amdgpu.vgpr x4>, reg<amdgpu.vgpr x4>) -> reg<amdgpu.vgpr x8>
  %result = v_wmma_f16_16x16x16_f16_w64 %lhs, %rhs, %acc
  return %result
}

// ----
// Nodes 0 and 1 are the LDS reads, node 2 is the transparent concat, and node 3
// is the WMMA consumer. The planned wait must attach to node 3, not node 2.
