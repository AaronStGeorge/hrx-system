// ====
// RUN: emit amdgpu-wait-counter-plan-json @copy_forwards_lds_wait

amdgpu.target<gfx1100> @target
low.func.def target(@target) @copy_forwards_lds_wait(%addr: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %loaded = ds_read_b32 %addr
  %copied = copy %loaded : reg<amdgpu.vgpr> -> reg<amdgpu.vgpr>
  %result = v_add_f32 %copied, %rhs
  return %result
}

