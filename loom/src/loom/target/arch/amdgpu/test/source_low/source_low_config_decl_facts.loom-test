// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target

config.decl @runtime.column_count : %value: index where [range(%value, 4, 64), mul(%value, 4)]

kernel.def target(@target) @config_decl_facts_bound_dynamic_view() {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 4 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %base = index.constant 0 : offset
  %lane = kernel.workitem.id<x> : index
  %columns = config.get @runtime.column_count : index
  %input_view = buffer.view %input[%base] : buffer -> view<[%columns]xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<[%columns]xi32, #dense>
  %loaded = vector.load %input_view[%lane] : view<[%columns]xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%lane] : vector<1xi32>, view<[%columns]xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(4, 1, 1) @config_decl_facts_bound_dynamic_view() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %14 = v_lshlrev_b32_src0_inline %lane, 2
  %loaded = global_load_b32_saddr %14, %input_view
  global_store_b32_saddr %14, %loaded, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target

config.decl @runtime.column_count : %value: index where [range(%value, 3072, 8192), mul(%value, 4)]

kernel.def target(@target) @config_decl_matvec_block_lane_vec4_dynamic_view() {
  %unit = index.constant 1 : index
  %lane_count = index.constant 64 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%lane_count, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %lane = kernel.workitem.id<x> : index
  %base_offset = index.constant 0 : offset
  %columns = config.get @runtime.column_count : index
  %block_begin = index.constant 0 : index
  %block_end = index.constant 12 : index
  %block_step = index.constant 4 : index
  %lanes_per_group = index.constant 16 : index
  %block_stride = index.constant 105 : index
  %input_view = buffer.view %input[%base_offset] : buffer -> view<[%columns]xf32, #dense>
  %output_view = buffer.view %output[%base_offset] : buffer -> view<[%columns]xf32, #dense>
  scf.for %block_base = [%block_begin to %block_end step %block_step] {
    %lane_group = index.div %lane, %lanes_per_group : index
    %lane_offset = index.rem %lane, %lanes_per_group : index
    %block = index.add %block_base, %lane_group : index
    %block_origin = index.mul %block, %block_stride : index
    %origin = index.add %block_origin, %lane_offset : index
    %loaded = vector.load %input_view[%origin] : view<[%columns]xf32, #dense> -> vector<4xf32>
    vector.store %loaded, %output_view[%origin] : vector<4xf32>, view<[%columns]xf32, #dense>
  }
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @config_decl_matvec_block_lane_vec4_dynamic_view() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %block_begin = s_mov_b32 0
  %block_end = s_mov_b32 12
  %block_step = s_mov_b32 4
  low.br ^_bb1(%block_begin: reg<amdgpu.sgpr>)
^_bb1(%block_base: reg<amdgpu.sgpr>):
  %38 = s_cmp_lt_i32 %block_base, %block_end
  low.cond_br %38, ^_bb2, ^_bb3 : reg<amdgpu.scc>
^_bb2:
  %lane_group = v_lshrrev_b32_lit %lane, 4
  %41 = v_mov_b32 15
  %lane_offset = v_and_b32 %lane, %41
  %43 = v_mov_b32_copy %block_base
  %block = v_add_u32 %43, %lane_group
  %origin = v_mad_u32_u24_src1_lit %block, %lane_offset, 105
  %46 = v_lshlrev_b32_src0_inline %origin, 2
  %loaded = global_load_b128_saddr %46, %input_view
  global_store_b128_saddr %46, %loaded, %output_view
  %49 = s_add_u32 %block_base, %block_step
  low.br ^_bb1(%49: reg<amdgpu.sgpr>)
^_bb3:
  return
}

