// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_prefetch.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1200> @target
func.def target(@target) @prefetch_static(%input: buffer) {
  %base = index.constant 16 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[4] {intent = read, locality = l1} : view<64xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @prefetch_static() {
  %input_view = low.resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 272} : reg<amdgpu.sgpr x2>
  %4 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %5 = low.op<amdgpu.hal.buffer_descriptor>(%input_view) {cache_swizzle_stride = 0, valid_byte_count = 272} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  low.op<amdgpu.s_buffer_prefetch_data>(%5, %4) {count = 1, offset = 32} : (reg<amdgpu.sgpr x4>, reg<amdgpu.sgpr>)
  low.return
}

// ====

amdgpu.target<gfx1200> @target
kernel.def target(@target) @prefetch_workgroup_id(%input: buffer) {
  %c1 = index.constant 1 : index
  %c1025 = index.constant 1025 : index
  kernel.launch.config workgroups(%c1025, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %gid = kernel.workgroup.id<x> : index
  %bounded_gid = index.assume %gid [range(%gid, 0, 1024)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[%bounded_gid] {intent = read, locality = l2} : view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @prefetch_workgroup_id() {
  %bounded_gid = low.live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = low.resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %10 = low.const<amdgpu.s_mov_b32> {imm32 = 2} : reg<amdgpu.sgpr>
  %11 = low.op<amdgpu.s_lshl_b32>(%bounded_gid, %10) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr>
  %12 = low.op<amdgpu.hal.buffer_descriptor>(%input_view) {cache_swizzle_stride = 0, valid_byte_count = 256} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  low.op<amdgpu.s_buffer_prefetch_data>(%12, %11) {count = 1, offset = 0} : (reg<amdgpu.sgpr x4>, reg<amdgpu.sgpr>)
  low.return
}

// ====

amdgpu.target<gfx1200> @target
kernel.def target(@target) @prefetch_fixed_query_offset(%input: buffer) {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c8, %c4, %c1) : index
} launch {
  %workgroup_size_x = kernel.workgroup.size<x> : index
  %workgroup_size_y = kernel.workgroup.size<y> : index
  %subgroup_size = kernel.subgroup.size : index
  %subgroup_count = kernel.subgroup.count : index
  %offset0 = index.add %workgroup_size_x, %workgroup_size_y : index
  %offset1 = index.add %offset0, %subgroup_size : index
  %offset = index.add %offset1, %subgroup_count : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[%offset] {intent = read, locality = l1} : view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 1) @prefetch_fixed_query_offset() {
  %input_view = low.resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %21 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %22 = low.op<amdgpu.hal.buffer_descriptor>(%input_view) {cache_swizzle_stride = 0, valid_byte_count = 256} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  low.op<amdgpu.s_buffer_prefetch_data>(%22, %21) {count = 1, offset = 180} : (reg<amdgpu.sgpr x4>, reg<amdgpu.sgpr>)
  low.return
}
