// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_prefetch.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx12 output=low

func.def @prefetch_static(%input: buffer) {
  %base = index.constant 16 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[4] {intent = read, locality = l1} : view<64xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @prefetch_static() asm<amdgpu.gfx12.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 272} : reg<amdgpu.sgpr x4>
  %4 = s_mov_b32 0
  s_buffer_prefetch_data %input_view, %4 {offset = 32, count = 1}
  return
}

// ====

kernel.def @prefetch_workgroup_id(%input: buffer) {
  %gid = kernel.workgroup.id<x> : index
  %bounded_gid = index.assume %gid [range(%gid, 0, 1024)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[%bounded_gid] {intent = read, locality = l2} : view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @prefetch_workgroup_id() asm<amdgpu.gfx12.core> {
  %bounded_gid = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %7 = s_mov_b32 2
  %8 = s_lshl_b32 %bounded_gid, %7
  s_buffer_prefetch_data %input_view, %8 {count = 1}
  return
}

// ====

kernel.def workgroup_size(8, 4, 1) @prefetch_fixed_query_offset(%input: buffer) {
  %workgroup_size_x = kernel.workgroup.size<x> : index
  %workgroup_size_y = kernel.workgroup.size<y> : index
  %subgroup_size = kernel.subgroup.size : index
  %subgroup_count = kernel.subgroup.count : index
  %offset0 = index.add %workgroup_size_x, %workgroup_size_y : index
  %offset1 = index.add %offset0, %subgroup_size : index
  %offset = index.add %offset1, %subgroup_count : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  view.prefetch %input_view[%offset] {intent = read, locality = l1} : view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 1) @prefetch_fixed_query_offset() asm<amdgpu.gfx12.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %workgroup_size_x = s_mov_b32 8
  %workgroup_size_y = s_mov_b32 4
  %subgroup_size = s_mov_b32 32
  %subgroup_count = s_mov_b32 1
  %offset0 = s_add_u32 %workgroup_size_x, %workgroup_size_y
  %offset1 = s_add_u32 %offset0, %subgroup_size
  %offset = s_add_u32 %offset1, %subgroup_count
  %18 = s_mov_b32 0
  s_buffer_prefetch_data %input_view, %18 {offset = 180, count = 1}
  return
}
