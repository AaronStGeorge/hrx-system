amdgpu.target<gfx1200> @target
kernel.def target(@target) @prefetch_workgroup_id() {
  %unit = index.constant 1 : index
  %workgroups = index.constant 1025 : index
  kernel.launch.config workgroups(%workgroups, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch(%input: buffer) {
  %workgroup = kernel.workgroup.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1025xi32, #dense>
  // REMARK@+1: BACKEND/041 "selected prefetch 'read/l2'" "immediate offset 0" "dynamic index 'soffset'" "count 1"
  view.prefetch %input_view[%workgroup] {intent = read, locality = l2} : view<1025xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @prefetch_workgroup_id() asm<amdgpu.rdna4.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4100} : reg<amdgpu.sgpr x2>
  %8 = s_lshl_b32_rhs_inline %workgroup, 2
  %10 = slice %input_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %11 = slice %input_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %12 = s_mov_b32 65535
  %13 = s_and_b32 %11, %12
  %14 = concat(%10, %13) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %15 = s_mov_b32 4100
  %16 = s_mov_b32 822243328
  %17 = concat(%14, %15, %16) : (reg<amdgpu.sgpr x2>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x4>
  s_buffer_prefetch_data %17, %8 {count = 1}
  return
}

