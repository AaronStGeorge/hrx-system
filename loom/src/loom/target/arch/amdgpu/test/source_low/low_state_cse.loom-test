  %m0b = low.const<amdgpu.s_mov_b32_m0.imm> {imm32 = 0} : reg<amdgpu.m0>
  low.op<amdgpu.ds_write_addtid_b32>(%value1, %m0b) {offset = 4} : (reg<amdgpu.vgpr>, reg<amdgpu.m0>)
  low.return
