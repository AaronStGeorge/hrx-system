// RUN: pass low-select-operand-forms,low-dce

amdgpu.target<gfx1100> @target

low.func.def target(@target) @vop2_literal_add(%rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  %lhs = low.const<amdgpu.v_mov_b32> {imm32 = 7} : reg<amdgpu.vgpr>
  %result = low.op<amdgpu.v_add_u32>(%lhs, %rhs) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}

// ----
amdgpu.target<gfx1100> @target

low.func.def target(@target) @vop2_literal_add(%rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  %result = low.op<amdgpu.v_add_u32.lit>(%rhs) {imm32 = 7} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}

// ====

// RUN: pass low-select-operand-forms,low-dce

amdgpu.target<gfx1100> @target

low.func.def target(@target) @vop2_literal_shift(%value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  %shift = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %result = low.op<amdgpu.v_lshlrev_b32>(%shift, %value) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}

// ----
amdgpu.target<gfx1100> @target

low.func.def target(@target) @vop2_literal_shift(%value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  %result = low.op<amdgpu.v_lshlrev_b32.lit>(%value) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}
