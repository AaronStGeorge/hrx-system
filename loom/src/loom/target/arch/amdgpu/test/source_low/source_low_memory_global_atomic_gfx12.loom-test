// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_global_atomic.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1200> @target
kernel.def target(@target) @global_atomic_add_i32(%input: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  %old = view.atomic.rmw<addi> %one, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  kernel.return
}

// ----
low.kernel.def target(@target) @global_atomic_add_i32() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer} : reg<amdgpu.sgpr x4>
  %one = low.const<amdgpu.s_mov_b32> {imm32 = 1} : reg<amdgpu.sgpr>
  %10 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %11 = low.slice %view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %12 = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  low.op<amdgpu.global_atomic_add_u32_saddr>(%10, %12, %11) {offset = 0, scope = 2} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>)
  %13 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %14 = low.slice %view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %15 = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  %old = low.op<amdgpu.global_atomic_add_u32_rtn_saddr>(%13, %15, %14) {offset = 0, scope = 2} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>) -> reg<amdgpu.vgpr>
  low.return
}

