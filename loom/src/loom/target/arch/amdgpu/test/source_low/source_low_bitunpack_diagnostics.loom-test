// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @q3_width_rejected(%packed: vector<3xi8>) -> (vector<8xi32>) {
  // ERROR@+1: AMDGPU/023 {constraint_key="bitunpack.width_dword_divisor"}
  %unpacked = vector.bitunpacks<3> %packed : vector<3xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @bitunpack_lane_count_rejected(%packed: vector<16xi8>) -> (vector<32xi32>) {
  // ERROR@+1: AMDGPU/023 {constraint_key="bitunpack.lane_count"}
  %unpacked = vector.bitunpacku<4> %packed : vector<16xi8> -> vector<32xi32>
  func.return %unpacked : vector<32xi32>
}

