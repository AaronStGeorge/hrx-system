// RUN: emit source-low output=low sanitizer=access sanitizer-reporting=trap

amdgpu.target<gfx1100> @target

func.def target(@target) @sanitizer_repeated_dense_access_read(%input: buffer) {
  %base = index.constant 0 : offset
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %input_view = buffer.view %input_global[%base] : buffer -> view<2xi32, #dense>
  sanitizer.assert.accesses<read> %input_view[0] {static_count = 2, static_extents = [1], static_strides = [1]} : view<2xi32, #dense>
  func.return
}

