// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @sanitizer_aligned_granule_access_read(%input: buffer) {
  %base = index.constant 0 : offset
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %input_aligned = buffer.assume.alignment %input_global {minimum_alignment = 64} : buffer
  %input_view = buffer.view %input_aligned[%base] : buffer -> view<16xi32, #dense>
  sanitizer.assert.access<read> %input_view[0] {static_extents = [16]} : view<16xi32, #dense>
  func.return
}

// ----
