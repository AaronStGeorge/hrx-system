low.kernel.def target(@target) @async_gather_multi_packet_newer_group() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %source = low.resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %bytes = low.const<amdgpu.s_mov_b32> {imm32 = 3072} : reg<amdgpu.sgpr>
  %20 = low.storage.reserve {byte_alignment = 16, byte_length = 3072} : low.storage<workgroup>
  %dest1b = low.storage.address %20 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %22 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %23 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %24 = low.op<amdgpu.s_mov_b32_m0>(%23) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%22, %source, %24) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  %25 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %26 = low.const<amdgpu.s_mov_b32> {imm32 = 1024} : reg<amdgpu.sgpr>
  %27 = low.op<amdgpu.s_mov_b32_m0>(%26) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%25, %source, %27) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  %28 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %29 = low.const<amdgpu.s_mov_b32> {imm32 = 2048} : reg<amdgpu.sgpr>
  %30 = low.op<amdgpu.s_mov_b32_m0>(%29) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%28, %source, %30) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.op<amdgpu.s_waitcnt>() {lgkmcnt = 63, vmcnt = 2} : ()
  low.op<amdgpu.s_waitcnt>() {lgkmcnt = 63, vmcnt = 0} : ()
  low.return
}

