low.kernel.def target(@target) @async_gather_second_lds_slot() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %source = low.resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %pad_bytes = low.const<amdgpu.s_mov_b32> {imm32 = 256} : reg<amdgpu.sgpr>
  %scratch_bytes = low.const<amdgpu.s_mov_b32> {imm32 = 1024} : reg<amdgpu.sgpr>
  %17 = low.storage.reserve {byte_alignment = 16, byte_length = 256} : low.storage<workgroup>
  %pad = low.storage.address %17 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %19 = low.storage.reserve {byte_alignment = 16, byte_length = 1024} : low.storage<workgroup>
  %dest = low.storage.address %19 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %21 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %22 = low.const<amdgpu.s_mov_b32> {imm32 = 256} : reg<amdgpu.sgpr>
  %23 = low.op<amdgpu.s_mov_b32_m0>(%22) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%21, %source, %23) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.op<amdgpu.s_waitcnt>() {lgkmcnt = 63, vmcnt = 0} : ()
  low.return
}
