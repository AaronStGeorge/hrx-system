low.func.def target(@target) abi(hal_kernel) @i32_reduce_add() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %12 = v_mov_b32 0
  %loaded = global_load_b128 %12, %input_view
  %14 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %15 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = v_add_u32 %14, %15
  %17 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_add_u32 %16, %17
  %19 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_u32 %18, %19
  global_store_b32 %12, %stored, %output_view
  return
}

