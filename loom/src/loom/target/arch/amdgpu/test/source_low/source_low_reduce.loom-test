// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_reduce.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @i32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %init = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %loaded, %init : vector<4xi32>, i32
  %stored = vector.from_elements %sum : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) @i32_reduce_add() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %12 = v_mov_b32 0
  %13 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %12, %13 {offset = 0}
  %init = s_mov_b32 0
  %16 = v_mov_b32 0
  %17 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_add_u32 %16, %17
  %19 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_add_u32 %18, %19
  %21 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = v_add_u32 %20, %21
  %23 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_u32 %22, %23
  %25 = v_mov_b32 0
  %26 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %25, %stored, %26 {offset = 0}
  return
}

// ====

func.def @f32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %init = scalar.constant 0.0 : f32
  %sum = vector.reduce<addf> %loaded, %init : vector<4xf32>, f32
  %stored = vector.from_elements %sum : vector<1xf32>
  vector.store %stored, %output_view[0] : vector<1xf32>, view<1xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) @f32_reduce_add() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %12 = v_mov_b32 0
  %13 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %12, %13 {offset = 0}
  %init = v_mov_b32 0
  %16 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %17 = v_add_f32 %init, %16
  %18 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = v_add_f32 %17, %18
  %20 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %21 = v_add_f32 %19, %20
  %22 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_f32 %21, %22
  %24 = v_mov_b32 0
  %25 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %24, %stored, %25 {offset = 0}
  return
}
