  %18 = v_add_u32 %16, %17
  %19 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_u32 %18, %19
  global_store_b32_saddr %12, %stored, %output_view
  return
}

