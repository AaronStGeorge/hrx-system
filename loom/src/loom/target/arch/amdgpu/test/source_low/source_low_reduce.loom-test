// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_reduce.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %init = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %loaded, %init : vector<4xi32>, i32
  %stored = vector.from_elements %sum : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32_reduce_add() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %11 = v_mov_b32 0
  %loaded = global_load_b128 %11, %input_view
  %init = s_mov_b32 0
  %14 = v_mov_b32 0
  %15 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = v_add_u32 %14, %15
  %17 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_add_u32 %16, %17
  %19 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_add_u32 %18, %19
  %21 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_u32 %20, %21
  %23 = v_mov_b32 0
  global_store_b32 %23, %stored, %output_view
  return
}

