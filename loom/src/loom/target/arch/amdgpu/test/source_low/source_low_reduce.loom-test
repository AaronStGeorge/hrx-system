amdgpu.target<gfx1100> @target
func.def target(@target) @i32_reduce_minui_select_sentinel(%values: vector<4xi32>) -> (i32) {
  %zero = scalar.constant 0 : i32
  %zeros = vector.splat %zero : vector<4xi32>
  %is_zero = vector.cmpi eq, %values, %zeros : vector<4xi32> -> vector<4xi1>
  %start = scalar.constant 0 : i32
  %step = scalar.constant 1 : i32
  %indices = vector.iota %start step %step : vector<4xi32>
  %sentinel = scalar.constant 2147483647 : i32
  %sentinels = vector.splat %sentinel : vector<4xi32>
  %selected = vector.select %is_zero, %indices, %sentinels : vector<4xi32>
  %result = vector.reduce<minui> %selected, %sentinel : vector<4xi32>, i32
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32_reduce_minui_select_sentinel(%values: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %26 = slice %values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %27 = v_cmp_eq_i32_src1_inline %26 {rhs = 0}
  %28 = slice %values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %29 = v_cmp_eq_i32_src1_inline %28 {rhs = 0}
  %30 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %31 = v_cmp_eq_i32_src1_inline %30 {rhs = 0}
  %32 = slice %values[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %33 = v_cmp_eq_i32_src1_inline %32 {rhs = 0}
  %50 = v_cndmask_b32_src0_lit_src1_inline %27 {imm32 = 2147483647, true_value = 0}
  %52 = v_cndmask_b32_src0_lit_src1_inline %29 {imm32 = 2147483647, true_value = 1}
  %54 = v_cndmask_b32_src0_lit_src1_inline %31 {imm32 = 2147483647, true_value = 2}
  %56 = v_cndmask_b32_src0_lit_src1_inline %33 {imm32 = 2147483647, true_value = 3}
  %60 = v_min_u32 %50, %52
  %62 = v_min_u32 %60, %54
  %result = v_min_u32 %62, %56
  return %result
}
