low.func.def target(@target) abi(hal_kernel) @f32_reduce_add() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %11 = v_mov_b32 0
  %loaded = global_load_b128 %11, %input_view
  %init = v_mov_b32 0
  %14 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %15 = v_add_f32 %init, %14
  %16 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %17 = v_add_f32 %15, %16
  %18 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = v_add_f32 %17, %18
  %20 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = v_add_f32 %19, %20
  %22 = v_mov_b32 0
  global_store_b32 %22, %stored, %output_view
  return
}
