// RUN: emit source-low diagnostics=memory output=low

amdgpu.target<gfx1100> @target

kernel.def target(@target) @static_lds_bank_pattern_unknown() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch() {
  %zero = index.constant 0 : offset
  %bytes = index.constant 4 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<1xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  // REMARK@+1: BACKEND/017 {memory_space="workgroup", operation_kind="store", packet_key="amdgpu.ds_write_b32", dynamic_stride_bytes="0", vector_lane_stride_bytes="4", bank_stride_words="0", bank_conflict_degree="0", bank_conflict_kind="bank-pattern-unknown"}
  vector.store %one, %scratch_view[0] : vector<1xi32>, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @static_lds_bank_pattern_unknown() asm<amdgpu.rdna3.core> {
  %6 = storage {byte_alignment = 4, byte_length = 4} : low.storage<workgroup>
  %one = v_mov_b32 1
  %9 = v_mov_b32 0
  ds_write_b32 %9, %one
  return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) @global_memory_diagnostics_stay_silent() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch(%output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @global_memory_diagnostics_stay_silent() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %one = v_mov_b32 1
  %10 = v_lshlrev_b32_src0_inline %tid, 2
  global_store_b32_saddr %10, %one, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) @multi_term_lds_bank_pattern_unknown() {
  %c1 = index.constant 1 : index
  %c4 = index.constant 4 : index
  %c8 = index.constant 8 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c8, %c4, %c1) : index
} launch() {
  %lane_x = kernel.workitem.id<x> : index
  %lane_y = kernel.workitem.id<y> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 128 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<8x4xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  // REMARK@+1: BACKEND/017 {memory_space="workgroup", operation_kind="store", packet_key="amdgpu.ds_write_b32", dynamic_stride_bytes="0", vector_lane_stride_bytes="4", bank_stride_words="0", bank_conflict_degree="0", bank_conflict_kind="bank-pattern-unknown"}
  vector.store %one, %scratch_view[%lane_x, %lane_y] : vector<1xi32>, view<8x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 1) @multi_term_lds_bank_pattern_unknown() asm<amdgpu.rdna3.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %lane_x = v_and_b32_lit %packed_tid, 1023
  %12 = v_lshrrev_b32_src0_inline %packed_tid, 10
  %lane_y = v_and_b32_lit %12, 1023
  %14 = storage {byte_alignment = 16, byte_length = 128} : low.storage<workgroup>
  %one = v_mov_b32 1
  %17 = v_lshlrev_b32_src0_inline %lane_x, 4
  %18 = v_lshlrev_b32_src0_inline %lane_y, 2
  %19 = v_add_u32 %17, %18
  ds_write_b32 %19, %one
  return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) @lds_read2_write2_structured_bank_fields() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch(%output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 2048 : offset
  %layout = encoding.layout.strided [8, 2] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, %layout>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x2xi32, #dense>
  %one = vector.constant 1 : vector<2xi32>
  // REMARK@+1: BACKEND/017 {memory_space="workgroup", operation_kind="store", packet_key="amdgpu.ds_write2_b32", dynamic_stride_bytes="32", vector_lane_stride_bytes="8", bank_stride_words="8", bank_conflict_degree="8", bank_conflict_kind="bank-conflict-risk"}
  vector.store %one, %scratch_view[%tid, 0] : vector<2xi32>, view<64x4xi32, %layout>
  // REMARK@+1: BACKEND/017 {memory_space="workgroup", operation_kind="load", packet_key="amdgpu.ds_read2_b32", dynamic_stride_bytes="32", vector_lane_stride_bytes="8", bank_stride_words="8", bank_conflict_degree="8", bank_conflict_kind="bank-conflict-risk"}
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x4xi32, %layout> -> vector<2xi32>
  vector.store %loaded, %output_view[%tid, 0] : vector<2xi32>, view<64x2xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @lds_read2_write2_structured_bank_fields() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %14 = storage {byte_alignment = 16, byte_length = 2048} : low.storage<workgroup>
  %16 = v_mov_b32 1
  %19 = v_lshlrev_b32_src0_inline %tid, 5
  ds_write2_b32 %19, %16, %16 {offset1 = 2}
  %loaded = ds_read2_b32 %19 {offset1 = 2}
  %24 = v_lshlrev_b32_src0_inline %tid, 3
  global_store_b64_saddr %24, %loaded, %output_view
  return
}
