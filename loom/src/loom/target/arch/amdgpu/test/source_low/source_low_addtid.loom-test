// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_indexed.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @workgroup_memory_workitem_x_b32() {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %scratch_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  %loaded = vector.load %scratch_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %scratch_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @workgroup_memory_workitem_x_b32() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %bytes = low.const<amdgpu.s_mov_b32> {imm32 = 256} : reg<amdgpu.sgpr>
  %10 = low.storage.reserve {byte_alignment = 16, byte_length = 256} : low.storage<workgroup>
  %scratch_view = low.storage.address %10 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %one = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %14 = low.op<amdgpu.s_mov_b32_m0>(%13) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.ds_write_addtid_b32>(%one, %14) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.m0>)
  %15 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %16 = low.op<amdgpu.s_mov_b32_m0>(%15) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  %loaded = low.op<amdgpu.ds_read_addtid_b32>(%16) {offset = 0} : (reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %18 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %19 = low.op<amdgpu.s_mov_b32_m0>(%18) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.ds_write_addtid_b32>(%loaded, %19) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.m0>)
  low.return
}
