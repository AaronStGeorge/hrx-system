  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %14 = storage {byte_alignment = 16, byte_length = 128} : low.storage<workgroup>
  %initial = v_mov_b32 0
  %replacement = v_mov_b32 1
  %18 = s_mov_b32_m0_imm 0
  ds_write_addtid_b32 %initial, %18
  %inside = v_cmp_lt_u32_src1_inline %lane {rhs = 16}
  %20, %21 = s_and_saveexec_b64 %inside
  low.cond_br %21, ^_bb1, ^_bb3 : reg<amdgpu.scc>
^_bb1:
  %22 = s_mov_b32_m0_imm 0
  ds_write_addtid_b32 %replacement, %22
  low.br ^_bb3
^_bb2:
  %23 = s_mov_b32_m0_imm 0
  %loaded = ds_read_addtid_b32 %23
  %25 = s_mov_b32_m0_imm 0
  ds_write_addtid_b32 %loaded, %25
  return
^_bb3:
  s_mov_b64_exec %20
  low.br ^_bb2
}

