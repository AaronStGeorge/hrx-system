  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %10 = storage {byte_alignment = 16, byte_length = 256} : low.storage<workgroup>
  %one = v_mov_b32 1
  %13 = v_lshlrev_b32_src0_inline %lane, 2
  ds_write_b32 %13, %one
  %loaded = ds_read_b32 %13
  ds_write_b32 %13, %loaded
  return
}

