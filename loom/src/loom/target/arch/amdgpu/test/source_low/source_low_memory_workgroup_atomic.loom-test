  %19 = v_mov_b32 255
  ds_or_b32 %18, %19
  %20 = v_lshlrev_b32_lit %tid, 2
  %21 = v_add_u32 %scratch_view, %20
  %22 = v_mov_b32 255
  ds_xor_b32 %21, %22
  %23 = v_lshlrev_b32_lit %tid, 2
  %24 = v_add_u32 %scratch_view, %23
  %25 = v_mov_b32 255
  %old_and = ds_and_rtn_b32 %24, %25
  %27 = v_lshlrev_b32_lit %tid, 2
  %28 = v_add_u32 %scratch_view, %27
  %29 = v_mov_b32 255
  %old_or = ds_or_rtn_b32 %28, %29
  %31 = v_lshlrev_b32_lit %tid, 2
  %32 = v_add_u32 %scratch_view, %31
  %33 = v_mov_b32 255
