  %bytes = s_mov_b32 256
  %11 = storage {byte_alignment = 4, byte_length = 256} : low.storage<workgroup>
  %scratch_view = storage_address %11 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %mask = s_mov_b32 255
  %14 = v_lshlrev_b32_lit %tid, 2
  %15 = v_add_u32 %scratch_view, %14
  %16 = v_mov_b32 255
  ds_and_b32 %15, %16
