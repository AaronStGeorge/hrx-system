kernel.def @lds_atomic_add_i32() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  view.atomic.reduce<addi> %one, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense>
  %old = view.atomic.rmw<addi> %one, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : i32, view<64xi32, #dense> -> i32
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_atomic_add_i32() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 256
  %10 = storage {byte_alignment = 4, byte_length = 256} : low.storage<workgroup>
  %scratch_view = storage_address %10 {offset = 0} : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %one = s_mov_b32 1
  %13 = v_lshlrev_b32_lit %tid, 2
  %14 = v_add_u32 %scratch_view, %13
  %15 = v_mov_b32 1
  ds_add_u32 %14, %15 {offset = 0}
  %16 = v_lshlrev_b32_lit %tid, 2
  %17 = v_add_u32 %scratch_view, %16
  %18 = v_mov_b32 1
  %old = ds_add_rtn_u32 %17, %18 {offset = 0}
  return
}

