low.func.def target(@target) abi(hal_kernel) @i32x8_to_i4x8_bitpack(%codes: reg<amdgpu.vgpr x8>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %5 = slice %codes[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %6 = v_and_b32_src0_inline %5, 15
  %7 = slice %codes[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %8 = v_and_b32_src0_inline %7, 15
  %9 = v_lshl_add_u32_shift_imm %8, %6, 4
