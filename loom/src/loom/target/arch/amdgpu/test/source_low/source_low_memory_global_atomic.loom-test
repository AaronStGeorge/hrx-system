  %16 = low.const<amdgpu.v_mov_b32> {imm32 = 0} : reg<amdgpu.vgpr>
  %17 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %18 = low.op<amdgpu.hal.buffer_descriptor>(%view) {cache_swizzle_stride = 0, valid_byte_count = 4294967295} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
