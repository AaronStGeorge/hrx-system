  view.atomic.reduce<ori> %mask, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  view.atomic.reduce<xori> %mask, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  %old_and = view.atomic.rmw<andi> %mask, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  %old_or = view.atomic.rmw<ori> %mask, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  %old_xor = view.atomic.rmw<xori> %mask, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  kernel.return
}

