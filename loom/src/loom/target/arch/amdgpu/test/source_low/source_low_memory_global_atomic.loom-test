  view.atomic.reduce<minui> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  view.atomic.reduce<maxui> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  %old_minsi = view.atomic.rmw<minsi> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  %old_maxsi = view.atomic.rmw<maxsi> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  %old_minui = view.atomic.rmw<minui> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  %old_maxui = view.atomic.rmw<maxui> %limit, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense> -> i32
  kernel.return
}

