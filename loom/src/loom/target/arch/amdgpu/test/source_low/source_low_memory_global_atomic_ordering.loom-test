// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_global_atomic_ordering.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @global_atomic_release_reduce_i32() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch(%input: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space<global> %input : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = release, scope = device} : i32, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @global_atomic_release_reduce_i32() asm<amdgpu.rdna3.core> {
  %view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %11 = v_mov_b32 0
  %12 = s_mov_b32 0
  %15 = slice %view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %16 = slice %view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %17 = s_mov_b32 65535
  %18 = s_and_b32 %16, %17
  %19 = concat(%15, %18) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %20 = s_mov_b32 256
  %21 = s_mov_b32 822243328
  %22 = concat(%19, %20, %21) : (reg<amdgpu.sgpr x2>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x4>
  s_waitcnt {vmcnt = 0, lgkmcnt = 15}
  s_waitcnt_vscnt {vscnt = 0}
  %14 = v_mov_b32 1
  buffer_atomic_add_u32 %14, %22, %11, %12
  return
}

