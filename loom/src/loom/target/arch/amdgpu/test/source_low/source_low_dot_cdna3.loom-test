func.def target(@target) @bf16_score_gather_dot2(%query: vector<2xbf16>, %key_cache: buffer, %token_offset0: index, %acc: vector<1xf32>) -> (vector<1xf32>) {
  %base = index.constant 0 : offset
  %start = index.constant 0 : index
  %step = index.constant 7 : index
  %token_offset = index.assume %token_offset0 [range(%token_offset0, 0, 4088)] : index
  %key_cache_view = buffer.view %key_cache[%base] : buffer -> view<4096xbf16, #dense>
  %offsets = vector.iota %start step %step : vector<2xindex>
  %key_pair = vector.gather %key_cache_view[%token_offset][%offsets] : view<4096xbf16, #dense>, vector<2xindex> -> vector<2xbf16>
  %score = vector.dot2f %query, %key_pair, %acc : vector<2xbf16>, vector<2xbf16>, vector<1xf32>
  func.return %score : vector<1xf32>
}

