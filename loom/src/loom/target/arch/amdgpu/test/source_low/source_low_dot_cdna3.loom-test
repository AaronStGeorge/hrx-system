low.func.def target(@target) abi(hal_kernel) @bf16_dot2f_wide(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x2>, %acc: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.cdna3.core> {
  %9 = slice %lhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %10 = v_lshlrev_b32_lit %9, 16
  %11 = slice %lhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %12 = v_lshlrev_b32_lit %11, 16
  %14 = slice %rhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = v_lshlrev_b32_lit %14, 16
  %16 = slice %rhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_lshlrev_b32_lit %16, 16
  %20 = v_and_b32_lit %9, 4294901760
  %22 = v_and_b32_lit %11, 4294901760
  %25 = v_and_b32_lit %14, 4294901760
  %27 = v_and_b32_lit %16, 4294901760
  %31 = slice %acc[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %32 = v_fma_f32 %10, %15, %31
  %35 = slice %acc[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %36 = v_fma_f32 %12, %17, %35
  %41 = v_fma_f32 %20, %25, %32
  %45 = v_fma_f32 %22, %27, %36
  %dot = concat(%41, %45) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %dot
}

