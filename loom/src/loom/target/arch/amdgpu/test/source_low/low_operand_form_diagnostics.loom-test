  // REMARK@+1: BACKEND/042 {source_descriptor_key="amdgpu.s_add_u32", replacement_descriptor_key="amdgpu.s_add_u32.rhs_inline", decision="selected", reason_key="selected", immediate_name="imm32", immediate_value="3", tied_operand_name="<none>", tied_value_name="<none>"}
