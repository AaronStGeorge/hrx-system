amdgpu.target<gfx1100> @target
func.def target(@target) @i8x4_addi_chain(%packed: vector<1xi32>, %bias: vector<4xi8>, %delta: vector<4xi8>) -> (vector<4xi8>) {
  %bytes = vector.bitcast %packed : vector<1xi32> to vector<4xi8>
  %biased = vector.addi %bytes, %bias : vector<4xi8>
  %result = vector.addi %biased, %delta : vector<4xi8>
  func.return %result : vector<4xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_addi_chain(%bytes: reg<amdgpu.vgpr>, %bias: reg<amdgpu.vgpr>, %delta: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %11 = v_and_b32_lit %bytes, 2139062143
  %12 = v_and_b32_lit %bias, 2139062143
  %13 = v_add_u32 %11, %12
  %14 = v_xor_b32 %bytes, %bias
  %15 = v_and_b32_lit %14, 2155905152
  %biased = v_xor_b32 %13, %15
  %17 = v_and_b32_lit %biased, 2139062143
  %18 = v_and_b32_lit %delta, 2139062143
  %19 = v_add_u32 %17, %18
  %20 = v_xor_b32 %biased, %delta
  %21 = v_and_b32_lit %20, 2155905152
  %result = v_xor_b32 %19, %21
  return %result
}

