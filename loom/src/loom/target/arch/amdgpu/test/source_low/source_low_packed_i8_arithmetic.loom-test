amdgpu.target<gfx1100> @target
func.def target(@target) @i8x4_addi_arguments(%lhs: vector<4xi8>, %rhs: vector<4xi8>) -> (vector<4xi8>) {
  %sum = vector.addi %lhs, %rhs : vector<4xi8>
  func.return %sum : vector<4xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_addi_arguments(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %7 = v_and_b32_lit %lhs, 2139062143
  %8 = v_and_b32_lit %rhs, 2139062143
  %9 = v_add_u32 %7, %8
  %10 = v_xor_b32 %lhs, %rhs
  %11 = v_and_b32_lit %10, 2155905152
  %sum = v_xor_b32 %9, %11
  return %sum
}

