amdgpu.target<gfx1100> @target
func.def target(@target) @i8x4_cfg_arg_addi(%lhs: i32, %rhs: i32, %true_value: vector<4xi8>, %false_value: vector<4xi8>, %bias: vector<4xi8>) -> (vector<4xi8>) {
  %condition = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %condition, ^then, ^else
^then:
  cfg.br ^join(%true_value: vector<4xi8>)
^else:
  cfg.br ^join(%false_value: vector<4xi8>)
^join(%selected: vector<4xi8>):
  %result = vector.addi %selected, %bias : vector<4xi8>
  func.return %result : vector<4xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_cfg_arg_addi(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %true_value: reg<amdgpu.vgpr>, %false_value: reg<amdgpu.vgpr>, %bias: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %condition = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %condition, ^then, ^else : reg<amdgpu.scc>
^then:
  low.br ^join(%true_value: reg<amdgpu.vgpr>)
^else:
  low.br ^join(%false_value: reg<amdgpu.vgpr>)
^join(%selected: reg<amdgpu.vgpr>):
  %17 = v_and_b32_lit %selected, 2139062143
  %18 = v_and_b32_lit %bias, 2139062143
  %19 = v_add_u32 %17, %18
  %20 = v_xor_b32 %selected, %bias
  %21 = v_and_b32_lit %20, 2155905152
  %result = v_xor_b32 %19, %21
  return %result
}
