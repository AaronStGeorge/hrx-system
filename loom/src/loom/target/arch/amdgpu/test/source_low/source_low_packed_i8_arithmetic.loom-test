amdgpu.target<gfx1100> @target
func.def target(@target) @i8x4_scf_if_addi(%lhs: i32, %rhs: i32, %true_value: vector<4xi8>, %false_value: vector<4xi8>, %bias: vector<4xi8>) -> (vector<4xi8>) {
  %condition = scalar.cmpi slt, %lhs, %rhs : i32
  %selected = scf.if %condition -> (vector<4xi8>) {
    scf.yield %true_value : vector<4xi8>
  } else {
    scf.yield %false_value : vector<4xi8>
  }
  %result = vector.addi %selected, %bias : vector<4xi8>
  func.return %result : vector<4xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_scf_if_addi(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %true_value: reg<amdgpu.vgpr>, %false_value: reg<amdgpu.vgpr>, %bias: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %16 = v_mov_b32_copy %lhs
  %17 = v_mov_b32_copy %rhs
  %condition = v_cmp_lt_i32 %16, %17
  %selected = v_cndmask_b32 %false_value, %true_value, %condition
  %20 = v_and_b32_lit %selected, 2139062143
  %21 = v_and_b32_lit %bias, 2139062143
  %22 = v_add_u32 %20, %21
  %23 = v_xor_b32 %selected, %bias
  %24 = v_and_b32_lit %23, 2155905152
  %result = v_xor_b32 %22, %24
  return %result
}

