  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %20 = v_lshlrev_b32_lit %tid, 2
  %value = global_load_b32 %20, %input_view
  %23 = v_mov_b32 28
  %result = ds_bpermute_b32 %23, %value
  global_store_b32 %20, %result, %output_view
  return
}

