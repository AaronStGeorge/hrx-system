  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %15 = v_lshlrev_b32_lit %tid, 2
  %16 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %value = global_load_b32 %15, %16
  %lane = s_mov_b32 7
  %19 = v_mov_b32 28
  %result = ds_bpermute_b32 %19, %value
  %21 = v_lshlrev_b32_lit %tid, 2
  %22 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %21, %result, %22
  return
}

