  %result = low.op<amdgpu.ds_bpermute_b32>(%30, %value) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %32 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %33 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %34 = low.op<amdgpu.s_mov_b32_m0>(%33) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_store_b32_saddr>(%32, %result, %output_view, %34) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.return
}
