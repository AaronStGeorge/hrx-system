  %zero = s_mov_b32 0
  %16 = v_lshlrev_b32_lit %tid, 4
  %17 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %16, %17
  %offset = s_mov_b32 4
  %width = s_mov_b32 32
  %21 = v_and_b32_lit %tid, 31
  %22 = v_mov_b32 4
  %23 = v_add_u32 %21, %22
  %24 = v_mov_b32 32
  %valid = v_cmp_lt_u32 %23, %24
  %26 = v_lshlrev_b32_lit %23, 2
  %27 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %28 = ds_bpermute_b32 %26, %27
  %29 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %30 = ds_bpermute_b32 %26, %29
  %31 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = ds_bpermute_b32 %26, %31
  %33 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = ds_bpermute_b32 %26, %33
  %shuffle = concat(%28, %30, %32, %34) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %36 = v_lshlrev_b32_lit %tid, 4
  %37 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
