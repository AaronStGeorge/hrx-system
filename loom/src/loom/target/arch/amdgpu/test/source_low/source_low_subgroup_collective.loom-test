  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %21 = v_lshlrev_b32_src0_inline %tid, 2
  %22 = s_mov_b32_m0_imm 0
  %value = global_load_dword_saddr %21, %input_view, %22
  %25 = v_mov_b32 252
  %result = ds_bpermute_b32 %25, %value
  global_store_dword_saddr %21, %result, %output_view, %22
  return
}

