low.kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_broadcast_i32_wave32() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %15 = v_lshlrev_b32_lit %tid, 2
  %value = global_load_b32 %15, %input_view
  %lane = s_mov_b32 7
  %18 = v_mov_b32 28
  %result = ds_bpermute_b32 %18, %value
  %20 = v_lshlrev_b32_lit %tid, 2
  global_store_b32 %20, %result, %output_view
  return
}

