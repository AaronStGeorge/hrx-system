// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @race_access_global_rejected(%input: buffer) {
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space<global> %input : buffer
  %view = buffer.view %global[%zero] : buffer -> view<1xi32, #dense>
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.workgroup_memory_required"}
  sanitizer.race.access<read> %view[0] : view<1xi32, #dense>
  func.return
}

// ====

amdgpu.target<gfx1100> @target
kernel.def target(@target) @race_access_workgroup_requires_runtime_config() {
  %one = index.constant 1 : index
  %workgroup_size = index.constant 64 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%workgroup_size, %one, %one) : index
} launch() {
  %lane = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.runtime_config_required"}
  sanitizer.race.access<write> %view[%lane] : view<64xi32, #dense>
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target
kernel.def target(@target) @race_access_atomic_rejected() {
  %one = index.constant 1 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%one, %one, %one) : index
} launch() {
  %zero = index.constant 0 : offset
  %bytes = index.constant 4 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %view = buffer.view %scratch[%zero] : buffer -> view<1xi32, #dense>
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.atomic_access_unsupported"}
  sanitizer.race.access<read_write> %view[0] {atomic = true, ordering = acq_rel, scope = workgroup} : view<1xi32, #dense>
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @race_sync_requires_runtime_config() {
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.runtime_config_required"}
  sanitizer.race.sync<workgroup> {ordering = acq_rel, scope = workgroup}
  func.return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @race_sync_global_rejected() {
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.workgroup_memory_required"}
  sanitizer.race.sync<global> {ordering = acq_rel, scope = workgroup}
  func.return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @race_sync_device_scope_rejected() {
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.workgroup_scope_required"}
  sanitizer.race.sync<workgroup> {ordering = acq_rel, scope = device}
  func.return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @race_sync_acquire_rejected() {
  // ERROR@+1: AMDGPU/023 {constraint_key="target_contract.sanitizer_race.acq_rel_sync_required"}
  sanitizer.race.sync<workgroup> {ordering = acquire, scope = workgroup}
  func.return
}
