  %42 = slice %41[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %43 = slice %41[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %44 = v_readfirstlane_b32 %42
  %45 = v_readfirstlane_b32 %43
