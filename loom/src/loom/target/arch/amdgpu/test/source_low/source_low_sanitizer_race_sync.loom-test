  %19 = v_mov_b32 0
  %20 = global_load_b64_saddr %19, %12 {offset = 16, glc = 1, dlc = 1}
  %21 = slice %20[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %22 = slice %20[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
