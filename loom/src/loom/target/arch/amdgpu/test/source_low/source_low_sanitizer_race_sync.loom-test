  %50 = slice %48[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %51 = v_readfirstlane_b32 %49
  %52 = v_readfirstlane_b32 %50
  %54 = v_mov_b32 0
  %55 = global_load_b64_saddr %54, %12 {offset = 88, glc = 1, dlc = 1}
  %56 = slice %55[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %57 = slice %55[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %58 = v_readfirstlane_b32 %56
  %59 = v_readfirstlane_b32 %57
  %60 = concat(%58, %59) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %61 = s_load_dword_offset_only %5 {offset = 12}
  %62 = s_mov_b32 6
  %63 = s_lshr_b32 %61, %62
  %64 = s_load_dword_offset_only %5 {offset = 16}
  %65 = s_mul_i32 %3, %63
