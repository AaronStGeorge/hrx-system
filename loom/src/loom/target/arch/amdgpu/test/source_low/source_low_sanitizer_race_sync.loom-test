low.kernel.def target(@target) workgroup_size(64, 1, 1) @race_sync_workgroup_barrier() asm<amdgpu.rdna3.core> {
  %2 = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
