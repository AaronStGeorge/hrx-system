// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @bitpack_width_rejected(%codes: vector<8xi32>) -> (vector<4xi8>) {
  // ERROR@+1: AMDGPU/023 {constraint_key="bitpack.width"}
  %packed = vector.bitpack<4> %codes : vector<8xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @bitpack_source_type_rejected(%codes: vector<4xi8>) -> (vector<4xi8>) {
  // ERROR@+1: AMDGPU/023 {constraint_key="bitpack.source_type"}
  %packed = vector.bitpack<8> %codes : vector<4xi8> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}
