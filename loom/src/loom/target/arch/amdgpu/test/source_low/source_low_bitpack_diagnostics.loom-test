// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @bitpack_width_rejected(%codes: vector<2xi32>) -> (vector<4xi8>) {
  // ERROR@+1: AMDGPU/040 {recipe_key="amdgpu.bitstream.pack_i8_from_i32", constraint_key="width"}
  %packed = vector.bitpack<16> %codes : vector<2xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

