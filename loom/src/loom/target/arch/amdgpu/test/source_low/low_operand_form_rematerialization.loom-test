// RUN: pass cse,low-select-operand-forms,low-dce

amdgpu.target<gfx1100> @target

low.func.def target(@target) @vop3_literal_rematerializes_remaining_constant(%factor: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) {
  %addend = low.const<amdgpu.v_mov_b32> {imm32 = 5} : reg<amdgpu.vgpr>
  %kept = low.op<amdgpu.v_mov_b32_copy>(%addend) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %literal = low.const<amdgpu.v_mov_b32> {imm32 = 9} : reg<amdgpu.vgpr>
  %result = low.op<amdgpu.v_mad_u32_u24>(%factor, %literal, %addend) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %kept, %result : reg<amdgpu.vgpr>, reg<amdgpu.vgpr>
}

