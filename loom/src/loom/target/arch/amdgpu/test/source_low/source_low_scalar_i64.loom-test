  %ule_result = v_cndmask_b32 %false_value, %true_value, %ule
  %ugt_result = v_cndmask_b32 %false_value, %true_value, %ugt
  %uge_result = v_cndmask_b32 %false_value, %true_value, %uge
  return %eq_result, %ne_result, %slt_result, %sle_result, %sgt_result, %sge_result, %ult_result, %ule_result, %ugt_result, %uge_result
}
