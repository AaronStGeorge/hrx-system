amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_i64_compare_constant_select(%lhs: i64, %true_value: f32, %false_value: f32) -> (f32) {
  %limit = scalar.constant 4294967296 : i64
  %cmp = scalar.cmpi ult, %lhs, %limit : i64
  %result = scf.select %cmp, %true_value, %false_value : f32
  func.return %result : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_i64_compare_constant_select(%lhs: reg<amdgpu.sgpr x2>, %true_value: reg<amdgpu.vgpr>, %false_value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %11 = s_mov_b32 0
  %12 = s_mov_b32 1
  %14 = slice %lhs[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %15 = v_mov_b32_copy %14
  %16 = slice %lhs[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %17 = v_mov_b32_copy %16
  %19 = v_mov_b32_copy %11
  %21 = v_mov_b32_copy %12
  %22 = v_cmp_lt_u32 %17, %21
  %23 = v_cmp_lt_u32 %15, %19
  %24 = v_cmp_eq_i32 %17, %21
  %25 = s_and_b64 %24, %23
  %cmp = s_or_b64 %22, %25
  %result = v_cndmask_b32 %false_value, %true_value, %cmp
  return %result
}

