amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_i64_bitwise_sgpr(%lhs: i64, %rhs: i64) -> (i64, i64, i64) {
  %and = scalar.andi %lhs, %rhs : i64
  %or = scalar.ori %and, %lhs : i64
  %xor = scalar.xori %or, %rhs : i64
  func.return %and, %or, %xor : i64, i64, i64
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_i64_bitwise_sgpr(%lhs: reg<amdgpu.sgpr x2>, %rhs: reg<amdgpu.sgpr x2>) -> (reg<amdgpu.sgpr x2>, reg<amdgpu.sgpr x2>, reg<amdgpu.sgpr x2>) asm<amdgpu.rdna3.core> {
  %and = s_and_b64 %lhs, %rhs
  %or = s_or_b64 %and, %lhs
  %xor = s_xor_b64 %or, %rhs
  return %and, %or, %xor
}

