// ----
low.func.def target(@target) abi(hal_kernel) @scalar_i64_compare_slt_return(%lhs: reg<amdgpu.sgpr x2>, %rhs: reg<amdgpu.sgpr x2>) -> (reg<amdgpu.sgpr x2>) asm<amdgpu.rdna3.core> {
  %7 = slice %lhs[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %8 = v_mov_b32_copy %7
  %9 = slice %lhs[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %10 = v_mov_b32_copy %9
  %11 = slice %rhs[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %12 = v_mov_b32_copy %11
  %13 = slice %rhs[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %14 = v_mov_b32_copy %13
  %15 = v_cmp_lt_i32 %10, %14
  %16 = v_cmp_lt_u32 %8, %12
  %17 = v_cmp_eq_i32 %10, %14
  %18 = s_and_b64 %17, %16
  %cmp = s_or_b64 %15, %18
  return %cmp
}

