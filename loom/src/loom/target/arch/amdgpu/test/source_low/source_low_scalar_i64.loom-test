amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_i64_compare_slt_if(%lhs: i64, %rhs: i64, %then_value: i32, %else_value: i32) -> (i32) {
  %cmp = scalar.cmpi slt, %lhs, %rhs : i64
  %result = scf.if %cmp -> (i32) {
    scf.yield %then_value : i32
  } else {
    scf.yield %else_value : i32
  }
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_i64_compare_slt_if(%lhs: reg<amdgpu.sgpr x2>, %rhs: reg<amdgpu.sgpr x2>, %then_value: reg<amdgpu.sgpr>, %else_value: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %13 = slice %lhs[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %14 = v_mov_b32_copy %13
  %15 = slice %lhs[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %16 = v_mov_b32_copy %15
  %17 = slice %rhs[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %18 = v_mov_b32_copy %17
  %19 = slice %rhs[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %20 = v_mov_b32_copy %19
  %21 = v_cmp_lt_i32 %16, %20
  %22 = v_cmp_lt_u32 %14, %18
  %23 = v_cmp_eq_i32 %16, %20
  %24 = s_and_b64 %23, %22
  %cmp = s_or_b64 %21, %24
  %26 = v_mov_b32_copy %then_value
  %27 = v_mov_b32_copy %else_value
  %result = v_cndmask_b32 %27, %26, %cmp
  return %result
}

