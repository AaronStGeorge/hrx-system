  %51 = slice %lhs_values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %53 = slice %rhs_values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %54 = slice %rhs_values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %60 = v_cmp_eq_i32 %51, %54
  %61 = v_cmp_eq_i32 %50, %53
  %eq = s_and_b64 %60, %61
  %67 = v_cmp_ne_i32 %51, %54
  %68 = v_cmp_ne_i32 %50, %53
  %ne = s_or_b64 %67, %68
  %74 = v_cmp_lt_i32 %51, %54
  %75 = v_cmp_lt_u32 %50, %53
  %77 = s_and_b64 %60, %75
  %slt = s_or_b64 %74, %77
  %84 = v_cmp_le_u32 %50, %53
  %86 = s_and_b64 %60, %84
  %sle = s_or_b64 %74, %86
  %92 = v_cmp_gt_i32 %51, %54
  %93 = v_cmp_gt_u32 %50, %53
  %95 = s_and_b64 %60, %93
  %sgt = s_or_b64 %92, %95
  %102 = v_cmp_ge_u32 %50, %53
  %104 = s_and_b64 %60, %102
  %sge = s_or_b64 %92, %104
  %110 = v_cmp_lt_u32 %51, %54
  %ult = s_or_b64 %110, %77
  %ule = s_or_b64 %110, %86
  %128 = v_cmp_gt_u32 %51, %54
  %ugt = s_or_b64 %128, %95
  %uge = s_or_b64 %128, %104
  %eq_result = v_cndmask_b32 %false_value, %true_value, %eq
  %ne_result = v_cndmask_b32 %false_value, %true_value, %ne
  %slt_result = v_cndmask_b32 %false_value, %true_value, %slt
  %sle_result = v_cndmask_b32 %false_value, %true_value, %sle
