  %10 = slice %lhs_values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %12 = slice %rhs_values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %13 = slice %rhs_values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19, %20 = v_add_co_u32 %9, %12
  %21, %22 = v_add_co_ci_u32 %10, %13, %20
  %sum = concat(%19, %21) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
