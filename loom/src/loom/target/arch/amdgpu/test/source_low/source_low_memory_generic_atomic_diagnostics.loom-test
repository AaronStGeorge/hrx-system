// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @unknown_atomic_is_not_flat(%input: buffer) {
  %zero = index.constant 0 : offset
  %view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %one = scalar.constant 1 : i32
  // ERROR@+1: AMDGPU/023 {constraint_key="atomic.memory_space"}
  view.atomic.reduce<addi> %one, %view[0] {ordering = relaxed, scope = device} : i32, view<1xi32, #dense>
  func.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) @generic_dynamic_atomic_rejected(%input: buffer) {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %generic = buffer.assume.memory_space<generic> %input : buffer
  %view = buffer.view %generic[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  // ERROR@+1: AMDGPU/020 {op_name="view.atomic.reduce", operation_kind="atomic_reduce", memory_space="generic", dynamic_term_index="0", byte_stride="4"}
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = relaxed, scope = device} : i32, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @generic_dynamic_atomic_rejected() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %view = low.resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %one = low.const<amdgpu.s_mov_b32> {imm32 = 1} : reg<amdgpu.sgpr>
  %11 = low.slice %view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %12 = low.slice %view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %13 = low.op<amdgpu.v_mov_b32_copy>(%11) : (reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr>
  %14 = low.op<amdgpu.v_mov_b32_copy>(%12) : (reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr>
  %15 = low.concat(%13, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %16 = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  low.op<amdgpu.flat_atomic_add_u32>(%15, %16) {offset = 0} : (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr>)
  low.return
}
