// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_i32_memory.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @i32_bitwise(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %loaded = vector.load %input_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  %mask = vector.constant 15 : vector<1xi32>
  %masked = vector.andi %loaded, %mask : vector<1xi32>
  %tag = vector.constant 240 : vector<1xi32>
  %with_tag = vector.ori %masked, %tag : vector<1xi32>
  %result = vector.xori %with_tag, %loaded : vector<1xi32>
  vector.store %result, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_bitwise() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %16 = v_lshlrev_b32_lit %tid, 2
  %17 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %16, %17
  %masked = v_and_b32_lit %loaded, 15
  %with_tag = v_or_b32_lit %masked, 240
  %result = v_xor_b32 %with_tag, %loaded
  %22 = v_lshlrev_b32_lit %tid, 2
  %23 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %22, %result, %23
  return
}

// ====

kernel.def @i32_shift(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %loaded = vector.load %input_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  %shift = vector.constant 3 : vector<1xi32>
  %left = vector.shli %loaded, %shift : vector<1xi32>
  %logical = vector.shrui %loaded, %shift : vector<1xi32>
  %arithmetic = vector.shrsi %loaded, %shift : vector<1xi32>
  %joined = vector.ori %left, %logical : vector<1xi32>
  %result = vector.xori %joined, %arithmetic : vector<1xi32>
  vector.store %result, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_shift() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %17 = v_lshlrev_b32_lit %tid, 2
  %18 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %17, %18
  %left = v_lshlrev_b32_lit %loaded, 3
  %logical = v_lshrrev_b32_lit %loaded, 3
  %arithmetic = v_ashrrev_i32_lit %loaded, 3
  %joined = v_or_b32 %left, %logical
  %result = v_xor_b32 %joined, %arithmetic
  %25 = v_lshlrev_b32_lit %tid, 2
  %26 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %25, %result, %26
  return
}

