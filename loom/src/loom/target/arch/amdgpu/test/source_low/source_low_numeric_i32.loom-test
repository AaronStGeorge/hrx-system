low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_shift() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %18 = v_lshlrev_b32_src0_inline %lane, 2
  %loaded = global_load_b32_saddr %18, %input_view
  %left = v_lshlrev_b32_lit %loaded, 3
  %logical = v_lshrrev_b32_lit %loaded, 3
  %arithmetic = v_ashrrev_i32_lit %loaded, 3
  %joined = v_or_b32 %left, %logical
  %result = v_xor_b32 %joined, %arithmetic
  global_store_b32_saddr %18, %result, %output_view
  return
}

