amdgpu.target<gfx1100> @target
kernel.def target(@target) @i32_scalarized(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %lane0 = vector.extract %loaded[0] : vector<4xi32> -> i32
  %lane1 = vector.extract %loaded[1] : vector<4xi32> -> i32
  %mask = scalar.constant 255 : i32
  %masked = scalar.andi %lane0, %mask : i32
  %shift = scalar.constant 3 : i32
  %left = scalar.shli %masked, %shift : i32
  %logical = scalar.shrui %lane1, %shift : i32
  %mixed = scalar.xori %left, %logical : i32
  %lane2 = vector.extract %loaded[2] : vector<4xi32> -> i32
  %lane3 = vector.extract %loaded[3] : vector<4xi32> -> i32
  %result = vector.from_elements %mixed, %logical, %lane2, %lane3 : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @i32_scalarized() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %25 = v_mov_b32 0
  %loaded = global_load_b128 %25, %input_view
  %lane0 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane1 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %mask = s_mov_b32 255
  %30 = v_mov_b32 255
  %masked = v_and_b32 %lane0, %30
  %shift = s_mov_b32 3
  %33 = v_mov_b32 3
  %left = v_lshlrev_b32 %33, %masked
  %35 = v_mov_b32 3
  %logical = v_lshrrev_b32 %35, %lane1
  %mixed = v_xor_b32 %left, %logical
  %lane2 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane3 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %result = concat(%mixed, %logical, %lane2, %lane3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %41 = v_mov_b32 0
  global_store_b128 %41, %result, %output_view
  return
}
