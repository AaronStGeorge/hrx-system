// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_i32_memory.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @i32_bitwise(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %loaded = vector.load %input_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  %mask = vector.constant 15 : vector<1xi32>
  %masked = vector.andi %loaded, %mask : vector<1xi32>
  %tag = vector.constant 240 : vector<1xi32>
  %with_tag = vector.ori %masked, %tag : vector<1xi32>
  %result = vector.xori %with_tag, %loaded : vector<1xi32>
  vector.store %result, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_bitwise() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %17 = v_mov_b32 2
  %18 = v_lshlrev_b32 %17, %tid
  %19 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %18, %19 {offset = 0}
  %mask = v_mov_b32 15
  %masked = v_and_b32 %loaded, %mask
  %tag = v_mov_b32 240
  %with_tag = v_or_b32 %masked, %tag
  %result = v_xor_b32 %with_tag, %loaded
  %26 = v_mov_b32 2
  %27 = v_lshlrev_b32 %26, %tid
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %27, %result, %28 {offset = 0}
  return
}

// ====

kernel.def @i32_shift(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %loaded = vector.load %input_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  %shift = vector.constant 3 : vector<1xi32>
  %left = vector.shli %loaded, %shift : vector<1xi32>
  %logical = vector.shrui %loaded, %shift : vector<1xi32>
  %arithmetic = vector.shrsi %loaded, %shift : vector<1xi32>
  %joined = vector.ori %left, %logical : vector<1xi32>
  %result = vector.xori %joined, %arithmetic : vector<1xi32>
  vector.store %result, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_shift() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %18 = v_mov_b32 2
  %19 = v_lshlrev_b32 %18, %tid
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %19, %20 {offset = 0}
  %shift = v_mov_b32 3
  %left = v_lshlrev_b32 %shift, %loaded
  %logical = v_lshrrev_b32 %shift, %loaded
  %arithmetic = v_ashrrev_i32 %shift, %loaded
  %joined = v_or_b32 %left, %logical
  %result = v_xor_b32 %joined, %arithmetic
  %28 = v_mov_b32 2
  %29 = v_lshlrev_b32 %28, %tid
  %30 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %29, %result, %30 {offset = 0}
  return
}

// ====

kernel.def @i32_scalarized(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %lane0 = vector.extract %loaded[0] : vector<4xi32> -> i32
  %lane1 = vector.extract %loaded[1] : vector<4xi32> -> i32
  %mask = scalar.constant 255 : i32
  %masked = scalar.andi %lane0, %mask : i32
  %shift = scalar.constant 3 : i32
  %left = scalar.shli %masked, %shift : i32
  %logical = scalar.shrui %lane1, %shift : i32
  %mixed = scalar.xori %left, %logical : i32
  %lane2 = vector.extract %loaded[2] : vector<4xi32> -> i32
  %lane3 = vector.extract %loaded[3] : vector<4xi32> -> i32
  %result = vector.from_elements %mixed, %logical, %lane2, %lane3 : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_scalarized() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %23 = v_mov_b32 4
  %24 = v_lshlrev_b32 %23, %tid
  %25 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %24, %25 {offset = 0}
  %lane0 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane1 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %mask = s_mov_b32 255
  %30 = v_mov_b32 255
  %masked = v_and_b32 %lane0, %30
  %shift = s_mov_b32 3
  %33 = v_mov_b32 3
  %left = v_lshlrev_b32 %33, %masked
  %35 = v_mov_b32 3
  %logical = v_lshrrev_b32 %35, %lane1
  %mixed = v_xor_b32 %left, %logical
  %lane2 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane3 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %result = concat(%mixed, %logical, %lane2, %lane3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %41 = v_mov_b32 4
  %42 = v_lshlrev_b32 %41, %tid
  %43 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %42, %result, %43 {offset = 0}
  return
}
