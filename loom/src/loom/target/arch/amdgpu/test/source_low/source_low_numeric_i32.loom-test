low.kernel.def target(@target) workgroup_size(1, 1, 1) @i32_shift() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %20 = v_mov_b32 0
  %loaded = global_load_b32 %20, %input_view
  %left = v_lshlrev_b32_lit %loaded, 3
  %logical = v_lshrrev_b32_lit %loaded, 3
  %arithmetic = v_ashrrev_i32_lit %loaded, 3
  %joined = v_or_b32 %left, %logical
  %result = v_xor_b32 %joined, %arithmetic
  %27 = v_mov_b32 0
  global_store_b32 %27, %result, %output_view
  return
}

