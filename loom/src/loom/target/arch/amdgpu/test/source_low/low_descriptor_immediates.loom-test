// RUN: verify

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @vop3_inline_source_shift(%value: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %shifted = v_lshlrev_b32_vop3_imm %value, 64
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @vop3_bfe_offset_width_inline(%value: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %signed = v_bfe_i32_offset_width_inline %value {offset = 8, width = 8}
  %unsigned = v_bfe_u32_offset_width_inline %value {offset = 4, width = 4}
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @sop2_inline_source_shift(%value: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %shifted = s_lshl_b32_rhs_inline %value, 64
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @global_vaddr_named_offset(%addr: reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %loaded = global_load_b128_vaddr %addr {offset = 16}
  global_store_b128_vaddr %addr, %loaded {offset = 32}
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @vop3_inline_source_shift_out_of_range(%value: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="imm32", actual_value="65", expected_constraint="0..64"}
  %shifted = v_lshlrev_b32_vop3_imm %value, 65
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @vop3_bfe_offset_out_of_range(%value: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="offset", actual_value="32", expected_constraint="0..31"}
  %extracted = v_bfe_i32_offset_width_inline %value {offset = 32, width = 8}
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @vop3_bfe_width_out_of_range(%value: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="width", actual_value="33", expected_constraint="0..32"}
  %extracted = v_bfe_i32_offset_width_inline %value {offset = 8, width = 33}
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @sop2_inline_source_shift_out_of_range(%value: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="imm32", actual_value="65", expected_constraint="0..64"}
  %shifted = s_lshl_b32_rhs_inline %value, 65
  return
}

// ====

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @dpp_control_out_of_range(%value: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="dpp_ctrl", actual_value="512", expected_constraint="0..511"}
  %shifted = v_mov_b32_dpp16 %value {dpp_ctrl = 512}
  return
}

// ====

amdgpu.target<gfx950> @gfx950_target
low.func.def target(@gfx950_target) @sdwa_selector_out_of_range(%value: reg<amdgpu.vgpr>) asm<amdgpu.cdna4.core> {
  // ERROR@+1: STRUCTURE/014 {attr_name="dst_sel", actual_value="7", expected_constraint="0..6"}
  %selected = v_mov_b32_sdwa %value {dst_sel = 7, dst_unused = 0, src0_sel = 0, src0_sext = 0}
  return
}
