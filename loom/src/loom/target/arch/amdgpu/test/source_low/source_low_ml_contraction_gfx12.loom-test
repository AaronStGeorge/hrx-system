low.func.def target(@target) abi(hal_kernel) @tail_selected_f32_dot(%lhs: reg<amdgpu.vgpr x4>, %rhs: reg<amdgpu.vgpr x4>, %acc: reg<amdgpu.vgpr>, %lane: reg<amdgpu.sgpr>, %limit: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna4.core> {
  %15 = slice %lhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %17 = v_fma_f32 %15, %16, %acc
  %18 = slice %lhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_fmac_f32 %17, %18, %19
  %21 = slice %lhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_fmac_f32 %20, %21, %22
  %24 = slice %lhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot = v_fmac_f32 %23, %24, %25
  %27 = v_mov_b32_copy %lane
  %28 = v_mov_b32_copy %limit
  %inside = v_cmp_lt_i32 %27, %28
  %selected = v_cndmask_b32 %acc, %dot, %inside
  return %selected
}
