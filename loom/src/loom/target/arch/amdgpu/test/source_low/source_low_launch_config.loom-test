// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target

kernel.def target(@target) @computed_launch_config_workgroup_size() {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %size = index.mul %c8, %c8 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%size, %c1, %c1) : index
} launch {
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @computed_launch_config_workgroup_size() asm<amdgpu.rdna3.core> {
  return
}
