amdgpu.target<gfx1100> @target
func.def target(@target) @packed5_split_payload_offsets(%weights: buffer, %block0: index, %word0: index) -> (i32, i32) {
  %block = index.assume %block0 [range(%block0, 0, 63)] : index
  %word = index.assume %word0 [range(%word0, 0, 3)] : index
  %block_byte_stride = index.constant 22 : offset
  %side_bits_header_offset = index.constant 2 : offset
  %low_bits_header_offset = index.constant 6 : offset
  %word_byte_stride = index.constant 4 : offset
  %block_base = index.scale %block, %block_byte_stride : index, offset -> offset
  %side_bits_byte_offset = index.add %block_base, %side_bits_header_offset : offset
  %low_bits_base = index.add %block_base, %low_bits_header_offset : offset
  %low_word_byte_offset = index.scale %word, %word_byte_stride : index, offset -> offset
  %low_bits_byte_offset = index.add %low_bits_base, %low_word_byte_offset : offset
  %weights_global = buffer.assume.memory_space<global> %weights : buffer
  %side_bits_view = buffer.view %weights_global[%side_bits_byte_offset] : buffer -> view<1xi32, #dense>
  %low_bits_view = buffer.view %weights_global[%low_bits_byte_offset] : buffer -> view<1xi32, #dense>
  %side_bits_word = view.load %side_bits_view[0] : view<1xi32, #dense> -> i32
  %low_bits_word = view.load %low_bits_view[0] : view<1xi32, #dense> -> i32
  func.return %side_bits_word, %low_bits_word : i32, i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @packed5_split_payload_offsets(%block: reg<amdgpu.sgpr>, %word: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %low_bits_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %block_byte_stride = s_mov_b32 22
  %low_bits_header_offset = s_mov_b32 6
  %word_byte_stride = s_mov_b32 4
  %block_base = s_mul_i32 %block, %block_byte_stride
  %low_bits_base = s_add_u32 %block_base, %low_bits_header_offset
  %low_word_byte_offset = s_mul_i32 %word, %word_byte_stride
  %low_bits_byte_offset = s_add_u32 %low_bits_base, %low_word_byte_offset
  %35 = v_mov_b32 0
  %36 = s_mul_i32_rhs_inline %block, 22
  %37 = slice %low_bits_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %38 = slice %low_bits_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %39 = s_mov_b32 0
  %40 = s_add_u32 %37, %36
  %41 = s_addc_u32 %38, %39
  %42 = concat(%40, %41) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %side_bits_word = global_load_b32_saddr %35, %42 {offset = 2}
  %48 = s_add_u32 %37, %low_bits_byte_offset
  %49 = s_addc_u32 %38, %39
  %50 = concat(%48, %49) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %low_bits_word = global_load_b32_saddr %35, %50
  return %side_bits_word, %low_bits_word
}

