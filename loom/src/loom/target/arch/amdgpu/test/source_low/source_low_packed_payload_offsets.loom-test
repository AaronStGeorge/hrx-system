amdgpu.target<gfx1100> @target
func.def target(@target) @packed6_split_payload_offsets(%weights: buffer, %block0: index, %low_word0: index, %high_word0: index, %scale0: index) -> (i32, i32, f16) {
  %block = index.assume %block0 [range(%block0, 0, 63)] : index
  %low_word = index.assume %low_word0 [range(%low_word0, 0, 31)] : index
  %high_word = index.assume %high_word0 [range(%high_word0, 0, 15)] : index
  %scale = index.assume %scale0 [range(%scale0, 0, 15)] : index
  %block_byte_stride = index.constant 210 : offset
  %low_bits_header_offset = index.constant 0 : offset
  %high_bits_header_offset = index.constant 128 : offset
  %scale_header_offset = index.constant 192 : offset
  %word_byte_stride = index.constant 4 : offset
  %half_byte_stride = index.constant 2 : offset
  %block_base = index.scale %block, %block_byte_stride : index, offset -> offset
  %low_bits_base = index.add %block_base, %low_bits_header_offset : offset
  %high_bits_base = index.add %block_base, %high_bits_header_offset : offset
  %scale_base = index.add %block_base, %scale_header_offset : offset
  %low_word_byte_offset = index.scale %low_word, %word_byte_stride : index, offset -> offset
  %high_word_byte_offset = index.scale %high_word, %word_byte_stride : index, offset -> offset
  %scale_element_byte_offset = index.scale %scale, %half_byte_stride : index, offset -> offset
  %low_bits_byte_offset = index.add %low_bits_base, %low_word_byte_offset : offset
  %high_bits_byte_offset = index.add %high_bits_base, %high_word_byte_offset : offset
  %scale_byte_offset = index.add %scale_base, %scale_element_byte_offset : offset
  %weights_global = buffer.assume.memory_space<global> %weights : buffer
  %low_bits_view = buffer.view %weights_global[%low_bits_byte_offset] : buffer -> view<1xi32, #dense>
  %high_bits_view = buffer.view %weights_global[%high_bits_byte_offset] : buffer -> view<1xi32, #dense>
  %scale_view = buffer.view %weights_global[%scale_byte_offset] : buffer -> view<1xf16, #dense>
  %low_bits_word = view.load %low_bits_view[0] : view<1xi32, #dense> -> i32
  %high_bits_word = view.load %high_bits_view[0] : view<1xi32, #dense> -> i32
  %scale_value = view.load %scale_view[0] : view<1xf16, #dense> -> f16
  func.return %low_bits_word, %high_bits_word, %scale_value : i32, i32, f16
}

// ----
low.func.def target(@target) abi(hal_kernel) @packed6_split_payload_offsets(%block: reg<amdgpu.sgpr>, %low_word: reg<amdgpu.sgpr>, %high_word: reg<amdgpu.sgpr>, %scale: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %scale_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %block_byte_stride = s_mov_b32 210
  %high_bits_header_offset = s_mov_b32 128
  %scale_header_offset = s_mov_b32 192
  %word_byte_stride = s_mov_b32 4
  %half_byte_stride = s_mov_b32 2
  %block_base = s_mul_i32 %block, %block_byte_stride
  %high_bits_base = s_add_u32 %block_base, %high_bits_header_offset
  %scale_base = s_add_u32 %block_base, %scale_header_offset
  %low_word_byte_offset = s_mul_i32 %low_word, %word_byte_stride
  %high_word_byte_offset = s_mul_i32 %high_word, %word_byte_stride
  %scale_element_byte_offset = s_mul_i32 %scale, %half_byte_stride
  %low_bits_byte_offset = s_add_u32 %block_base, %low_word_byte_offset
  %high_bits_byte_offset = s_add_u32 %high_bits_base, %high_word_byte_offset
  %scale_byte_offset = s_add_u32 %scale_base, %scale_element_byte_offset
  %57 = v_mov_b32 0
  %58 = slice %scale_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %59 = slice %scale_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %60 = s_mov_b32 0
  %61 = s_add_u32 %58, %low_bits_byte_offset
  %62 = s_addc_u32 %59, %60
  %63 = concat(%61, %62) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %low_bits_word = global_load_b32_saddr %57, %63
  %69 = s_add_u32 %58, %high_bits_byte_offset
  %70 = s_addc_u32 %59, %60
  %71 = concat(%69, %70) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %high_bits_word = global_load_b32_saddr %57, %71
  %77 = s_add_u32 %58, %scale_byte_offset
  %78 = s_addc_u32 %59, %60
  %79 = concat(%77, %78) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %scale_value = global_load_u16_saddr %57, %79
  return %low_bits_word, %high_bits_word, %scale_value
}
