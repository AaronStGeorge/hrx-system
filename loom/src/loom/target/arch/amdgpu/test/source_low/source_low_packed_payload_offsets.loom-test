// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @packed4_payload_word_offset(%weights: buffer, %block0: index, %word0: index) -> (i32) {
  %block = index.assume %block0 [range(%block0, 0, 63)] : index
  %word = index.assume %word0 [range(%word0, 0, 3)] : index
  %block_byte_stride = index.constant 18 : offset
  %payload_header_offset = index.constant 2 : offset
  %word_byte_stride = index.constant 4 : offset
  %block_base = index.scale %block, %block_byte_stride : index, offset -> offset
  %payload_base = index.add %block_base, %payload_header_offset : offset
  %word_byte_offset = index.scale %word, %word_byte_stride : index, offset -> offset
  %byte_offset = index.add %payload_base, %word_byte_offset : offset
  %weights_global = buffer.assume.memory_space<global> %weights : buffer
  %word_view = buffer.view %weights_global[%byte_offset] : buffer -> view<1xi32, #dense>
  %packed_word = view.load %word_view[0] : view<1xi32, #dense> -> i32
  func.return %packed_word : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @packed4_payload_word_offset(%block: reg<amdgpu.sgpr>, %word: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %word_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %block_byte_stride = s_mov_b32 18
  %payload_header_offset = s_mov_b32 2
  %word_byte_stride = s_mov_b32 4
  %block_base = s_mul_i32 %block, %block_byte_stride
  %payload_base = s_add_u32 %block_base, %payload_header_offset
  %word_byte_offset = s_mul_i32 %word, %word_byte_stride
  %byte_offset = s_add_u32 %payload_base, %word_byte_offset
  %27 = v_mov_b32 0
  %28 = slice %word_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %29 = slice %word_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %30 = s_mov_b32 0
  %31 = s_add_u32 %28, %byte_offset
  %32 = s_addc_u32 %29, %30
  %33 = concat(%31, %32) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %packed_word = global_load_b32_saddr %27, %33
  return %packed_word
}

