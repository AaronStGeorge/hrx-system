// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @adjacent_f16_scalar_loads_pack() {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 32 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%input: buffer, %output: buffer) {
  %lane = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %one = index.constant 1 : index
  %input_view = buffer.view %input[%zero] : buffer -> view<64xf16, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf16, #dense>
  %next = index.add %lane, %one : index
  %a = view.load %input_view[%lane] : view<64xf16, #dense> -> f16
  %b = view.load %input_view[%next] : view<64xf16, #dense> -> f16
  view.store %a, %output_view[%lane] : f16, view<64xf16, #dense>
  view.store %b, %output_view[%next] : f16, view<64xf16, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(32, 1, 1) @adjacent_f16_scalar_loads_pack() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 128} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 128} : reg<amdgpu.sgpr x2>
  %18 = v_lshlrev_b32_src0_inline %lane, 1
  %a = global_load_b32_saddr %18, %input_view
  %b = v_lshrrev_b32_src0_inline %a, 16
  global_store_short_saddr %18, %a, %output_view
  global_store_short_saddr %18, %b, %output_view {offset = 2}
  return
}
