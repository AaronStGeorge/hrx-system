// RUN: emit source-low output=low

amdgpu.target<gfx942> @target

// The bias load intentionally stays outside the lane0 branch. Cross-wave
// workgroup reduction narrows EXEC internally, and later all-lane memory
// operations must not reuse VGPR materializations produced under that narrowed
// participant set.
kernel.def target(@target) @workgroup_reduce_then_all_lane_bias_load() {
  %one = index.constant 1 : index
  %workgroup_size = index.constant 128 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%workgroup_size, %one, %one) : index
} launch(%input: buffer, %bias: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 127)] : index
  %base = index.constant 0 : offset
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %bias_global = buffer.assume.memory_space<global> %bias : buffer
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %input_noalias, %bias_noalias, %output_noalias = buffer.assume.noalias %input_global, %bias_global, %output_global : buffer, buffer, buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<128xf32, #dense>
  %bias_view = buffer.view %bias_noalias[%base] : buffer -> view<1xbf16, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<2xf32, #dense>
  %value = view.load %input_view[%tid] : view<128xf32, #dense> -> f32
  %sum0 = kernel.workgroup.reduce<addf> %value : f32
  %sum1 = kernel.workgroup.reduce<addf> %value : f32
  %bias_bf16 = view.load %bias_view[%zero] : view<1xbf16, #dense> -> bf16
  %bias_f32 = scalar.extf %bias_bf16 : bf16 to f32
  %result0 = scalar.addf<reassoc|nnan|ninf|nsz> %sum0, %bias_f32 : f32
  %result1 = scalar.addf<reassoc|nnan|ninf|nsz> %sum1, %bias_f32 : f32
  %is_lane0 = index.cmp eq, %tid, %zero : index
  scf.if %is_lane0 {
    view.store %result0, %output_view[%zero] : f32, view<2xf32, #dense>
    view.store %result1, %output_view[%one] : f32, view<2xf32, #dense>
  }
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(128, 1, 1) @workgroup_reduce_then_all_lane_bias_load() asm<amdgpu.cdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %bias_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 2} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 8} : reg<amdgpu.sgpr x2>
  %33 = v_lshlrev_b32_src0_inline %tid, 2
  %34 = s_mov_b32_m0_imm 0
  %value = global_load_dword_saddr %33, %input_view, %34
  %36 = v_and_b32_src0_inline %tid, 63
  %37 = storage {byte_alignment = 4, byte_length = 8} : low.storage<workgroup>
  %38 = storage_address %37 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %39 = v_xor_b32_src0_inline %36, 32
  %40 = v_lshlrev_b32_src0_inline %39, 2
  %41 = ds_bpermute_b32 %40, %value
  %42 = v_add_f32 %value, %41
  %43 = v_xor_b32_src0_inline %36, 16
  %44 = v_lshlrev_b32_src0_inline %43, 2
  %45 = ds_bpermute_b32 %44, %42
  %46 = v_add_f32 %42, %45
  %47 = v_xor_b32_src0_inline %36, 8
  %48 = v_lshlrev_b32_src0_inline %47, 2
  %49 = ds_bpermute_b32 %48, %46
  %50 = v_add_f32 %46, %49
  %51 = v_xor_b32_src0_inline %36, 4
  %52 = v_lshlrev_b32_src0_inline %51, 2
  %53 = ds_bpermute_b32 %52, %50
  %54 = v_add_f32 %50, %53
  %55 = v_xor_b32_src0_inline %36, 2
  %56 = v_lshlrev_b32_src0_inline %55, 2
  %57 = ds_bpermute_b32 %56, %54
  %58 = v_add_f32 %54, %57
  %59 = v_xor_b32_src0_inline %36, 1
  %60 = v_lshlrev_b32_src0_inline %59, 2
  %61 = ds_bpermute_b32 %60, %58
  %62 = v_add_f32 %58, %61
  %63 = v_lshrrev_b32_src0_inline %tid, 6
  %64 = v_lshlrev_b32_src0_inline %63, 2
  %65 = v_mov_b32 1
  %66 = v_cmp_lt_u32 %36, %65
  %67, %68 = s_and_saveexec_b64 %66
  %69 = v_add_u32 %38, %64
  ds_write_b32 %69, %62
  s_mov_b64_exec %67
  s_barrier
  %70 = v_mov_b32 2
  %71 = v_cmp_lt_u32 %tid, %70
  %72, %73 = s_and_saveexec_b64 %71
  %74 = v_lshlrev_b32_src0_inline %36, 2
  %75 = v_add_u32 %38, %74
  %76 = ds_read_b32 %75
  %77 = v_xor_b32_src0_inline %36, 1
  %78 = v_lshlrev_b32_src0_inline %77, 2
  %79 = ds_bpermute_b32 %78, %76
  %80 = v_add_f32 %76, %79
  %81, %82 = s_and_saveexec_b64 %66
  %83 = v_add_u32 %38, %74
  ds_write_b32 %83, %80
  s_mov_b64_exec %81
  s_mov_b64_exec %72
  s_barrier
  %sum0 = ds_read_b32 %38
  %85 = v_and_b32_src0_inline %tid, 63
  %86 = storage {byte_alignment = 4, byte_length = 8} : low.storage<workgroup>
  %87 = storage_address %86 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %88 = v_xor_b32_src0_inline %85, 32
  %89 = v_lshlrev_b32_src0_inline %88, 2
  %90 = ds_bpermute_b32 %89, %value
  %91 = v_add_f32 %value, %90
  %92 = v_xor_b32_src0_inline %85, 16
  %93 = v_lshlrev_b32_src0_inline %92, 2
  %94 = ds_bpermute_b32 %93, %91
  %95 = v_add_f32 %91, %94
  %96 = v_xor_b32_src0_inline %85, 8
  %97 = v_lshlrev_b32_src0_inline %96, 2
  %98 = ds_bpermute_b32 %97, %95
  %99 = v_add_f32 %95, %98
  %100 = v_xor_b32_src0_inline %85, 4
  %101 = v_lshlrev_b32_src0_inline %100, 2
  %102 = ds_bpermute_b32 %101, %99
  %103 = v_add_f32 %99, %102
  %104 = v_xor_b32_src0_inline %85, 2
  %105 = v_lshlrev_b32_src0_inline %104, 2
  %106 = ds_bpermute_b32 %105, %103
  %107 = v_add_f32 %103, %106
  %108 = v_xor_b32_src0_inline %85, 1
  %109 = v_lshlrev_b32_src0_inline %108, 2
  %110 = ds_bpermute_b32 %109, %107
  %111 = v_add_f32 %107, %110
  %112 = v_lshrrev_b32_src0_inline %tid, 6
  %113 = v_lshlrev_b32_src0_inline %112, 2
  %114 = v_mov_b32 1
  %115 = v_cmp_lt_u32 %85, %114
  %116, %117 = s_and_saveexec_b64 %115
  %118 = v_add_u32 %87, %113
  ds_write_b32 %118, %111
  s_mov_b64_exec %116
  s_barrier
  %119 = v_mov_b32 2
  %120 = v_cmp_lt_u32 %tid, %119
  %121, %122 = s_and_saveexec_b64 %120
  %123 = v_lshlrev_b32_src0_inline %85, 2
  %124 = v_add_u32 %87, %123
  %125 = ds_read_b32 %124
  %126 = v_xor_b32_src0_inline %85, 1
  %127 = v_lshlrev_b32_src0_inline %126, 2
  %128 = ds_bpermute_b32 %127, %125
  %129 = v_add_f32 %125, %128
  %130, %131 = s_and_saveexec_b64 %115
  %132 = v_add_u32 %87, %123
  ds_write_b32 %132, %129
  s_mov_b64_exec %130
  s_mov_b64_exec %121
  s_barrier
  %sum1 = ds_read_b32 %87
  %134 = v_mov_b32 0
  %135 = s_mov_b32_m0_imm 0
  %bias_bf16 = global_load_d16_b16_saddr %134, %bias_view, %135
  %bias_f32 = v_lshlrev_b32_src0_16_low16 %bias_bf16
  %result0 = v_add_f32 %sum0, %bias_f32
  %result1 = v_add_f32 %sum1, %bias_f32
  %is_lane0 = v_cmp_eq_i32_src1_inline %tid {rhs = 0}
  %141, %142 = s_and_saveexec_b64 %is_lane0
  low.cond_br %142, ^_bb1, ^_bb2 : reg<amdgpu.scc>
^_bb1:
  %143 = v_mov_b32 0
  %144 = s_mov_b32_m0_imm 0
  global_store_dword_saddr %143, %result0, %output_view, %144
  global_store_dword_saddr %143, %result1, %output_view, %144 {offset = 4}
  low.br ^_bb2
^_bb2:
  s_mov_b64_exec %141
  return
}
