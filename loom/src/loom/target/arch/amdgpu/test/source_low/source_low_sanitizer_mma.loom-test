// RUN: emit source-low output=low sanitizer=access sanitizer-reporting=trap

amdgpu.target<gfx1100> @target

kernel.def target(@target) @sanitizer_fragment_result_store() {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 64 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch(%output: buffer) {
  %base = index.constant 0 : offset
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %output_view = buffer.view %output_global[%base] : buffer -> view<16x16xf32, #dense>
  %lhs_data = vector.constant 0.0 : vector<16xf16>
  %rhs_data = vector.constant 0.0 : vector<16xf16>
  %init_data = vector.constant 0.0 : vector<8xf32>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<16xf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<16xf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xf16>, vector<16xf16>, vector<8xf32>
  vector.fragment.store<result> %result, %output_view[0, 0] shape [%m, %n] : vector<8xf32>, view<16x16xf32, #dense>
  kernel.return
}

