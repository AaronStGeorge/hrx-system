  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %12 = v_mov_b32_copy %scale
  %13 = v_mov_b32 0
  global_store_b32_saddr %13, %12, %output_view
  return
}

