// ----
low.func.def target(@target) abi(hal_kernel) @vector_fptrunc_bf16x3(%input: reg<amdgpu.vgpr x3>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %5 = slice %input[0] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %6 = v_lshrrev_b32_src0_inline %5, 16
  %7 = v_and_b32_src0_inline %6, 1
  %8 = v_add_u32_lit %7, 32767
  %9 = v_add_u32 %5, %8
  %10 = v_lshrrev_b32_src0_inline %9, 16
  %11 = slice %input[1] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %12 = v_lshrrev_b32_src0_inline %11, 16
  %13 = v_and_b32_src0_inline %12, 1
  %14 = v_add_u32_lit %13, 32767
  %15 = v_add_u32 %11, %14
  %16 = v_lshrrev_b32_src0_inline %15, 16
  %17 = v_lshlrev_b32_src0_inline %16, 16
  %18 = v_or_b32 %10, %17
  %19 = slice %input[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %20 = v_lshrrev_b32_src0_inline %19, 16
  %21 = v_and_b32_src0_inline %20, 1
  %22 = v_add_u32_lit %21, 32767
  %23 = v_add_u32 %19, %22
  %24 = v_lshrrev_b32_src0_inline %23, 16
  %converted = concat(%18, %24) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %converted
}

