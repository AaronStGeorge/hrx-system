amdgpu.target<gfx1100> @target
kernel.def target(@target) @scalar_sitofp_i8_load_store() {
  %count = index.constant 1 : index
  kernel.launch.config workgroups(%count, %count, %count) workgroup_size(%count, %count, %count) : index
} launch(%input: buffer, %output: buffer) {
  %base = index.constant 0 : offset
  %index = index.constant 0 : index
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %input_noalias, %output_noalias = buffer.assume.noalias %input_global, %output_global : buffer, buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<1xi8, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<1xf32, #dense>
  %loaded = view.load %input_view[%index] : view<1xi8, #dense> -> i8
  %converted = scalar.sitofp %loaded : i8 to f32
  view.store %converted, %output_view[%index] : f32, view<1xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @scalar_sitofp_i8_load_store() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 1} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %16 = v_mov_b32 0
  %loaded = global_load_i8_saddr %16, %input_view
  %converted = v_cvt_f32_i32 %loaded
  global_store_b32_saddr %16, %converted, %output_view
  return
}

