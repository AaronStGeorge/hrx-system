amdgpu.target<gfx1100> @target
func.def target(@target) @vector_quantize_round_f32_to_i8x4(%values: vector<4xf32>, %inverse_scale: f32) -> (vector<4xi8>) {
  %scale = vector.splat %inverse_scale : vector<4xf32>
  %scaled = vector.mulf %values, %scale : vector<4xf32>
  %rounded = vector.roundf %scaled : vector<4xf32>
  %i32 = vector.fptosi %rounded : vector<4xf32> to vector<4xi32>
  %packed = vector.trunci %i32 : vector<4xi32> to vector<4xi8>
  func.return %packed : vector<4xi8>
}

