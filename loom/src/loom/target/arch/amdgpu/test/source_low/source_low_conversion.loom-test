// ----
low.func.def target(@target) abi(hal_kernel) @scalar_fptrunc_bf16_store(%input: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 2} : reg<amdgpu.sgpr x2>
  %7 = v_lshrrev_b32_lit %input, 16
  %8 = v_and_b32_lit %7, 1
  %9 = v_add_u32_lit %8, 32767
  %10 = v_add_u32 %input, %9
  %converted = v_lshrrev_b32_lit %10, 16
  %12 = v_mov_b32 0
  global_store_short %12, %converted, %output_view
  return
}

