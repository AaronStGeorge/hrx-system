amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_fptrunc_f32_store(%output: buffer, %input: f32) {
  %base = index.constant 0 : offset
  %output_view = buffer.view %output[%base] : buffer -> view<1xf16, #dense>
  %converted = scalar.fptrunc %input : f32 to f16
  view.store %converted, %output_view[0] : f16, view<1xf16, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_fptrunc_f32_store(%input: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 2} : reg<amdgpu.sgpr x2>
  %converted = v_cvt_f16_f32 %input
  %8 = v_mov_b32 0
  global_store_short %8, %converted, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_fptrunc_bf16_store(%output: buffer, %input: f32) {
  %base = index.constant 0 : offset
  %output_view = buffer.view %output[%base] : buffer -> view<1xbf16, #dense>
  %converted = scalar.fptrunc %input : f32 to bf16
  view.store %converted, %output_view[0] : bf16, view<1xbf16, #dense>
