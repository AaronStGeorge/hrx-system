  %8 = v_and_b32_src0_inline %7, 1
  %9 = v_add_u32_lit %8, 32767
  %10 = v_add_u32 %5, %9
  %11 = v_lshrrev_b32_src0_inline %10, 16
  %12 = v_lshrrev_b32_src0_inline %6, 16
  %13 = v_and_b32_src0_inline %12, 1
  %14 = v_add_u32_lit %13, 32767
  %15 = v_add_u32 %6, %14
  %16 = v_lshrrev_b32_src0_inline %15, 16
  %17 = v_cvt_pk_u16_u32 %11, %16
  %18 = slice %input[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %19 = v_lshrrev_b32_src0_inline %18, 16
  %20 = v_and_b32_src0_inline %19, 1
  %21 = v_add_u32_lit %20, 32767
  %22 = v_add_u32 %18, %21
  %23 = v_lshrrev_b32_src0_inline %22, 16
  %converted = concat(%17, %23) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %converted
}

