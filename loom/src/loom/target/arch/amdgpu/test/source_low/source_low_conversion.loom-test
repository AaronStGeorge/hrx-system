amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_extsi_i32_store(%output: buffer, %input: i32) {
  %base = index.constant 0 : offset
  %output_view = buffer.view %output[%base] : buffer -> view<1xi64, #dense>
  %converted = scalar.extsi %input : i32 to i64
  view.store %converted, %output_view[0] : i64, view<1xi64, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_extsi_i32_store(%input: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 8} : reg<amdgpu.sgpr x2>
  %7 = v_mov_b32_copy %input
  %8 = v_ashrrev_i32_src0_inline %7, 31
  %converted = concat(%7, %8) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %10 = v_mov_b32 0
  global_store_b64 %10, %converted, %output_view
  return
}
