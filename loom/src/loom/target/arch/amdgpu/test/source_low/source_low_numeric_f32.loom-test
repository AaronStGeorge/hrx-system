low.func.def target(@target) abi(hal_kernel) @f32_uniform_vector_fma() -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %a_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %b_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %c_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %22 = s_mov_b32 0
  %a = s_load_dwordx4 %a_view, %22
  %b = s_load_dwordx4 %b_view, %22
  %c = s_load_dwordx4 %c_view, %22
  %28 = slice %c[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %29 = v_mov_b32_copy %28
  %30 = slice %c[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %31 = v_mov_b32_copy %30
  %32 = slice %c[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %33 = v_mov_b32_copy %32
  %34 = slice %c[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %35 = v_mov_b32_copy %34
  %37 = slice %a[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %38 = slice %b[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %40 = v_fma_f32 %37, %38, %29
  %41 = slice %a[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %42 = slice %b[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %44 = v_fma_f32 %41, %42, %31
  %45 = slice %a[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %46 = slice %b[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %48 = v_fma_f32 %45, %46, %33
  %49 = slice %a[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %50 = slice %b[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %52 = v_fma_f32 %49, %50, %35
  %result = concat(%40, %44, %48, %52) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %result
}

