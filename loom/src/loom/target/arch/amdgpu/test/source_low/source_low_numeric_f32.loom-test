amdgpu.target<gfx1100> @target
func.def target(@target) @f32_native_math(%input: f32) -> (f32, f32, f32) {
  %exp2 = scalar.exp2f %input : f32
  %sqrt = scalar.sqrtf %input : f32
  %rsqrt = scalar.rsqrtf %input : f32
  func.return %exp2, %sqrt, %rsqrt : f32, f32, f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32_native_math(%input: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %exp2 = v_exp_f32 %input
  %sqrt = v_sqrt_f32 %input
  %rsqrt = v_rsq_f32 %input
  return %exp2, %sqrt, %rsqrt
}

