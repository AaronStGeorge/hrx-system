func.def @f32_fma(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %bias = vector.constant 0.5 : vector<1xf32>
  %fma = vector.fmaf %lhs, %rhs, %bias : vector<1xf32>
  %result = vector.subf %fma, %bias : vector<1xf32>
  vector.store %result, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) @f32_fma() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %rhs_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %18 = v_mov_b32 2
  %19 = v_lshlrev_b32 %18, %tid
  %20 = slice %lhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %lhs = global_load_b32 %19, %20 {offset = 0}
  %22 = v_mov_b32 2
  %23 = v_lshlrev_b32 %22, %tid
  %24 = slice %rhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %rhs = global_load_b32 %23, %24 {offset = 0}
  %bias = v_mov_b32 1056964608
  %fma = v_fma_f32 %lhs, %rhs, %bias
  %result = v_sub_f32 %fma, %bias
  %29 = v_mov_b32 2
  %30 = v_lshlrev_b32 %29, %tid
  %31 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %30, %result, %31 {offset = 0}
  return
}

