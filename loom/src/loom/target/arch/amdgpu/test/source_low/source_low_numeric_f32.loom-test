  %a = s_load_dword %a_view, %22
  %b = s_load_dword %b_view, %22
  %c = s_load_dword %c_view, %22
  %28 = v_mov_b32_copy %c
  %result = v_fma_f32 %a, %b, %28
  return %result
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32_uniform_vector_fma(%a_buffer: buffer, %b_buffer: buffer, %c_buffer: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %a_global = buffer.assume.memory_space<global> %a_buffer : buffer
  %b_global = buffer.assume.memory_space<global> %b_buffer : buffer
  %c_global = buffer.assume.memory_space<global> %c_buffer : buffer
  %a_noalias, %b_noalias, %c_noalias = buffer.assume.noalias %a_global, %b_global, %c_global : buffer, buffer, buffer
  %a_view = buffer.view %a_noalias[%base] : buffer -> view<4xf32, #dense>
  %b_view = buffer.view %b_noalias[%base] : buffer -> view<4xf32, #dense>
  %c_view = buffer.view %c_noalias[%base] : buffer -> view<4xf32, #dense>
  %a = vector.load %a_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %b = vector.load %b_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %c = vector.load %c_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %result = vector.fmaf %a, %b, %c : vector<4xf32>
  func.return %result : vector<4xf32>
}

