amdgpu.target<gfx1100> @target
kernel.def target(@target) @f32_scalarized(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %lhs0 = vector.extract %lhs[0] : vector<4xf32> -> f32
  %rhs0 = vector.extract %rhs[0] : vector<4xf32> -> f32
  %lane0 = scalar.addf %lhs0, %rhs0 : f32
  %lhs1 = vector.extract %lhs[1] : vector<4xf32> -> f32
  %rhs1 = vector.extract %rhs[1] : vector<4xf32> -> f32
  %lane1 = scalar.mulf %lhs1, %rhs1 : f32
  %lhs2 = vector.extract %lhs[2] : vector<4xf32> -> f32
  %rhs2 = vector.extract %rhs[2] : vector<4xf32> -> f32
  %lane2 = scalar.subf %lhs2, %rhs2 : f32
  %lhs3 = vector.extract %lhs[3] : vector<4xf32> -> f32
  %rhs3 = vector.extract %rhs[3] : vector<4xf32> -> f32
  %bias = scalar.constant 0.5 : f32
  %lane3 = scalar.fmaf %lhs3, %rhs3, %bias : f32
  %result = vector.from_elements %lane0, %lane1, %lane2, %lane3 : vector<4xf32>
  vector.store %result, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @f32_scalarized() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %rhs_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %33 = v_mov_b32 0
  %lhs = global_load_b128 %33, %lhs_view
  %35 = v_mov_b32 0
  %rhs = global_load_b128 %35, %rhs_view
  %lhs0 = slice %lhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs0 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane0 = v_add_f32 %lhs0, %rhs0
  %lhs1 = slice %lhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs1 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane1 = v_mul_f32 %lhs1, %rhs1
  %lhs2 = slice %lhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs2 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane2 = v_sub_f32 %lhs2, %rhs2
  %lhs3 = slice %lhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs3 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %bias = v_mov_b32 1056964608
  %lane3 = v_fma_f32 %lhs3, %rhs3, %bias
  %result = concat(%lane0, %lane1, %lane2, %lane3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %51 = v_mov_b32 0
  global_store_b128 %51, %result, %output_view
  return
}
