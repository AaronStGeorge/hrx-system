low.func.def target(@target) abi(hal_kernel) @vector_f32_native_math(%input: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %9 = slice %input[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %10 = v_exp_f32 %9
  %11 = slice %input[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %12 = v_exp_f32 %11
  %exp2 = concat(%10, %12) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %14 = slice %input[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = v_sqrt_f32 %14
  %16 = slice %input[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_sqrt_f32 %16
  %sqrt = concat(%15, %17) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %19 = slice %exp2[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %20 = slice %sqrt[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %21 = v_add_f32 %19, %20
  %22 = slice %exp2[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = slice %sqrt[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_add_f32 %22, %23
  %sum = concat(%21, %24) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %26 = slice %input[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %27 = v_rsq_f32 %26
  %28 = slice %input[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %29 = v_rsq_f32 %28
  %rsqrt = concat(%27, %29) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %31 = slice %sum[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %32 = slice %rsqrt[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %33 = v_mul_f32 %31, %32
  %34 = slice %sum[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %35 = slice %rsqrt[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %36 = v_mul_f32 %34, %35
  %result = concat(%33, %36) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %result
}

