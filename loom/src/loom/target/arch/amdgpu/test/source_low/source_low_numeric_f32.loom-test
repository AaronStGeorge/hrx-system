amdgpu.target<gfx1100> @target
func.def target(@target) @vector_f32_native_math(%input: vector<2xf32>) -> (vector<2xf32>) {
  %exp2 = vector.exp2f %input : vector<2xf32>
  %sqrt = vector.sqrtf %input : vector<2xf32>
  %sum = vector.addf %exp2, %sqrt : vector<2xf32>
  %rsqrt = vector.rsqrtf %input : vector<2xf32>
  %result = vector.mulf %sum, %rsqrt : vector<2xf32>
  func.return %result : vector<2xf32>
}

