// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_f32_memory.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @f32_arith(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %sum = vector.addf %lhs, %rhs : vector<1xf32>
  %product = vector.mulf %sum, %rhs : vector<1xf32>
  vector.store %product, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) @f32_arith() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %rhs_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %17 = v_mov_b32 2
  %18 = v_lshlrev_b32 %17, %tid
  %19 = slice %lhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %lhs = global_load_b32 %18, %19 {offset = 0}
  %21 = v_mov_b32 2
  %22 = v_lshlrev_b32 %21, %tid
  %23 = slice %rhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %rhs = global_load_b32 %22, %23 {offset = 0}
  %sum = v_add_f32 %lhs, %rhs
  %product = v_mul_f32 %sum, %rhs
  %27 = v_mov_b32 2
  %28 = v_lshlrev_b32 %27, %tid
  %29 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %28, %product, %29 {offset = 0}
  return
}

