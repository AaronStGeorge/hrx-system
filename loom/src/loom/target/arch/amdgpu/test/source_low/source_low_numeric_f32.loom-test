func.def target(@target) @f32_uniform_vector_bitops(%input: buffer) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %input_global = buffer.assume.memory_space<global> %input : buffer
  %input_noalias = buffer.assume.noalias %input_global : buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<4xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %negated = vector.negf %loaded : vector<4xf32>
  %absolute = vector.absf %loaded : vector<4xf32>
  %result = vector.addf %negated, %absolute : vector<4xf32>
  func.return %result : vector<4xf32>
}

