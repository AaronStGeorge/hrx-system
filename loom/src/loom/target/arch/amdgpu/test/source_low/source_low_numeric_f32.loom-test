// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_f32_memory.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @f32_arith(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %sum = vector.addf %lhs, %rhs : vector<1xf32>
  %product = vector.mulf %sum, %rhs : vector<1xf32>
  vector.store %product, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @f32_arith() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %rhs_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %17 = v_lshlrev_b32_lit %tid, 2
  %18 = slice %lhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %lhs = global_load_b32 %17, %18
  %20 = v_lshlrev_b32_lit %tid, 2
  %21 = slice %rhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %rhs = global_load_b32 %20, %21
  %sum = v_add_f32 %lhs, %rhs
  %product = v_mul_f32 %sum, %rhs
  %25 = v_lshlrev_b32_lit %tid, 2
  %26 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %25, %product, %26
  return
}

// ====

kernel.def @f32_fma(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xf32, #dense>
  %lhs = vector.load %lhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %rhs = vector.load %rhs_view[%tid] : view<64xf32, #dense> -> vector<1xf32>
  %bias = vector.constant 0.5 : vector<1xf32>
  %fma = vector.fmaf %lhs, %rhs, %bias : vector<1xf32>
  %result = vector.subf %fma, %bias : vector<1xf32>
  vector.store %result, %output_view[%tid] : vector<1xf32>, view<64xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @f32_fma() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %rhs_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %18 = v_lshlrev_b32_lit %tid, 2
  %19 = slice %lhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %lhs = global_load_b32 %18, %19
  %21 = v_lshlrev_b32_lit %tid, 2
  %22 = slice %rhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %rhs = global_load_b32 %21, %22
  %bias = v_mov_b32 1056964608
  %fma = v_fma_f32 %lhs, %rhs, %bias
  %result = v_sub_f32 %fma, %bias
  %27 = v_lshlrev_b32_lit %tid, 2
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %27, %result, %28
  return
}

// ====

kernel.def @f32_scalarized(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %lhs0 = vector.extract %lhs[0] : vector<4xf32> -> f32
  %rhs0 = vector.extract %rhs[0] : vector<4xf32> -> f32
  %lane0 = scalar.addf %lhs0, %rhs0 : f32
  %lhs1 = vector.extract %lhs[1] : vector<4xf32> -> f32
  %rhs1 = vector.extract %rhs[1] : vector<4xf32> -> f32
  %lane1 = scalar.mulf %lhs1, %rhs1 : f32
  %lhs2 = vector.extract %lhs[2] : vector<4xf32> -> f32
  %rhs2 = vector.extract %rhs[2] : vector<4xf32> -> f32
  %lane2 = scalar.subf %lhs2, %rhs2 : f32
  %lhs3 = vector.extract %lhs[3] : vector<4xf32> -> f32
  %rhs3 = vector.extract %rhs[3] : vector<4xf32> -> f32
  %bias = scalar.constant 0.5 : f32
  %lane3 = scalar.fmaf %lhs3, %rhs3, %bias : f32
  %result = vector.from_elements %lane0, %lane1, %lane2, %lane3 : vector<4xf32>
  vector.store %result, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @f32_scalarized() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %rhs_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %29 = v_lshlrev_b32_lit %tid, 4
  %30 = slice %lhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %lhs = global_load_b128 %29, %30
  %32 = v_lshlrev_b32_lit %tid, 4
  %33 = slice %rhs_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %rhs = global_load_b128 %32, %33
  %lhs0 = slice %lhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs0 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane0 = v_add_f32 %lhs0, %rhs0
  %lhs1 = slice %lhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs1 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane1 = v_mul_f32 %lhs1, %rhs1
  %lhs2 = slice %lhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs2 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %lane2 = v_sub_f32 %lhs2, %rhs2
  %lhs3 = slice %lhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %rhs3 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %bias = v_mov_b32 1056964608
  %lane3 = v_fma_f32 %lhs3, %rhs3, %bias
  %result = concat(%lane0, %lane1, %lane2, %lane3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %49 = v_lshlrev_b32_lit %tid, 4
  %50 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %49, %result, %50
  return
}
