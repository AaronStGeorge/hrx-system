  %lhs = concat(%32, %34) : (reg<amdgpu.vgpr x4>, reg<amdgpu.vgpr x4>) -> reg<amdgpu.vgpr x8>
  %39 = global_load_b128 %31, %rhs_view
  %41 = global_load_b128 %31, %rhs_view {offset = 16}
  %rhs = concat(%39, %41) : (reg<amdgpu.vgpr x4>, reg<amdgpu.vgpr x4>) -> reg<amdgpu.vgpr x8>
  %45 = v_lshlrev_b32_lit %23, 2
  %46 = global_load_b32 %45, %init_view
  %48 = global_load_b32 %45, %init_view {offset = 128}
  %50 = global_load_b32 %45, %init_view {offset = 256}
  %52 = global_load_b32 %45, %init_view {offset = 384}
  %54 = global_load_b32 %45, %init_view {offset = 512}
  %56 = global_load_b32 %45, %init_view {offset = 640}
  %58 = global_load_b32 %45, %init_view {offset = 768}
  %60 = global_load_b32 %45, %init_view {offset = 896}
  %init = concat(%46, %48, %50, %52, %54, %56, %58, %60) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  %result = v_wmma_f32_16x16x16_f16 %lhs, %rhs, %init
  %65 = slice %result[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %65, %out_view
  %67 = slice %result[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %67, %out_view {offset = 128}
  %69 = slice %result[2] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %69, %out_view {offset = 256}
  %71 = slice %result[3] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %71, %out_view {offset = 384}
  %73 = slice %result[4] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %73, %out_view {offset = 512}
  %75 = slice %result[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %75, %out_view {offset = 640}
  %77 = slice %result[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %77, %out_view {offset = 768}
  %79 = slice %result[7] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32 %45, %79, %out_view {offset = 896}
