func.def target(@target) @scaled_wmma_f8_selectors(%lhs_data: vector<16xi32>, %rhs_data: vector<16xi32>, %init_data: vector<8xf32>, %scale_a: vector<1xi32>, %scale_b: vector<1xi32>) -> (vector<8xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 128 : index
  %schema = encoding.define #matrix_operand<element_format=f8e5m2, payload_elements=64, payload_registers=16, scale_format=f8e4m3, scale_group_elements=32, scale_operands=1, scale_topology=block_1d, zero_scale_fallback=true> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {scale = %scale_a : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {scale = %scale_b : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xi32>, vector<16xi32>, vector<8xf32>
  func.return %result : vector<8xf32>
}

