  %36 = slice %first[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %37 = slice %bias_data[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %38 = v_add_f32 %36, %37
  %39 = slice %first[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %40 = slice %bias_data[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
