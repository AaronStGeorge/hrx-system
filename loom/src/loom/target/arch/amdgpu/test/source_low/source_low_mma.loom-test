low.func.def target(@target) abi(hal_kernel) @f16_wmmar3_epilogue_add_init(%lhs: reg<amdgpu.vgpr x8>, %rhs: reg<amdgpu.vgpr x8>, %init: reg<amdgpu.vgpr x8>, %bias_data: reg<amdgpu.vgpr x8>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %first = v_wmma_f32_16x16x16_f16 %lhs, %rhs, %init
  %20 = slice %first[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %21 = slice %bias_data[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %22 = v_add_f32 %20, %21
  %23 = slice %first[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %24 = slice %bias_data[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %25 = v_add_f32 %23, %24
  %26 = slice %first[2] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %27 = slice %bias_data[2] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %28 = v_add_f32 %26, %27
  %29 = slice %first[3] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %30 = slice %bias_data[3] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %31 = v_add_f32 %29, %30
  %32 = slice %first[4] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %33 = slice %bias_data[4] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %34 = v_add_f32 %32, %33
  %35 = slice %first[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %36 = slice %bias_data[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %37 = v_add_f32 %35, %36
  %38 = slice %first[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %39 = slice %bias_data[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %40 = v_add_f32 %38, %39
  %41 = slice %first[7] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %42 = slice %bias_data[7] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %43 = v_add_f32 %41, %42
  %biased = concat(%22, %25, %28, %31, %34, %37, %40, %43) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  %second = v_wmma_f32_16x16x16_f16 %lhs, %rhs, %biased
  return %second
}

