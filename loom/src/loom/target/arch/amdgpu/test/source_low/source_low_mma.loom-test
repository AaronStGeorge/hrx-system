amdgpu.target<gfx1100> @target
kernel.def target(@target) @f16_wmmar3_fragment_memory_workgroup(%lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %unit = index.constant 1 : index
  %workgroup_size = index.constant 32 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %scratch_bytes = index.constant 512 : offset
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 31)] : index
  %rhs_layout = encoding.layout.strided [1, 16] : encoding<layout>
  %lhs_buffer_view = buffer.view %lhs_buffer[%base] : buffer -> view<32x8xf16, #dense>
  %rhs_buffer_view = buffer.view %rhs_buffer[%base] : buffer -> view<32x8xf16, #dense>
  %init_view = buffer.view %init_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %lhs_scratch = buffer.alloca %scratch_bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %rhs_scratch = buffer.alloca %scratch_bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %lhs_scratch_stage = buffer.view %lhs_scratch[%base] : buffer -> view<32x8xf16, #dense>
  %rhs_scratch_stage = buffer.view %rhs_scratch[%base] : buffer -> view<32x8xf16, #dense>
  %lhs_loaded = vector.load %lhs_buffer_view[%tid, 0] : view<32x8xf16, #dense> -> vector<8xf16>
  %rhs_loaded = vector.load %rhs_buffer_view[%tid, 0] : view<32x8xf16, #dense> -> vector<8xf16>
  vector.store %lhs_loaded, %lhs_scratch_stage[%tid, 0] : vector<8xf16>, view<32x8xf16, #dense>
  vector.store %rhs_loaded, %rhs_scratch_stage[%tid, 0] : vector<8xf16>, view<32x8xf16, #dense>
  kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}
  %lhs_scratch_tile = buffer.view %lhs_scratch[%base] : buffer -> view<16x16xf16, #dense>
  %rhs_scratch_tile = buffer.view %rhs_scratch[%base] : buffer -> view<16x16xf16, %rhs_layout>
  %lhs = vector.fragment.load<lhs> %lhs_scratch_tile[0, 0] shape [%m, %k] : view<16x16xf16, #dense> -> vector<16xf16>
  %rhs = vector.fragment.load<rhs> %rhs_scratch_tile[0, 0] shape [%k, %n] : view<16x16xf16, %rhs_layout> -> vector<16xf16>
  %init = vector.fragment.load<init> %init_view[0, 0] shape [%m, %n] : view<16x16xf32, #dense> -> vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xf16>, vector<16xf16>, vector<8xf32>
  vector.fragment.store<result> %result, %out_view[0, 0] shape [%m, %n] : vector<8xf32>, view<16x16xf32, #dense>
  kernel.return
}

