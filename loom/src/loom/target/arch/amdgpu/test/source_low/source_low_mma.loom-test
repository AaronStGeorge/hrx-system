// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @f16_wmmar3(%lhs_data: vector<16xf16>, %rhs_data: vector<16xf16>, %init_data: vector<8xf32>) -> (vector<8xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<16xf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<16xf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xf16>, vector<16xf16>, vector<8xf32>
  func.return %result : vector<8xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f16_wmmar3(%lhs: reg<amdgpu.vgpr x8>, %rhs: reg<amdgpu.vgpr x8>, %init: reg<amdgpu.vgpr x8>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %result = v_wmma_f32_16x16x16_f16 %lhs, %rhs, %init
  return %result
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @f16_wmmar3_wrong_payload(%lhs_data: vector<8xf16>, %rhs_data: vector<8xf16>, %init_data: vector<8xf32>) -> (vector<8xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<8xf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<8xf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  // ERROR@+1: BACKEND/001 "no AMDGPU matrix descriptor matches the physical operand payload shapes"
  %result = vector.mma %lhs, %rhs, %init : vector<8xf16>, vector<8xf16>, vector<8xf32>
  func.return %result : vector<8xf32>
}

// ====

amdgpu.target<gfx1250> @target
func.def target(@target) @scaled_wmma_f8_selectors(%lhs_data: vector<16xi32>, %rhs_data: vector<16xi32>, %init_data: vector<8xf32>, %scale_a: vector<1xi32>, %scale_b: vector<1xi32>) -> (vector<8xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 128 : index
  %schema = encoding.define #matrix_operand<element_format=f8e5m2, payload_elements=64, payload_registers=16, scale_format=f8e4m3, scale_group_elements=32, scale_operands=1, scale_topology=block_1d, zero_scale_fallback=true> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {scale = %scale_a : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {scale = %scale_b : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xi32>, vector<16xi32>, vector<8xf32>
  func.return %result : vector<8xf32>
}

// ----

low.func.def target(@target) abi(hal_kernel) @scaled_wmma_f8_selectors(%lhs: reg<amdgpu.vgpr x16>, %rhs: reg<amdgpu.vgpr x16>, %init: reg<amdgpu.vgpr x8>, %scale_a: reg<amdgpu.vgpr>, %scale_b: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna4.gfx125x.core> {
  %result = v_wmma_scale_f32_16x16x128_f8f6f4_f8_f8 %lhs, %rhs, %init, %scale_a, %scale_b {matrix_a_fmt = 1, matrix_b_fmt = 1, matrix_a_scale = 0, matrix_b_scale = 0, matrix_a_scale_fmt = 2, matrix_b_scale_fmt = 2, matrix_a_reuse = 0, matrix_b_reuse = 0}
  return %result
}

// ====

amdgpu.target<gfx1250> @target
func.def target(@target) @scaled_wmma_missing_scale_format(%lhs_data: vector<16xi32>, %rhs_data: vector<16xi32>, %init_data: vector<8xf32>, %scale: vector<1xi32>) -> (vector<8xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 128 : index
  %schema = encoding.define #matrix_operand<element_format=f8e5m2, payload_elements=64, payload_registers=16, scale_group_elements=32, scale_operands=1, scale_topology=block_1d, zero_scale_fallback=true> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {scale = %scale : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {scale = %scale : vector<1xi32>, schema = %schema : encoding<schema>} : vector<16xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<8xf32>
  // ERROR@+1: BACKEND/001 "the selected AMDGPU matrix descriptor requires scale format selector facts"
  %result = vector.mma %lhs, %rhs, %init : vector<16xi32>, vector<16xi32>, vector<8xf32>
  func.return %result : vector<8xf32>
}
