amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_scan_cluster_rejected() {
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup scan lowering requires full subgroup scans with cluster_size and cluster_stride absent"
  %prefix = kernel.subgroup.scan<addi> %value {cluster_size = 16, direction = forward, mode = inclusive} : i32
  kernel.return
}

