// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_match_any_requires_legalization() {
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup match requires target legalization before source-to-low"
  %mask = kernel.subgroup.match.any %value : i32 -> i64
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_match_all_requires_legalization() {
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup match requires target legalization before source-to-low"
  %mask, %all = kernel.subgroup.match.all %value : i32 -> i64, i1
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_vote_ballot_uniform_predicate_rejected() {
  %lhs = scalar.constant 1 : i32
  %rhs = scalar.constant 2 : i32
  %predicate = scalar.cmpi slt, %lhs, %rhs : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup vote.ballot lowering requires a divergent i1 predicate"
  %mask = kernel.subgroup.vote.ballot %predicate : i1 -> i32
  kernel.return
}

