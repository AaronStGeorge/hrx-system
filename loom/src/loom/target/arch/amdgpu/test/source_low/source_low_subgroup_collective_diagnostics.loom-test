// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_broadcast_dynamic_lane_rejected(%input: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %lane_vector = vector.load %input_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %lane = vector.extract %lane_vector[0] : vector<1xi32> -> i32
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup broadcast requires an exact source lane"
  %broadcast = kernel.subgroup.broadcast %value from %lane : i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_broadcast_lane_out_of_range_rejected() {
  %value = scalar.constant 1 : i32
  %lane = scalar.constant 32 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup broadcast source lane must be within the selected wave32 or wave64 subgroup"
  %broadcast = kernel.subgroup.broadcast %value from %lane : i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_broadcast_payload_rejected() {
  %value = vector.constant 1 : vector<4xi8>
  %lane = scalar.constant 0 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup broadcast requires an i32 or f32 scalar"
  %broadcast = kernel.subgroup.broadcast %value from %lane : vector<4xi8>, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_broadcast_first_payload_rejected() {
  %value = vector.constant 1 : vector<4xi8>
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup broadcast.first requires an i32 or f32 scalar"
  %broadcast = kernel.subgroup.broadcast.first %value : vector<4xi8>
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_shuffle_dynamic_offset_rejected(%input: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %offset_vector = vector.load %input_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %offset = vector.extract %offset_vector[0] : vector<1xi32> -> i32
  %width = scalar.constant 32 : i32
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup shuffle requires an exact lane offset"
  %shuffle, %valid = kernel.subgroup.shuffle<xor> %value, %offset, %width : i32, i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_shuffle_partial_width_rejected() {
  %value = scalar.constant 1 : i32
  %offset = scalar.constant 1 : i32
  %width = scalar.constant 16 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup shuffle currently requires full selected wave32 or wave64 width"
  %shuffle, %valid = kernel.subgroup.shuffle<down> %value, %offset, %width : i32, i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_shuffle_offset_out_of_range_rejected() {
  %value = scalar.constant 1 : i32
  %offset = scalar.constant 32 : i32
  %width = scalar.constant 32 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup shuffle offset/index must be within the selected wave32 or wave64 subgroup"
  %shuffle, %valid = kernel.subgroup.shuffle<index> %value, %offset, %width : i32, i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_shuffle_payload_rejected() {
  %value = vector.constant 1 : vector<4xi8>
  %offset = scalar.constant 0 : i32
  %width = scalar.constant 32 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup shuffle requires an i32 or f32 scalar"
  %shuffle, %valid = kernel.subgroup.shuffle<index> %value, %offset, %width : vector<4xi8>, i32, i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_reduce_cluster_rejected() {
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup reduce lowering requires full subgroup reductions with cluster_size and cluster_stride absent"
  %sum = kernel.subgroup.reduce<addi> %value {cluster_size = 16} : i32
  kernel.return
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_reduce_kind_rejected() {
  %value = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup reduce requires an i32 add/mul/and/or/xor or f32 add/mul/minnum/maxnum combining kind"
  %min = kernel.subgroup.reduce<minsi> %value : i32
  kernel.return
}

