// RUN: emit source-low output=low

amdgpu.target<gfx950> @target
kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_active_mask_i32_wave64_rejected() {
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup mask lowering requires an i64 mask result on wave64 targets"
  %mask = kernel.subgroup.active.mask : i32
  kernel.return
}
