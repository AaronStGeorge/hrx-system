  // ERROR@+1: BACKEND/001 "AMDGPU subgroup scan requires an i32 add/mul/and/or/xor or f32 add/mul/minnum/maxnum combining kind"
  %prefix = kernel.subgroup.scan<minsi> %value {direction = forward, mode = inclusive} : i32
  kernel.return
}

