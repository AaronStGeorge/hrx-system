func.def @i32_scalar_2d_store(%input: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4x8xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4x8xi32, #dense>
  %loaded = vector.load %input_view[%y, %x] : view<4x8xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%y, %x] : vector<1xi32>, view<4x8xi32, #dense>
  func.return
}

