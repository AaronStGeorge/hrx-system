  %raise = concat(%19, %20, %21, %22) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %24 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = slice %raise[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %26 = v_add_u32 %24, %25
  %27 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %28 = slice %raise[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %29 = v_add_u32 %27, %28
  %30 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %31 = slice %raise[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = v_add_u32 %30, %31
  %33 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = slice %raise[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = v_add_u32 %33, %34
  %raised = concat(%26, %29, %32, %35) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %37 = v_mov_b32 4
  %38 = v_mov_b32 4
  %39 = v_mov_b32 4
  %40 = v_mov_b32 4
  %drop = concat(%37, %38, %39, %40) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %42 = slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %43 = slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %44 = v_sub_nc_u32 %42, %43
  %45 = slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %46 = slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %47 = v_sub_nc_u32 %45, %46
  %48 = slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %49 = slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %50 = v_sub_nc_u32 %48, %49
  %51 = slice %raised[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %52 = slice %drop[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %53 = v_sub_nc_u32 %51, %52
  %result = concat(%44, %47, %50, %53) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %55 = v_mov_b32 4
  %56 = v_lshlrev_b32 %55, %tid
  %57 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %56, %result, %57 {offset = 0}
