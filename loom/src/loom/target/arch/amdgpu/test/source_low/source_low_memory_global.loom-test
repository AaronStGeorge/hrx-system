  low.br ^loop(%next: reg<amdgpu.vgpr x2>)
^_bb3:
  %38 = s_mov_b64_exec_read
  low.br ^loop(%26: reg<amdgpu.vgpr x2>)
^_bb4:
  s_mov_b64_exec %38
  return
}
