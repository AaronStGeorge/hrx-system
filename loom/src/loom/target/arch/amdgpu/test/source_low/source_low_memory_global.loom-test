low.kernel.def target(@target) workgroup_size(16, 1, 1) @rank2_vector_tile_transpose() asm<amdgpu.rdna3.core> {
  %block = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %tile_base = v_lshlrev_b32_lit %block, 2
  %59 = v_lshlrev_b32_src0_inline %tile_base, 2
  %60 = global_load_b128_saddr %59, %input_view
  %65 = global_load_b128_saddr %59, %input_view {offset = 256}
  %70 = global_load_b128_saddr %59, %input_view {offset = 512}
  %75 = global_load_b128_saddr %59, %input_view {offset = 768}
