  %14 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %14, 1023
  %zero = s_mov_b32 0
  %17 = v_lshlrev_b32_lit %y, 5
  %18 = v_lshlrev_b32_lit %x, 2
  %19 = v_add_u32 %17, %18
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %19, %20
  %22 = v_lshlrev_b32_lit %y, 5
  %23 = v_lshlrev_b32_lit %x, 2
  %24 = v_add_u32 %22, %23
  %25 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %24, %loaded, %25
  return
