low.kernel.def target(@target) @i32_b128() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %16 = v_lshlrev_b32_lit %tid, 4
  %17 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %16, %17
  %19 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_add_u32_lit %19, 9
  %21 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = v_add_u32_lit %21, 9
  %23 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %24 = v_add_u32_lit %23, 9
  %25 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %26 = v_add_u32_lit %25, 9
  %raised = concat(%20, %22, %24, %26) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %28 = v_mov_b32 4
  %29 = v_mov_b32 4
  %30 = v_mov_b32 4
  %31 = v_mov_b32 4
  %drop = concat(%28, %29, %30, %31) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %33 = slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = v_sub_nc_u32 %33, %34
  %36 = slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %37 = slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %38 = v_sub_nc_u32 %36, %37
  %39 = slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %40 = slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %41 = v_sub_nc_u32 %39, %40
  %42 = slice %raised[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %43 = slice %drop[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %44 = v_sub_nc_u32 %42, %43
  %result = concat(%35, %38, %41, %44) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %46 = v_lshlrev_b32_lit %tid, 4
  %47 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %46, %result, %47
  return
}

