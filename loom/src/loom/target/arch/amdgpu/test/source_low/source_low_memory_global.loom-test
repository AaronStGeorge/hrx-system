low.func.def target(@target) abi(hal_kernel) @descriptor_b128_off_zero() -> (reg<amdgpu.vgpr x4>) {
  %input_view = low.resource<hal_binding> {extent = 16, index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %8 = low.op<amdgpu.hal.buffer_descriptor>(%input_view) {cache_swizzle_stride = 0, extent = 16} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  %loaded = low.op<amdgpu.buffer_load_b128_off_zero>(%8) {offset = 0} : (reg<amdgpu.sgpr x4>) -> reg<amdgpu.vgpr x4>
  low.return %loaded : reg<amdgpu.vgpr x4>
}

