  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 280} : reg<amdgpu.sgpr x2>
  %25 = s_mov_b32 2
  %source_base = s_lshl_b32 %workgroup, %25
  %output_prefix = s_mov_b32 6
  %output_base = s_add_u32 %source_base, %output_prefix
  %29 = s_lshl_b32_rhs_inline %source_base, 2
  %loaded = s_load_dwordx4 %input_view, %29
  %31 = slice %loaded[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %32 = v_mov_b32_copy %31
  %33 = slice %loaded[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %34 = v_mov_b32_copy %33
  %35 = slice %loaded[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %36 = v_mov_b32_copy %35
  %37 = slice %loaded[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %38 = v_mov_b32_copy %37
  %39 = concat(%32, %34, %36, %38) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %40 = v_mov_b32 0
  %41 = s_lshl_b32_rhs_inline %output_base, 2
  %42 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %43 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %44 = s_mov_b32 0
  %45 = s_add_u32 %42, %41
  %46 = s_addc_u32 %43, %44
  %47 = concat(%45, %46) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b128_saddr %40, %39, %47
  return
