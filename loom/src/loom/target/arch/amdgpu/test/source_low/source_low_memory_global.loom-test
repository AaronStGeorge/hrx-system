kernel.def target(@target) @i32_readonly_uniform_smem(%input: buffer, %output: buffer) {
  %unit = index.constant 1 : index
  %workgroups = index.constant 16 : index
  %workgroup_size = index.constant 64 : index
  kernel.launch.config workgroups(%workgroups, %unit, %unit) workgroup_size(%workgroup_size, %unit, %unit) : index
} launch {
  %workgroup = kernel.workgroup.id<x> : index
  %base = index.constant 0 : offset
  %input_global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %input_noalias = buffer.assume.noalias %input_global : buffer
  %output_global = buffer.assume.memory_space %output {memory_space = global} : buffer
  %output_noalias = buffer.assume.noalias %output_global : buffer
  %input_view = buffer.view %input_noalias[%base] : buffer -> view<16x2xi32, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<16xi32, #dense>
  %loaded = vector.load %input_view[%workgroup, 0] : view<16x2xi32, #dense> -> vector<2xi32>
  %lane = vector.extract %loaded[0] : vector<2xi32> -> i32
  view.store %lane, %output_view[%workgroup] : i32, view<16xi32, #dense>
  kernel.return
}

