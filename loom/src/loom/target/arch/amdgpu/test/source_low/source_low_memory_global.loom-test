amdgpu.target<gfx1100> @target
kernel.def target(@target) @i32_b128(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %raise = vector.constant 9 : vector<4xi32>
  %raised = vector.addi %loaded, %raise : vector<4xi32>
  %drop = vector.constant 4 : vector<4xi32>
  %result = vector.subi %raised, %drop : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @i32_b128() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %15 = v_lshlrev_b32_lit %tid, 4
  %loaded = global_load_b128 %15, %input_view
  %17 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_add_u32_lit %17, 9
  %19 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_add_u32_lit %19, 9
  %21 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = v_add_u32_lit %21, 9
  %23 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %24 = v_add_u32_lit %23, 9
  %raised = concat(%18, %20, %22, %24) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %26 = v_mov_b32 4
  %27 = v_mov_b32 4
  %28 = v_mov_b32 4
  %29 = v_mov_b32 4
  %drop = concat(%26, %27, %28, %29) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %31 = slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %33 = v_sub_nc_u32 %31, %32
  %34 = slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %36 = v_sub_nc_u32 %34, %35
  %37 = slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %38 = slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %39 = v_sub_nc_u32 %37, %38
  %40 = slice %raised[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %41 = slice %drop[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %42 = v_sub_nc_u32 %40, %41
  %result = concat(%33, %36, %39, %42) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %44 = v_lshlrev_b32_lit %tid, 4
  global_store_b128 %44, %result, %output_view
  return
}

