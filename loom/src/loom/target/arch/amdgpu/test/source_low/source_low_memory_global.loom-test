low.kernel.def target(@target) @i32_scalar_2d_store() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x4>
  %x = v_and_b32_lit %packed_tid, 1023
  %14 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %14, 1023
  %16 = v_lshlrev_b32_lit %y, 5
  %17 = v_lshlrev_b32_lit %x, 2
  %18 = v_add_u32 %16, %17
  %19 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %18, %19
  %21 = v_lshlrev_b32_lit %y, 5
  %22 = v_lshlrev_b32_lit %x, 2
  %23 = v_add_u32 %21, %22
  %24 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %23, %loaded, %24
  return
}

