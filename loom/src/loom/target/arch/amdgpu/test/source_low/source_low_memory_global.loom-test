low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_readonly_uniform_smem_loop_bound() asm<amdgpu.rdna3.core> {
  %control_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %input_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %start = s_mov_b32 0
  %step = s_mov_b32 1
  %zero = v_mov_b32 0
  %limit = s_load_dword %control_view, %start
  low.br ^_bb1(%start: reg<amdgpu.sgpr>, %zero: reg<amdgpu.vgpr>)
^_bb1(%position: reg<amdgpu.sgpr>, %current_sum: reg<amdgpu.vgpr>):
  %42 = s_cmp_lt_i32 %position, %limit
  low.cond_br %42, ^_bb2, ^_bb3 : reg<amdgpu.scc>
^_bb2:
  %43 = s_mov_b32 2
  %44 = s_lshl_b32 %position, %43
  %loaded = s_load_dword %input_view, %44
  %next_sum = v_add_f32 %loaded, %current_sum
  %47 = s_add_u32 %position, %step
  low.br ^_bb1(%47: reg<amdgpu.sgpr>, %next_sum: reg<amdgpu.vgpr>)
^_bb3:
  global_store_b32_saddr %zero, %current_sum, %output_view
  return
}

