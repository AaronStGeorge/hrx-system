// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @global_saddr_fallback(%input: buffer, %output: buffer) {
  %base = index.constant 4 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @global_saddr_fallback() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 20} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 20} : reg<amdgpu.sgpr x2>
  %8 = v_mov_b32 0
  %loaded = global_load_b128_saddr %8, %input_view {offset = 4}
  global_store_b128_saddr %8, %loaded, %output_view {offset = 4}
  return
}

