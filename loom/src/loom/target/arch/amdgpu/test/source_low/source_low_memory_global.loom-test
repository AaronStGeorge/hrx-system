low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_readonly_uniform_smem_scalar_branch() asm<amdgpu.rdna3.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %21 = s_mov_b32 2
  %22 = s_lshl_b32 %workgroup, %21
  %loaded = s_load_dword %input_view, %22
  %zero = s_mov_b32 0
  %negative = s_cmp_lt_i32 %loaded, %zero
  low.cond_br %negative, ^then, ^join : reg<amdgpu.scc>
^then:
  %26 = v_mov_b32_copy %zero
  %27 = v_mov_b32 0
  %29 = concat(%workgroup, %zero) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %31 = s_lshl_b64 %29, %21
  %32 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %33 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %34 = slice %31[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %35 = slice %31[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %36 = s_add_u32 %32, %34
  %37 = s_addc_u32 %33, %35
  %38 = concat(%36, %37) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b32_saddr %27, %26, %38
  low.br ^join
^join:
  return
}

