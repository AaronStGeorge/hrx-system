  %89 = slice %75[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %90 = slice %75[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %91 = slice %75[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %114 = concat(%76, %80, %84, %88) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %116 = v_lshlrev_b32_src0_inline %tile_base, 4
  global_store_b128_saddr %116, %114, %output_view
  %121 = concat(%77, %81, %85, %89) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %116, %121, %output_view {offset = 16}
  %129 = concat(%78, %82, %86, %90) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %116, %129, %output_view {offset = 32}
  %137 = concat(%79, %83, %87, %91) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %116, %137, %output_view {offset = 48}
