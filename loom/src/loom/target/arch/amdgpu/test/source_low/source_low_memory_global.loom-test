  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x4>
  %11 = v_mov_b32 1023
  %x = v_and_b32 %packed_tid, %11
  %13 = v_mov_b32 10
  %14 = v_lshrrev_b32 %13, %packed_tid
  %15 = v_mov_b32 1023
  %y = v_and_b32 %14, %15
  %zero = s_mov_b32 0
  %18 = v_mov_b32 5
  %19 = v_lshlrev_b32 %18, %y
  %20 = v_mov_b32 2
  %21 = v_lshlrev_b32 %20, %x
  %22 = v_add_u32 %19, %21
  %23 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %22, %23 {offset = 0}
  %25 = v_mov_b32 5
  %26 = v_lshlrev_b32 %25, %y
  %27 = v_mov_b32 2
  %28 = v_lshlrev_b32 %27, %x
  %29 = v_add_u32 %26, %28
  %30 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %29, %loaded, %30 {offset = 0}
