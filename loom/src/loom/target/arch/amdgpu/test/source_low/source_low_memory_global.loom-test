low.kernel.def target(@target) workgroup_size(1, 1, 1) @i32_b128() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %20 = v_mov_b32 0
  %loaded = global_load_b128 %20, %input_view
  %22 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_add_u32_lit %22, 9
  %24 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = v_add_u32_lit %24, 9
  %26 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %27 = v_add_u32_lit %26, 9
  %28 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %29 = v_add_u32_lit %28, 9
  %31 = v_mov_b32 4
  %38 = v_sub_nc_u32 %23, %31
  %41 = v_sub_nc_u32 %25, %31
  %44 = v_sub_nc_u32 %27, %31
  %47 = v_sub_nc_u32 %29, %31
  %result = concat(%38, %41, %44, %47) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128 %20, %result, %output_view
  return
}

