low.kernel.def target(@target) workgroup_size(1, 1, 1) @f32x4_readonly_uniform_smem_copy() asm<amdgpu.rdna3.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 280} : reg<amdgpu.sgpr x2>
  %27 = s_mov_b32 2
  %source_base = s_lshl_b32 %workgroup, %27
  %output_prefix = s_mov_b32 6
  %output_base = s_add_u32 %source_base, %output_prefix
  %32 = s_lshl_b32 %source_base, %27
  %loaded = s_load_dwordx4 %input_view, %32
  %34 = slice %loaded[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %35 = v_mov_b32_copy %34
  %36 = slice %loaded[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %37 = v_mov_b32_copy %36
  %38 = slice %loaded[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %39 = v_mov_b32_copy %38
  %40 = slice %loaded[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %41 = v_mov_b32_copy %40
  %42 = concat(%35, %37, %39, %41) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %43 = v_mov_b32 0
  %44 = s_mov_b32 0
  %45 = concat(%output_base, %44) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %47 = s_lshl_b64 %45, %27
  %48 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %49 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %50 = slice %47[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %51 = slice %47[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %52 = s_add_u32 %48, %50
  %53 = s_addc_u32 %49, %51
  %54 = concat(%52, %53) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b128_saddr %43, %42, %54
  return
}

