low.func.def target(@target) abi(hal_kernel) @i32_b128() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %15 = v_mov_b32 4
  %16 = v_lshlrev_b32 %15, %tid
  %17 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %16, %17 {offset = 0}
  %19 = v_mov_b32 9
  %20 = v_mov_b32 9
  %21 = v_mov_b32 9
