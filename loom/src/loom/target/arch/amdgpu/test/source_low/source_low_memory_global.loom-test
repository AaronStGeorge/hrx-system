// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_global.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @global_saddr_fallback(%input: buffer, %output: buffer) {
  %base = index.constant 4 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @global_saddr_fallback() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 20} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 20} : reg<amdgpu.sgpr x2>
  %8 = v_mov_b32 0
  %loaded = global_load_b128 %8, %input_view {offset = 4}
  %10 = v_mov_b32 0
  global_store_b128 %10, %loaded, %output_view {offset = 4}
  return
}

// ====

amdgpu.target<gfx1100> @target
kernel.def target(@target) @i32_b128(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %raise = vector.constant 9 : vector<4xi32>
  %raised = vector.addi %loaded, %raise : vector<4xi32>
  %drop = vector.constant 4 : vector<4xi32>
  %result = vector.subi %raised, %drop : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @i32_b128() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %18 = v_mov_b32 0
  %loaded = global_load_b128 %18, %input_view
  %20 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %21 = v_add_u32_lit %20, 9
  %22 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_add_u32_lit %22, 9
  %24 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = v_add_u32_lit %24, 9
  %26 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %27 = v_add_u32_lit %26, 9
  %raised = concat(%21, %23, %25, %27) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %29 = v_mov_b32 4
  %30 = v_mov_b32 4
  %31 = v_mov_b32 4
  %32 = v_mov_b32 4
  %drop = concat(%29, %30, %31, %32) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %34 = slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %36 = v_sub_nc_u32 %34, %35
  %37 = slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %38 = slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %39 = v_sub_nc_u32 %37, %38
  %40 = slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %41 = slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %42 = v_sub_nc_u32 %40, %41
  %43 = slice %raised[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %44 = slice %drop[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %45 = v_sub_nc_u32 %43, %44
  %result = concat(%36, %39, %42, %45) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %47 = v_mov_b32 0
  global_store_b128 %47, %result, %output_view
  return
}

