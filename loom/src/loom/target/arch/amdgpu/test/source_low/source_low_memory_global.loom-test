low.kernel.def target(@target) @i32_b128() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %15 = v_lshlrev_b32_lit %tid, 4
  %16 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %15, %16
  %18 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = v_add_u32_lit %18, 9
  %20 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %21 = v_add_u32_lit %20, 9
  %22 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_add_u32_lit %22, 9
  %24 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = v_add_u32_lit %24, 9
  %raised = concat(%19, %21, %23, %25) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %27 = v_mov_b32 4
  %28 = v_mov_b32 4
  %29 = v_mov_b32 4
  %30 = v_mov_b32 4
  %drop = concat(%27, %28, %29, %30) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %32 = slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %33 = slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = v_sub_nc_u32 %32, %33
  %35 = slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %36 = slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %37 = v_sub_nc_u32 %35, %36
  %38 = slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %39 = slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %40 = v_sub_nc_u32 %38, %39
  %41 = slice %raised[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %42 = slice %drop[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %43 = v_sub_nc_u32 %41, %42
  %result = concat(%34, %37, %40, %43) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %45 = v_lshlrev_b32_lit %tid, 4
  %46 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %45, %result, %46
  return
}

