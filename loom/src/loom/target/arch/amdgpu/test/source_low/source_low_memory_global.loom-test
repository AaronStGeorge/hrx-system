low.kernel.def target(@target) @i32_scalar_2d_store() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %x = v_and_b32_lit %packed_tid, 1023
  %14 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %14, 1023
  %16 = v_lshlrev_b32_lit %y, 5
  %17 = v_lshlrev_b32_lit %x, 2
  %18 = v_add_u32 %16, %17
  %loaded = global_load_b32 %18, %input_view
  %20 = v_lshlrev_b32_lit %y, 5
  %21 = v_lshlrev_b32_lit %x, 2
  %22 = v_add_u32 %20, %21
  global_store_b32 %22, %loaded, %output_view
  return
}

