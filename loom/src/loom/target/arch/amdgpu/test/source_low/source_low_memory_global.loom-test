  %85 = slice %70[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %86 = slice %70[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %87 = slice %70[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
