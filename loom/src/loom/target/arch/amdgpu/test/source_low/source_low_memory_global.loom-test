low.kernel.def target(@target) workgroup_size(1, 1, 1) @i32_scalar_2d_store() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %x = v_and_b32_lit %packed_tid, 1023
  %17 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %17, 1023
  %19 = v_mov_b32 0
  %loaded = global_load_b32 %19, %input_view
  %21 = v_mov_b32 0
  global_store_b32 %21, %loaded, %output_view
  return
}

