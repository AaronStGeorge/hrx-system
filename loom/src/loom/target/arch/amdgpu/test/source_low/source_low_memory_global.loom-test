// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @global_saddr_fallback(%input: buffer, %output: buffer) {
  %base = index.constant 4 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @global_saddr_fallback() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 20} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 20} : reg<amdgpu.sgpr x4>
  %base = s_mov_b32 4
  %9 = v_mov_b32 0
  %10 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %9, %10 {offset = 4}
  %12 = v_mov_b32 0
  %13 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %12, %loaded, %13 {offset = 4}
  return
}

