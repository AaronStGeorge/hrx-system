low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_readonly_uniform_smem() asm<amdgpu.rdna3.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 128} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %29 = s_mov_b32 3
  %30 = s_lshl_b32 %workgroup, %29
  %lane = s_load_dword %input_view, %30
  %32 = v_mov_b32_copy %lane
  %33 = v_mov_b32 0
  %34 = s_mov_b32 0
  %35 = concat(%workgroup, %34) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %36 = s_mov_b32 2
  %37 = s_lshl_b64 %35, %36
  %38 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %39 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %40 = slice %37[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %41 = slice %37[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %42 = s_add_u32 %38, %40
  %43 = s_addc_u32 %39, %41
  %44 = concat(%42, %43) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b32_saddr %33, %32, %44
  return
}

