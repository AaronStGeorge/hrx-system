low.kernel.def target(@target) workgroup_size(32, 1, 1) @i32_dynamic_leading_dim_global_saddr(%columns: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %column = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %zero = s_mov_b32 0
  %19 = v_mov_b32_copy %zero
  %20 = v_lshlrev_b32_lit %column, 5
  %25 = s_mul_i32 %workgroup, %columns
  %26 = s_mul_hi_u32 %workgroup, %columns
  %27 = s_mul_i32 %zero, %columns
  %28 = s_add_u32 %26, %27
  %29 = concat(%25, %28) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %30 = s_mov_b32 5
  %31 = s_lshl_b64 %29, %30
  %32 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %33 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %34 = slice %31[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %35 = slice %31[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %36 = s_add_u32 %32, %34
  %37 = s_addc_u32 %33, %35
  %38 = concat(%36, %37) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b32 %20, %19, %38
  return
}

