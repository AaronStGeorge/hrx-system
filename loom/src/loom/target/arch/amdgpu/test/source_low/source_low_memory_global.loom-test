low.func.def target(@target) abi(hal_kernel) @global_saddr_fallback() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 20} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 20} : reg<amdgpu.sgpr x2>
  %8 = v_mov_b32 0
  %loaded = global_load_b128_saddr %8, %input_view {offset = 4}
  global_store_b128_saddr %8, %loaded, %output_view {offset = 4}
  return
}

