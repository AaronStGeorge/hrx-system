low.kernel.def target(@target) workgroup_size(64, 1, 1) @i32_readonly_uniform_smem() asm<amdgpu.rdna3.core> {
  %workgroup = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 128} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %27 = s_lshl_b32_rhs_inline %workgroup, 3
  %lane = s_load_dword %input_view, %27
  %29 = v_mov_b32_copy %lane
  %30 = v_mov_b32 0
  %31 = s_lshl_b32_rhs_inline %workgroup, 2
  %32 = slice %output_view[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %33 = slice %output_view[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %34 = s_mov_b32 0
  %35 = s_add_u32 %32, %31
  %36 = s_addc_u32 %33, %34
  %37 = concat(%35, %36) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  global_store_b32_saddr %30, %29, %37
  return
}

