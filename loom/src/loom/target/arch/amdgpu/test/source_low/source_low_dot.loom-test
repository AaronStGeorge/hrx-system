// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32_uniform_smem_vector_operands(%lhs: vector<4xf32>, %weights: buffer) -> (f32) {
  %base = index.constant 0 : offset
  %weights_global = buffer.assume.memory_space %weights {memory_space = global} : buffer
  %weights_noalias = buffer.assume.noalias %weights_global : buffer
  %weights_view = buffer.view %weights_noalias[%base] : buffer -> view<2x4xf32, #dense>
  %rhs = vector.load %weights_view[0, 0] : view<2x4xf32, #dense> -> vector<4xf32>
  %bias_vector = vector.load %weights_view[1, 0] : view<2x4xf32, #dense> -> vector<4xf32>
  %bias = vector.extract %bias_vector[0] : vector<4xf32> -> f32
  %scaled = vector.mulf %lhs, %rhs : vector<4xf32>
  %dot = vector.dotf %scaled, %rhs, %bias : vector<4xf32>, vector<4xf32>, f32
  func.return %dot : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32_uniform_smem_vector_operands(%lhs: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %weights_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 32} : reg<amdgpu.sgpr x2>
  %19 = s_mov_b32 0
  %rhs = s_load_dwordx4 %weights_view, %19
  %bias = s_load_dword %weights_view, %19 {offset = 16}
  %23 = slice %rhs[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %24 = slice %lhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %25 = v_mul_f32 %23, %24
  %26 = slice %rhs[1] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %27 = slice %lhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %28 = v_mul_f32 %26, %27
  %29 = slice %rhs[2] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %30 = slice %lhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %31 = v_mul_f32 %29, %30
  %32 = slice %rhs[3] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr>
  %33 = slice %lhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = v_mul_f32 %32, %33
  %38 = v_fma_f32 %25, %23, %bias
  %41 = v_fma_f32 %28, %26, %38
  %44 = v_fma_f32 %31, %29, %41
  %dot = v_fma_f32 %34, %32, %44
  return %dot
}
