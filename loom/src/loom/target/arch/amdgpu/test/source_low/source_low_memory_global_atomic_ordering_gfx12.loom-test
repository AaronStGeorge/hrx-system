// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_global_atomic_ordering.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx12 output=low

func.def @global_atomic_release_reduce_i32(%input: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = release, scope = device} : i32, view<64xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) @global_atomic_release_reduce_i32() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %one = low.const<amdgpu.s_mov_b32> {imm32 = 1} : reg<amdgpu.sgpr>
  %10 = low.const<amdgpu.v_mov_b32> {imm32 = 2} : reg<amdgpu.vgpr>
  %11 = low.op<amdgpu.v_lshlrev_b32>(%10, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %12 = low.slice %view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %13 = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  low.op<amdgpu.global_atomic_add_u32_saddr>(%11, %13, %12) {offset = 0, scope = 2} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>)
  low.return
}

