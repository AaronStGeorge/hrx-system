func.def target(@target) @scalar_erf_rational_constant_edges() -> (f32, f32, f32) {
  %negative_saturation = scalar.constant -4.0 : f32
  %origin = scalar.constant 0.0 : f32
  %positive_saturation = scalar.constant 4.0 : f32
  %negative = scalar.erff %negative_saturation : f32
  %center = scalar.erff %origin : f32
  %positive = scalar.erff %positive_saturation : f32
  func.return %negative, %center, %positive : f32, f32, f32
}
