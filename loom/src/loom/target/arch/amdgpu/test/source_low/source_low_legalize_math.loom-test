amdgpu.target<gfx942> @target

low.func.def target(@target) abi(hal_kernel) @cdna3_native_turn_math(%input: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) {
  %log = low.op<amdgpu.v_log_f32>(%input) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %sin = low.op<amdgpu.v_sin_f32>(%input) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %cos = low.op<amdgpu.v_cos_f32>(%input) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %log, %sin, %cos : reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>
}
