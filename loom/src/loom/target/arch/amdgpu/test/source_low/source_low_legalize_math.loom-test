  %29 = low.op<amdgpu.v_add_u32>(%24, %28) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %30 = low.op<amdgpu.v_lshrrev_b32.src0_inline>(%29) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %31 = low.op<amdgpu.v_lshrrev_b32.src0_inline>(%25) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %32 = low.op<amdgpu.v_and_b32.src0_inline>(%31) {imm32 = 1} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %33 = low.op<amdgpu.v_add_u32.lit>(%32) {imm32 = 32767} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %34 = low.op<amdgpu.v_add_u32>(%25, %33) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %35 = low.op<amdgpu.v_lshrrev_b32.src0_inline>(%34) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %result = low.op<amdgpu.v_cvt_pk_u16_u32>(%30, %35) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}

