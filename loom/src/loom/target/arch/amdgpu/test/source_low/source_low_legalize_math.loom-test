  %5 = scalar.constant 0.044715 : f32
  %6 = scalar.constant 0.79788456080286544 : f32
  %7 = scalar.mulf<afn> %input, %input : f32
  %8 = scalar.mulf<afn> %7, %input : f32
  %9 = scalar.mulf<afn> %5, %8 : f32
  %10 = scalar.addf<afn> %input, %9 : f32
  %11 = scalar.mulf<afn> %6, %10 : f32
  %12 = scalar.tanhf<afn> %11 : f32
  %13 = scalar.addf<afn> %4, %12 : f32
  %14 = scalar.mulf<afn> %3, %input : f32
  %result = scalar.mulf<afn> %14, %13 : f32
  func.return %result : f32
}

