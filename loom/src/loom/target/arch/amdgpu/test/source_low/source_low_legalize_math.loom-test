// RUN: pass legalize-math,source-to-low,low-dce

amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_box_muller_native_math(%u1: f32, %u2: f32) -> (f32, f32) {
  %two_pi = scalar.constant 6.283185307179586 : f32
  %radius_base = scalar.logf<afn> %u1 : f32
  %negative_two = scalar.constant -2.0 : f32
  %radius_squared = scalar.mulf<afn> %negative_two, %radius_base : f32
  %radius = scalar.sqrtf<afn> %radius_squared : f32
  %theta = scalar.mulf<afn> %u2, %two_pi : f32
  %sine = scalar.sinf<afn> %theta : f32
  %cosine = scalar.cosf<afn> %theta : f32
  %z0 = scalar.mulf<afn> %radius, %cosine : f32
  %z1 = scalar.mulf<afn> %radius, %sine : f32
  func.return %z0, %z1 : f32, f32
}
// ----
amdgpu.target<gfx1100> @target

low.func.def target(@target) abi(hal_kernel) @scalar_box_muller_native_math(%u1: reg<amdgpu.vgpr>, %u2: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) {
  %23 = low.op<amdgpu.v_log_f32>(%u1) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %radius_base = low.op<amdgpu.v_mul_f32.lit>(%23) {imm32 = 1060205080} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %radius_squared = low.op<amdgpu.v_mul_f32.src0_inline>(%radius_base) {imm32 = 3221225472} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %radius = low.op<amdgpu.v_sqrt_f32>(%radius_squared) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %sine = low.op<amdgpu.v_sin_f32>(%u2) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %cosine = low.op<amdgpu.v_cos_f32>(%u2) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %z0 = low.op<amdgpu.v_mul_f32>(%radius, %cosine) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %z1 = low.op<amdgpu.v_mul_f32>(%radius, %sine) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %z0, %z1 : reg<amdgpu.vgpr>, reg<amdgpu.vgpr>
}

