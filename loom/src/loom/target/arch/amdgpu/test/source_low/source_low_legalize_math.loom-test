amdgpu.target<gfx1100> @target
func.def target(@target) @vector_logistic_exp2(%input: vector<4xf32>) -> (vector<4xf32>) {
  %result = vector.logisticf %input : vector<4xf32>
  func.return %result : vector<4xf32>
}
// ----
amdgpu.target<gfx1100> @target

func.def target(@target) @vector_logistic_exp2(%input: vector<4xf32>) -> (vector<4xf32>) {
  %3 = vector.constant -1.4426950408889634 : vector<4xf32>
  %4 = vector.constant 1.0 : vector<4xf32>
  %5 = vector.mulf %input, %3 : vector<4xf32>
  %6 = vector.exp2f %5 : vector<4xf32>
  %7 = vector.addf %4, %6 : vector<4xf32>
  %result = vector.divf %4, %7 : vector<4xf32>
  func.return %result : vector<4xf32>
}

