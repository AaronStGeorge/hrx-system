func.def target(@target) @cdna3_native_turn_math(%input: f32) -> (f32, f32, f32) {
  %log = scalar.log2f<afn> %input : f32
  %sin = scalar.sinturnsf<afn> %input : f32
  %cos = scalar.costurnsf<afn> %input : f32
  func.return %log, %sin, %cos : f32, f32, f32
}
