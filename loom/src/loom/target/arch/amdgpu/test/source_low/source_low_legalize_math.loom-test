  %20 = low.slice %18[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %21 = low.op<amdgpu.v_mul_f32>(%19, %20) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %22 = low.slice %14[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = low.slice %18[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = low.op<amdgpu.v_mul_f32>(%22, %23) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %25 = low.concat(%21, %24) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %26 = low.slice %25[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %27 = low.op<amdgpu.v_lshrrev_b32.lit>(%26) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %28 = low.op<amdgpu.v_and_b32.lit>(%27) {imm32 = 1} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %29 = low.op<amdgpu.v_add_u32.lit>(%28) {imm32 = 32767} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %30 = low.op<amdgpu.v_add_u32>(%26, %29) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %31 = low.op<amdgpu.v_lshrrev_b32.lit>(%30) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %32 = low.slice %25[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %33 = low.op<amdgpu.v_lshrrev_b32.lit>(%32) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %34 = low.op<amdgpu.v_and_b32.lit>(%33) {imm32 = 1} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %35 = low.op<amdgpu.v_add_u32.lit>(%34) {imm32 = 32767} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %36 = low.op<amdgpu.v_add_u32>(%32, %35) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %37 = low.op<amdgpu.v_lshrrev_b32.lit>(%36) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %38 = low.op<amdgpu.v_lshlrev_b32.lit>(%37) {imm32 = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %result = low.op<amdgpu.v_or_b32>(%31, %38) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %result : reg<amdgpu.vgpr>
}
