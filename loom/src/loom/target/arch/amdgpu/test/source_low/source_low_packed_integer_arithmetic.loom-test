func.def target(@target) @i16x4_mul_minmax_storage_tuple(%lhs: vector<4xi16>, %rhs: vector<4xi16>) -> (vector<4xi16>, vector<4xi16>, vector<4xi16>, vector<4xi16>, vector<4xi16>) {
  %product = vector.muli %lhs, %rhs : vector<4xi16>
  %smin = vector.minsi %lhs, %rhs : vector<4xi16>
  %smax = vector.maxsi %lhs, %rhs : vector<4xi16>
  %umin = vector.minui %lhs, %rhs : vector<4xi16>
  %umax = vector.maxui %lhs, %rhs : vector<4xi16>
  func.return %product, %smin, %smax, %umin, %umax : vector<4xi16>, vector<4xi16>, vector<4xi16>, vector<4xi16>, vector<4xi16>
}

