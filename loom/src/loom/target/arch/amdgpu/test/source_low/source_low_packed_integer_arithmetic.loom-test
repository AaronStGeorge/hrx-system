amdgpu.target<gfx1100> @target
func.def target(@target) @i16x4_bitcast_mul_maxui_chain(%packed: vector<2xi32>, %scale: vector<4xi16>, %limit: vector<4xi16>) -> (vector<4xi16>) {
  %lanes = vector.bitcast %packed : vector<2xi32> to vector<4xi16>
  %product = vector.muli %lanes, %scale : vector<4xi16>
  %result = vector.maxui %product, %limit : vector<4xi16>
  func.return %result : vector<4xi16>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i16x4_bitcast_mul_maxui_chain(%lanes: reg<amdgpu.vgpr x2>, %scale: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %11 = slice %lanes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %12 = slice %scale[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %13 = v_pk_mul_lo_u16 %11, %12
  %14 = slice %lanes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = slice %scale[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %16 = v_pk_mul_lo_u16 %14, %15
  %19 = slice %limit[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %20 = v_pk_max_u16 %13, %19
  %22 = slice %limit[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = v_pk_max_u16 %16, %22
  %result = concat(%20, %23) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %result
}

