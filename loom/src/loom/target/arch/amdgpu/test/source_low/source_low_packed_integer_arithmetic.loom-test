// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i8x8_bitwise_storage_tuple(%lhs: vector<8xi8>, %rhs: vector<8xi8>) -> (vector<8xi8>, vector<8xi8>, vector<8xi8>) {
  %and = vector.andi %lhs, %rhs : vector<8xi8>
  %or = vector.ori %lhs, %rhs : vector<8xi8>
  %xor = vector.xori %lhs, %rhs : vector<8xi8>
  func.return %and, %or, %xor : vector<8xi8>, vector<8xi8>, vector<8xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x8_bitwise_storage_tuple(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %13 = slice %lhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %14 = slice %rhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = v_and_b32 %13, %14
  %16 = slice %lhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = slice %rhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %18 = v_and_b32 %16, %17
  %and = concat(%15, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %22 = v_or_b32 %13, %14
  %25 = v_or_b32 %16, %17
  %or = concat(%22, %25) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %29 = v_xor_b32 %13, %14
  %32 = v_xor_b32 %16, %17
  %xor = concat(%29, %32) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %and, %or, %xor
}

