amdgpu.target<gfx1100> @target
func.def target(@target) @i16x4_select_xori(%lhs: i32, %rhs: i32, %true_value: vector<4xi16>, %false_value: vector<4xi16>, %mask: vector<4xi16>) -> (vector<4xi16>) {
  %condition = scalar.cmpi slt, %lhs, %rhs : i32
  %predicate = vector.splat %condition : vector<4xi1>
  %selected = vector.select %predicate, %true_value, %false_value : vector<4xi16>
  %result = vector.xori %selected, %mask : vector<4xi16>
  func.return %result : vector<4xi16>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i16x4_select_xori(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %true_value: reg<amdgpu.vgpr x2>, %false_value: reg<amdgpu.vgpr x2>, %mask: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %16 = v_mov_b32_copy %lhs
  %17 = v_mov_b32_copy %rhs
  %condition = v_cmp_lt_i32 %16, %17
  %19 = slice %true_value[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %20 = slice %false_value[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %21 = v_cndmask_b32 %20, %19, %condition
  %22 = slice %true_value[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = slice %false_value[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_cndmask_b32 %23, %22, %condition
  %27 = slice %mask[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %28 = v_xor_b32 %21, %27
  %30 = slice %mask[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %31 = v_xor_b32 %24, %30
  %result = concat(%28, %31) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %result
}

