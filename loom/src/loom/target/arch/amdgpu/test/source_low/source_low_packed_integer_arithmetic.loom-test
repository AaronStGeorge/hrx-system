  %38 = v_pk_max_i16 %22, %23
  %smax = concat(%35, %38) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %42 = v_pk_min_u16 %19, %20
