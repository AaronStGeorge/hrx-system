amdgpu.target<gfx1100> @target
func.def target(@target) @i16x4_cfg_arg_andi(%lhs: i32, %rhs: i32, %true_value: vector<4xi16>, %false_value: vector<4xi16>, %mask: vector<4xi16>) -> (vector<4xi16>) {
  %condition = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %condition, ^then, ^else
^then:
  cfg.br ^join(%true_value: vector<4xi16>)
^else:
  cfg.br ^join(%false_value: vector<4xi16>)
^join(%selected: vector<4xi16>):
  %result = vector.andi %selected, %mask : vector<4xi16>
  func.return %result : vector<4xi16>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i16x4_cfg_arg_andi(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %true_value: reg<amdgpu.vgpr x2>, %false_value: reg<amdgpu.vgpr x2>, %mask: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %condition = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %condition, ^then, ^else : reg<amdgpu.scc>
^then:
  low.br ^join(%true_value: reg<amdgpu.vgpr x2>)
^else:
  low.br ^join(%false_value: reg<amdgpu.vgpr x2>)
^join(%selected: reg<amdgpu.vgpr x2>):
  %17 = slice %selected[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %18 = slice %mask[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %19 = v_and_b32 %17, %18
  %20 = slice %selected[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %21 = slice %mask[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %22 = v_and_b32 %20, %21
  %result = concat(%19, %22) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %result
}
