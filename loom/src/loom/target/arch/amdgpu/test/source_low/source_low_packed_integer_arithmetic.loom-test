amdgpu.target<gfx1100> @target
func.def target(@target) @i16x4_shift_storage_tuple(%value: vector<4xi16>, %shift: vector<4xi16>) -> (vector<4xi16>, vector<4xi16>, vector<4xi16>) {
  %left = vector.shli %value, %shift : vector<4xi16>
  %signed_right = vector.shrsi %value, %shift : vector<4xi16>
  %unsigned_right = vector.shrui %value, %shift : vector<4xi16>
  func.return %left, %signed_right, %unsigned_right : vector<4xi16>, vector<4xi16>, vector<4xi16>
}

