low.func.def target(@target) abi(hal_kernel) @i16x4_shift_storage_tuple(%value: reg<amdgpu.vgpr x2>, %shift: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %13 = slice %shift[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %14 = slice %value[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = v_pk_lshlrev_b16 %13, %14
  %16 = slice %shift[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = slice %value[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %18 = v_pk_lshlrev_b16 %16, %17
  %left = concat(%15, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %22 = v_pk_ashrrev_i16 %13, %14
  %25 = v_pk_ashrrev_i16 %16, %17
  %signed_right = concat(%22, %25) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %29 = v_pk_lshrrev_b16 %13, %14
  %32 = v_pk_lshrrev_b16 %16, %17
  %unsigned_right = concat(%29, %32) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %left, %signed_right, %unsigned_right
}

