amdgpu.target<gfx1100> @target
func.def target(@target) @i32x4_shuffle_duplicate(%values: vector<4xi32>) -> (vector<4xi32>) {
  %shuffled = vector.shuffle<[0, 0, 2, 2]> %values : vector<4xi32>
  func.return %shuffled : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32x4_shuffle_duplicate(%values: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %5 = slice %values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %7 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %shuffled = concat(%5, %5, %7, %7) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %shuffled
}

