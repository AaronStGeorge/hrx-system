// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4_concat_pair(%lhs: vector<4xf32>, %rhs: vector<4xf32>) -> (vector<8xf32>) {
  %wide = vector.concat<0> %lhs, %rhs : vector<4xf32>, vector<4xf32> -> vector<8xf32>
  func.return %wide : vector<8xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4_concat_pair(%lhs: reg<amdgpu.vgpr x4>, %rhs: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %7 = slice %lhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %8 = slice %lhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %9 = slice %lhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %10 = slice %lhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %11 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %12 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %13 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %14 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %wide = concat(%7, %8, %9, %10, %11, %12, %13, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  return %wide
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32x8_deinterleave_pair(%interleaved: vector<8xf32>) -> (vector<4xf32>, vector<4xf32>) {
  %even, %odd = vector.deinterleave<0> %interleaved : vector<8xf32> -> vector<4xf32>, vector<4xf32>
  func.return %even, %odd : vector<4xf32>, vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x8_deinterleave_pair(%interleaved: reg<amdgpu.vgpr x8>) -> (reg<amdgpu.vgpr x4>, reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %8 = slice %interleaved[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %9 = slice %interleaved[2] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %10 = slice %interleaved[4] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %11 = slice %interleaved[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %even = concat(%8, %9, %10, %11) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %13 = slice %interleaved[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %14 = slice %interleaved[3] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %15 = slice %interleaved[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %16 = slice %interleaved[7] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %odd = concat(%13, %14, %15, %16) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %even, %odd
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4_interleave_pair(%even: vector<4xf32>, %odd: vector<4xf32>) -> (vector<8xf32>) {
  %interleaved = vector.interleave<0> %even, %odd : vector<4xf32>, vector<4xf32> -> vector<8xf32>
  func.return %interleaved : vector<8xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4_interleave_pair(%even: reg<amdgpu.vgpr x4>, %odd: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %7 = slice %even[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %8 = slice %odd[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %9 = slice %even[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %10 = slice %odd[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %11 = slice %even[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %12 = slice %odd[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %13 = slice %even[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %14 = slice %odd[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %interleaved = concat(%7, %8, %9, %10, %11, %12, %13, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  return %interleaved
}
