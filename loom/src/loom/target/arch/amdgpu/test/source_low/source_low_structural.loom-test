low.func.def target(@target) abi(hal_kernel) @f32x2x4_transpose(%values: reg<amdgpu.vgpr x8>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %5 = slice %values[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %6 = slice %values[4] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %7 = slice %values[1] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %8 = slice %values[5] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %9 = slice %values[2] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %10 = slice %values[6] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %11 = slice %values[3] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %12 = slice %values[7] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  %transposed = concat(%5, %6, %7, %8, %9, %10, %11, %12) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
