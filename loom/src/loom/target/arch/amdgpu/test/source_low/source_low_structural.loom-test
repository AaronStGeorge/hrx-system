amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4x4_extract_row(%values: vector<4x4xf32>) -> (vector<4xf32>) {
  %row = vector.extract %values[2] : vector<4x4xf32> -> vector<4xf32>
  func.return %row : vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4x4_extract_row(%values: reg<amdgpu.vgpr x16>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %5 = slice %values[8] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr>
  %6 = slice %values[9] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr>
  %7 = slice %values[10] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr>
  %8 = slice %values[11] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr>
  %row = concat(%5, %6, %7, %8) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %row
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4x4_extract_scalar(%values: vector<4x4xf32>) -> (f32) {
  %lane = vector.extract %values[3, 1] : vector<4x4xf32> -> f32
  func.return %lane : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4x4_extract_scalar(%values: reg<amdgpu.vgpr x16>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[13] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr>
  return %lane
}
