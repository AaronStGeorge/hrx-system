func.def target(@target) @f32x2x4_transpose(%values: vector<2x4xf32>) -> (vector<4x2xf32>) {
  %transposed = vector.transpose<[1, 0]> %values : vector<2x4xf32> -> vector<4x2xf32>
  func.return %transposed : vector<4x2xf32>
