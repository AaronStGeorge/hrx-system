amdgpu.target<gfx1100> @target
func.def target(@target) @packed_i8_dequant_gemv_two_outputs(%packed: vector<1xi32>, %scale: f16, %rhs0: vector<4xf32>, %rhs1: vector<4xf32>, %acc0: f32, %acc1: f32) -> (f32, f32) {
  %q_i32 = vector.bitunpacks<8> %packed : vector<1xi32> -> vector<4xi32>
  %q_f32 = vector.sitofp %q_i32 : vector<4xi32> to vector<4xf32>
  %scale_f32 = scalar.extf %scale : f16 to f32
  %scale_vector = vector.splat %scale_f32 : vector<4xf32>
  %scaled_q = vector.mulf<reassoc|nnan|ninf|nsz|contract> %q_f32, %scale_vector : vector<4xf32>
  %dot0 = vector.dotf %scaled_q, %rhs0, %acc0 : vector<4xf32>, vector<4xf32>, f32
  %dot1 = vector.dotf %scaled_q, %rhs1, %acc1 : vector<4xf32>, vector<4xf32>, f32
  func.return %dot0, %dot1 : f32, f32
}

