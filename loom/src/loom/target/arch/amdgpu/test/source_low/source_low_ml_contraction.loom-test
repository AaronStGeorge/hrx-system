  %81 = slice %rhs0[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %82 = v_fmac_f32 %79, %61, %81
  %84 = slice %rhs0[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %partial = v_fmac_f32 %82, %63, %84
  %87 = slice %rhs1[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %88 = v_fma_f32 %66, %87, %partial
