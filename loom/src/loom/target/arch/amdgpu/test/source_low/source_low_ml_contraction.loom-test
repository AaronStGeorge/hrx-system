amdgpu.target<gfx1100> @target
func.def target(@target) @fp8bf8_dot4_two_outputs(%lhs: vector<2xi32>, %rhs0: vector<2xi32>, %rhs1: vector<2xi32>, %acc0: vector<2xf32>, %acc1: vector<2xf32>) -> (vector<2xf32>, vector<2xf32>) {
  %dot0 = vector.dot4f8<fp8bf8> %lhs, %rhs0, %acc0 : vector<2xi32>, vector<2xf32>
  %dot1 = vector.dot4f8<fp8bf8> %lhs, %rhs1, %acc1 : vector<2xi32>, vector<2xf32>
  func.return %dot0, %dot1 : vector<2xf32>, vector<2xf32>
}

