  %16 = slice %acc[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_dot8_i32_iu4_s4u4 %14, %15, %16
  %18 = slice %lhs0[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %19 = slice %rhs0[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %20 = slice %acc[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
