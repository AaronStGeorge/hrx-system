  %28 = slice %rhs1[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %30 = v_dot8_i32_iu4_s4u4 %27, %28, %21
  %dot = concat(%26, %30) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
