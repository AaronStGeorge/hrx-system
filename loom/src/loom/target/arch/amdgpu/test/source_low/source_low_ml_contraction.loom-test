low.func.def target(@target) abi(hal_kernel) @packed_i8_dequant_gemv_two_outputs(%packed: reg<amdgpu.vgpr>, %scale: reg<amdgpu.vgpr>, %rhs0: reg<amdgpu.vgpr x4>, %rhs1: reg<amdgpu.vgpr x4>, %acc0: reg<amdgpu.vgpr>, %acc1: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %23 = v_bfe_i32_offset_width_inline %packed {offset = 0, width = 8}
  %24 = v_bfe_i32_offset_width_inline %packed {offset = 8, width = 8}
  %25 = v_bfe_i32_offset_width_inline %packed {offset = 16, width = 8}
  %26 = v_ashrrev_i32_src0_inline %packed, 24
  %29 = v_cvt_f32_i32 %23
  %31 = v_cvt_f32_i32 %24
  %33 = v_cvt_f32_i32 %25
  %35 = v_cvt_f32_i32 %26
  %38 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %29, 0
  %40 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %31, 0
  %42 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %33, 0
  %44 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %35, 0
  %47 = slice %rhs0[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %48 = v_fma_f32 %38, %47, %acc0
  %50 = slice %rhs0[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %51 = v_fmac_f32 %48, %40, %50
  %53 = slice %rhs0[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %54 = v_fmac_f32 %51, %42, %53
  %56 = slice %rhs0[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot0 = v_fmac_f32 %54, %44, %56
  %59 = slice %rhs1[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %60 = v_fma_f32 %38, %59, %acc1
  %62 = slice %rhs1[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %63 = v_fmac_f32 %60, %40, %62
  %65 = slice %rhs1[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %66 = v_fmac_f32 %63, %42, %65
  %68 = slice %rhs1[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot1 = v_fmac_f32 %66, %44, %68
  return %dot0, %dot1
}

