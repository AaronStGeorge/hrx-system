low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_f16x8_b128_extract_scalar_stores() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %24 = storage {byte_alignment = 16, byte_length = 16} : low.storage<workgroup>
  %26 = v_mov_b32 0
  %loaded = global_load_b128_saddr %26, %input_view
  %lane0 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  ds_write_b16 %26, %lane0
  %lane1 = v_lshrrev_b32_src0_inline %lane0, 16
  ds_write_b16 %26, %lane1 {offset = 2}
  %lane2 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  ds_write_b16 %26, %lane2 {offset = 4}
  %lane3 = v_lshrrev_b32_src0_inline %lane2, 16
  ds_write_b16 %26, %lane3 {offset = 6}
  %lane4 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  ds_write_b16 %26, %lane4 {offset = 8}
  %lane5 = v_lshrrev_b32_src0_inline %lane4, 16
  ds_write_b16 %26, %lane5 {offset = 10}
  %lane6 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  ds_write_b16 %26, %lane6 {offset = 12}
  %lane7 = v_lshrrev_b32_src0_inline %lane6, 16
  ds_write_b16 %26, %lane7 {offset = 14}
  %roundtrip = ds_read_b128 %26
  global_store_b128_saddr %26, %roundtrip, %output_view
  return
}

