amdgpu.target<gfx1100> @target
kernel.def target(@target) @lds_f16_strided_scalar_roundtrip(%input: buffer, %output: buffer) {
  %unit = index.constant 1 : index
  %tile = index.constant 16 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%tile, %tile, %unit) : index
} launch {
  %row0 = kernel.workitem.id<x> : index
  %col0 = kernel.workitem.id<y> : index
  %row = index.assume %row0 [range(%row0, 0, 15)] : index
  %col = index.assume %col0 [range(%col0, 0, 15)] : index
  %base = index.constant 0 : offset
  %bytes = index.constant 512 : offset
  %rhs_layout = encoding.layout.strided [1, 16] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 2, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%base] : buffer -> view<16x16xf16, #dense>
  %scratch_view = buffer.view %scratch[%base] : buffer -> view<16x16xf16, %rhs_layout>
  %output_view = buffer.view %output[%base] : buffer -> view<16x16xf16, #dense>
  %loaded = view.load %input_view[%row, %col] : view<16x16xf16, #dense> -> f16
  view.store %loaded, %scratch_view[%row, %col] : f16, view<16x16xf16, %rhs_layout>
  %roundtrip = view.load %scratch_view[%row, %col] : view<16x16xf16, %rhs_layout> -> f16
  view.store %roundtrip, %output_view[%row, %col] : f16, view<16x16xf16, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(16, 16, 1) @lds_f16_strided_scalar_roundtrip() asm<amdgpu.rdna3.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %row = v_and_b32_lit %packed_tid, 1023
  %30 = v_lshrrev_b32_src0_inline %packed_tid, 10
  %col = v_and_b32_lit %30, 1023
  %33 = storage {byte_alignment = 2, byte_length = 512} : low.storage<workgroup>
  %35 = v_lshl_add_u32_shift_imm %row, %col, 4
  %36 = v_lshlrev_b32_src0_inline %35, 1
  %loaded = global_load_u16_saddr %36, %input_view
  %38 = v_lshlrev_b32_src0_inline %row, 1
  %39 = v_lshlrev_b32_src0_inline %col, 5
  %40 = v_add_u32 %38, %39
  ds_write_b16 %40, %loaded
  %roundtrip = ds_read_u16 %40
  global_store_short_saddr %36, %roundtrip, %output_view
  return
}
