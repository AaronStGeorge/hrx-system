kernel.def target(@target) @lds_f16x8_b128_extract_scalar_stores(%input: buffer, %output: buffer) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %bytes = index.constant 16 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%base] : buffer -> view<8xf16, #dense>
  %scratch_view = buffer.view %scratch[%base] : buffer -> view<8xf16, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<8xf16, #dense>
  %loaded = vector.load %input_view[0] : view<8xf16, #dense> -> vector<8xf16>
  %lane0 = vector.extract %loaded[0] : vector<8xf16> -> f16
  view.store %lane0, %scratch_view[0] : f16, view<8xf16, #dense>
  %lane1 = vector.extract %loaded[1] : vector<8xf16> -> f16
  view.store %lane1, %scratch_view[1] : f16, view<8xf16, #dense>
  %lane2 = vector.extract %loaded[2] : vector<8xf16> -> f16
  view.store %lane2, %scratch_view[2] : f16, view<8xf16, #dense>
  %lane3 = vector.extract %loaded[3] : vector<8xf16> -> f16
  view.store %lane3, %scratch_view[3] : f16, view<8xf16, #dense>
  %lane4 = vector.extract %loaded[4] : vector<8xf16> -> f16
  view.store %lane4, %scratch_view[4] : f16, view<8xf16, #dense>
  %lane5 = vector.extract %loaded[5] : vector<8xf16> -> f16
  view.store %lane5, %scratch_view[5] : f16, view<8xf16, #dense>
  %lane6 = vector.extract %loaded[6] : vector<8xf16> -> f16
  view.store %lane6, %scratch_view[6] : f16, view<8xf16, #dense>
  %lane7 = vector.extract %loaded[7] : vector<8xf16> -> f16
  view.store %lane7, %scratch_view[7] : f16, view<8xf16, #dense>
  %roundtrip = vector.load %scratch_view[0] : view<8xf16, #dense> -> vector<8xf16>
  vector.store %roundtrip, %output_view[0] : vector<8xf16>, view<8xf16, #dense>
  kernel.return
}

