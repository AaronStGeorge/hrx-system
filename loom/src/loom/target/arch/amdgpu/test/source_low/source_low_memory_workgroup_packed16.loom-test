// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_packed16.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @lds_f16x4_b64_roundtrip(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 512 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 8, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xf16, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xf16, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf16, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xf16>, view<64x4xf16, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xf16>, view<64x4xf16, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_f16x4_b64_roundtrip() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x2>
  %bytes = s_mov_b32 512
  %19 = storage {byte_alignment = 8, byte_length = 512} : low.storage<workgroup>
  %scratch_view = storage_address %19 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %21 = v_mov_b32 0
  %loaded = global_load_b64 %21, %input_view
  ds_write_b64 %scratch_view, %loaded
  %roundtrip = ds_read_b64 %scratch_view
  %24 = v_mov_b32 0
  global_store_b64 %24, %roundtrip, %output_view
  return
}

