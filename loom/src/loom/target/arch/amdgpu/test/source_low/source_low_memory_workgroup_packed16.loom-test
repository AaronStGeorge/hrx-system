// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_packed16.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @lds_f16x4_b64_roundtrip(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 512 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 8, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xf16, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xf16, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf16, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xf16>, view<64x4xf16, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xf16, #dense> -> vector<4xf16>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xf16>, view<64x4xf16, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_f16x4_b64_roundtrip() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 512
  %17 = storage {byte_alignment = 8, byte_length = 512} : low.storage<workgroup>
  %scratch_view = storage_address %17 {offset = 0} : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %19 = v_lshlrev_b32_lit %tid, 3
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b64 %19, %20 {offset = 0}
  %22 = v_lshlrev_b32_lit %tid, 3
  %23 = v_add_u32 %scratch_view, %22
  ds_write_b64 %23, %loaded {offset = 0}
  %24 = v_lshlrev_b32_lit %tid, 3
  %25 = v_add_u32 %scratch_view, %24
  %roundtrip = ds_read_b64 %25 {offset = 0}
  %27 = v_lshlrev_b32_lit %tid, 3
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b64 %27, %roundtrip, %28 {offset = 0}
  return
}

