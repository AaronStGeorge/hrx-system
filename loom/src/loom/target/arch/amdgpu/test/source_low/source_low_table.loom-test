  %16 = slice %grid[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32 2
  %18 = slice %codes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %19 = v_cmp_eq_i32 %18, %15
  %20 = v_cndmask_b32 %13, %14, %19
  %21 = v_cmp_eq_i32 %18, %17
  %22 = v_cndmask_b32 %20, %16, %21
  %23 = slice %codes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_cmp_eq_i32 %23, %15
  %25 = v_cndmask_b32 %13, %14, %24
  %26 = v_cmp_eq_i32 %23, %17
  %27 = v_cndmask_b32 %25, %16, %26
  %decoded = concat(%22, %27) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %decoded
}
