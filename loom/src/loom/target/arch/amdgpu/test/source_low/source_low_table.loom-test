low.kernel.def target(@target) workgroup_size(1, 1, 1) @f32_table_lookup_i8_codes() asm<amdgpu.rdna3.core> {
  %codes_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 8} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 32} : reg<amdgpu.sgpr x2>
  %21 = v_mov_b32 0
  %codes = global_load_b32_saddr %21, %codes_view
  %g0 = v_mov_b32 3212836864
  %g1 = v_mov_b32 3204448256
  %g2 = v_mov_b32 1056964608
  %g3 = v_mov_b32 1069547520
  %30 = v_mov_b32 1
  %32 = v_mov_b32 2
  %34 = v_mov_b32 3
  %35 = v_and_b32_lit %codes, 255
  %36 = v_cmp_eq_i32 %35, %30
  %37 = v_cndmask_b32 %g0, %g1, %36
  %38 = v_cmp_eq_i32 %35, %32
  %39 = v_cndmask_b32 %37, %g2, %38
  %40 = v_cmp_eq_i32 %35, %34
  %41 = v_cndmask_b32 %39, %g3, %40
  %42 = v_bfe_u32_offset_width_inline %codes {offset = 8, width = 8}
  %43 = v_cmp_eq_i32 %42, %30
  %44 = v_cndmask_b32 %g0, %g1, %43
  %45 = v_cmp_eq_i32 %42, %32
  %46 = v_cndmask_b32 %44, %g2, %45
  %47 = v_cmp_eq_i32 %42, %34
  %48 = v_cndmask_b32 %46, %g3, %47
  %49 = v_bfe_u32_offset_width_inline %codes {offset = 16, width = 8}
  %50 = v_cmp_eq_i32 %49, %30
  %51 = v_cndmask_b32 %g0, %g1, %50
  %52 = v_cmp_eq_i32 %49, %32
  %53 = v_cndmask_b32 %51, %g2, %52
  %54 = v_cmp_eq_i32 %49, %34
  %55 = v_cndmask_b32 %53, %g3, %54
  %56 = v_bfe_u32_offset_width_inline %codes {offset = 24, width = 8}
  %57 = v_cmp_eq_i32 %56, %30
  %58 = v_cndmask_b32 %g0, %g1, %57
  %59 = v_cmp_eq_i32 %56, %32
  %60 = v_cndmask_b32 %58, %g2, %59
  %61 = v_cmp_eq_i32 %56, %34
  %62 = v_cndmask_b32 %60, %g3, %61
  %decoded = concat(%41, %48, %55, %62) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %21, %decoded, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32_table_lookup_i32_codes(%codes: vector<2xi32>) -> (vector<2xf32>) {
  %g0 = scalar.constant 2.0 : f32
  %g1 = scalar.constant -3.0 : f32
  %g2 = scalar.constant 5.0 : f32
  %grid = vector.from_elements %g0, %g1, %g2 : vector<3xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<3xf32>, vector<2xi32> -> vector<2xf32>
  func.return %decoded : vector<2xf32>
}

