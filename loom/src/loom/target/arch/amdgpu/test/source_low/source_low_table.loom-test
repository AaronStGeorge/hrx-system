low.func.def target(@target) abi(hal_kernel) @f32_table_lookup_dynamic_grid(%grid: reg<amdgpu.vgpr x3>, %codes: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %7 = slice %grid[0] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %8 = slice %grid[1] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %9 = slice %grid[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %10 = slice %codes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %11 = v_cmp_eq_i32_src1_inline %10 {rhs = 1}
  %12 = v_cndmask_b32 %7, %8, %11
  %13 = v_cmp_eq_i32_src1_inline %10 {rhs = 2}
  %14 = v_cndmask_b32 %12, %9, %13
  %15 = slice %codes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %16 = v_cmp_eq_i32_src1_inline %15 {rhs = 1}
  %17 = v_cndmask_b32 %7, %8, %16
  %18 = v_cmp_eq_i32_src1_inline %15 {rhs = 2}
  %19 = v_cndmask_b32 %17, %9, %18
  %decoded = concat(%14, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %decoded
}

