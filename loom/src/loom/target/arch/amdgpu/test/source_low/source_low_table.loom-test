low.func.def target(@target) abi(hal_kernel) @f32_table_lookup_i32_codes(%codes: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.gfx11.core> {
  %g0 = v_mov_b32 1073741824
  %g1 = v_mov_b32 3225419776
  %g2 = v_mov_b32 1084227584
  %grid = concat(%g0, %g1, %g2) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x3>
  %13 = slice %grid[0] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %14 = slice %grid[1] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %15 = v_mov_b32 1
  %16 = slice %grid[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32 2
  %18 = slice %codes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %19 = v_cmp_eq_i32 %18, %15
  %20 = v_cndmask_b32 %13, %14, %19
  %21 = v_cmp_eq_i32 %18, %17
  %22 = v_cndmask_b32 %20, %16, %21
  %23 = slice %codes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_cmp_eq_i32 %23, %15
  %25 = v_cndmask_b32 %13, %14, %24
  %26 = v_cmp_eq_i32 %23, %17
  %27 = v_cndmask_b32 %25, %16, %26
  %decoded = concat(%22, %27) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %decoded
}
