// TEMPLATE: loom/src/loom/test/corpus/source_low/lookup_table.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @f32_table_lookup_i8_codes(%codes_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 1)] : index
  %zero = index.constant 0 : offset
  %four = index.constant 4 : index
  %base = index.mul %tid, %four : index
  %codes_view = buffer.view %codes_buffer[%zero] : buffer -> view<8xi8, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<8xf32, #dense>
  %codes = vector.load %codes_view[%base] : view<8xi8, #dense> -> vector<4xi8>
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant -0.5 : f32
  %g2 = scalar.constant 0.5 : f32
  %g3 = scalar.constant 1.5 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi8> -> vector<4xf32>
  vector.store %decoded, %output_view[%base] : vector<4xf32>, view<8xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @f32_table_lookup_i8_codes() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %codes_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 32} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %four = s_mov_b32 4
  %21 = v_mov_b32 4
  %base = v_mul_lo_u32 %tid, %21
  %23 = slice %codes_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %codes = global_load_b32 %base, %23 {offset = 0}
  %g0 = v_mov_b32 3212836864
  %g1 = v_mov_b32 3204448256
  %g2 = v_mov_b32 1056964608
  %g3 = v_mov_b32 1069547520
  %grid = concat(%g0, %g1, %g2, %g3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %30 = slice %grid[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %31 = slice %grid[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = v_mov_b32 1
  %33 = slice %grid[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = v_mov_b32 2
  %35 = slice %grid[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %36 = v_mov_b32 3
  %37 = v_and_b32_lit %codes, 255
  %38 = v_cmp_eq_i32 %37, %32
  %39 = v_cndmask_b32 %30, %31, %38
  %40 = v_cmp_eq_i32 %37, %34
  %41 = v_cndmask_b32 %39, %33, %40
  %42 = v_cmp_eq_i32 %37, %36
  %43 = v_cndmask_b32 %41, %35, %42
  %44 = v_lshrrev_b32_lit %codes, 8
  %45 = v_and_b32_lit %44, 255
  %46 = v_cmp_eq_i32 %45, %32
  %47 = v_cndmask_b32 %30, %31, %46
  %48 = v_cmp_eq_i32 %45, %34
  %49 = v_cndmask_b32 %47, %33, %48
  %50 = v_cmp_eq_i32 %45, %36
  %51 = v_cndmask_b32 %49, %35, %50
  %52 = v_lshrrev_b32_lit %codes, 16
  %53 = v_and_b32_lit %52, 255
  %54 = v_cmp_eq_i32 %53, %32
  %55 = v_cndmask_b32 %30, %31, %54
  %56 = v_cmp_eq_i32 %53, %34
  %57 = v_cndmask_b32 %55, %33, %56
  %58 = v_cmp_eq_i32 %53, %36
  %59 = v_cndmask_b32 %57, %35, %58
  %60 = v_lshrrev_b32_lit %codes, 24
  %61 = v_and_b32_lit %60, 255
  %62 = v_cmp_eq_i32 %61, %32
  %63 = v_cndmask_b32 %30, %31, %62
  %64 = v_cmp_eq_i32 %61, %34
  %65 = v_cndmask_b32 %63, %33, %64
  %66 = v_cmp_eq_i32 %61, %36
  %67 = v_cndmask_b32 %65, %35, %66
  %decoded = concat(%43, %51, %59, %67) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %69 = v_lshlrev_b32_lit %base, 2
  %70 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %69, %decoded, %70 {offset = 0}
  return
}

// ====

func.def @f32_table_lookup_i32_codes(%codes: vector<2xi32>) -> (vector<2xf32>) {
  %g0 = scalar.constant 2.0 : f32
  %g1 = scalar.constant -3.0 : f32
  %g2 = scalar.constant 5.0 : f32
  %grid = vector.from_elements %g0, %g1, %g2 : vector<3xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<3xf32>, vector<2xi32> -> vector<2xf32>
  func.return %decoded : vector<2xf32>
}

