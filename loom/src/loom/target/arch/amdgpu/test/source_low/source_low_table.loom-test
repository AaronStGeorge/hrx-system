// TEMPLATE: loom/src/loom/test/corpus/source_low/lookup_table.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @f32_table_lookup_i8_codes() {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch(%codes_buffer: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 1)] : index
  %base_offset = index.constant 0 : offset
  %code_stride = index.constant 4 : index
  %base = index.mul %tid, %code_stride : index
  %codes_view = buffer.view %codes_buffer[%base_offset] : buffer -> view<8xi8, #dense>
  %output_view = buffer.view %output[%base_offset] : buffer -> view<8xf32, #dense>
  %codes = vector.load %codes_view[%base] : view<8xi8, #dense> -> vector<4xi8>
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant -0.5 : f32
  %g2 = scalar.constant 0.5 : f32
  %g3 = scalar.constant 1.5 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi8> -> vector<4xf32>
  vector.store %decoded, %output_view[%base] : vector<4xf32>, view<8xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @f32_table_lookup_i8_codes() asm<amdgpu.rdna3.core> {
  %codes_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 8} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 32} : reg<amdgpu.sgpr x2>
  %21 = v_mov_b32 0
  %codes = global_load_b32_saddr %21, %codes_view
  %g0 = v_mov_b32 3212836864
  %32 = v_and_b32_lit %codes, 255
  %33 = v_cmp_eq_i32_src1_inline %32 {rhs = 1}
  %34 = v_cndmask_b32_src1_lit %g0, %33, 3204448256
  %35 = v_cmp_eq_i32_src1_inline %32 {rhs = 2}
  %36 = v_cndmask_b32_src1_lit %34, %35, 1056964608
  %37 = v_cmp_eq_i32_src1_inline %32 {rhs = 3}
  %38 = v_cndmask_b32_src1_lit %36, %37, 1069547520
  %39 = v_bfe_u32_offset_width_inline %codes {offset = 8, width = 8}
  %40 = v_cmp_eq_i32_src1_inline %39 {rhs = 1}
  %41 = v_cndmask_b32_src1_lit %g0, %40, 3204448256
  %42 = v_cmp_eq_i32_src1_inline %39 {rhs = 2}
  %43 = v_cndmask_b32_src1_lit %41, %42, 1056964608
  %44 = v_cmp_eq_i32_src1_inline %39 {rhs = 3}
  %45 = v_cndmask_b32_src1_lit %43, %44, 1069547520
  %46 = v_bfe_u32_offset_width_inline %codes {offset = 16, width = 8}
  %47 = v_cmp_eq_i32_src1_inline %46 {rhs = 1}
  %48 = v_cndmask_b32_src1_lit %g0, %47, 3204448256
  %49 = v_cmp_eq_i32_src1_inline %46 {rhs = 2}
  %50 = v_cndmask_b32_src1_lit %48, %49, 1056964608
  %51 = v_cmp_eq_i32_src1_inline %46 {rhs = 3}
  %52 = v_cndmask_b32_src1_lit %50, %51, 1069547520
  %53 = v_bfe_u32_offset_width_inline %codes {offset = 24, width = 8}
  %54 = v_cmp_eq_i32_src1_inline %53 {rhs = 1}
  %55 = v_cndmask_b32_src1_lit %g0, %54, 3204448256
  %56 = v_cmp_eq_i32_src1_inline %53 {rhs = 2}
  %57 = v_cndmask_b32_src1_lit %55, %56, 1056964608
  %58 = v_cmp_eq_i32_src1_inline %53 {rhs = 3}
  %59 = v_cndmask_b32_src1_lit %57, %58, 1069547520
  %decoded = concat(%38, %45, %52, %59) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %21, %decoded, %output_view
  return
}

