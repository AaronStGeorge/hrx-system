low.func.def target(@target) abi(hal_kernel) @f32_table_lookup_i32_codes(%codes: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %g0 = v_mov_b32 1073741824
  %16 = slice %codes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_cmp_eq_i32_src1_inline %16 {rhs = 1}
  %18 = v_cndmask_b32_src1_lit %g0, %17, 3225419776
  %19 = v_cmp_eq_i32_src1_inline %16 {rhs = 2}
  %20 = v_cndmask_b32_src1_lit %18, %19, 1084227584
  %21 = slice %codes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %22 = v_cmp_eq_i32_src1_inline %21 {rhs = 1}
  %23 = v_cndmask_b32_src1_lit %g0, %22, 3225419776
  %24 = v_cmp_eq_i32_src1_inline %21 {rhs = 2}
  %25 = v_cndmask_b32_src1_lit %23, %24, 1084227584
  %decoded = concat(%20, %25) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %decoded
}

