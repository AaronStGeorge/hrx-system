// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @scalar_ieee_minimum_rejected(%lhs: f32, %rhs: f32) -> (f32) {
  // ERROR@+1: BACKEND/001
  %min = scalar.minimumf %lhs, %rhs : f32
  func.return %min : f32
}

// ====

func.def @vector_ieee_maximum_rejected(%lhs: vector<2xf32>, %rhs: vector<2xf32>) -> (vector<2xf32>) {
  // ERROR@+1: BACKEND/001
  %max = vector.maximumf %lhs, %rhs : vector<2xf32>
  func.return %max : vector<2xf32>
}

// ====

kernel.def @global_atomic_ieee_minimum_rejected(%input: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xf32, #dense>
  %limit = scalar.constant 1.0 : f32
  // ERROR@+1: BACKEND/001
  view.atomic.reduce<minimumf> %limit, %view[%tid] {ordering = relaxed, scope = device} : f32, view<64xf32, #dense>
  kernel.return
}

// ====

kernel.def @lds_atomic_ieee_maximum_rejected() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 4, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xf32, #dense>
  %limit = scalar.constant 1.0 : f32
  // ERROR@+1: BACKEND/001
  view.atomic.reduce<maximumf> %limit, %scratch_view[%tid] {ordering = relaxed, scope = workgroup} : f32, view<64xf32, #dense>
  kernel.return
}
