  %53 = v_and_b32_lit %50, 4294967247
  %54 = v_or_b32 %53, %52
  %55 = slice %high[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %56 = slice %low[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %57 = v_and_b32_lit %55, 3
