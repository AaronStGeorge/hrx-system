  %22 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_and_b32_lit %22, 15
  %low = concat(%17, %19, %21, %23) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %25 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %26 = v_lshrrev_b32_lit %25, 4
  %27 = v_and_b32_lit %26, 3
  %28 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %29 = v_lshrrev_b32_lit %28, 4
  %30 = v_and_b32_lit %29, 3
  %31 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = v_lshrrev_b32_lit %31, 4
  %33 = v_and_b32_lit %32, 3
  %34 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = v_lshrrev_b32_lit %34, 4
  %36 = v_and_b32_lit %35, 3
  %high = concat(%27, %30, %33, %36) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %38 = slice %high[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %39 = slice %low[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %40 = v_and_b32_lit %38, 3
  %41 = v_lshlrev_b32_lit %40, 4
  %42 = v_and_b32_lit %39, 4294967247
  %43 = v_or_b32 %42, %41
  %44 = slice %high[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %45 = slice %low[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %46 = v_and_b32_lit %44, 3
  %47 = v_lshlrev_b32_lit %46, 4
  %48 = v_and_b32_lit %45, 4294967247
  %49 = v_or_b32 %48, %47
  %50 = slice %high[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %51 = slice %low[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %52 = v_and_b32_lit %50, 3
  %53 = v_lshlrev_b32_lit %52, 4
  %54 = v_and_b32_lit %51, 4294967247
  %55 = v_or_b32 %54, %53
  %56 = slice %high[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %57 = slice %low[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %58 = v_and_b32_lit %56, 3
  %59 = v_lshlrev_b32_lit %58, 4
  %60 = v_and_b32_lit %57, 4294967247
  %61 = v_or_b32 %60, %59
  %merged = concat(%43, %49, %55, %61) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %63 = v_mov_b32 32
  %64 = v_mov_b32 32
