low.func.def target(@target) abi(hal_kernel) @i32_bitfield_insert() asm<amdgpu.gfx11.core> {
  %field_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %base_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %13 = v_mov_b32 0
  %field = global_load_b32 %13, %field_view
  %15 = v_mov_b32 0
  %base = global_load_b32 %15, %base_view
  %17 = v_and_b32_lit %field, 15
  %18 = v_lshlrev_b32_lit %17, 8
  %19 = v_and_b32_lit %base, 4294963455
  %inserted = v_or_b32 %19, %18
  %21 = v_mov_b32 0
  global_store_b32 %21, %inserted, %output_view
  return
}

