low.func.def target(@target) abi(hal_kernel) @i32_bitfield_insert() asm<amdgpu.rdna3.core> {
  %field_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %base_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %13 = v_mov_b32 0
  %field = global_load_b32 %13, %field_view
  %base = global_load_b32 %13, %base_view
  %17 = v_and_b32_src0_inline %field, 15
  %18 = v_lshlrev_b32_src0_inline %17, 8
  %19 = v_and_b32_lit %base, 4294963455
  %inserted = v_or_b32 %19, %18
  global_store_b32 %13, %inserted, %output_view
  return
}

