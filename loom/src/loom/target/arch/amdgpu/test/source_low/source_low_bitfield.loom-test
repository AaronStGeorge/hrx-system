// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i32_bitfield_extractu(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %nibble = vector.bitfield.extractu %loaded {offset = 4, width = 4} : vector<1xi32> -> vector<1xi32>
  vector.store %nibble, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32_bitfield_extractu() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %9 = v_mov_b32 0
  %loaded = global_load_b32 %9, %input_view
  %11 = v_lshrrev_b32_lit %loaded, 4
  %nibble = v_and_b32_lit %11, 15
  %13 = v_mov_b32 0
  global_store_b32 %13, %nibble, %output_view
  return
}

