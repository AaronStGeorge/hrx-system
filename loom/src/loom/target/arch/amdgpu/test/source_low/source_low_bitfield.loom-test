  %bias = concat(%63, %64, %65, %66) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %68 = slice %merged[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %69 = slice %bias[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %70 = v_sub_nc_u32 %68, %69
  %71 = slice %merged[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %72 = slice %bias[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %73 = v_sub_nc_u32 %71, %72
  %74 = slice %merged[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %75 = slice %bias[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %76 = v_sub_nc_u32 %74, %75
  %77 = slice %merged[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %78 = slice %bias[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %79 = v_sub_nc_u32 %77, %78
  %result = concat(%70, %73, %76, %79) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
