low.func.def target(@target) abi(hal_kernel) @i32_bitfield_b128_shape() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %13 = v_mov_b32 0
  %loaded = global_load_b128_saddr %13, %input_view
  %15 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = v_and_b32_src0_inline %15, 15
  %17 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = v_and_b32_src0_inline %17, 15
  %19 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_and_b32_src0_inline %19, 15
  %21 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = v_and_b32_src0_inline %21, 15
  %25 = v_bfe_u32_offset_width_inline %15 {offset = 4, width = 2}
  %27 = v_bfe_u32_offset_width_inline %17 {offset = 4, width = 2}
  %29 = v_bfe_u32_offset_width_inline %19 {offset = 4, width = 2}
  %31 = v_bfe_u32_offset_width_inline %21 {offset = 4, width = 2}
  %35 = v_and_b32_src0_inline %25, 3
  %36 = v_lshlrev_b32_src0_inline %35, 4
  %37 = v_and_b32_lit %16, 4294967247
  %38 = v_or_b32 %37, %36
  %41 = v_and_b32_src0_inline %27, 3
  %42 = v_lshlrev_b32_src0_inline %41, 4
  %43 = v_and_b32_lit %18, 4294967247
  %44 = v_or_b32 %43, %42
  %47 = v_and_b32_src0_inline %29, 3
  %48 = v_lshlrev_b32_src0_inline %47, 4
  %49 = v_and_b32_lit %20, 4294967247
  %50 = v_or_b32 %49, %48
  %53 = v_and_b32_src0_inline %31, 3
  %54 = v_lshlrev_b32_src0_inline %53, 4
  %55 = v_and_b32_lit %22, 4294967247
  %56 = v_or_b32 %55, %54
  %58 = v_mov_b32 32
  %65 = v_sub_nc_u32 %38, %58
  %68 = v_sub_nc_u32 %44, %58
  %71 = v_sub_nc_u32 %50, %58
  %74 = v_sub_nc_u32 %56, %58
  %result = concat(%65, %68, %71, %74) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  global_store_b128_saddr %13, %result, %output_view
  return
}
