low.func.def target(@target) @i32_bitfield_insert() asm<amdgpu.gfx11.core> {
  %field_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %base_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 2, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %14 = v_mov_b32 0
  %15 = slice %field_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %field = global_load_b32 %14, %15 {offset = 0}
  %17 = v_mov_b32 0
  %18 = slice %base_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %base = global_load_b32 %17, %18 {offset = 0}
  %20 = v_mov_b32 15
  %21 = v_and_b32 %field, %20
  %22 = v_mov_b32 8
  %23 = v_lshlrev_b32 %22, %21
  %24 = v_mov_b32 4294963455
  %25 = v_and_b32 %base, %24
  %inserted = v_or_b32 %25, %23
  %27 = v_mov_b32 0
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %27, %inserted, %28 {offset = 0}
  return
}

