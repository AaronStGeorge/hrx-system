func.def @i32_bitfield_extractu(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %nibble = vector.bitfield.extractu %loaded {offset = 4, width = 4} : vector<1xi32> -> vector<1xi32>
  vector.store %nibble, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) @i32_bitfield_extractu() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %10 = v_mov_b32 0
  %11 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %10, %11 {offset = 0}
  %13 = v_mov_b32 4
  %14 = v_lshrrev_b32 %13, %loaded
  %15 = v_mov_b32 15
  %nibble = v_and_b32 %14, %15
  %17 = v_mov_b32 0
  %18 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %17, %nibble, %18 {offset = 0}
  return
}

