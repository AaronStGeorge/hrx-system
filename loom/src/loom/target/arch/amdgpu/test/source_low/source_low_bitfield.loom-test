low.func.def target(@target) abi(hal_kernel) @i32_bitfield_extractu() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %9 = v_mov_b32 0
  %loaded = global_load_b32 %9, %input_view
  %11 = v_lshrrev_b32_src0_inline %loaded, 4
  %nibble = v_and_b32_src0_inline %11, 15
  global_store_b32 %9, %nibble, %output_view
  return
}

