func.def target(@target) @index_uniform_shift_mask(%value: i32) -> (index, index) {
  %value_index = index.cast %value : i32 to index
  %bounded_value = index.assume %value_index [range(%value_index, 0, 1024)] : index
  %shift = index.constant 7 : index
  %quotient = index.shrui %bounded_value, %shift : index
  %mask = index.constant 127 : index
  %remainder = index.andi %bounded_value, %mask : index
  func.return %quotient, %remainder : index, index
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_uniform_shift_mask(%bounded_value: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %shift = s_mov_b32 7
  %quotient = s_lshr_b32 %bounded_value, %shift
  %mask = s_mov_b32 127
  %remainder = s_and_b32 %bounded_value, %mask
  return %quotient, %remainder
}

