// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_uniform(%lhs: i32, %rhs: i32) -> (i1) {
  %lhs_index = index.cast %lhs : i32 to index
  %rhs_index = index.cast %rhs : i32 to index
  %result = index.cmp slt, %lhs_index, %rhs_index : index
  func.return %result : i1
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_uniform(%lhs_index: reg<amdgpu.sgpr>, %rhs_index: reg<amdgpu.sgpr>) -> (reg<amdgpu.scc>) asm<amdgpu.rdna3.core> {
  %result = s_cmp_lt_i32 %lhs_index, %rhs_index
  return %result
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_divergent(%values: vector<2xi32>, %limit: i32) {
  %lane_i32 = vector.extract %values[0] : vector<2xi32> -> i32
  %lane = index.cast %lane_i32 : i32 to index
  %limit_index = index.cast %limit : i32 to index
  %condition = index.cmp slt, %lane, %limit_index : index
  cfg.cond_br %condition, ^then, ^join : i1
^then:
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_divergent(%values: reg<amdgpu.vgpr x2>, %limit_index: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %9 = v_mov_b32_copy %limit_index
  %condition = v_cmp_lt_i32 %lane, %9
  %11, %12 = s_and_saveexec_b64 %condition
  low.cond_br %12, ^then, ^_bb3 : reg<amdgpu.scc>
^then:
  low.br ^_bb3
^join:
  return
^_bb3:
  s_mov_b64_exec %11
  low.br ^join
}
