func.def target(@target) @index_uniform_div_rem_power_of_two(%value: i32) -> (index, index) {
  %value_index = index.cast %value : i32 to index
  %bounded_value = index.assume %value_index [range(%value_index, 0, 31)] : index
  %divisor = index.constant 8 : index
  %quotient = index.div %bounded_value, %divisor : index
  %remainder = index.rem %bounded_value, %divisor : index
  func.return %quotient, %remainder : index, index
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_uniform_div_rem_power_of_two(%bounded_value: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %15 = s_mov_b32 3
  %quotient = s_lshr_b32 %bounded_value, %15
  %17 = s_mov_b32 7
  %remainder = s_and_b32 %bounded_value, %17
  return %quotient, %remainder
}

