amdgpu.target<gfx1100> @target
func.def target(@target) @index_mixed_uniform_divergent_i1_bitwise_select(%values: vector<2xi32>, %reference_count: i32, %lower: i32, %true_value: f32, %false_value: f32) -> (f32) {
  %lane_i32 = vector.extract %values[0] : vector<2xi32> -> i32
  %lane = index.cast %lane_i32 : i32 to index
  %lower_index = index.cast %lower : i32 to index
  %empty_reference_count = scalar.constant 0 : i32
  %has_reference = scalar.cmpi ne, %reference_count, %empty_reference_count : i32
  %at_or_above_lower = index.cmp sge, %lane, %lower_index : index
  %inside_reference = scalar.andi %has_reference, %at_or_above_lower : i1
  %selected = scf.select %inside_reference, %true_value, %false_value : f32
  func.return %selected : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_mixed_uniform_divergent_i1_bitwise_select(%values: reg<amdgpu.vgpr x2>, %reference_count: reg<amdgpu.sgpr>, %lower_index: reg<amdgpu.sgpr>, %true_value: reg<amdgpu.vgpr>, %false_value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %empty_reference_count = s_mov_b32 0
  %has_reference = s_cmp_lg_i32 %reference_count, %empty_reference_count
  %23 = v_mov_b32_copy %lower_index
  %at_or_above_lower = v_cmp_ge_i32 %lane, %23
  %25 = s_mov_b64_exec_read
  %26 = slice %25[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %27 = slice %25[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %29 = s_cselect_b32 %26, %empty_reference_count, %has_reference
  %30 = s_cselect_b32 %27, %empty_reference_count, %has_reference
  %31 = concat(%29, %30) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %inside_reference = s_and_b64 %31, %at_or_above_lower
  %selected = v_cndmask_b32 %false_value, %true_value, %inside_reference
  return %selected
}

