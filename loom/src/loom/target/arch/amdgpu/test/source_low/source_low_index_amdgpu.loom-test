// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @index_uniform_multiply(%lhs: i32) -> (index) {
  %lhs_index = index.cast %lhs : i32 to index
  %bounded_lhs = index.assume %lhs_index [range(%lhs_index, 0, 1023)] : index
  %stride = index.constant 128 : index
  %product = index.mul %bounded_lhs, %stride : index
  func.return %product : index
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_uniform_multiply(%bounded_lhs: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %10 = s_mov_b32 7
  %product = s_lshl_b32 %bounded_lhs, %10
  return %product
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_uniform_madd(%row_i32: i32, %column_i32: i32) -> (index) {
  %row_index = index.cast %row_i32 : i32 to index
  %column_index = index.cast %column_i32 : i32 to index
  %row = index.assume %row_index [range(%row_index, 0, 7)] : index
  %column = index.assume %column_index [range(%column_index, 0, 6)] : index
  %row_stride = index.constant 7 : index
  %linear = index.madd %row, %row_stride, %column : index
  func.return %linear : index
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_uniform_madd(%row: reg<amdgpu.sgpr>, %column: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %row_stride = s_mov_b32 7
  %13 = s_mul_i32 %row, %row_stride
  %linear = s_add_u32 %13, %column
  return %linear
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_uniform_shift_mask(%value: i32) -> (index, index) {
  %value_index = index.cast %value : i32 to index
  %bounded_value = index.assume %value_index [range(%value_index, 0, 1024)] : index
  %shift = index.constant 7 : index
  %quotient = index.shrui %bounded_value, %shift : index
  %mask = index.constant 127 : index
  %remainder = index.andi %bounded_value, %mask : index
  func.return %quotient, %remainder : index, index
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_uniform_shift_mask(%bounded_value: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %shift = s_mov_b32 7
  %quotient = s_lshr_b32 %bounded_value, %shift
  %mask = s_mov_b32 127
  %remainder = s_and_b32 %bounded_value, %mask
  return %quotient, %remainder
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_divergent_shift_mask(%values: vector<2xi32>) {
  %lane_i32 = vector.extract %values[0] : vector<2xi32> -> i32
  %lane = index.cast %lane_i32 : i32 to index
  %bounded_lane = index.assume %lane [range(%lane, 0, 63)] : index
  %shift = index.constant 2 : index
  %quotient = index.shrui %bounded_lane, %shift : index
  %mask = index.constant 7 : index
  %remainder = index.andi %bounded_lane, %mask : index
  %condition = index.cmp slt, %quotient, %remainder : index
  cfg.cond_br %condition, ^then, ^join : i1
^then:
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_divergent_shift_mask(%values: reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_uniform(%lhs: i32, %rhs: i32) -> (i1) {
  %lhs_index = index.cast %lhs : i32 to index
  %rhs_index = index.cast %rhs : i32 to index
  %result = index.cmp slt, %lhs_index, %rhs_index : index
  func.return %result : i1
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_uniform(%lhs_index: reg<amdgpu.sgpr>, %rhs_index: reg<amdgpu.sgpr>) -> (reg<amdgpu.scc>) asm<amdgpu.rdna3.core> {
  %result = s_cmp_lt_i32 %lhs_index, %rhs_index
  return %result
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_divergent(%values: vector<2xi32>, %limit: i32) {
  %lane_i32 = vector.extract %values[0] : vector<2xi32> -> i32
  %lane = index.cast %lane_i32 : i32 to index
  %limit_index = index.cast %limit : i32 to index
  %condition = index.cmp slt, %lane, %limit_index : index
  cfg.cond_br %condition, ^then, ^join : i1
^then:
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_divergent(%values: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @dynamic_vector_extract_i32(%values: vector<2xi32>, %lane_index: index, %limit: i32) {
  %lane = vector.extract %values[%lane_index] : vector<2xi32> -> i32
  %condition = scalar.cmpi slt, %lane, %limit : i32
  cfg.cond_br %condition, ^then, ^join : i1
^then:
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @dynamic_vector_extract_i32(%values: reg<amdgpu.vgpr x2>, %lane_index: reg<amdgpu.sgpr>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @dynamic_exact_vector_extract_i32(%values: vector<2xi32>) -> (i32) {
  %lane_index = index.constant 1 : index
  %lane = vector.extract %values[%lane_index] : vector<2xi32> -> i32
  func.return %lane : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @dynamic_exact_vector_extract_i32(%values: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  return %lane
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @dynamic_exact_iota_extract_i32() -> (i32) {
  %lane_index = index.constant 2 : index
  %start = scalar.constant 3 : i32
  %step = scalar.constant 4 : i32
  %lanes = vector.iota %start step %step : vector<4xi32>
  %lane = vector.extract %lanes[%lane_index] : vector<4xi32> -> i32
  func.return %lane : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @dynamic_exact_iota_extract_i32() -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %lane = s_mov_b32 11
  return %lane
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @dynamic_base_iota_i32(%start: i32) -> (vector<4xi32>) {
  %step = scalar.constant 1 : i32
  %lanes = vector.iota %start step %step : vector<4xi32>
  func.return %lanes : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @dynamic_base_iota_i32(%start: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %7 = v_mov_b32_copy %start
  %8 = v_add_u32_lit %7, 1
  %9 = v_add_u32_lit %7, 2
  %10 = v_add_u32_lit %7, 3
  %lanes = concat(%7, %8, %9, %10) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %lanes
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @dynamic_step_iota_i32(%start: i32, %step: i32) -> (vector<4xi32>) {
  %lanes = vector.iota %start step %step : vector<4xi32>
  func.return %lanes : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @dynamic_step_iota_i32(%start: reg<amdgpu.sgpr>, %step: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %7 = v_mov_b32_copy %start
  %8 = v_mov_b32_copy %step
  %9 = v_add_u32 %7, %8
  %10 = v_lshlrev_b32_lit %8, 1
  %11 = v_add_u32 %7, %10
  %12 = v_mov_b32 3
  %13 = v_mul_lo_u32 %8, %12
  %14 = v_add_u32 %7, %13
  %lanes = concat(%7, %9, %11, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %lanes
}
