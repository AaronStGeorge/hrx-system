// RUN: emit amdgpu-occupancy-json @gfx11_spill amdgpu.vgpr=2

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_spill(%a: reg<amdgpu.vgpr>, %b: reg<amdgpu.vgpr>, %c: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) {
