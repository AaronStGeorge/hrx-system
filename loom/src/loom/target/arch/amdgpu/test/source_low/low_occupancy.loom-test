// RUN: emit amdgpu-occupancy-json @cdna_mixed_vector_pressure diagnostics=summary

amdgpu.target<gfx942> @gfx942_target
// REMARK@+4: BACKEND/010 "uses 0 of 800 amdgpu.sgpr" "6%" "limited by 'amdgpu.vgpr_agpr'"
// REMARK@+3: BACKEND/010 "uses 256 of 512 amdgpu.vgpr" "6%" "limited by 'amdgpu.vgpr_agpr'"
// REMARK@+2: BACKEND/010 "uses 128 of 256 amdgpu.agpr" "6%" "limited by 'amdgpu.vgpr_agpr'"
// REMARK@+1: BACKEND/010 "uses 384 of 512 amdgpu.vgpr_agpr" "6%" "limited by 'amdgpu.vgpr_agpr'"
low.func.def target(@gfx942_target) @cdna_mixed_vector_pressure(%vgpr: reg<amdgpu.vgpr x256>, %agpr: reg<amdgpu.agpr x128>) -> (reg<amdgpu.vgpr x256>, reg<amdgpu.agpr x128>) {
  low.return %vgpr, %agpr : reg<amdgpu.vgpr x256>, reg<amdgpu.agpr x128>
}

