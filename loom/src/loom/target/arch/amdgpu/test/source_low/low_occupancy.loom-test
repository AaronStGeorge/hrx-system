// RUN: emit amdgpu-occupancy-json @cdna_fragment_accumulator_pressure diagnostics=summary

amdgpu.target<gfx942> @gfx942_target
// REMARK@+4: BACKEND/010 "uses 0 of 800 amdgpu.sgpr" "50%" "limited by 'amdgpu.agpr'"
// REMARK@+3: BACKEND/010 "uses 32 of 512 amdgpu.vgpr" "50%" "limited by 'amdgpu.agpr'"
// REMARK@+2: BACKEND/010 "uses 32 of 256 amdgpu.agpr" "50%" "limited by 'amdgpu.agpr'"
// REMARK@+1: BACKEND/010 "uses 64 of 512 amdgpu.vgpr_agpr" "50%" "limited by 'amdgpu.agpr'"
low.func.def target(@gfx942_target) @cdna_fragment_accumulator_pressure(%lhs: reg<amdgpu.vgpr x16>, %rhs: reg<amdgpu.vgpr x16>, %acc: reg<amdgpu.agpr x32>) -> (reg<amdgpu.agpr x32>) asm<amdgpu.cdna3.core> {
  %lhs0 = slice %lhs[0] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs0 = slice %rhs[0] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc0 = slice %acc[0] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out0 = v_mfma_f32_16x16x16_bf16 %lhs0, %rhs0, %acc0
  %lhs1 = slice %lhs[2] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs1 = slice %rhs[2] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc1 = slice %acc[4] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out1 = v_mfma_f32_16x16x16_bf16 %lhs1, %rhs1, %acc1
  %lhs2 = slice %lhs[4] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs2 = slice %rhs[4] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc2 = slice %acc[8] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out2 = v_mfma_f32_16x16x16_bf16 %lhs2, %rhs2, %acc2
  %lhs3 = slice %lhs[6] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs3 = slice %rhs[6] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc3 = slice %acc[12] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out3 = v_mfma_f32_16x16x16_bf16 %lhs3, %rhs3, %acc3
  %lhs4 = slice %lhs[8] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs4 = slice %rhs[8] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc4 = slice %acc[16] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out4 = v_mfma_f32_16x16x16_bf16 %lhs4, %rhs4, %acc4
  %lhs5 = slice %lhs[10] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs5 = slice %rhs[10] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc5 = slice %acc[20] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out5 = v_mfma_f32_16x16x16_bf16 %lhs5, %rhs5, %acc5
  %lhs6 = slice %lhs[12] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs6 = slice %rhs[12] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc6 = slice %acc[24] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out6 = v_mfma_f32_16x16x16_bf16 %lhs6, %rhs6, %acc6
  %lhs7 = slice %lhs[14] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %rhs7 = slice %rhs[14] : reg<amdgpu.vgpr x16> -> reg<amdgpu.vgpr x2>
  %acc7 = slice %acc[28] : reg<amdgpu.agpr x32> -> reg<amdgpu.agpr x4>
  %out7 = v_mfma_f32_16x16x16_bf16 %lhs7, %rhs7, %acc7
  %result = concat(%out0, %out1, %out2, %out3, %out4, %out5, %out6, %out7) : (reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>, reg<amdgpu.agpr x4>) -> reg<amdgpu.agpr x32>
  return %result
}

