// RUN: emit amdgpu-occupancy-json @gfx11_scc_does_not_contribute

amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_scc_does_not_contribute(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^then, ^else : reg<amdgpu.scc>
^then:
  return %value
^else:
  return %value
}

