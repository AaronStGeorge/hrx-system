// RUN: emit amdgpu-occupancy-json @gfx11_pressure diagnostics=summary fixed=%value:physical_register:64:1

amdgpu.target<gfx1100> @gfx11_target
// REMARK@+2: BACKEND/010 "uses 0 of 800 amdgpu.sgpr" "93%" "limited by 'amdgpu.vgpr'"
// REMARK@+1: BACKEND/010 "uses 65 of 1024 amdgpu.vgpr" "93%" "limited by 'amdgpu.vgpr'"
low.func.def target(@gfx11_target) @gfx11_pressure(%value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  low.return %value : reg<amdgpu.vgpr>
}

