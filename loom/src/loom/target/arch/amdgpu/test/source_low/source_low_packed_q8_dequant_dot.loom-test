low.kernel.def target(@target) workgroup_size(64, 1, 1) @q8_packed_word_global_dequant_dot4_kernel() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %scale_view = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %rhs_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 4096} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 256} : reg<amdgpu.sgpr x2>
  %q_byte_offset = v_lshlrev_b32_lit %lane, 2
  %scale_index = v_lshrrev_b32_lit %lane, 3
  %packed = global_load_b32_saddr %q_byte_offset, %scale_view
  %52 = v_lshlrev_b32_src0_inline %scale_index, 1
  %scale = global_load_u16_saddr %52, %scale_view
  %54 = v_lshlrev_b32_src0_inline %q_byte_offset, 2
  %rhs = global_load_b128_saddr %54, %rhs_view
  %56 = v_bfe_i32_offset_width_inline %packed {offset = 0, width = 8}
  %57 = v_bfe_i32_offset_width_inline %packed {offset = 8, width = 8}
  %58 = v_bfe_i32_offset_width_inline %packed {offset = 16, width = 8}
  %59 = v_ashrrev_i32_src0_inline %packed, 24
  %62 = v_cvt_f32_i32 %56
  %64 = v_cvt_f32_i32 %57
  %66 = v_cvt_f32_i32 %58
  %68 = v_cvt_f32_i32 %59
  %scale_f32 = v_cvt_f32_f16 %scale
  %74 = v_mul_f32 %62, %scale_f32
  %77 = v_mul_f32 %64, %scale_f32
  %80 = v_mul_f32 %66, %scale_f32
  %83 = v_mul_f32 %68, %scale_f32
  %acc = v_mov_b32 0
  %87 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %88 = v_fma_f32 %74, %87, %acc
  %90 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %91 = v_fmac_f32 %88, %77, %90
  %93 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %94 = v_fmac_f32 %91, %80, %93
  %96 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot = v_fmac_f32 %94, %83, %96
  %98 = v_lshlrev_b32_src0_inline %lane, 2
  global_store_b32_saddr %98, %dot, %output_view
  return
}

