low.func.def target(@target) abi(hal_kernel) @q8_packed_word_scalar_extract_dequant_dot4(%packed: reg<amdgpu.sgpr>, %scale: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr x4>, %acc: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %shift8 = s_mov_b32 8
  %shift16 = s_mov_b32 16
  %shift24 = s_mov_b32 24
  %q0_shifted = s_lshl_b32 %packed, %shift24
  %q1_shifted = s_lshl_b32 %packed, %shift16
  %q2_shifted = s_lshl_b32 %packed, %shift8
  %q0_i32 = s_ashr_i32 %q0_shifted, %shift24
  %q1_i32 = s_ashr_i32 %q1_shifted, %shift24
  %q2_i32 = s_ashr_i32 %q2_shifted, %shift24
  %q3_i32 = s_ashr_i32 %packed, %shift24
  %q0_f32 = v_cvt_f32_i32 %q0_i32
  %q1_f32 = v_cvt_f32_i32 %q1_i32
  %q2_f32 = v_cvt_f32_i32 %q2_i32
  %q3_f32 = v_cvt_f32_i32 %q3_i32
  %scale_f32 = v_cvt_f32_f16 %scale
  %s0 = v_mul_f32 %q0_f32, %scale_f32
  %s1 = v_mul_f32 %q1_f32, %scale_f32
  %s2 = v_mul_f32 %q2_f32, %scale_f32
  %s3 = v_mul_f32 %q3_f32, %scale_f32
  %52 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %53 = v_fma_f32 %s0, %52, %acc
  %55 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %56 = v_fmac_f32 %53, %s1, %55
  %58 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %59 = v_fmac_f32 %56, %s2, %58
  %61 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot = v_fmac_f32 %59, %s3, %61
  return %dot
}
