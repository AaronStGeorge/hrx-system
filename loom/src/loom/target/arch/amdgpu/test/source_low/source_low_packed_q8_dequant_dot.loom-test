amdgpu.target<gfx1100> @target
func.def target(@target) @q8_packed_word_scalar_extract_dequant_dot4(%packed: i32, %scale: f16, %rhs: vector<4xf32>, %acc: f32) -> (f32) {
  %shift8 = scalar.constant 8 : i32
  %shift16 = scalar.constant 16 : i32
  %shift24 = scalar.constant 24 : i32
  %q0_shifted = scalar.shli %packed, %shift24 : i32
  %q1_shifted = scalar.shli %packed, %shift16 : i32
  %q2_shifted = scalar.shli %packed, %shift8 : i32
  %q0_i32 = scalar.shrsi %q0_shifted, %shift24 : i32
  %q1_i32 = scalar.shrsi %q1_shifted, %shift24 : i32
  %q2_i32 = scalar.shrsi %q2_shifted, %shift24 : i32
  %q3_i32 = scalar.shrsi %packed, %shift24 : i32
  %q0_f32 = scalar.sitofp %q0_i32 : i32 to f32
  %q1_f32 = scalar.sitofp %q1_i32 : i32 to f32
  %q2_f32 = scalar.sitofp %q2_i32 : i32 to f32
  %q3_f32 = scalar.sitofp %q3_i32 : i32 to f32
  %scale_f32 = scalar.extf %scale : f16 to f32
  %s0 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %q0_f32, %scale_f32 : f32
  %s1 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %q1_f32, %scale_f32 : f32
  %s2 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %q2_f32, %scale_f32 : f32
  %s3 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %q3_f32, %scale_f32 : f32
  %scaled_q = vector.from_elements %s0, %s1, %s2, %s3 : vector<4xf32>
  %dot = vector.dotf %scaled_q, %rhs, %acc : vector<4xf32>, vector<4xf32>, f32
  func.return %dot : f32
}

