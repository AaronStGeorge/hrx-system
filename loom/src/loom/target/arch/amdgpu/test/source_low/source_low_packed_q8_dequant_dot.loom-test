low.func.def target(@target) abi(hal_kernel) @q8_packed_word_dequant_dot4(%packed: reg<amdgpu.vgpr>, %scale: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr x4>, %acc: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %16 = v_bfe_i32_offset_width_inline %packed {offset = 0, width = 8}
  %17 = v_bfe_i32_offset_width_inline %packed {offset = 8, width = 8}
  %18 = v_bfe_i32_offset_width_inline %packed {offset = 16, width = 8}
  %19 = v_ashrrev_i32_src0_inline %packed, 24
  %22 = v_cvt_f32_i32 %16
  %24 = v_cvt_f32_i32 %17
  %26 = v_cvt_f32_i32 %18
  %28 = v_cvt_f32_i32 %19
  %scale_f32 = v_cvt_f32_f16 %scale
  %34 = v_mul_f32 %22, %scale_f32
  %37 = v_mul_f32 %24, %scale_f32
  %40 = v_mul_f32 %26, %scale_f32
  %43 = v_mul_f32 %28, %scale_f32
  %46 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %47 = v_fma_f32 %34, %46, %acc
  %49 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %50 = v_fmac_f32 %47, %37, %49
  %52 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %53 = v_fmac_f32 %50, %40, %52
  %55 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot = v_fmac_f32 %53, %43, %55
  return %dot
}

