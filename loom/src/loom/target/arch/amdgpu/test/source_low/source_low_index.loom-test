amdgpu.target<gfx1100> @target
kernel.def target(@target) @workitem_y_lds_uses_explicit_vaddr(%output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %value = vector.constant 7 : vector<1xi32>
  vector.store %value, %scratch_view[%y] : vector<1xi32>, view<64xi32, #dense>
  %loaded = vector.load %scratch_view[%y] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%y] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @workitem_y_lds_uses_explicit_vaddr() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %14 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %14, 1023
  %bytes = s_mov_b32 256
  %17 = storage {byte_alignment = 16, byte_length = 256} : low.storage<workgroup>
  %scratch_view = storage_address %17 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %value = v_mov_b32 7
  ds_write_b32 %scratch_view, %value
  %loaded = ds_read_b32 %scratch_view
  %21 = v_mov_b32 0
  global_store_b32 %21, %loaded, %output_view
  return
}

