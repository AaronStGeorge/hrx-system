low.kernel.def target(@target) @index_madd_constant_addend_global_b32() asm<amdgpu.gfx11.core> {
  %x = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 64} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 64} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %row_stride = s_mov_b32 4
  %16 = v_mov_b32 4
  %17 = v_mul_lo_u32 %x, %16
  %linear = v_add_u32_lit %17, 1
  %19 = v_lshlrev_b32_lit %linear, 2
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %19, %20 {offset = 0}
  %22 = v_lshlrev_b32_lit %linear, 2
  %23 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %22, %loaded, %23 {offset = 0}
  return
}

