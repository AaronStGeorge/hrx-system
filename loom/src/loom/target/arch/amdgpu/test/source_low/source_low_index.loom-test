// TEMPLATE: loom/src/loom/test/corpus/source_low/index_addressing.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @index_madd_global_b32(%input: buffer, %output: buffer) {
  %x0 = kernel.workitem.id<x> : index
  %x = index.assume %x0 [range(%x0, 0, 3)] : index
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 3)] : index
  %zero = index.constant 0 : offset
  %row_stride = index.constant 4 : index
  %linear = index.madd %y, %row_stride, %x : index
  %input_view = buffer.view %input[%zero] : buffer -> view<16xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<16xi32, #dense>
  %loaded = vector.load %input_view[%linear] : view<16xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%linear] : vector<1xi32>, view<16xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @index_madd_global_b32() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 64} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 64} : reg<amdgpu.sgpr x4>
  %15 = v_mov_b32 1023
  %x = v_and_b32 %packed_tid, %15
  %17 = v_mov_b32 10
  %18 = v_lshrrev_b32 %17, %packed_tid
  %19 = v_mov_b32 1023
  %y = v_and_b32 %18, %19
  %zero = s_mov_b32 0
  %row_stride = s_mov_b32 4
  %23 = v_mov_b32 4
  %24 = v_mul_lo_u32 %y, %23
  %linear = v_add_u32 %24, %x
  %26 = v_mov_b32 2
  %27 = v_lshlrev_b32 %26, %linear
  %28 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32 %27, %28 {offset = 0}
  %30 = v_mov_b32 2
  %31 = v_lshlrev_b32 %30, %linear
  %32 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %31, %loaded, %32 {offset = 0}
  return
}

// ====

kernel.def @workitem_y_lds_uses_explicit_vaddr(%output: buffer) {
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %value = vector.constant 7 : vector<1xi32>
  vector.store %value, %scratch_view[%y] : vector<1xi32>, view<64xi32, #dense>
  %loaded = vector.load %scratch_view[%y] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%y] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @workitem_y_lds_uses_explicit_vaddr() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %12 = v_mov_b32 10
  %13 = v_lshrrev_b32 %12, %packed_tid
  %14 = v_mov_b32 1023
  %y = v_and_b32 %13, %14
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 256
  %scratch_view = frame_index @workitem_y_lds_uses_explicit_vaddr__lds5 {offset = 0} : reg<amdgpu.vgpr>
  %value = v_mov_b32 7
  %20 = v_mov_b32 2
  %21 = v_lshlrev_b32 %20, %y
  %22 = v_add_u32 %scratch_view, %21
  ds_write_b32 %22, %value {offset = 0}
  %23 = v_mov_b32 2
  %24 = v_lshlrev_b32 %23, %y
  %25 = v_add_u32 %scratch_view, %24
  %loaded = ds_read_b32 %25 {offset = 0}
  %27 = v_mov_b32 2
  %28 = v_lshlrev_b32 %27, %y
  %29 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %28, %loaded, %29 {offset = 0}
  return
}

low.slot @workitem_y_lds_uses_explicit_vaddr__lds5 {align = 16, function = @workitem_y_lds_uses_explicit_vaddr, size = 256, space = lds}
