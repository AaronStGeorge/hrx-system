amdgpu.target<gfx1100> @target
kernel.def target(@target) @dispatch_id_xy_global_b32(%output: buffer) {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c4 = index.constant 4 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c8, %c4, %c1) : index
} launch {
  %dispatch_x0 = kernel.workitem.dispatch.id<x> : index
  %dispatch_x = index.assume %dispatch_x0 [range(%dispatch_x0, 0, 31)] : index
  %dispatch_y0 = kernel.workitem.dispatch.id<y> : index
  %dispatch_y = index.assume %dispatch_y0 [range(%dispatch_y0, 0, 15)] : index
  %row_stride = index.constant 32 : index
  %linear = index.madd %dispatch_y, %row_stride, %dispatch_x : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<512xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%linear] : vector<1xi32>, view<512xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 1) @dispatch_id_xy_global_b32() asm<amdgpu.gfx11.core> {
  %14 = live_in<amdgpu.workgroup_id.x> : reg<amdgpu.sgpr>
  %15 = live_in<amdgpu.workgroup_id.y> : reg<amdgpu.sgpr>
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 2048} : reg<amdgpu.sgpr x2>
  %18 = v_and_b32_lit %packed_tid, 1023
  %19 = v_mov_b32_copy %14
  %20 = v_lshlrev_b32_lit %19, 3
  %dispatch_x = v_add_u32 %20, %18
  %22 = v_lshrrev_b32_lit %packed_tid, 10
  %23 = v_and_b32_lit %22, 1023
  %24 = v_mov_b32_copy %15
  %25 = v_lshlrev_b32_lit %24, 2
  %dispatch_y = v_add_u32 %25, %23
  %row_stride = s_mov_b32 32
  %28 = v_mov_b32 32
  %29 = v_mul_lo_u32 %dispatch_y, %28
  %linear = v_add_u32 %29, %dispatch_x
  %one = v_mov_b32 1
  %32 = v_lshlrev_b32_lit %linear, 2
  global_store_b32 %32, %one, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_uniform(%lhs: i32, %rhs: i32) -> (i1) {
  %lhs_index = index.cast %lhs : i32 to index
  %rhs_index = index.cast %rhs : i32 to index
  %result = index.cmp slt, %lhs_index, %rhs_index : index
  func.return %result : i1
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_uniform(%lhs_index: reg<amdgpu.sgpr>, %rhs_index: reg<amdgpu.sgpr>) -> (reg<amdgpu.scc>) asm<amdgpu.gfx11.core> {
  %result = s_cmp_lt_i32 %lhs_index, %rhs_index
  return %result
}

// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @index_cast_compare_divergent(%values: vector<2xi32>, %limit: i32) {
  %lane_i32 = vector.extract %values[0] : vector<2xi32> -> i32
  %lane = index.cast %lane_i32 : i32 to index
  %limit_index = index.cast %limit : i32 to index
  %condition = index.cmp slt, %lane, %limit_index : index
  cfg.cond_br %condition, ^then, ^join : i1
^then:
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @index_cast_compare_divergent(%values: reg<amdgpu.vgpr x2>, %limit_index: reg<amdgpu.sgpr>) asm<amdgpu.gfx11.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %9 = v_mov_b32_copy %limit_index
  %condition = v_cmp_lt_i32 %lane, %9
  %11, %12 = s_and_saveexec_b64 %condition
  low.cond_br %12, ^then, ^join : reg<amdgpu.scc>
^then:
  low.br ^join
^join:
  s_mov_b64_exec %11
  return
}
