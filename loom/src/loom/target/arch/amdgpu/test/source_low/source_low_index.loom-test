kernel.def @workitem_y_lds_uses_explicit_vaddr(%output: buffer) {
  %y0 = kernel.workitem.id<y> : index
  %y = index.assume %y0 [range(%y0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %value = vector.constant 7 : vector<1xi32>
  vector.store %value, %scratch_view[%y] : vector<1xi32>, view<64xi32, #dense>
  %loaded = vector.load %scratch_view[%y] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%y] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @workitem_y_lds_uses_explicit_vaddr() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %12 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %12, 1023
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 256
  %scratch_view = frame_index @workitem_y_lds_uses_explicit_vaddr__lds5 {offset = 0} : reg<amdgpu.vgpr>
  %value = v_mov_b32 7
  %18 = v_lshlrev_b32_lit %y, 2
  %19 = v_add_u32 %scratch_view, %18
  ds_write_b32 %19, %value {offset = 0}
  %20 = v_lshlrev_b32_lit %y, 2
  %21 = v_add_u32 %scratch_view, %20
  %loaded = ds_read_b32 %21 {offset = 0}
  %23 = v_lshlrev_b32_lit %y, 2
  %24 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %23, %loaded, %24 {offset = 0}
  return
}

low.slot @workitem_y_lds_uses_explicit_vaddr__lds5 {align = 16, function = @workitem_y_lds_uses_explicit_vaddr, size = 256, space = lds}
