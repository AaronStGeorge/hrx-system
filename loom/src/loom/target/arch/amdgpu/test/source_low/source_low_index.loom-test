  %packed_tid = live_in<amdgpu.workitem_id.packed.xy> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 64} : reg<amdgpu.sgpr x2>
  %x = v_and_b32_lit %packed_tid, 1023
  %20 = v_lshrrev_b32_lit %packed_tid, 10
  %y = v_and_b32_lit %20, 1023
  %22 = v_lshlrev_b32_lit %y, 2
  %linear = v_add_u32 %22, %x
  %24 = v_lshlrev_b32_lit %linear, 2
  %loaded = global_load_b32 %24, %input_view
  global_store_b32 %24, %loaded, %output_view
  return
}

