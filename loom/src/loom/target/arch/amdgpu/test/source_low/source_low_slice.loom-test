  %low = vector.slice %bytes[0] : vector<4xi8> -> vector<2xi8>
  func.return %low : vector<2xi8>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_slice_low_half(%low: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  return %low
}

