amdgpu.target<gfx1100> @target
func.def target(@target) @i32x4_insert_dynamic(%values: vector<4xi32>, %value: i32, %lane: index) -> (vector<4xi32>) {
  %updated = vector.insert %value into %values[%lane] : i32, vector<4xi32>
  func.return %updated : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32x4_insert_dynamic(%values: reg<amdgpu.vgpr x4>, %value: reg<amdgpu.sgpr>, %lane: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %9 = v_mov_b32_copy %value
  %10 = v_mov_b32_copy %lane
  %11 = slice %values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %12 = v_mov_b32 0
  %13 = v_cmp_eq_i32 %10, %12
  %14 = v_cndmask_b32 %11, %9, %13
  %15 = slice %values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %16 = v_mov_b32 1
  %17 = v_cmp_eq_i32 %10, %16
  %18 = v_cndmask_b32 %15, %9, %17
  %19 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = v_mov_b32 2
  %21 = v_cmp_eq_i32 %10, %20
  %22 = v_cndmask_b32 %19, %9, %21
  %23 = slice %values[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %24 = v_mov_b32 3
  %25 = v_cmp_eq_i32 %10, %24
  %26 = v_cndmask_b32 %23, %9, %25
  %updated = concat(%14, %18, %22, %26) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %updated
}
