// ----
low.func.def target(@target) abi(hal_kernel) @i8x4_slice_high_half(%bytes: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %high = v_lshrrev_b32_lit %bytes, 16
  return %high
}

