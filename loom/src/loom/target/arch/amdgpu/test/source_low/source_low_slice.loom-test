// ====

amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4_insert_dynamic(%values: vector<4xf32>, %value: f32, %lane: index) -> (vector<4xf32>) {
  %updated = vector.insert %value into %values[%lane] : f32, vector<4xf32>
  func.return %updated : vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4_insert_dynamic(%values: reg<amdgpu.vgpr x4>, %value: reg<amdgpu.vgpr>, %lane: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %9 = v_mov_b32_copy %lane
  %10 = slice %values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %11 = v_mov_b32 0
  %12 = v_cmp_eq_i32 %9, %11
  %13 = v_cndmask_b32 %10, %value, %12
  %14 = slice %values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %15 = v_mov_b32 1
  %16 = v_cmp_eq_i32 %9, %15
  %17 = v_cndmask_b32 %14, %value, %16
  %18 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = v_mov_b32 2
  %20 = v_cmp_eq_i32 %9, %19
  %21 = v_cndmask_b32 %18, %value, %20
  %22 = slice %values[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_mov_b32 3
  %24 = v_cmp_eq_i32 %9, %23
  %25 = v_cndmask_b32 %22, %value, %24
  %updated = concat(%13, %17, %21, %25) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %updated
}

