// TEMPLATE: loom/src/loom/test/corpus/source_low/vector_slice.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i32x4_slice_middle(%values: vector<4xi32>) -> (vector<2xi32>) {
  %middle = vector.slice %values[1] : vector<4xi32> -> vector<2xi32>
  func.return %middle : vector<2xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32x4_slice_middle(%values: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.gfx11.core> {
  %5 = slice %values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %6 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %middle = concat(%5, %6) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %middle
}

