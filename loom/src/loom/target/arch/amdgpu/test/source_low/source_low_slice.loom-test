amdgpu.target<gfx1100> @target
func.def target(@target) @f32x4_insert_static(%values: vector<4xf32>, %value: f32) -> (vector<4xf32>) {
  %updated = vector.insert %value into %values[2] : f32, vector<4xf32>
  func.return %updated : vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32x4_insert_static(%values: reg<amdgpu.vgpr x4>, %value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %7 = slice %values[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %8 = slice %values[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %9 = slice %values[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %10 = slice %values[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %updated = concat(%7, %8, %value, %10) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %updated
}

