amdgpu.target<gfx1100> @target
func.def target(@target) @i8x4_slice_high_half(%bytes: vector<4xi8>) -> (vector<2xi8>) {
  %high = vector.slice %bytes[2] : vector<4xi8> -> vector<2xi8>
  func.return %high : vector<2xi8>
