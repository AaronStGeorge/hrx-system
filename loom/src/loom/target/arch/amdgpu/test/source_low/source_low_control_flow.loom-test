func.def target(@target) @cfg_if_scalar_compare(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = scalar.addi %a, %b : i32
  cfg.br ^join(%then: i32)
^else:
  %else = scalar.subi %a, %b : i32
  cfg.br ^join(%else: i32)
^join(%result: i32):
  func.return %result : i32
}

