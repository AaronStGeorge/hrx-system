low.func.def target(@target) abi(hal_kernel) @divergent_if_else(%values: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 8} : reg<amdgpu.sgpr x2>
  %then = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32_copy %limit
  %cond = v_cmp_lt_i32 %then, %17
  %19, %20 = s_and_saveexec_b64 %cond
  low.cond_br %20, ^then, ^_bb4 : reg<amdgpu.scc>
^then:
  %22 = v_mov_b32 0
  global_store_b32_saddr %22, %then, %output_view
  low.br ^_bb4
^else:
  %else = v_sub_nc_u32 %17, %then
  %25 = v_mov_b32 0
  global_store_b32_saddr %25, %else, %output_view
  low.br ^_bb5
^join:
  %joined = v_mov_b32 1
  %27 = v_mov_b32 0
  global_store_b32_saddr %27, %joined, %output_view {offset = 4}
  return
^_bb4:
  %21 = s_xor_b64_exec %19
  low.cond_br %21, ^else, ^_bb5 : reg<amdgpu.scc>
^_bb5:
  s_mov_b64_exec %19
  low.br ^join
}

