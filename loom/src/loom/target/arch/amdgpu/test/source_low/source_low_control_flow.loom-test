  %channel_start = index.assume %channel_start0 [range(%channel_start0, 0, 252)] : index
  %positive_global = buffer.assume.memory_space<global> %positive : buffer
  %negative_global = buffer.assume.memory_space<global> %negative : buffer
  %output_global = buffer.assume.memory_space<global> %output : buffer
  %positive_noalias, %negative_noalias, %output_noalias = buffer.assume.noalias %positive_global, %negative_global, %output_global : buffer, buffer, buffer
