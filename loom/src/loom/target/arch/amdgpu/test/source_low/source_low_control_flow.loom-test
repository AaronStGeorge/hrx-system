func.def target(@target) @divergent_region_with_uniform_loop(%values: vector<2xi32>) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %limit = scalar.constant 8 : i32
  %start = scalar.constant 0 : i32
  %step = scalar.constant 1 : i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  cfg.cond_br %cond, ^then, ^join : i1
^then:
  cfg.br ^loop(%start: i32)
^loop(%i: i32):
  %next = scalar.addi %i, %step : i32
  %again = scalar.cmpi slt, %next, %limit : i32
  cfg.cond_br %again, ^body, ^join : i1
^body:
  cfg.br ^loop(%next: i32)
^join:
  func.return
}

