    %positive_values = vector.load %positive_view[%channel_start] : view<256xf32, #dense> -> vector<4xf32>
    scf.yield %positive_values : vector<4xf32>
  } else {
    %negative_values = vector.load %negative_view[%channel_start] : view<256xf32, #dense> -> vector<4xf32>
    scf.yield %negative_values : vector<4xf32>
  }
  vector.store %values, %output_view[%channel_start] : vector<4xf32>, view<256xf32, #dense>
  kernel.return
