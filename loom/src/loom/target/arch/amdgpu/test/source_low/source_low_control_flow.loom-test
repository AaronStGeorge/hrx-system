low.func.def target(@target) abi(hal_kernel) @cfg_if_scalar_compare(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %a: reg<amdgpu.sgpr>, %b: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^then, ^else : reg<amdgpu.scc>
^then:
  %then = s_add_u32 %a, %b
  low.br ^join(%then: reg<amdgpu.sgpr>)
^else:
  %else = s_sub_u32 %a, %b
  low.br ^join(%else: reg<amdgpu.sgpr>)
^join(%result: reg<amdgpu.sgpr>):
  return %result
}

// ====

amdgpu.target<gfx1100> @target

kernel.def target(@target) @cfg_exact_divergent_condition(%output: buffer) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %lane = kernel.workitem.id<x> : index
  %cond = index.cmp eq, %lane, %lane : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %value = vector.constant 1 : vector<1xi32>
  vector.store %value, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  kernel.return
^else:
  kernel.return
}

kernel.def target(@target) @cfg_exact_false_divergent_condition(%output: buffer) {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch {
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %lane = kernel.workitem.id<x> : index
  %cond = index.cmp ne, %lane, %lane : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  kernel.return
^else:
  %value = vector.constant 2 : vector<1xi32>
  vector.store %value, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @cfg_exact_divergent_condition() asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %value = v_mov_b32 1
  %20 = v_mov_b32 0
  global_store_b32_saddr %20, %value, %output_view
  return
}

low.kernel.def target(@target) workgroup_size(1, 1, 1) @cfg_exact_false_divergent_condition() asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %value = v_mov_b32 2
  %23 = v_mov_b32 0
  global_store_b32_saddr %23, %value, %output_view
  return
}

