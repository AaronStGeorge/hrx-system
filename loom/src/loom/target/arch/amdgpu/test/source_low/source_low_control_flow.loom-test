func.def target(@target) @divergent_if_else_vector_result(%values: vector<2xi32>, %limit: i32, %state: vector<2xi32>) -> (vector<2xi32>) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = vector.insert %lane into %state[0] : i32, vector<2xi32>
  cfg.br ^join(%then: vector<2xi32>)
^else:
  %biased = scalar.subi %limit, %lane : i32
  %else = vector.insert %biased into %state[1] : i32, vector<2xi32>
  cfg.br ^join(%else: vector<2xi32>)
^join(%result: vector<2xi32>):
  func.return %result : vector<2xi32>
}

