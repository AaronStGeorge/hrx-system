func.def target(@target) @cfg_branch_condition_sink_cross_block(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %outer = scalar.cmpi slt, %lhs, %rhs : i32
  %inner = scalar.cmpi slt, %a, %b : i32
  %sum = scalar.addi %a, %b : i32
  cfg.cond_br %outer, ^then, ^else
^then:
  cfg.cond_br %inner, ^inside, ^outside
^inside:
  cfg.br ^join(%sum: i32)
^outside:
  cfg.br ^join(%a: i32)
^else:
  %diff = scalar.subi %a, %b : i32
  cfg.br ^join(%diff: i32)
^join(%result: i32):
  func.return %result : i32
}

