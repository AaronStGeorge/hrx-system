// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @cfg_if_scalar_compare(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = scalar.addi %a, %b : i32
  cfg.br ^join(%then: i32)
^else:
  %else = scalar.subi %a, %b : i32
  cfg.br ^join(%else: i32)
^join(%result: i32):
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @cfg_if_scalar_compare(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %a: reg<amdgpu.sgpr>, %b: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^then, ^else : reg<amdgpu.scc>
^then:
  %then = s_add_u32 %a, %b
  low.br ^join(%then: reg<amdgpu.sgpr>)
^else:
  %else = s_sub_u32 %a, %b
  low.br ^join(%else: reg<amdgpu.sgpr>)
^join(%result: reg<amdgpu.sgpr>):
  return %result
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_if_else(%values: vector<2xi32>, %limit: i32, %output: buffer) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = vector.from_elements %lane : vector<1xi32>
  vector.store %then, %output_view[0] : vector<1xi32>, view<2xi32, #dense>
  cfg.br ^join
^else:
  %else_value = scalar.subi %limit, %lane : i32
  %else = vector.from_elements %else_value : vector<1xi32>
  vector.store %else, %output_view[0] : vector<1xi32>, view<2xi32, #dense>
  cfg.br ^join
^join:
  %joined = vector.constant 1 : vector<1xi32>
  vector.store %joined, %output_view[1] : vector<1xi32>, view<2xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @divergent_if_else(%values: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x2>
  %then = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32_copy %limit
  %cond = v_cmp_lt_i32 %then, %17
  %19, %20 = s_and_saveexec_b64 %cond
  low.cond_br %20, ^then, ^_bb4 : reg<amdgpu.scc>
^then:
  %22 = v_mov_b32 0
  global_store_b32 %22, %then, %output_view
  low.br ^_bb4
^else:
  %23 = v_mov_b32_copy %limit
  %else = v_sub_nc_u32 %23, %then
  %25 = v_mov_b32 0
  global_store_b32 %25, %else, %output_view
  low.br ^_bb5
^join:
  %joined = v_mov_b32 1
  %27 = v_mov_b32 0
  global_store_b32 %27, %joined, %output_view {offset = 4}
  return
^_bb4:
  %21 = s_xor_b64_exec %19
  low.cond_br %21, ^else, ^_bb5 : reg<amdgpu.scc>
^_bb5:
  s_mov_b64_exec %19
  low.br ^join
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_then_only(%values: vector<2xi32>, %limit: i32, %output: buffer) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  cfg.cond_br %cond, ^then, ^join : i1
^then:
  %biased = scalar.addi %lane, %limit : i32
  %stored = vector.from_elements %biased : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<2xi32, #dense>
  cfg.br ^join
^join:
  %joined = vector.constant 1 : vector<1xi32>
  vector.store %joined, %output_view[1] : vector<1xi32>, view<2xi32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @divergent_then_only(%values: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x2>
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = v_mov_b32_copy %limit
  %cond = v_cmp_lt_i32 %lane, %15
  %17, %18 = s_and_saveexec_b64 %cond
  low.cond_br %18, ^then, ^_bb3 : reg<amdgpu.scc>
^then:
  %19 = v_mov_b32_copy %limit
  %stored = v_add_u32 %lane, %19
  %21 = v_mov_b32 0
  global_store_b32 %21, %stored, %output_view
  low.br ^_bb3
^join:
  %joined = v_mov_b32 1
  %23 = v_mov_b32 0
  global_store_b32 %23, %joined, %output_view {offset = 4}
  return
^_bb3:
  s_mov_b64_exec %17
  low.br ^join
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_region_with_uniform_loop(%values: vector<2xi32>) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %limit = scalar.constant 8 : i32
  %start = scalar.constant 0 : i32
  %step = scalar.constant 1 : i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  cfg.cond_br %cond, ^then, ^join : i1
^then:
  cfg.br ^loop(%start: i32)
^loop(%i: i32):
  %next = scalar.addi %i, %step : i32
  %again = scalar.cmpi slt, %next, %limit : i32
  cfg.cond_br %again, ^body, ^join : i1
^body:
  cfg.br ^loop(%next: i32)
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @divergent_region_with_uniform_loop(%values: reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %limit = s_mov_b32 8
  %start = s_mov_b32 0
  %step = s_mov_b32 1
  %15 = v_mov_b32 8
  %cond = v_cmp_lt_i32 %lane, %15
  %17, %18 = s_and_saveexec_b64 %cond
  low.cond_br %18, ^then, ^_bb5 : reg<amdgpu.scc>
^then:
  low.br ^loop(%start: reg<amdgpu.sgpr>)
^loop(%i: reg<amdgpu.sgpr>):
  %next = s_add_u32 %i, %step
  %again = s_cmp_lt_i32 %next, %limit
  low.cond_br %again, ^body, ^_bb5 : reg<amdgpu.scc>
^body:
  low.br ^loop(%next: reg<amdgpu.sgpr>)
^join:
  return
^_bb5:
  s_mov_b64_exec %17
  low.br ^join
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_passthrough_else_loop_state(%values: vector<2xi32>, %state: vector<2xi32>) -> (vector<2xi32>) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %limit = scalar.constant 8 : i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %start = scalar.constant 0 : i32
  %stop = scalar.constant 2 : i32
  %step = scalar.constant 1 : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^loop(%start: i32, %state: vector<2xi32>)
^loop(%i: i32, %iter: vector<2xi32>):
  %again = scalar.cmpi slt, %i, %stop : i32
  cfg.cond_br %again, ^body, ^then_exit : i1
^body:
  %updated = vector.insert %lane into %iter[0] : i32, vector<2xi32>
  %next = scalar.addi %i, %step : i32
  cfg.br ^loop(%next: i32, %updated: vector<2xi32>)
^then_exit:
  cfg.br ^join(%iter: vector<2xi32>)
^else:
  cfg.br ^join(%state: vector<2xi32>)
^join(%result: vector<2xi32>):
  func.return %result : vector<2xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @divergent_passthrough_else_loop_state(%values: reg<amdgpu.vgpr x2>, %state: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_mov_b32 8
  %cond = v_cmp_lt_i32 %lane, %24
  %start = s_mov_b32 0
  %stop = s_mov_b32 2
  %step = s_mov_b32 1
  %29, %30 = s_and_saveexec_b64 %cond
  low.cond_br %30, ^then, ^_bb7 : reg<amdgpu.scc>
^then:
  low.br ^loop(%start: reg<amdgpu.sgpr>, %state: reg<amdgpu.vgpr x2>)
^loop(%i: reg<amdgpu.sgpr>, %iter: reg<amdgpu.vgpr x2>):
  %again = s_cmp_lt_i32 %i, %stop
  low.cond_br %again, ^body, ^then_exit : reg<amdgpu.scc>
^body:
  %40 = slice %iter[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %updated = concat(%lane, %40) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %next = s_add_u32 %i, %step
  low.br ^loop(%next: reg<amdgpu.sgpr>, %updated: reg<amdgpu.vgpr x2>)
^then_exit:
  low.br ^_bb8(%iter: reg<amdgpu.vgpr x2>)
^else:
  low.br ^join(%state: reg<amdgpu.vgpr x2>)
^join(%result$20: reg<amdgpu.vgpr x2>):
  return %result$20
^_bb7:
  s_mov_b64_exec %29
  low.br ^else
^_bb8(%result$21: reg<amdgpu.vgpr x2>):
  s_mov_b64_exec %29
  %31 = slice %state[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %32 = slice %result$21[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %33 = v_cndmask_b32 %31, %32, %cond
  %34 = slice %state[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %35 = slice %result$21[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %36 = v_cndmask_b32 %34, %35, %cond
  %37 = concat(%33, %36) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  low.br ^join(%37: reg<amdgpu.vgpr x2>)
}
