  low.br ^_bb8
^before:
  %low_stored = v_sub_nc_u32 %23, %lane
  %41 = v_mov_b32 0
  global_store_b32_saddr %41, %low_stored, %output_view {offset = 8}
  low.br ^_bb6
^_bb5:
  %27 = s_xor_b64_exec %25
  low.cond_br %27, ^before, ^_bb6 : reg<amdgpu.scc>
^_bb6:
