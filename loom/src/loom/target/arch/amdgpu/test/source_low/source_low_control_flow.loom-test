// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @cfg_if_scalar_compare(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = scalar.addi %a, %b : i32
  cfg.br ^join(%then: i32)
^else:
  %else = scalar.subi %a, %b : i32
  cfg.br ^join(%else: i32)
^join(%result: i32):
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @cfg_if_scalar_compare(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %a: reg<amdgpu.sgpr>, %b: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.gfx11.core> {
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^then, ^else : reg<amdgpu.scc>
^then:
  %then = s_add_u32 %a, %b
  low.br ^join(%then: reg<amdgpu.sgpr>)
^else:
  %else = s_sub_u32 %a, %b
  low.br ^join(%else: reg<amdgpu.sgpr>)
^join(%result: reg<amdgpu.sgpr>):
  return %result
}

// ====

func.def @divergent_if(%values: vector<2xi32>, %limit: i32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  // ERROR@+1: BACKEND/001 "AMDGPU divergent branch lowering currently requires a then-only diamond"
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join
^else:
  cfg.br ^join
^join:
  func.return
}

// ====

func.def @divergent_then_only(%values: vector<2xi32>, %limit: i32) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  cfg.cond_br %cond, ^then, ^join : i1
^then:
  %biased = scalar.addi %lane, %limit : i32
  cfg.br ^join
^join:
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @divergent_then_only(%values: reg<amdgpu.vgpr x2>, %limit: reg<amdgpu.sgpr>) asm<amdgpu.gfx11.core> {
  %lane = slice %values[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %8 = v_mov_b32_copy %limit
  %cond = v_cmp_lt_i32 %lane, %8
  %10, %11 = s_and_saveexec_b64 %cond
  low.cond_br %11, ^then, ^join : reg<amdgpu.scc>
^then:
  %12 = v_mov_b32_copy %limit
  %biased = v_add_u32 %lane, %12
  low.br ^join
^join:
  s_mov_b64_exec %10
  return
}
