amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_if_else(%values: vector<2xi32>, %limit: i32, %output: buffer) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %cond = scalar.cmpi slt, %lane, %limit : i32
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %then = vector.from_elements %lane : vector<1xi32>
  vector.store %then, %output_view[0] : vector<1xi32>, view<2xi32, #dense>
  cfg.br ^join
^else:
  %else_value = scalar.subi %limit, %lane : i32
  %else = vector.from_elements %else_value : vector<1xi32>
  vector.store %else, %output_view[0] : vector<1xi32>, view<2xi32, #dense>
  cfg.br ^join
^join:
  %joined = vector.constant 1 : vector<1xi32>
  vector.store %joined, %output_view[1] : vector<1xi32>, view<2xi32, #dense>
  func.return
}

