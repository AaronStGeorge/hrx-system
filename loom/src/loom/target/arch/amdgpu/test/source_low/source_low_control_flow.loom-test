// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target

func.def target(@target) @cfg_branch_condition_sink(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %cond = scalar.cmpi slt, %lhs, %rhs : i32
  %sum = scalar.addi %a, %b : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%sum: i32)
^else:
  %diff = scalar.subi %a, %b : i32
  cfg.br ^join(%diff: i32)
^join(%result: i32):
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @cfg_branch_condition_sink(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %a: reg<amdgpu.sgpr>, %b: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %sum = s_add_u32 %a, %b
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^then, ^else : reg<amdgpu.scc>
^then:
  low.br ^join(%sum: reg<amdgpu.sgpr>)
^else:
  %diff = s_sub_u32 %a, %b
  low.br ^join(%diff: reg<amdgpu.sgpr>)
^join(%result: reg<amdgpu.sgpr>):
  return %result
}

// ====

amdgpu.target<gfx1100> @target

func.def target(@target) @cfg_branch_condition_sink_cross_block(%lhs: i32, %rhs: i32, %a: i32, %b: i32) -> (i32) {
  %outer = scalar.cmpi slt, %lhs, %rhs : i32
  %inner = scalar.cmpi slt, %a, %b : i32
  %sum = scalar.addi %a, %b : i32
  cfg.cond_br %outer, ^then, ^else : i1
^then:
  cfg.cond_br %inner, ^inside, ^outside : i1
^inside:
  cfg.br ^join(%sum: i32)
^outside:
  cfg.br ^join(%a: i32)
^else:
  %diff = scalar.subi %a, %b : i32
  cfg.br ^join(%diff: i32)
^join(%result: i32):
  func.return %result : i32
}

// ----
low.func.def target(@target) abi(hal_kernel) @cfg_branch_condition_sink_cross_block(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %a: reg<amdgpu.sgpr>, %b: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %sum = s_add_u32 %a, %b
  %outer = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %outer, ^then, ^else : reg<amdgpu.scc>
^then:
  %inner = s_cmp_lt_i32 %a, %b
  low.cond_br %inner, ^inside, ^outside : reg<amdgpu.scc>
^inside:
  low.br ^join(%sum: reg<amdgpu.sgpr>)
^outside:
  low.br ^join(%a: reg<amdgpu.sgpr>)
^else:
  %diff = s_sub_u32 %a, %b
  low.br ^join(%diff: reg<amdgpu.sgpr>)
^join(%result: reg<amdgpu.sgpr>):
  return %result
}

