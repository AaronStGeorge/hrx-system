amdgpu.target<gfx1100> @target

func.def target(@target) @divergent_nested_if_else_stores(%values: vector<2xi32>, %lower: i32, %upper: i32, %output: buffer) {
  %lane = vector.extract %values[0] : vector<2xi32> -> i32
  %after_lower = scalar.cmpi sge, %lane, %lower : i32
  %before_upper = scalar.cmpi slt, %lane, %upper : i32
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<3xi32, #dense>
  cfg.cond_br %after_lower, ^after, ^before : i1
^after:
  cfg.cond_br %before_upper, ^inside, ^outside_high : i1
^inside:
  %inside_value = scalar.addi %lane, %upper : i32
  %inside_stored = vector.from_elements %inside_value : vector<1xi32>
  vector.store %inside_stored, %output_view[0] : vector<1xi32>, view<3xi32, #dense>
  cfg.br ^join
^outside_high:
  %high_value = scalar.subi %lane, %upper : i32
  %high_stored = vector.from_elements %high_value : vector<1xi32>
  vector.store %high_stored, %output_view[1] : vector<1xi32>, view<3xi32, #dense>
  cfg.br ^join
^before:
  %low_value = scalar.subi %lower, %lane : i32
  %low_stored = vector.from_elements %low_value : vector<1xi32>
  vector.store %low_stored, %output_view[2] : vector<1xi32>, view<3xi32, #dense>
  cfg.br ^join
^join:
  func.return
}

