// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_b128.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @lds_b128_roundtrip(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_b128_roundtrip() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 1024
  %scratch_view = frame_index @lds_b128_roundtrip__lds6 {offset = 0} : reg<amdgpu.vgpr>
  %18 = v_mov_b32 4
  %19 = v_lshlrev_b32 %18, %tid
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %19, %20 {offset = 0}
  %22 = v_mov_b32 4
  %23 = v_lshlrev_b32 %22, %tid
  %24 = v_add_u32 %scratch_view, %23
  ds_write_b128 %24, %loaded {offset = 0}
  %25 = v_mov_b32 4
  %26 = v_lshlrev_b32 %25, %tid
  %27 = v_add_u32 %scratch_view, %26
  %roundtrip = ds_read_b128 %27 {offset = 0}
  %29 = v_mov_b32 4
  %30 = v_lshlrev_b32 %29, %tid
  %31 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %30, %roundtrip, %31 {offset = 0}
  return
}

low.slot @lds_b128_roundtrip__lds6 {align = 16, function = @lds_b128_roundtrip, size = 1024, space = lds}

