  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%large] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
