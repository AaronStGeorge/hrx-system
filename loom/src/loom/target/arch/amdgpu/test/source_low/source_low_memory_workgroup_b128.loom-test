low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_b128_large_static_offset_roundtrip() asm<amdgpu.rdna3.core> {
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %24 = storage {byte_alignment = 16, byte_length = 4096} : low.storage<workgroup>
  %26 = v_mov_b32 0
  %loaded = global_load_b128_saddr %26, %input_view
  ds_write_b128 %26, %loaded {offset = 1024}
  %roundtrip = ds_read_b128 %26 {offset = 1024}
