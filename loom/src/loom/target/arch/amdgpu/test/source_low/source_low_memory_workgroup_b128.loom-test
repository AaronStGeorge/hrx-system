// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_b128.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def @lds_b128_roundtrip(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_b128_roundtrip() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 1024
  %17 = storage {byte_alignment = 16, byte_length = 1024} : low.storage<workgroup>
  %scratch_view = storage_address %17 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %19 = v_lshlrev_b32_lit %tid, 4
  %20 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %19, %20
  %22 = v_lshlrev_b32_lit %tid, 4
  %23 = v_add_u32 %scratch_view, %22
  ds_write_b128 %23, %loaded
  %24 = v_lshlrev_b32_lit %tid, 4
  %25 = v_add_u32 %scratch_view, %24
  %roundtrip = ds_read_b128 %25
  %27 = v_lshlrev_b32_lit %tid, 4
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %27, %roundtrip, %28
  return
}

// ====

kernel.def @lds_b128_large_static_offset_roundtrip(%input: buffer, %output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %large = index.constant 1024 : offset
  %bytes = index.constant 4096 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%large] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_b128_large_static_offset_roundtrip() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %large = s_mov_b32 1024
  %bytes = s_mov_b32 4096
  %19 = storage {byte_alignment = 16, byte_length = 4096} : low.storage<workgroup>
  %scratch_view = storage_address %19 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %21 = v_lshlrev_b32_lit %tid, 4
  %22 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %21, %22
  %24 = v_lshlrev_b32_lit %tid, 4
  %25 = v_add_u32 %scratch_view, %24
  %26 = v_add_u32_lit %25, 1024
  ds_write_b128 %26, %loaded
  %27 = v_lshlrev_b32_lit %tid, 4
  %28 = v_add_u32 %scratch_view, %27
  %29 = v_add_u32_lit %28, 1024
  %roundtrip = ds_read_b128 %29
  %31 = v_lshlrev_b32_lit %tid, 4
  %32 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %31, %roundtrip, %32
  return
}
