low.kernel.def target(@target) workgroup_size(64, 1, 1) @lds_b128_large_static_offset_roundtrip() asm<amdgpu.rdna3.core> {
  %lane = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
