// TEMPLATE: loom/src/loom/test/corpus/source_low/memory_workgroup_b128.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
kernel.def target(@target) @lds_b128_roundtrip(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_b128_roundtrip() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %bytes = s_mov_b32 1024
  %19 = storage {byte_alignment = 16, byte_length = 1024} : low.storage<workgroup>
  %scratch_view = storage_address %19 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %21 = v_mov_b32 0
  %loaded = global_load_b128 %21, %input_view
  ds_write_b128 %scratch_view, %loaded
  %roundtrip = ds_read_b128 %scratch_view
  %24 = v_mov_b32 0
  global_store_b128 %24, %roundtrip, %output_view
  return
}

// ====

amdgpu.target<gfx1100> @target
kernel.def target(@target) @lds_b128_large_static_offset_roundtrip(%input: buffer, %output: buffer) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %large = index.constant 1024 : offset
  %bytes = index.constant 4096 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %scratch_view = buffer.view %scratch[%large] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  %roundtrip = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %roundtrip, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @lds_b128_large_static_offset_roundtrip() asm<amdgpu.rdna3.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x2>
  %bytes = s_mov_b32 4096
  %20 = storage {byte_alignment = 16, byte_length = 4096} : low.storage<workgroup>
  %scratch_view = storage_address %20 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %22 = v_mov_b32 0
  %loaded = global_load_b128 %22, %input_view
  %24 = v_add_u32_lit %scratch_view, 1024
  ds_write_b128 %24, %loaded
  %25 = v_add_u32_lit %scratch_view, 1024
  %roundtrip = ds_read_b128 %25
  %27 = v_mov_b32 0
  global_store_b128 %27, %roundtrip, %output_view
  return
}
