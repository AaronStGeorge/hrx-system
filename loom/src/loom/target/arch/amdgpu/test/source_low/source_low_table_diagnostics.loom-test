// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i16_table_lookup_rejected(%codes: vector<4xi16>) -> (vector<4xf32>) {
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant 0.0 : f32
  %g2 = scalar.constant 1.0 : f32
  %g3 = scalar.constant 2.0 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  // ERROR@+1: AMDGPU/023 {constraint_key="table_lookup.shape"}
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi16> -> vector<4xf32>
  func.return %decoded : vector<4xf32>
}
