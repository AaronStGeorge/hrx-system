low.kernel.def target(@target) @lds_read2_write2_diagnostics() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 2048
  %scratch_view = frame_index @lds_read2_write2_diagnostics__lds6 {offset = 0} : reg<amdgpu.vgpr>
  %16 = v_mov_b32 1
  %17 = v_mov_b32 1
  %one = concat(%16, %17) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %19 = v_mov_b32 5
  %20 = v_lshlrev_b32 %19, %tid
  %21 = v_add_u32 %scratch_view, %20
  %22 = slice %one[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = slice %one[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  ds_write2_b32 %21, %22, %23 {offset0 = 0, offset1 = 2}
  %24 = v_mov_b32 5
  %25 = v_lshlrev_b32 %24, %tid
  %26 = v_add_u32 %scratch_view, %25
  %loaded = ds_read2_b32 %26 {offset0 = 0, offset1 = 2}
  %28 = v_mov_b32 3
  %29 = v_lshlrev_b32 %28, %tid
  %30 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b64 %29, %loaded, %30 {offset = 0}
  return
}

