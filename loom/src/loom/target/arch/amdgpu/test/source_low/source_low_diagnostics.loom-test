  %18 = v_mov_b32 1
  %one = concat(%15, %16, %17, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %20 = v_mov_b32 4
