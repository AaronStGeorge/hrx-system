kernel.def target(@target) @lds_read2_write2_diagnostics(%output: buffer) {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 2048 : offset
  %layout = encoding.layout.strided [8, 2] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, %layout>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x2xi32, #dense>
  %one = vector.constant 1 : vector<2xi32>
  // REMARK@+1: BACKEND/017 "selected store memory packet 'amdgpu.ds_write2_b32'" "dynamic stride 32 byte(s)" "conflict degree 8" "bank-conflict-risk"
  vector.store %one, %scratch_view[%tid, 0] : vector<2xi32>, view<64x4xi32, %layout>
  // REMARK@+1: BACKEND/017 "selected load memory packet 'amdgpu.ds_read2_b32'" "dynamic stride 32 byte(s)" "conflict degree 8" "bank-conflict-risk"
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x4xi32, %layout> -> vector<2xi32>
  vector.store %loaded, %output_view[%tid, 0] : vector<2xi32>, view<64x2xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @lds_read2_write2_diagnostics() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x2>
  %bytes = s_mov_b32 2048
  %17 = storage {byte_alignment = 16, byte_length = 2048} : low.storage<workgroup>
  %scratch_view = storage_address %17 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %19 = v_mov_b32 1
  %20 = v_mov_b32 1
  %one = concat(%19, %20) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %22 = v_lshlrev_b32_lit %tid, 5
  %23 = v_add_u32 %scratch_view, %22
  %24 = slice %one[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %25 = slice %one[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  ds_write2_b32 %23, %24, %25 {offset1 = 2}
  %26 = v_lshlrev_b32_lit %tid, 5
  %27 = v_add_u32 %scratch_view, %26
  %loaded = ds_read2_b32 %27 {offset1 = 2}
  %29 = v_lshlrev_b32_lit %tid, 3
  global_store_b64 %29, %loaded, %output_view
  return
}

