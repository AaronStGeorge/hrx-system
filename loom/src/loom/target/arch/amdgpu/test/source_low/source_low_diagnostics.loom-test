// RUN: emit source-low target-preset=amdgpu-gfx11 diagnostics=memory output=low

kernel.def @lds_b32_diagnostics(%output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 256 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  // REMARK@+1: BACKEND/017 "selected store memory packet 'amdgpu.ds_write_addtid_b32'" "dynamic stride 4 byte(s)" "conflict degree 1" "bank-conflict-free"
  vector.store %one, %scratch_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  // REMARK@+1: BACKEND/017 "selected load memory packet 'amdgpu.ds_read_addtid_b32'" "dynamic stride 4 byte(s)" "conflict degree 1" "bank-conflict-free"
  %loaded = vector.load %scratch_view[%tid] : view<64xi32, #dense> -> vector<1xi32>
  vector.store %loaded, %output_view[%tid] : vector<1xi32>, view<64xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_b32_diagnostics() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %bytes = low.const<amdgpu.s_mov_b32> {imm32 = 256} : reg<amdgpu.sgpr>
  %14 = low.storage.reserve {byte_alignment = 16, byte_length = 256} : low.storage<workgroup>
  %scratch_view = low.storage.address %14 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %one = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  %17 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %18 = low.op<amdgpu.s_mov_b32_m0>(%17) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.ds_write_addtid_b32>(%one, %18) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.m0>)
  %19 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %20 = low.op<amdgpu.s_mov_b32_m0>(%19) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  %loaded = low.op<amdgpu.ds_read_addtid_b32>(%20) {offset = 0} : (reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %22 = low.op<amdgpu.v_lshlrev_b32.lit>(%tid) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %23 = low.slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  low.op<amdgpu.global_store_b32_saddr>(%22, %loaded, %23) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>)
  low.return
}

// ====

kernel.def @lds_padded_diagnostics(%output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 2048 : offset
  %layout = encoding.layout.strided [5, 1] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, %layout>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %one = vector.constant 1 : vector<4xi32>
  // REMARK@+1: BACKEND/017 "selected store memory packet 'amdgpu.ds_write_b128'" "dynamic stride 20 byte(s)" "conflict degree 1" "padded-bank-conflict-free"
  vector.store %one, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, %layout>
  // REMARK@+1: BACKEND/017 "selected load memory packet 'amdgpu.ds_read_b128'" "dynamic stride 20 byte(s)" "conflict degree 1" "padded-bank-conflict-free"
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x4xi32, %layout> -> vector<4xi32>
  vector.store %loaded, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_padded_diagnostics() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 2048
  %15 = storage {byte_alignment = 16, byte_length = 2048} : low.storage<workgroup>
  %scratch_view = storage_address %15 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32 1
  %18 = v_mov_b32 1
  %19 = v_mov_b32 1
  %20 = v_mov_b32 1
  %one = concat(%17, %18, %19, %20) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %22 = v_mov_b32 20
  %23 = v_mul_lo_u32 %tid, %22
  %24 = v_add_u32 %scratch_view, %23
  ds_write_b128 %24, %one
  %25 = v_mov_b32 20
  %26 = v_mul_lo_u32 %tid, %25
  %27 = v_add_u32 %scratch_view, %26
  %loaded = ds_read_b128 %27
  %29 = v_lshlrev_b32_lit %tid, 4
  %30 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %29, %loaded, %30
  return
}

// ====

kernel.def @lds_read2_write2_diagnostics(%output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 2048 : offset
  %layout = encoding.layout.strided [8, 2] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, %layout>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x2xi32, #dense>
  %one = vector.constant 1 : vector<2xi32>
  // REMARK@+1: BACKEND/017 "selected store memory packet 'amdgpu.ds_write2_b32'" "dynamic stride 32 byte(s)" "conflict degree 8" "bank-conflict-risk"
  vector.store %one, %scratch_view[%tid, 0] : vector<2xi32>, view<64x4xi32, %layout>
  // REMARK@+1: BACKEND/017 "selected load memory packet 'amdgpu.ds_read2_b32'" "dynamic stride 32 byte(s)" "conflict degree 8" "bank-conflict-risk"
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x4xi32, %layout> -> vector<2xi32>
  vector.store %loaded, %output_view[%tid, 0] : vector<2xi32>, view<64x2xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_read2_write2_diagnostics() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 512} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 2048
  %15 = storage {byte_alignment = 16, byte_length = 2048} : low.storage<workgroup>
  %scratch_view = storage_address %15 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32 1
  %18 = v_mov_b32 1
  %one = concat(%17, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %20 = v_lshlrev_b32_lit %tid, 5
  %21 = v_add_u32 %scratch_view, %20
  %22 = slice %one[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %23 = slice %one[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  ds_write2_b32 %21, %22, %23 {offset1 = 2}
  %24 = v_lshlrev_b32_lit %tid, 5
  %25 = v_add_u32 %scratch_view, %24
  %loaded = ds_read2_b32 %25 {offset1 = 2}
  %27 = v_lshlrev_b32_lit %tid, 3
  %28 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b64 %27, %loaded, %28
  return
}

