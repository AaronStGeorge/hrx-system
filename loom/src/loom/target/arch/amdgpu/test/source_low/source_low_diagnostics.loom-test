kernel.def @lds_conflict_risk_diagnostics(%output: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %one = vector.constant 1 : vector<4xi32>
  // REMARK@+1: BACKEND/017 "selected store memory packet 'amdgpu.ds_write_b128'" "dynamic stride 16 byte(s)" "conflict degree 4" "bank-conflict-risk"
  vector.store %one, %scratch_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  // REMARK@+1: BACKEND/017 "selected load memory packet 'amdgpu.ds_read_b128'" "dynamic stride 16 byte(s)" "conflict degree 4" "bank-conflict-risk"
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) @lds_conflict_risk_diagnostics() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %bytes = s_mov_b32 1024
  %14 = storage {byte_alignment = 16, byte_length = 1024} : low.storage<workgroup>
  %scratch_view = storage_address %14 : low.storage<workgroup> -> reg<amdgpu.vgpr>
  %16 = v_mov_b32 1
  %17 = v_mov_b32 1
  %18 = v_mov_b32 1
  %19 = v_mov_b32 1
  %one = concat(%16, %17, %18, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %21 = v_lshlrev_b32_lit %tid, 4
  %22 = v_add_u32 %scratch_view, %21
  ds_write_b128 %22, %one
  %23 = v_lshlrev_b32_lit %tid, 4
  %24 = v_add_u32 %scratch_view, %23
  %loaded = ds_read_b128 %24
  %26 = v_lshlrev_b32_lit %tid, 4
  %27 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %26, %loaded, %27
  return
}

// ====

func.def @i8x2_load_rejected(%input: buffer) -> (vector<2xi8>) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<2xi8, #dense>
  // ERROR@+1: BACKEND/001 "requires the vector footprint to exactly fill complete 32-bit memory registers"
  %loaded = vector.load %input_view[0] : view<2xi8, #dense> -> vector<2xi8>
  func.return %loaded : vector<2xi8>
}

// ====

kernel.def @lds_i8x8_strided_load_rejected() {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 4096 : offset
  %layout = encoding.layout.strided [8, 2] : encoding<layout>
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x8xi8, %layout>
  // ERROR@+1: BACKEND/001 "requires unit stride along the vector axis"
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x8xi8, %layout> -> vector<8xi8>
  kernel.return
}

// ====

kernel.def @cache_policy_non_temporal_load_rejected(%input: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  // ERROR@+1: BACKEND/001 "descriptor set 'amdgpu.gfx11.core' cannot faithfully encode vector memory cache policy device/non_temporal"
  %loaded = vector.load %input_view[%tid, 0] {cache_scope = device, cache_temporal = non_temporal} : view<64x4xi32, #dense> -> vector<4xi32>
  kernel.return
}

// ====

kernel.def @cache_policy_workgroup_store_rejected() {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 1024 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %one = vector.constant 1 : vector<4xi32>
  // ERROR@+1: BACKEND/001 "workgroup memory packets cannot encode cache policy device/non_temporal"
  vector.store %one, %scratch_view[%tid, 0] {cache_scope = device, cache_temporal = non_temporal} : vector<4xi32>, view<64x4xi32, #dense>
  kernel.return
}

// ====

kernel.def @global_atomic_system_scope_rejected(%input: buffer) {
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 63)] : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "supports workgroup scope for workgroup memory and device scope for global memory"
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = release, scope = system} : i32, view<64xi32, #dense>
  kernel.return
}

// ====

kernel.def @global_dynamic_offset_sum_rejected(%input: buffer) {
  %x0 = kernel.workitem.id<x> : index
  %base_x = index.constant 4294966000 : index
  %x = index.add %x0, %base_x : index
  %y0 = kernel.workitem.id<y> : index
  %base_y = index.constant 2000 : index
  %y = index.add %y0, %base_y : index
  %zero = index.constant 0 : offset
  %layout = encoding.layout.strided [1, 1] : encoding<layout>
  %input_view = buffer.view %input[%zero] : buffer -> view<4294967296x4096xi8, %layout>
  // ERROR@+1: BACKEND/001 "AMDGPU memory lowering requires dynamic byte offsets to be proven non-negative and 32-bit"
  %loaded = vector.load %input_view[%x, %y] : view<4294967296x4096xi8, %layout> -> vector<4xi8>
  kernel.return
}

