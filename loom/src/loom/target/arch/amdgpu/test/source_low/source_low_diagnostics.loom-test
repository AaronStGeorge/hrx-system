kernel.def @index_add_result_width_rejected() {
  %x = kernel.workitem.id<x> : index
  %base = index.constant 4294967000 : index
  // ERROR@+1: BACKEND/001 "AMDGPU index lowering requires address results proven non-negative and 32-bit"
  %sum = index.add %x, %base : index
  kernel.return
}

// ====

kernel.def @index_madd_result_width_rejected() {
  %x = kernel.workitem.id<x> : index
  %scale = index.constant 2 : index
  %base = index.constant 4294967000 : index
  // ERROR@+1: BACKEND/001 "AMDGPU index lowering requires address results proven non-negative and 32-bit"
  %sum = index.madd %x, %scale, %base : index
  kernel.return
}

// ====

kernel.def @workgroup_count_rejected() {
  // ERROR@+1: BACKEND/001 "AMDGPU HAL kernel ABI does not expose dispatch workgroup count live-ins yet"
  %count = kernel.workgroup.count<x> : index
  kernel.return
}

// ====

kernel.def @subgroup_id_rejected() {
  // ERROR@+1: BACKEND/001 "AMDGPU source-to-low currently requires a fixed workgroup size for subgroup index queries"
  %id = kernel.subgroup.id : index
  kernel.return
}

// ====

kernel.def @subgroup_lane_id_rejected() {
  // ERROR@+1: BACKEND/001 "AMDGPU source-to-low currently requires a fixed workgroup size for subgroup index queries"
  %id = kernel.subgroup.lane.id : index
  kernel.return
}

// ====

kernel.def @subgroup_reduce_rejected(%value: f32) {
  // ERROR@+1: BACKEND/001 "AMDGPU subgroup reduce lowering requires a fixed workgroup size that is an exact multiple"
  %sum = kernel.subgroup.reduce<addf> %value : f32
  kernel.return
}

// ====

kernel.def @workgroup_vote_count_rejected(%predicate: i1) {
  // ERROR@+1: BACKEND/001 "AMDGPU source-to-low needs target packet lowering for this collective form"
  %count = kernel.workgroup.vote.count %predicate : i1 -> i32
  kernel.return
}

// ====

func.def @reduce_axes_rejected(%v: vector<4xi32>, %init: i32) -> (i32) {
  // ERROR@+1: BACKEND/001 "vector.reduce.axes" "descriptor mapping"
  %r = vector.reduce.axes<addi> %v, %init axes [0] : vector<4xi32>, i32
  func.return %r : i32
}
