// RUN: emit source-low output=low

amdgpu.target<gfx942> @target
func.def target(@target) @bf16_mfma(%lhs_data: vector<4xbf16>, %rhs_data: vector<4xbf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xbf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xbf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xbf16>, vector<4xbf16>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @bf16_mfma(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x2>, %init: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.cdna3.core> {
  %result = v_mfma_f32_16x16x16_bf16 %lhs, %rhs, %init : reg<amdgpu.vgpr x4>
  return %result
}

// ====

amdgpu.target<gfx942> @target

kernel.def target(@target) @bf16_mfma_fragment_memory(%lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %unit = index.constant 1 : index
  %threads = index.constant 64 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%threads, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %rhs_layout = encoding.layout.strided [1, 16] : encoding<layout>
  %lhs_view = buffer.view %lhs_buffer[%base] : buffer -> view<16x16xbf16, #dense>
  %rhs_view = buffer.view %rhs_buffer[%base] : buffer -> view<16x16xbf16, %rhs_layout>
  %init_view = buffer.view %init_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %lhs = vector.fragment.load<lhs> %lhs_view[0, 0] shape [%m, %k] : view<16x16xbf16, #dense> -> vector<4xbf16>
  %rhs = vector.fragment.load<rhs> %rhs_view[0, 0] shape [%k, %n] : view<16x16xbf16, %rhs_layout> -> vector<4xbf16>
  %init = vector.fragment.load<init> %init_view[0, 0] shape [%m, %n] : view<16x16xf32, #dense> -> vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xbf16>, vector<4xbf16>, vector<4xf32>
  vector.fragment.store<result> %result, %out_view[0, 0] shape [%m, %n] : vector<4xf32>, view<16x16xf32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @bf16_mfma_fragment_memory() {
  %23 = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = low.resource<hal_binding> {extent = 512, index = 0, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %rhs_view = low.resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %init_view = low.resource<hal_binding> {extent = 1024, index = 2, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %out_view = low.resource<hal_binding> {extent = 1024, index = 3, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %29 = low.op<amdgpu.v_and_b32.lit>(%23) {imm32 = 15} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %30 = low.op<amdgpu.v_lshrrev_b32.lit>(%23) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %31 = low.op<amdgpu.v_lshlrev_b32.lit>(%30) {imm32 = 3} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %32 = low.op<amdgpu.v_lshlrev_b32.lit>(%29) {imm32 = 5} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %33 = low.op<amdgpu.v_add_u32>(%31, %32) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %34 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %35 = low.op<amdgpu.s_mov_b32_m0>(%34) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  %36 = low.op<amdgpu.global_load_b32_saddr>(%33, %lhs_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %40 = low.op<amdgpu.v_add_u32.lit>(%33) {imm32 = 4} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %43 = low.op<amdgpu.global_load_b32_saddr>(%40, %lhs_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %lhs = low.concat(%36, %43) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %52 = low.op<amdgpu.global_load_b32_saddr>(%33, %rhs_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %59 = low.op<amdgpu.global_load_b32_saddr>(%40, %rhs_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %rhs = low.concat(%52, %59) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %63 = low.op<amdgpu.v_lshlrev_b32.lit>(%30) {imm32 = 8} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %64 = low.op<amdgpu.v_lshlrev_b32.lit>(%29) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %65 = low.op<amdgpu.v_add_u32>(%63, %64) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %68 = low.op<amdgpu.global_load_b32_saddr>(%65, %init_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %72 = low.op<amdgpu.v_add_u32.lit>(%65) {imm32 = 64} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %75 = low.op<amdgpu.global_load_b32_saddr>(%72, %init_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %79 = low.op<amdgpu.v_add_u32.lit>(%65) {imm32 = 128} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %82 = low.op<amdgpu.global_load_b32_saddr>(%79, %init_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %86 = low.op<amdgpu.v_add_u32.lit>(%65) {imm32 = 192} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %89 = low.op<amdgpu.global_load_b32_saddr>(%86, %init_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>) -> reg<amdgpu.vgpr>
  %init = low.concat(%68, %75, %82, %89) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %result = low.op<amdgpu.v_mfma_f32_16x16x16_bf16>(%lhs, %rhs, %init) : (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x4>) -> reg<amdgpu.vgpr x4>
  %94 = low.slice %result[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  low.op<amdgpu.global_store_b32_saddr>(%65, %94, %out_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  %100 = low.slice %result[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  low.op<amdgpu.global_store_b32_saddr>(%72, %100, %out_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  %107 = low.slice %result[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  low.op<amdgpu.global_store_b32_saddr>(%79, %107, %out_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  %114 = low.slice %result[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  low.op<amdgpu.global_store_b32_saddr>(%86, %114, %out_view, %35) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.return
}

// ====

amdgpu.target<gfx942> @target
func.def target(@target) @bf16_smfmac(%lhs_data: vector<2xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xf32>, %sparsity: vector<1xi32>) -> (vector<4xf32>) {
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 32 : index
  %lhs_schema = encoding.define #matrix_operand<element_format=bf16, payload_elements=4, payload_registers=2, sparsity=n_m_structured> : encoding<schema>
  %rhs_schema = encoding.define #matrix_operand<element_format=bf16, payload_elements=8, payload_registers=4> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {sparsity = %sparsity : vector<1xi32>, schema = %lhs_schema : encoding<schema>} : vector<2xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {schema = %rhs_schema : encoding<schema>} : vector<4xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<2xi32>, vector<4xi32>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @bf16_smfmac(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x4>, %init: reg<amdgpu.vgpr x4>, %sparsity: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.cdna3.core> {
  %result = v_smfmac_f32_16x16x32_bf16 %init, %lhs, %rhs, %sparsity
  return %result
}

// ====

amdgpu.target<gfx942> @target
func.def target(@target) @bf16_mfma_wrong_tile(%lhs_data: vector<4xbf16>, %rhs_data: vector<4xbf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 17 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xbf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xbf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  // ERROR@+1: AMDGPU/021 {matrix_constraint="tile_shape"}
  %result = vector.mma %lhs, %rhs, %init : vector<4xbf16>, vector<4xbf16>, vector<4xf32>
  func.return %result : vector<4xf32>
}
