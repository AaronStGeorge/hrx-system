low.kernel.def target(@target) workgroup_size(64, 1, 1) @bf16_mfma_fragment_memory() asm<amdgpu.cdna3.core> {
  %23 = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %lhs_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 512} : reg<amdgpu.sgpr x2>
  %rhs_view = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<amdgpu.sgpr x2>
  %init_view = resource<hal_binding> {index = 2, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %out_view = resource<hal_binding> {index = 3, source_type = hal.buffer, extent = 1024} : reg<amdgpu.sgpr x2>
  %29 = v_and_b32_src0_inline %23, 15
  %30 = v_lshrrev_b32_src0_inline %23, 4
  %31 = v_lshlrev_b32_src0_inline %30, 3
  %32 = v_lshlrev_b32_src0_inline %29, 5
  %33 = v_add_u32 %31, %32
  %34 = s_mov_b32_m0_imm 0
  %lhs = global_load_dwordx2_saddr %33, %lhs_view, %34
  %rhs = global_load_dwordx2_saddr %33, %rhs_view, %34
  %45 = v_lshlrev_b32_src0_inline %30, 8
  %46 = v_lshlrev_b32_src0_inline %29, 2
  %47 = v_add_u32 %45, %46
  %49 = global_load_dword_saddr %47, %init_view, %34
  %54 = global_load_dword_saddr %47, %init_view, %34 {offset = 64}
  %59 = global_load_dword_saddr %47, %init_view, %34 {offset = 128}
  %64 = global_load_dword_saddr %47, %init_view, %34 {offset = 192}
  %init = concat(%49, %54, %59, %64) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %66 = copy %init : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr x4>
  %result = v_mfma_f32_16x16x16_bf16 %lhs, %rhs, %66
  %70 = slice %result[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  global_store_dword_saddr %47, %70, %out_view, %34
  %75 = slice %result[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  global_store_dword_saddr %47, %75, %out_view, %34 {offset = 64}
  %80 = slice %result[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  global_store_dword_saddr %47, %80, %out_view, %34 {offset = 128}
  %85 = slice %result[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  global_store_dword_saddr %47, %85, %out_view, %34 {offset = 192}
  return
}

