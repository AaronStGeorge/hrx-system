kernel.def target(@target) @f32_fragment_memory_dynamic_lds_base(%input_buffer: buffer, %out_buffer: buffer) {
  %unit = index.constant 1 : index
  %threads = index.constant 256 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%threads, %unit, %unit) : index
} launch {
  %base = index.constant 0 : offset
  %sixty_four = index.constant 64 : index
  %wave_stride_bytes = index.constant 1024 : index
  %scratch_bytes = index.constant 4096 : offset
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %tid0 = kernel.workitem.id<x> : index
  %tid = index.assume %tid0 [range(%tid0, 0, 255)] : index
  %wave0 = index.div %tid, %sixty_four : index
  %wave = index.assume %wave0 [range(%wave0, 0, 3)] : index
  %wave_offset_index = index.mul %wave, %wave_stride_bytes : index
  %wave_offset = index.cast %wave_offset_index : index to offset
  %input_view = buffer.view %input_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<16x16xf32, #dense>
  %scratch = buffer.alloca %scratch_bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%wave_offset] : buffer -> view<16x16xf32, #dense>
  %input_fragment = vector.fragment.load<init> %input_view[0, 0] shape [%m, %n] : view<16x16xf32, #dense> -> vector<4xf32>
  vector.fragment.store<result> %input_fragment, %scratch_view[0, 0] shape [%m, %n] : vector<4xf32>, view<16x16xf32, #dense>
  kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}
  %scratch_fragment = vector.fragment.load<init> %scratch_view[0, 0] shape [%m, %n] : view<16x16xf32, #dense> -> vector<4xf32>
  vector.fragment.store<result> %scratch_fragment, %out_view[0, 0] shape [%m, %n] : vector<4xf32>, view<16x16xf32, #dense>
  kernel.return
}

