amdgpu.target<gfx1100> @target
func.def target(@target) @scalar_f32_minnum_maxnum(%lhs: f32, %rhs: f32) -> (f32) {
  %min = scalar.minnumf %lhs, %rhs : f32
  %max = scalar.maxnumf %lhs, %rhs : f32
  %sum = scalar.addf %min, %max : f32
  func.return %sum : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_f32_minnum_maxnum(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %min = v_min_f32 %lhs, %rhs
  %max = v_max_f32 %lhs, %rhs
  %sum = v_add_f32 %min, %max
  return %sum
}

