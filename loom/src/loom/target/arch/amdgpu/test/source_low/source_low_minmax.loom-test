  %14 = v_mov_b32_copy %limit
  %is_lane = v_cmp_lt_i32 %lane, %14
  %16 = v_mov_b32_copy %fallback
  %selected = v_cndmask_b32 %16, %lane, %is_lane
  %is_selected = v_cmp_ne_i32 %selected, %16
  %result = v_cndmask_b32 %16, %selected, %is_selected
  return %result
}

