// TEMPLATE: loom/src/loom/test/corpus/source_low/numeric_minmax.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @scalar_f32_minnum_maxnum(%lhs: f32, %rhs: f32) -> (f32) {
  %min = scalar.minnumf %lhs, %rhs : f32
  %max = scalar.maxnumf %lhs, %rhs : f32
  %sum = scalar.addf %min, %max : f32
  func.return %sum : f32
}

// ----
low.func.def target(@target) abi(hal_kernel) @scalar_f32_minnum_maxnum(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %min = v_min_f32 %lhs, %rhs
  %max = v_max_f32 %lhs, %rhs
  %sum = v_add_f32 %min, %max
  return %sum
}

// ====

func.def @vector_f32_minnum_maxnum(%lhs: vector<2xf32>, %rhs: vector<2xf32>) -> (vector<2xf32>) {
  %min = vector.minnumf %lhs, %rhs : vector<2xf32>
  %max = vector.maxnumf %lhs, %rhs : vector<2xf32>
  %sum = vector.addf %min, %max : vector<2xf32>
  func.return %sum : vector<2xf32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @vector_f32_minnum_maxnum(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.gfx11.core> {
  %9 = slice %lhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %10 = slice %rhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %11 = v_min_f32 %9, %10
  %12 = slice %lhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %13 = slice %rhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %14 = v_min_f32 %12, %13
  %min = concat(%11, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %16 = slice %lhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = slice %rhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %18 = v_max_f32 %16, %17
  %19 = slice %lhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %20 = slice %rhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %21 = v_max_f32 %19, %20
  %max = concat(%18, %21) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %23 = slice %min[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = slice %max[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %25 = v_add_f32 %23, %24
  %26 = slice %min[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %27 = slice %max[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %28 = v_add_f32 %26, %27
  %sum = concat(%25, %28) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %sum
}

// ====

func.def @f32_reduce_minnum_maxnum(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<2xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %min_init = scalar.constant 1000.0 : f32
  %min = vector.reduce<minnumf> %loaded, %min_init : vector<4xf32>, f32
  %max_init = scalar.constant -1000.0 : f32
  %max = vector.reduce<maxnumf> %loaded, %max_init : vector<4xf32>, f32
  %stored = vector.from_elements %min, %max : vector<2xf32>
  vector.store %stored, %output_view[0] : vector<2xf32>, view<2xf32, #dense>
  func.return
}

// ----
low.func.def target(@target) abi(hal_kernel) @f32_reduce_minnum_maxnum() asm<amdgpu.gfx11.core> {
  %input_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %14 = v_mov_b32 0
  %15 = slice %input_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b128 %14, %15 {offset = 0}
  %min_init = v_mov_b32 1148846080
  %18 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = v_min_f32 %min_init, %18
  %20 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %21 = v_min_f32 %19, %20
  %22 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %23 = v_min_f32 %21, %22
  %24 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %min = v_min_f32 %23, %24
  %max_init = v_mov_b32 3296329728
  %27 = slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %28 = v_max_f32 %max_init, %27
  %29 = slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %30 = v_max_f32 %28, %29
  %31 = slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %32 = v_max_f32 %30, %31
  %33 = slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %max = v_max_f32 %32, %33
  %stored = concat(%min, %max) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %36 = v_mov_b32 0
  %37 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b64 %36, %stored, %37 {offset = 0}
  return
}
