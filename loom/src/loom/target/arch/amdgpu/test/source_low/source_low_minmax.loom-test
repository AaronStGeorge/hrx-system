}

// ----
low.func.def target(@target) abi(hal_kernel) @vector_f32_minnum_maxnum(%lhs: reg<amdgpu.vgpr x2>, %rhs: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.rdna3.core> {
  %9 = slice %lhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %10 = slice %rhs[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %11 = v_min_f32 %9, %10
  %12 = slice %lhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %13 = slice %rhs[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %14 = v_min_f32 %12, %13
  %18 = v_max_f32 %9, %10
  %21 = v_max_f32 %12, %13
  %25 = v_add_f32 %11, %18
  %28 = v_add_f32 %14, %21
  %sum = concat(%25, %28) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %sum
}

