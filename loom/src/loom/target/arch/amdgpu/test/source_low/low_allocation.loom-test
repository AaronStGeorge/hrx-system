  %dispatch = low.live_in<amdgpu.dispatch_ptr> : reg<amdgpu.sgpr x2>
  %grid = low.op<amdgpu.s_load_dword_offset_only>(%dispatch) {offset = 12} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr>
  %late = low.const<amdgpu.s_mov_b32> {imm32 = 7} : reg<amdgpu.sgpr>
  %sum = low.op<amdgpu.s_add_u32>(%grid, %late) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr>
  low.return %sum : reg<amdgpu.sgpr>
}

