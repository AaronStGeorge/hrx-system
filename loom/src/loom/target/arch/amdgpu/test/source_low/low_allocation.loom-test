low.func.def target(@target) @dead_sgpr_result_preserves_live_predicate(%predicate: reg<amdgpu.sgpr x2>, %lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>) -> (reg<amdgpu.sgpr x2>) {
