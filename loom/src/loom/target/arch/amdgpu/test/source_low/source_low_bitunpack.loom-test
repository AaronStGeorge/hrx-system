// ----
low.func.def target(@target) abi(hal_kernel) @i8x2_to_u2x8_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %5 = v_and_b32_lit %packed, 3
  %6 = v_lshrrev_b32_lit %packed, 2
  %7 = v_and_b32_lit %6, 3
  %8 = v_lshrrev_b32_lit %packed, 4
  %9 = v_and_b32_lit %8, 3
  %10 = v_lshrrev_b32_lit %packed, 6
  %11 = v_and_b32_lit %10, 3
  %12 = v_lshrrev_b32_lit %packed, 8
  %13 = v_and_b32_lit %12, 3
  %14 = v_lshrrev_b32_lit %packed, 10
  %15 = v_and_b32_lit %14, 3
  %16 = v_lshrrev_b32_lit %packed, 12
  %17 = v_and_b32_lit %16, 3
  %18 = v_lshrrev_b32_lit %packed, 14
  %19 = v_and_b32_lit %18, 3
  %unpacked = concat(%5, %7, %9, %11, %13, %15, %17, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  return %unpacked
}
