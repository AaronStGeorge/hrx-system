  %8 = v_bfe_u32_offset_width_inline %packed {offset = 16, width = 8}
  %9 = v_lshl_add_u32_shift_imm %8, %7, 16
  %10 = v_bfe_u32_offset_width_inline %packed {offset = 24, width = 8}
  %unpacked = v_lshl_add_u32_shift_imm %10, %9, 24
  return %unpacked
}

