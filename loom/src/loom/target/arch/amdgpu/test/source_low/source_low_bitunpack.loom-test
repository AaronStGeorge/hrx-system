// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_bitunpack.loom-test
// RUN: emit source-low output=low

amdgpu.target<gfx1100> @target
func.def target(@target) @i32_to_u8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32_to_u8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %5 = v_and_b32_lit %packed, 255
  %6 = v_lshrrev_b32_lit %packed, 8
  %7 = v_and_b32_lit %6, 255
  %8 = v_lshrrev_b32_lit %packed, 16
  %9 = v_and_b32_lit %8, 255
  %10 = v_lshrrev_b32_lit %packed, 24
  %11 = v_and_b32_lit %10, 255
  %unpacked = concat(%5, %7, %9, %11) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

