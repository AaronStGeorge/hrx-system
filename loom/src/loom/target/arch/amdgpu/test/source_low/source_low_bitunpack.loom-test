low.func.def target(@target) abi(hal_kernel) @i32_to_u4x8_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x8>) asm<amdgpu.rdna3.core> {
  %5 = v_and_b32_lit %packed, 15
  %6 = v_lshrrev_b32_lit %packed, 4
  %7 = v_and_b32_lit %6, 15
  %8 = v_lshrrev_b32_lit %packed, 8
  %9 = v_and_b32_lit %8, 15
  %10 = v_lshrrev_b32_lit %packed, 12
  %11 = v_and_b32_lit %10, 15
  %12 = v_lshrrev_b32_lit %packed, 16
  %13 = v_and_b32_lit %12, 15
  %14 = v_lshrrev_b32_lit %packed, 20
  %15 = v_and_b32_lit %14, 15
  %16 = v_lshrrev_b32_lit %packed, 24
  %17 = v_and_b32_lit %16, 15
  %18 = v_lshrrev_b32_lit %packed, 28
  %19 = v_and_b32_lit %18, 15
  %unpacked = concat(%5, %7, %9, %11, %13, %15, %17, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  return %unpacked
}

