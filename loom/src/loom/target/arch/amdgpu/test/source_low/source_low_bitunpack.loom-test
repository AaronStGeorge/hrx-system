// ----
low.func.def target(@target) abi(hal_kernel) @i8x2_to_s4x4_bitunpack_i8_result(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %5 = v_lshlrev_b32_src0_inline %packed, 28
  %6 = v_ashrrev_i32_src0_inline %5, 28
  %7 = v_and_b32_lit %6, 255
  %8 = v_lshlrev_b32_src0_inline %packed, 24
  %9 = v_ashrrev_i32_src0_inline %8, 28
  %10 = v_and_b32_lit %9, 255
  %11 = v_lshl_add_u32_shift_imm %10, %7, 8
  %12 = v_lshlrev_b32_src0_inline %packed, 20
  %13 = v_ashrrev_i32_src0_inline %12, 28
  %14 = v_and_b32_lit %13, 255
  %15 = v_lshl_add_u32_shift_imm %14, %11, 16
  %16 = v_lshlrev_b32_src0_inline %packed, 16
  %17 = v_ashrrev_i32_src0_inline %16, 28
  %18 = v_and_b32_lit %17, 255
  %unpacked = v_lshl_add_u32_shift_imm %18, %15, 24
  return %unpacked
}

// ====

amdgpu.target<gfx1100> @target
kernel.def target(@target) @uniform_global_i32_to_u8x4_bitunpack_store() {
  %one = index.constant 1 : index
  kernel.launch.config workgroups(%one, %one, %one) workgroup_size(%one, %one, %one) : index
} launch(%values: buffer, %output: buffer) {
  %base = index.constant 0 : offset
  %index = index.constant 0 : index
  %values_noalias, %output_noalias = buffer.assume.noalias %values, %output : buffer, buffer
  %values_view = buffer.view %values_noalias[%base] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output_noalias[%base] : buffer -> view<4xi32, #dense>
  %packed = vector.load %values_view[%index] : view<1xi32, #dense> -> vector<1xi32>
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  vector.store %unpacked, %output_view[%index] : vector<4xi32>, view<4xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(1, 1, 1) @uniform_global_i32_to_u8x4_bitunpack_store() asm<amdgpu.rdna3.core> {
  %values_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 4} : reg<amdgpu.sgpr x2>
  %output_view = resource<hal_binding> {index = 1, source_type = hal.buffer, extent = 16} : reg<amdgpu.sgpr x2>
  %13 = s_mov_b32 0
  %packed = s_load_dword %values_view, %13
  %15 = v_mov_b32_copy %packed
  %16 = v_and_b32_lit %15, 255
  %17 = v_bfe_u32_offset_width_inline %15 {offset = 8, width = 8}
  %18 = v_bfe_u32_offset_width_inline %15 {offset = 16, width = 8}
  %19 = v_bfe_u32_offset_width_inline %15 {offset = 24, width = 8}
  %unpacked = concat(%16, %17, %18, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %21 = v_mov_b32 0
  global_store_b128_saddr %21, %unpacked, %output_view
  return
}
