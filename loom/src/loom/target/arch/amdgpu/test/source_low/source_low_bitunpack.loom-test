  %16 = v_lshrrev_b32_src0_inline %packed, 24
  %17 = v_and_b32_src0_inline %16, 15
  %18 = v_lshrrev_b32_src0_inline %packed, 28
  %19 = v_and_b32_src0_inline %18, 15
