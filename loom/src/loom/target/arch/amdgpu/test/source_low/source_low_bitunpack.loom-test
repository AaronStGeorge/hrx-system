// ----
low.func.def target(@target) abi(hal_kernel) @i8x2_to_s4x4_bitunpack_i8_result(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %5 = v_lshlrev_b32_src0_inline %packed, 28
  %6 = v_ashrrev_i32_src0_inline %5, 28
  %7 = v_and_b32_lit %6, 255
  %8 = v_lshlrev_b32_src0_inline %packed, 24
  %9 = v_ashrrev_i32_src0_inline %8, 28
  %10 = v_and_b32_lit %9, 255
  %11 = v_lshlrev_b32_src0_inline %10, 8
  %12 = v_or_b32 %7, %11
  %13 = v_lshlrev_b32_src0_inline %packed, 20
  %14 = v_ashrrev_i32_src0_inline %13, 28
  %15 = v_and_b32_lit %14, 255
  %16 = v_lshlrev_b32_src0_inline %15, 16
  %17 = v_or_b32 %12, %16
  %18 = v_lshlrev_b32_src0_inline %packed, 16
  %19 = v_ashrrev_i32_src0_inline %18, 28
  %20 = v_and_b32_lit %19, 255
  %21 = v_lshlrev_b32_src0_inline %20, 24
  %unpacked = v_or_b32 %17, %21
  return %unpacked
}
