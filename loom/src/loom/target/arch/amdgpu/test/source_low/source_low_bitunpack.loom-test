// TEMPLATE: loom/src/loom/test/corpus/source_low/packed_bitunpack.loom-test
// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

func.def @i32_to_u8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) @i32_to_u8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.gfx11.core> {
  %5 = v_mov_b32 255
  %6 = v_and_b32 %packed, %5
  %7 = v_mov_b32 8
  %8 = v_lshrrev_b32 %7, %packed
  %9 = v_and_b32 %8, %5
  %10 = v_mov_b32 16
  %11 = v_lshrrev_b32 %10, %packed
  %12 = v_and_b32 %11, %5
  %13 = v_mov_b32 24
  %14 = v_lshrrev_b32 %13, %packed
  %15 = v_and_b32 %14, %5
  %unpacked = concat(%6, %9, %12, %15) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

// ====

func.def @i32_to_s8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacks<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) @i32_to_s8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.gfx11.core> {
  %5 = v_mov_b32 24
  %6 = v_lshlrev_b32 %5, %packed
  %7 = v_mov_b32 24
  %8 = v_ashrrev_i32 %7, %6
  %9 = v_mov_b32 16
  %10 = v_lshlrev_b32 %9, %packed
  %11 = v_mov_b32 24
  %12 = v_ashrrev_i32 %11, %10
  %13 = v_mov_b32 8
  %14 = v_lshlrev_b32 %13, %packed
  %15 = v_mov_b32 24
  %16 = v_ashrrev_i32 %15, %14
  %17 = v_mov_b32 24
  %18 = v_ashrrev_i32 %17, %packed
  %unpacked = concat(%8, %12, %16, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

