amdgpu.target<gfx1100> @target
func.def target(@target) @i32_to_s8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacks<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@target) abi(hal_kernel) @i32_to_s8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.rdna3.core> {
  %5 = v_lshlrev_b32_lit %packed, 24
  %6 = v_ashrrev_i32_lit %5, 24
  %7 = v_lshlrev_b32_lit %packed, 16
  %8 = v_ashrrev_i32_lit %7, 24
  %9 = v_lshlrev_b32_lit %packed, 8
  %10 = v_ashrrev_i32_lit %9, 24
  %11 = v_ashrrev_i32_lit %packed, 24
  %unpacked = concat(%6, %8, %10, %11) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

