// ----
low.func.def target(@target) abi(hal_kernel) @i32_to_u8x4_bitunpack_i8_result(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %5 = v_and_b32_lit %packed, 255
  %6 = v_bfe_u32_offset_width_inline %packed {offset = 8, width = 8}
  %7 = v_lshlrev_b32_src0_inline %6, 8
  %8 = v_or_b32 %5, %7
  %9 = v_bfe_u32_offset_width_inline %packed {offset = 16, width = 8}
  %10 = v_lshlrev_b32_src0_inline %9, 16
  %11 = v_or_b32 %8, %10
  %12 = v_bfe_u32_offset_width_inline %packed {offset = 24, width = 8}
  %13 = v_lshlrev_b32_src0_inline %12, 24
  %unpacked = v_or_b32 %11, %13
  return %unpacked
}

