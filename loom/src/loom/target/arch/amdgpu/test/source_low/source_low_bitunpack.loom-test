  %10 = v_lshrrev_b32_src0_inline %packed, 6
  %11 = v_and_b32_src0_inline %10, 3
  %12 = v_lshrrev_b32_src0_inline %packed, 8
  %13 = v_and_b32_src0_inline %12, 3
  %14 = v_lshrrev_b32_src0_inline %packed, 10
  %15 = v_and_b32_src0_inline %14, 3
  %16 = v_lshrrev_b32_src0_inline %packed, 12
  %17 = v_and_b32_src0_inline %16, 3
  %18 = v_lshrrev_b32_src0_inline %packed, 14
  %19 = v_and_b32_src0_inline %18, 3
  %unpacked = concat(%5, %7, %9, %11, %13, %15, %17, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
