// RUN: emit source-low target-preset=amdgpu-gfx11 output=low

kernel.def workgroup_size(64, 1, 1) @subgroup_id_x_wave32(%output: buffer) {
  %subgroup_id = kernel.subgroup.id : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%subgroup_id] : vector<1xi32>, view<2xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_id_x_wave32() asm<amdgpu.gfx11.core> {
  %5 = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x4>
  %subgroup_id = v_lshrrev_b32_lit %5, 5
  %zero = s_mov_b32 0
  %one = v_mov_b32 1
  %10 = v_lshlrev_b32_lit %subgroup_id, 2
  %11 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b32 %10, %one, %11 {offset = 0}
  return
}

