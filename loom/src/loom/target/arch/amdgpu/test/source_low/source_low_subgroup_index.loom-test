amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(8, 4, 2) @subgroup_lane_id_xyz_wave32(%output: buffer) {
  %lane_id = kernel.subgroup.lane.id : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<32xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%lane_id] : vector<1xi32>, view<32xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 2) @subgroup_lane_id_xyz_wave32() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xyz> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %7 = v_and_b32_lit %packed_tid, 1023
  %8 = v_lshrrev_b32_lit %packed_tid, 10
  %9 = v_and_b32_lit %8, 1023
  %10 = v_lshlrev_b32_lit %9, 3
  %11 = v_add_u32 %7, %10
  %12 = v_lshrrev_b32_lit %packed_tid, 20
  %13 = v_and_b32_lit %12, 1023
  %14 = v_lshlrev_b32_lit %13, 5
  %15 = v_add_u32 %11, %14
  %lane_id = v_and_b32_lit %15, 31
  %one = v_mov_b32 1
  %18 = v_lshlrev_b32_lit %lane_id, 2
  global_store_b32 %18, %one, %output_view
  return
}

