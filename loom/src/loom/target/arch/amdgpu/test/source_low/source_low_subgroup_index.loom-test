// ====
// RUN: emit source-low output=low

amdgpu.target<gfx950> @target
kernel.def target(@target) @subgroup_id_x_wave64(%output: buffer) {
  %c1 = index.constant 1 : index
  %c128 = index.constant 128 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c128, %c1, %c1) : index
} launch {
  %subgroup_id = kernel.subgroup.id : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%subgroup_id] : vector<1xi32>, view<2xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(128, 1, 1) @subgroup_id_x_wave64() {
  %8 = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = low.resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x2>
  %subgroup_id = low.op<amdgpu.v_lshrrev_b32.lit>(%8) {imm32 = 6} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %one = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  %12 = low.op<amdgpu.v_lshlrev_b32.lit>(%subgroup_id) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %14 = low.op<amdgpu.hal.buffer_descriptor>(%output_view) {cache_swizzle_stride = 0, valid_byte_count = 8} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  low.op<amdgpu.buffer_store_dword>(%one, %14, %12, %13) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>)
  low.return
}

