// ----
low.kernel.def target(@target) workgroup_size(8, 4, 2) @subgroup_lane_id_xyz_wave32() asm<amdgpu.rdna3.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xyz> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, extent = 128} : reg<amdgpu.sgpr x2>
  %11 = v_and_b32_lit %packed_tid, 1023
  %12 = v_lshrrev_b32_src0_inline %packed_tid, 10
  %13 = v_and_b32_lit %12, 1023
  %14 = v_lshlrev_b32_src0_inline %13, 3
  %15 = v_add_u32 %11, %14
  %16 = v_lshrrev_b32_src0_inline %packed_tid, 20
  %17 = v_and_b32_lit %16, 1023
  %18 = v_lshlrev_b32_src0_inline %17, 5
  %19 = v_add_u32 %15, %18
  %lane_id = v_and_b32_src0_inline %19, 31
  %one = v_mov_b32 1
  %22 = v_lshlrev_b32_src0_inline %lane_id, 2
  global_store_b32_saddr %22, %one, %output_view
  return
}

