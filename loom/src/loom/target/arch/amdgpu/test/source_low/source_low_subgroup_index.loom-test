// ----
low.kernel.def target(@target) workgroup_size(64, 1, 1) @subgroup_lane_id_x_wave64() {
  %lane_id = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %output_view = low.resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 256} : reg<amdgpu.sgpr x2>
  %one = low.const<amdgpu.v_mov_b32> {imm32 = 1} : reg<amdgpu.vgpr>
  %8 = low.op<amdgpu.v_lshlrev_b32.lit>(%lane_id) {imm32 = 2} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %9 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %10 = low.op<amdgpu.hal.buffer_descriptor>(%output_view) {cache_swizzle_stride = 0, valid_byte_count = 256} : (reg<amdgpu.sgpr x2>) -> reg<amdgpu.sgpr x4>
  low.op<amdgpu.buffer_store_dword>(%one, %10, %8, %9) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>)
  low.return
}
