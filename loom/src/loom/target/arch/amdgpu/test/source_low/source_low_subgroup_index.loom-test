amdgpu.target<gfx1100> @target

kernel.def target(@target) workgroup_size(32, 1, 1) @subgroup_id_single_wave_gfx11(%output: buffer) {
  %subgroup_id = kernel.subgroup.id : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%subgroup_id] : vector<1xi32>, view<1xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(32, 1, 1) @subgroup_id_single_wave_gfx11() asm<amdgpu.gfx11.core> {
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x2>
  %subgroup_id = v_mov_b32 0
  %one = v_mov_b32 1
  %8 = v_mov_b32 0
  global_store_b32 %8, %one, %output_view
  return
}

