amdgpu.target<gfx1100> @target

kernel.def target(@target) @subgroup_lane_id_xyz_wave32(%output: buffer) {
  %c1 = index.constant 1 : index
  %c8 = index.constant 8 : index
  %c4 = index.constant 4 : index
  %c2 = index.constant 2 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c8, %c4, %c2) : index
} launch {
  %lane_id = kernel.subgroup.lane.id : index
  %zero = index.constant 0 : offset
  %output_view = buffer.view %output[%zero] : buffer -> view<32xi32, #dense>
  %one = vector.constant 1 : vector<1xi32>
  vector.store %one, %output_view[%lane_id] : vector<1xi32>, view<32xi32, #dense>
  kernel.return
}

// ----
low.kernel.def target(@target) workgroup_size(8, 4, 2) @subgroup_lane_id_xyz_wave32() asm<amdgpu.gfx11.core> {
  %packed_tid = live_in<amdgpu.workitem_id.packed.xyz> : reg<amdgpu.vgpr>
  %output_view = resource<hal_binding> {index = 0, source_type = hal.buffer, valid_byte_count = 128} : reg<amdgpu.sgpr x2>
  %12 = v_and_b32_lit %packed_tid, 1023
  %13 = v_lshrrev_b32_lit %packed_tid, 10
  %14 = v_and_b32_lit %13, 1023
  %15 = v_lshlrev_b32_lit %14, 3
  %16 = v_add_u32 %12, %15
  %17 = v_lshrrev_b32_lit %packed_tid, 20
  %18 = v_and_b32_lit %17, 1023
  %19 = v_lshlrev_b32_lit %18, 5
  %20 = v_add_u32 %16, %19
  %lane_id = v_and_b32_lit %20, 31
  %one = v_mov_b32 1
  %23 = v_lshlrev_b32_lit %lane_id, 2
  global_store_b32 %23, %one, %output_view
  return
}

