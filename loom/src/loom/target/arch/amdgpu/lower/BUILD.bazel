load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu:__pkg__"]

_AMDGPU_CANDIDATE_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/lower/candidates:__pkg__"]

_AMDGPU_CONTRACT_VISIBILITY = [
    "//loom/src/loom/target/arch/amdgpu/contracts:__pkg__",
]

_AMDGPU_LOWER_TABLE_VISIBILITY = (
    _AMDGPU_CANDIDATE_VISIBILITY +
    _AMDGPU_ROOT_VISIBILITY +
    _AMDGPU_CONTRACT_VISIBILITY
)

loom_cc_library(
    name = "kinds",
    hdrs = ["kinds.h"],
    visibility = _AMDGPU_LOWER_TABLE_VISIBILITY,
)

loom_cc_library(
    name = "materializers",
    hdrs = ["materializers.h"],
    visibility = _AMDGPU_CONTRACT_VISIBILITY,
    deps = [
        ":kinds",
        "//loom/src/loom/codegen/low/lower",
    ],
)

loom_cc_library(
    name = "lower",
    srcs = [
        "abi.c",
        "arithmetic.c",
        "async.c",
        "atomic.c",
        "bitpack.c",
        "buffer.c",
        "collective_combine.c",
        "collective_payload.c",
        "collective_reduce.c",
        "collective_scan.c",
        "control.c",
        "dot.c",
        "emit_support.c",
        "lds_layout.c",
        "mask.c",
        "matrix.c",
        "matrix_fragment.c",
        "memory.c",
        "memory_cache.c",
        "memory_diagnostics.c",
        "memory_emit.c",
        "memory_legality.c",
        "preamble.c",
        "prefetch.c",
        "registry.c",
        "structural.c",
        "subgroup_broadcast.c",
        "subgroup_mask.c",
        "subgroup_shuffle.c",
        "support.c",
        "sync.c",
        "table.c",
        "values.c",
    ],
    hdrs = [
        "abi.h",
        "arithmetic.h",
        "async.h",
        "bitpack.h",
        "buffer.h",
        "collective_combine.h",
        "collective_payload.h",
        "constants.h",
        "control.h",
        "dot.h",
        "emit.h",
        "legality.h",
        "lower.h",
        "mask.h",
        "matrix.h",
        "matrix_fragment.h",
        "memory.h",
        "plan.h",
        "preamble.h",
        "structural.h",
        "subgroup.h",
        "sync.h",
        "table.h",
        "topology.h",
        "types.h",
        "values.h",
        "workgroup.h",
    ],
    textual_hdrs = [
        "registry_tables.inl",
    ],
    visibility = _AMDGPU_ROOT_VISIBILITY,
    deps = [
        ":kinds",
        ":materializers",
        "//loom/src/loom/analysis:condition_facts",
        "//loom/src/loom/analysis:contract_vector",
        "//loom/src/loom/analysis:symbolic_expr",
        "//loom/src/loom/analysis:view_regions",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:function",
        "//loom/src/loom/codegen/low:source_memory_plan",
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:atomic",
        "//loom/src/loom/ops:cache",
        "//loom/src/loom/ops:combining",
        "//loom/src/loom/ops/buffer",
        "//loom/src/loom/ops/cfg",
        "//loom/src/loom/ops/encoding",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/kernel",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/scf",
        "//loom/src/loom/ops/vector",
        "//loom/src/loom/ops/view",
        "//loom/src/loom/target:low_legality",
        "//loom/src/loom/target:registers",
        "//loom/src/loom/target/arch/amdgpu:error_defs",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//loom/src/loom/target/arch/amdgpu/contracts",
        "//loom/src/loom/target/arch/amdgpu/hal:kernel_abi",
        "//loom/src/loom/target/arch/amdgpu/lower/candidates:atomic_candidates",
        "//loom/src/loom/target/arch/amdgpu/lower/candidates:compare_candidates",
        "//loom/src/loom/target/arch/amdgpu/matrix:contract",
        "//loom/src/loom/target/arch/amdgpu/matrix:projection",
        "//loom/src/loom/target/arch/amdgpu/planning:wait_packets",
        "//loom/src/loom/target/arch/amdgpu/planning:wait_plan",
