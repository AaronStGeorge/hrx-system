load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
    "loom_generated_textual_header",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu:__pkg__"]

_AMDGPU_CANDIDATE_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/lower/candidates:__pkg__"]

_AMDGPU_CONTRACT_VISIBILITY = [
    "//loom/src/loom/target/arch/amdgpu/contracts:__pkg__",
]

_AMDGPU_LOWER_TABLE_VISIBILITY = (
    _AMDGPU_CANDIDATE_VISIBILITY +
    _AMDGPU_ROOT_VISIBILITY +
    _AMDGPU_CONTRACT_VISIBILITY
)

_AMDGPU_MEMORY_CANDIDATE_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu/lower/candidates:memory_candidates"

_AMDGPU_TARGET_INFO_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu:target_info"

loom_cc_library(
    name = "kinds",
    hdrs = ["kinds.h"],
    visibility = _AMDGPU_LOWER_TABLE_VISIBILITY,
)

loom_cc_library(
    name = "materializers",
    hdrs = ["materializers.h"],
    visibility = _AMDGPU_CONTRACT_VISIBILITY,
    deps = [
        ":kinds",
        "//loom/src/loom/codegen/low/lower",
    ],
)

exports_files(
    [
        "registry.c",
        "registry_tables.inl",
    ],
    visibility = ["//loom/py/loom/target/arch/amdgpu/contracts:__pkg__"],
)

loom_generated_textual_header(
    name = "memory_descriptor_candidate_ranges_gen",
    generator = _AMDGPU_MEMORY_CANDIDATE_GENERATOR,
    output = "memory_descriptor_candidate_ranges.inl",
    output_flag = "--candidate-ranges",
)

loom_generated_textual_header(
    name = "memory_descriptor_candidates_gen",
    generator = _AMDGPU_MEMORY_CANDIDATE_GENERATOR,
    output = "memory_descriptor_candidates.inl",
    output_flag = "--candidate-rows",
)

loom_generated_textual_header(
    name = "memory_cache_policy_encoding_rows_gen",
    generator = _AMDGPU_TARGET_INFO_GENERATOR,
    output = "memory_cache_policy_encoding_rows.inl",
    output_flag = "--cache-policy-encoding-rows",
)

loom_generated_textual_header(
    name = "memory_cache_policy_temporal_th_gen",
    generator = _AMDGPU_TARGET_INFO_GENERATOR,
    output = "memory_cache_policy_temporal_th.inl",
    output_flag = "--cache-policy-temporal-th",
)

