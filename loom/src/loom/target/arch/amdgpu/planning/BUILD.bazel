load(
    "//loom/build_tools/amdgpu:descriptor_sets.bzl",
    "loom_amdgpu_descriptor_set_compatible_with",
)
load(
    "//loom/build_tools/amdgpu:target_config.bzl",
    "LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY",
)
load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
    "loom_generated_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_OCCUPANCY_TABLE_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu/planning:occupancy_tables"

_DESCRIPTOR_SET_CDNA3 = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.cdna3.core"]

_AMDGPU_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu:__pkg__"]

_AMDGPU_LOWER_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/lower:__pkg__"]

_AMDGPU_NATIVE_VISIBILITY = ["//loom/src/loom/target/emit/native/amdgpu:__pkg__"]

_AMDGPU_CHECK_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/check:__pkg__"]

_AMDGPU_NATIVE_PLANNING_VISIBILITY = (
    _AMDGPU_NATIVE_VISIBILITY +
    _AMDGPU_CHECK_VISIBILITY
)

loom_cc_library(
    name = "address_state",
    srcs = ["address_state.c"],
    hdrs = ["address_state.h"],
    visibility = _AMDGPU_NATIVE_PLANNING_VISIBILITY,
    deps = [
        "//loom/src/loom/codegen/low:allocation",
        "//loom/src/loom/codegen/low:builder",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:frame",
        "//loom/src/loom/codegen/low/schedule",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/target/arch/amdgpu/encoding",
        "//loom/src/loom/target/arch/amdgpu/refs:target_refs",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "descriptor_semantics",
    srcs = ["descriptor_semantics.c"],
    hdrs = ["descriptor_semantics.h"],
    deps = [
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target/arch/amdgpu/encoding",
        "//loom/src/loom/target/arch/amdgpu/refs:target_refs",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "matrix_wait_states",
    srcs = ["matrix_wait_states.c"],
    hdrs = ["matrix_wait_states.h"],
    deps = [
        "//loom/src/loom/target/arch/amdgpu:target_info_defs",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "matrix_wait_states_test",
    srcs = ["matrix_wait_states_test.cc"],
    deps = [
        ":matrix_wait_states",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_library(
    name = "wait_states",
    srcs = ["wait_states.c"],
    hdrs = ["wait_states.h"],
    deps = [
