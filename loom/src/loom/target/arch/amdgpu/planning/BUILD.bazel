        "//loom/src/loom/target/arch/amdgpu/encoding",
        "//loom/src/loom/target/arch/amdgpu/matrix:contract",
        "//loom/src/loom/target/arch/amdgpu/refs:target_refs",
        "//loom/src/loom/target/arch/amdgpu/target_id",
        "//loom/src/loom/util:json",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "wait_plan",
    srcs = ["wait_plan.c"],
    hdrs = ["wait_plan.h"],
    visibility = _AMDGPU_ROOT_VISIBILITY + _AMDGPU_LOWER_VISIBILITY,
    deps = [
        ":descriptor_semantics",
        "//loom/src/loom/codegen/low:allocation",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:packet",
        "//loom/src/loom/codegen/low:packet_hazard_plan",
        "//loom/src/loom/codegen/low:packet_hazard_plan_json",
        "//loom/src/loom/codegen/low:packet_progress",
        "//loom/src/loom/codegen/low/schedule",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/target/arch/amdgpu/refs:target_refs",
        "//loom/src/loom/target/arch/amdgpu/target_id",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "wait_packets",
