// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&1xi32=1985229328 --binding=&1xi32=1431633920 --binding=&2xi32=16843009,16843009 --binding=&2xi32=0 --expected_binding=1xi32=1985229328 --expected_binding=1xi32=1431633920 --expected_binding=2xi32=16843009,16843009 --expected_binding=2xi32=-58,-42

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%low_buffer: buffer, %high_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<1xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<1xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<2xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  %low_packed = vector.load %low_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %high_word = vector.load %high_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<2xi32, #dense> -> vector<2xi32>
  %low4 = vector.bitunpacku<4> %low_packed : vector<1xi32> -> vector<8xi32>
  %high_bytes = vector.bitcast %high_word : vector<1xi32> to vector<4xi8>
  %high_packed = vector.slice %high_bytes[2] : vector<4xi8> -> vector<2xi8>
  %high2 = vector.bitunpacku<2> %high_packed : vector<2xi8> -> vector<8xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<8xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<8xi32> -> vector<8xi8>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<2xi32> -> vector<8xi32>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<8xi32> -> vector<8xi8>
  %acc = vector.constant 0 : vector<2xi32>
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  vector.store %dot, %output_view[0] : vector<2xi32>, view<2xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=4,1,1 --binding=&4xi32=1985229328,1985229328,0,0 --binding=&4xi32=1431633920,0,1431633920,0 --binding=&2xi32=16843009,16843009 --binding=&8xi32=0 --expected_binding=4xi32=1985229328,1985229328,0,0 --expected_binding=4xi32=1431633920,0,1431633920,0 --expected_binding=2xi32=16843009,16843009 --expected_binding=8xi32=-58,-42,-122,-106,-64,-64,-128,-128

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%low_buffer: buffer, %high_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<2xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4x2xi32, #dense>
  %low_packed = vector.load %low_view[%tid] : view<4xi32, #dense> -> vector<1xi32>
  %high_word = vector.load %high_view[%tid] : view<4xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<2xi32, #dense> -> vector<2xi32>
  %low4 = vector.bitunpacku<4> %low_packed : vector<1xi32> -> vector<8xi32>
  %high_bytes = vector.bitcast %high_word : vector<1xi32> to vector<4xi8>
  %high_packed = vector.slice %high_bytes[2] : vector<4xi8> -> vector<2xi8>
  %high2 = vector.bitunpacku<2> %high_packed : vector<2xi8> -> vector<8xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<8xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<8xi32> -> vector<8xi8>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<2xi32> -> vector<8xi32>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<8xi32> -> vector<8xi8>
  %acc = vector.constant 0 : vector<2xi32>
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  vector.store %dot, %output_view[%tid, 0] : vector<2xi32>, view<4x2xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&8xi32=1,2,3,4,5,6,7,8 --binding=&8xi32=10,10,10,10,10,10,10,10 --binding=&8xi32=0 --expected_binding=8xi32=1,2,3,4,5,6,7,8 --expected_binding=8xi32=10,10,10,10,10,10,10,10 --expected_binding=8xi32=0,0,0,0,15,16,17,18

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<1x8xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<1x8xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1x8xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[%tid, 4] : view<1x8xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[%tid, 4] : view<1x8xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %sum, %output_view[%tid, 4] : vector<4xi32>, view<1x8xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

