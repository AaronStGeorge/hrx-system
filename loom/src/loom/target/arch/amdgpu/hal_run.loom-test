// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=4660,22136,255,1 --binding=&4xi32=0 --expected_binding=4xi32=4660,22136,255,1 --expected_binding=4xi32=64,128,240,16

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<1x4xi32, #dense> -> vector<4xi32>
  %shift = vector.constant 4 : vector<4xi32>
  %low_nibble = vector.bitfield.extractu %loaded {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high_nibble = vector.bitfield.extractu %loaded {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %low_shifted = vector.shli %low_nibble, %shift : vector<4xi32>
  %swapped = vector.ori %low_shifted, %high_nibble : vector<4xi32>
  %signed_high = vector.bitfield.extracts %loaded {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %mask = vector.constant 15 : vector<4xi32>
  %signed_nibble = vector.andi %signed_high, %mask : vector<4xi32>
  %result = vector.xori %swapped, %signed_nibble : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<1x4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=0,15,8,4 --binding=&4xi32=0,1,2,3 --binding=&4xi32=0 --expected_binding=4xi32=0,15,8,4 --expected_binding=4xi32=0,1,2,3 --expected_binding=4xi32=-32,-1,8,20

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%low_buffer: buffer, %high_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %low_packed = vector.load %low_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %high_packed = vector.load %high_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  vector.store %signed_q6, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=0,15,8,4 --binding=&4xi32=0,1,2,3 --binding=&1xi32=0 --expected_binding=4xi32=0,15,8,4 --expected_binding=4xi32=0,1,2,3 --expected_binding=1xi32=75

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%low_buffer: buffer, %high_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %low_packed = vector.load %low_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %high_packed = vector.load %high_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<4xi32> -> vector<4xi8>
  %rhs0 = scalar.constant 1 : i32
  %rhs1 = scalar.constant 2 : i32
  %rhs2 = scalar.constant 3 : i32
  %rhs3 = scalar.constant 4 : i32
  %rhs_i32 = vector.from_elements %rhs0, %rhs1, %rhs2, %rhs3 : vector<4xi32>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  %acc = vector.constant 5 : vector<1xi32>
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  vector.store %dot, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=2,2,1 --binding=&4xi32=1,2,3,4 --binding=&4xi32=5,6,7,8 --binding=&4xi32=0 --expected_binding=4xi32=1,2,3,4 --expected_binding=4xi32=5,6,7,8 --expected_binding=4xi32=19,22,43,50

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %k = index.constant 2 : index
  %lhs_base = index.madd %y, %k, %zero : index
  %lhs_next = index.add %lhs_base, %one : index
  %rhs_base = index.add %x, %zero : index
  %rhs_next = index.add %x, %k : index
  %output_index = index.madd %y, %k, %x : index
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<4xi32, #dense>
  %lhs0 = vector.load %lhs_view[%lhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %rhs0 = vector.load %rhs_view[%rhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %prod0 = vector.muli %lhs0, %rhs0 : vector<1xi32>
  %lhs1 = vector.load %lhs_view[%lhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %rhs1 = vector.load %rhs_view[%rhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %prod1 = vector.muli %lhs1, %rhs1 : vector<1xi32>
  %sum = vector.addi %prod0, %prod1 : vector<1xi32>
  vector.store %sum, %output_view[%output_index] : vector<1xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// REQUIRES: amdgpu-hal-b128
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&1xi32=336134112 --binding=&1xi32=67305985 --binding=&1xi32=0 --expected_binding=1xi32=336134112 --expected_binding=1xi32=67305985 --expected_binding=1xi32=75

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<1xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %lhs_packed = vector.load %lhs_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %lhs_i32 = vector.bitunpacks<8> %lhs_packed : vector<1xi32> -> vector<4xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<1xi32> -> vector<4xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<4xi32> -> vector<4xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  %acc = vector.constant 5 : vector<1xi32>
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  vector.store %dot, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

