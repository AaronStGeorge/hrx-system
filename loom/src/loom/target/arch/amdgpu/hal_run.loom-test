  %zero = index.constant 0 : offset
  %view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %value = vector.constant 42 : vector<1xi32>
  vector.store %value, %view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}
