target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<1xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<2xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<2xi32, #dense>
  %lhs_packed = vector.load %lhs_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<2xi32, #dense> -> vector<2xi32>
  %lhs_i32 = vector.bitunpacku<4> %lhs_packed : vector<1xi32> -> vector<8xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<2xi32> -> vector<8xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<8xi32> -> vector<8xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<8xi32> -> vector<8xi8>
  %acc = vector.constant 0 : vector<2xi32>
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  vector.store %dot, %output_view[0] : vector<2xi32>, view<2xi32, #dense>
  func.return
}
