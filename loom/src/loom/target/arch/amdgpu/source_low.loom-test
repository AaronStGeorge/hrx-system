// RUN: emit source-low @gfx11_target
target.preset @gfx11_target {key = "amdgpu-gfx11", source = @loom_kernel}

func.def @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %input_view = buffer.view %input[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %raise = vector.constant 9 : vector<4xi32>
  %raised = vector.addi %loaded, %raise : vector<4xi32>
  %drop = vector.constant 4 : vector<4xi32>
  %sum = vector.subi %raised, %drop : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}
