target.preset @gfx11_f32_target {key = "amdgpu-gfx11", source = @loom_f32_kernel}

func.def @loom_f32_kernel(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %sum = vector.addf %lhs, %rhs : vector<4xf32>
  %product = vector.mulf %sum, %rhs : vector<4xf32>
  %fma = vector.fmaf %lhs, %rhs, %product : vector<4xf32>
  %bias = vector.constant 0.5 : vector<4xf32>
  %biased = vector.addf %fma, %bias : vector<4xf32>
  %adjusted = vector.subf %biased, %bias : vector<4xf32>
  vector.store %adjusted, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  func.return
}

