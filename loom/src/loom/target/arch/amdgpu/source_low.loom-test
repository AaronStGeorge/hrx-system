  %32 = low.op<amdgpu.v_add_u32>(%30, %31) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %33 = low.slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %34 = low.slice %raise[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = low.op<amdgpu.v_add_u32>(%33, %34) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %raised = low.concat(%26, %29, %32, %35) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %37 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %38 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %39 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %40 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %drop = low.concat(%37, %38, %39, %40) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %42 = low.slice %raised[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %43 = low.slice %drop[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %44 = low.op<amdgpu.v_sub_u32>(%42, %43) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %45 = low.slice %raised[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %46 = low.slice %drop[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %47 = low.op<amdgpu.v_sub_u32>(%45, %46) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %48 = low.slice %raised[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %49 = low.slice %drop[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
