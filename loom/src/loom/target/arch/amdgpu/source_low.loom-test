  %bytes = s_mov_b32 1024
  %scratch_view = frame_index @lds_b128_roundtrip__lds5 {offset = 0} : reg<amdgpu.vgpr>
  %17 = v_mov_b32 4
  %18 = v_lshlrev_b32 %17, %tid
  %19 = s_mov_b32 0
  %loaded = buffer_load_b128 %input_view, %18, %19 {offset = 0}
  %21 = v_mov_b32 4
  %22 = v_lshlrev_b32 %21, %tid
  %23 = v_add_u32 %scratch_view, %22
  ds_write_b128 %23, %loaded {offset = 0}
  %24 = v_mov_b32 4
  %25 = v_lshlrev_b32 %24, %tid
