// RUN: emit source-low @gfx11_target
target.preset @gfx11_target {key = "amdgpu-gfx11", source = @loom_kernel}

func.def @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %input_view = buffer.view %input[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %raise = vector.constant 9 : vector<4xi32>
  %raised = vector.addi %loaded, %raise : vector<4xi32>
  %drop = vector.constant 4 : vector<4xi32>
  %sum = vector.subi %raised, %drop : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}
// ----
target.snapshot @gfx11_target__snapshot {artifact_format = elf, codegen_format = low_native, data_layout = "e-p:64:64-p1:64:64-p2:32:32-p3:32:32-p4:64:64-p5:32:32-p6:32:32-p7:160:256:256:32-p8:128:128:128:48-p9:192:256:256:32-i64:64-v16:16-v24:32-v32:32-v48:64-v96:128-v192:256-v256:256-v512:512-v1024:1024-v2048:2048-n32:64-S32-A5-G1-ni:7:8:9", default_pointer_bitwidth = 64, index_bitwidth = 32, memory_space_constant = 4, memory_space_descriptor = 7, memory_space_generic = 0, memory_space_global = 1, memory_space_host = 4294967295, memory_space_private = 5, memory_space_workgroup = 3, offset_bitwidth = 64, target_cpu = "gfx1100", target_features = "", target_triple = "amdgcn-amd-amdhsa"}

target.export @gfx11_target__export {abi = hal_kernel, export_symbol = "loom_kernel", hal_binding_alignment = 16, hal_buffer_resource_flags = 159744, hal_flat_workgroup_size_max = 64, hal_flat_workgroup_size_min = 64, hal_workgroup_size_x = 64, hal_workgroup_size_y = 1, hal_workgroup_size_z = 1, linkage = default, source = @loom_kernel}

target.config @gfx11_target__config {contract_feature_bits = 0, contract_set_key = "amdgpu.gfx11.core"}

target.bundle @gfx11_target {config = @gfx11_target__config, export_plan = @gfx11_target__export, snapshot = @gfx11_target__snapshot}

func.def @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %input_view = buffer.view %input[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %raise = vector.constant 9 : vector<4xi32>
  %raised = vector.addi %loaded, %raise : vector<4xi32>
  %drop = vector.constant 4 : vector<4xi32>
  %sum = vector.subi %raised, %drop : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

