// RUN: emit source-low @gfx11_i32_bitwise_target
target.preset @gfx11_i32_bitwise_target {key = "amdgpu-gfx11", source = @loom_i32_bitwise_kernel}

func.def @loom_i32_bitwise_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %input_view = buffer.view %input[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %mask = vector.constant 15 : vector<4xi32>
  %shift = vector.constant 4 : vector<4xi32>
  %masked = vector.andi %loaded, %mask : vector<4xi32>
  %left = vector.shli %masked, %shift : vector<4xi32>
  %logical = vector.shrui %loaded, %shift : vector<4xi32>
  %arithmetic = vector.shrsi %loaded, %shift : vector<4xi32>
  %packed = vector.ori %left, %logical : vector<4xi32>
  %mixed = vector.xori %packed, %arithmetic : vector<4xi32>
  %lane0 = vector.extract %loaded[0] : vector<4xi32> -> i32
  %lane1 = vector.extract %loaded[1] : vector<4xi32> -> i32
  %scalar_mask = scalar.constant 255 : i32
  %scalar_shift = scalar.constant 3 : i32
  %scalar_masked = scalar.andi %lane0, %scalar_mask : i32
  %scalar_left = scalar.shli %scalar_masked, %scalar_shift : i32
  %scalar_logical = scalar.shrui %lane1, %scalar_shift : i32
  %scalar_arithmetic = scalar.shrsi %lane1, %scalar_shift : i32
  %scalar_packed = scalar.ori %scalar_left, %scalar_logical : i32
  %scalar_mixed = scalar.xori %scalar_packed, %scalar_arithmetic : i32
  %uniform_lhs = scalar.constant 240 : i32
  %uniform_rhs = scalar.constant 15 : i32
  %uniform_and = scalar.andi %uniform_lhs, %uniform_rhs : i32
  %uniform_or = scalar.ori %uniform_and, %uniform_rhs : i32
  %uniform_xor = scalar.xori %uniform_or, %uniform_lhs : i32
  %uniform_shl = scalar.shli %uniform_xor, %uniform_rhs : i32
  %uniform_lshr = scalar.shrui %uniform_shl, %uniform_rhs : i32
  %uniform_ashr = scalar.shrsi %uniform_lshr, %uniform_rhs : i32
  %mixed1 = vector.extract %mixed[1] : vector<4xi32> -> i32
  %mixed2 = vector.extract %mixed[2] : vector<4xi32> -> i32
  %mixed3 = vector.extract %mixed[3] : vector<4xi32> -> i32
  %result = vector.from_elements %scalar_mixed, %mixed1, %mixed2, %mixed3 : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

