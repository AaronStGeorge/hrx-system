// RUN: emit source-low @amdgpu_i32_row_mix output=none
target.profile @gfx11_i32_row_mix_target preset("amdgpu-gfx11")

func.def target(@gfx11_i32_row_mix_target) @amdgpu_i32_row_mix(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %product = vector.muli %sum, %rhs : vector<4xi32>
  %result = vector.subi %product, %lhs : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_i32_gemm2_shape output=none
target.profile @gfx11_i32_gemm2_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_i32_gemm2_shape_target) @amdgpu_i32_gemm2_shape(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %k = index.constant 2 : index
  %lhs_base = index.madd %y, %k, %zero : index
  %lhs_next = index.add %lhs_base, %one : index
  %rhs_base = index.add %x, %zero : index
  %rhs_next = index.add %x, %k : index
  %output_index = index.madd %y, %k, %x : index
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<4xi32, #dense>
  %lhs0 = vector.load %lhs_view[%lhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %rhs0 = vector.load %rhs_view[%rhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %prod0 = vector.muli %lhs0, %rhs0 : vector<1xi32>
  %lhs1 = vector.load %lhs_view[%lhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %rhs1 = vector.load %rhs_view[%rhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %prod1 = vector.muli %lhs1, %rhs1 : vector<1xi32>
  %sum = vector.addi %prod0, %prod1 : vector<1xi32>
  vector.store %sum, %output_view[%output_index] : vector<1xi32>, view<4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_i32_b64 output=none
target.profile @gfx11_i32_b64_target preset("amdgpu-gfx11")

func.def target(@gfx11_i32_b64_target) @amdgpu_i32_b64(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x2xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x2xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x2xi32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x2xi32, #dense> -> vector<2xi32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x2xi32, #dense> -> vector<2xi32>
  %sum = vector.addi %lhs, %rhs : vector<2xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<2xi32>, view<64x2xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_lds_b96 output=none
target.profile @gfx11_lds_b96_target preset("amdgpu-gfx11")

func.def target(@gfx11_lds_b96_target) @amdgpu_lds_b96() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 768 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x3xi32, #dense>
  %value = vector.constant 7 : vector<3xi32>
  vector.store %value, %scratch_view[%tid, 0] : vector<3xi32>, view<64x3xi32, #dense>
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x3xi32, #dense> -> vector<3xi32>
  %lane0 = vector.extract %loaded[0] : vector<3xi32> -> i32
  %lane1 = vector.extract %loaded[1] : vector<3xi32> -> i32
  %lane2 = vector.extract %loaded[2] : vector<3xi32> -> i32
  %result = vector.from_elements %lane0, %lane1, %lane2 : vector<3xi32>
  vector.store %result, %scratch_view[%tid, 0] : vector<3xi32>, view<64x3xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_f32_micro_tile output=none
target.profile @gfx11_f32_micro_tile_target preset("amdgpu-gfx11")

func.def target(@gfx11_f32_micro_tile_target) @amdgpu_f32_micro_tile(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %bias = vector.constant 1.0 : vector<4xf32>
  %result = vector.fmaf %lhs, %rhs, %product : vector<4xf32>
  %biased = vector.addf %result, %bias : vector<4xf32>
  vector.store %biased, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  func.return
}
