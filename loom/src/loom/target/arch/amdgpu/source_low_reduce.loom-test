// RUN: emit source-low @i32_reduce_add output=low
target.profile @gfx11_reduce_target preset("amdgpu-gfx11")

func.def target(@gfx11_reduce_target) @i32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %init = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %loaded, %init : vector<4xi32>, i32
  %stored = vector.from_elements %sum : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}

// ----
low.func.def target(@gfx11_reduce_target) abi(hal_kernel) @i32_reduce_add() {
  %input_view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x4>
  %output_view = low.resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %12 = low.const<amdgpu.v_mov_b32> {imm32 = 0} : reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %loaded = low.op<amdgpu.buffer_load_b128>(%input_view, %12, %13) {offset = 0} : (reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr x4>
  %init = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %16 = low.const<amdgpu.v_mov_b32> {imm32 = 0} : reg<amdgpu.vgpr>
  %17 = low.slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %18 = low.op<amdgpu.v_add_u32>(%16, %17) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %19 = low.slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %20 = low.op<amdgpu.v_add_u32>(%18, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %21 = low.slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %22 = low.op<amdgpu.v_add_u32>(%20, %21) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %23 = low.slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = low.op<amdgpu.v_add_u32>(%22, %23) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.op<amdgpu.buffer_store_dword_off_zero>(%stored, %output_view) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>)
  low.return
}

// ====
// RUN: emit source-low @f32_reduce_add output=low
target.profile @gfx11_reduce_target preset("amdgpu-gfx11")

func.def target(@gfx11_reduce_target) @f32_reduce_add(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %init = scalar.constant 0.0 : f32
  %sum = vector.reduce<addf> %loaded, %init : vector<4xf32>, f32
  %stored = vector.from_elements %sum : vector<1xf32>
  vector.store %stored, %output_view[0] : vector<1xf32>, view<1xf32, #dense>
  func.return
}

// ----
low.func.def target(@gfx11_reduce_target) abi(hal_kernel) @f32_reduce_add() {
  %input_view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 16} : reg<amdgpu.sgpr x4>
  %output_view = low.resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 4} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %12 = low.const<amdgpu.v_mov_b32> {imm32 = 0} : reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %loaded = low.op<amdgpu.buffer_load_b128>(%input_view, %12, %13) {offset = 0} : (reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr x4>
  %init = low.const<amdgpu.v_mov_b32> {imm32 = 0} : reg<amdgpu.vgpr>
  %16 = low.slice %loaded[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %17 = low.op<amdgpu.v_add_f32>(%init, %16) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %18 = low.slice %loaded[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = low.op<amdgpu.v_add_f32>(%17, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %20 = low.slice %loaded[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %21 = low.op<amdgpu.v_add_f32>(%19, %20) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %22 = low.slice %loaded[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %stored = low.op<amdgpu.v_add_f32>(%21, %22) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.op<amdgpu.buffer_store_dword_off_zero>(%stored, %output_view) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>)
  low.return
}
