// ====
// RUN: emit source-low @vector_uitofp_i32x2 output=low
target.profile @gfx11_conversion_target preset("amdgpu-gfx11")

func.def target(@gfx11_conversion_target) @vector_uitofp_i32x2(%input: vector<2xi32>) -> (vector<2xf32>) {
  %converted = vector.uitofp %input : vector<2xi32> to vector<2xf32>
  func.return %converted : vector<2xf32>
}

// ----
low.func.def target(@gfx11_conversion_target) abi(hal_kernel) @vector_uitofp_i32x2__low(%input: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.gfx11.core> {
  %5 = slice %input[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %6 = v_cvt_f32_u32 %5
  %7 = slice %input[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %8 = v_cvt_f32_u32 %7
  %converted = concat(%6, %8) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %converted
}
