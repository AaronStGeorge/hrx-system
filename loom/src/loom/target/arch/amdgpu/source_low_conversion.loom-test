  %converted = scalar.sitofp %input : i32 to f32
  func.return %converted : f32
}

// ----
low.func.def target(@gfx11_conversion_target) abi(hal_kernel) @scalar_sitofp_i32__low(%input: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
