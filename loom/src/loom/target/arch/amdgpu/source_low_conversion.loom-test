// RUN: emit source-low @vector_sitofp_i32x2 output=low
target.profile @gfx11_conversion_target preset("amdgpu-gfx11")

func.def target(@gfx11_conversion_target) @vector_sitofp_i32x2(%input: vector<2xi32>, %scale: vector<2xf32>) -> (vector<2xf32>) {
  %converted = vector.sitofp %input : vector<2xi32> to vector<2xf32>
  %scaled = vector.mulf %converted, %scale : vector<2xf32>
  func.return %scaled : vector<2xf32>
}

// ----
low.func.def target(@gfx11_conversion_target) abi(hal_kernel) @vector_sitofp_i32x2__low(%input: reg<amdgpu.vgpr x2>, %scale: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) {
  %8 = low.slice %input[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %9 = low.op<amdgpu.v_cvt_f32_i32>(%8) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %10 = low.slice %input[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %11 = low.op<amdgpu.v_cvt_f32_i32>(%10) : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %converted = low.concat(%9, %11) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %13 = low.slice %converted[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %14 = low.slice %scale[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %15 = low.op<amdgpu.v_mul_f32>(%13, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %16 = low.slice %converted[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %17 = low.slice %scale[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %18 = low.op<amdgpu.v_mul_f32>(%16, %17) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %scaled = low.concat(%15, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  low.return %scaled : reg<amdgpu.vgpr x2>
}

// ====
// RUN: emit source-low @scalar_uitofp_i32 output=low
target.profile @gfx11_conversion_target preset("amdgpu-gfx11")

func.def target(@gfx11_conversion_target) @scalar_uitofp_i32(%input: i32) -> (f32) {
  %converted = scalar.uitofp %input : i32 to f32
  func.return %converted : f32
}

// ----
low.func.def target(@gfx11_conversion_target) abi(hal_kernel) @scalar_uitofp_i32__low(%input: reg<amdgpu.sgpr>) -> (reg<amdgpu.vgpr>) {
  %converted = low.op<amdgpu.v_cvt_f32_u32>(%input) : (reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr>
  low.return %converted : reg<amdgpu.vgpr>
}

