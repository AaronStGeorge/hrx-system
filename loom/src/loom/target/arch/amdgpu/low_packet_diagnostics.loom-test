// RUN: emit low-packet-json @gfx11_lds_crosslane diagnostics=packets output=none
target.profile @gfx11_lds_crosslane_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_lds_crosslane_target) @gfx11_lds_crosslane(%addr: reg<amdgpu.vgpr>, %value: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  // REMARK@+1: BACKEND/018 "selected lds-crosslane low packet 'amdgpu.ds_swizzle_b32'"
  %swizzled = low.op<amdgpu.ds_swizzle_b32>(%addr) {offset = 32} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  // REMARK@+1: BACKEND/018 "selected lds-crosslane low packet 'amdgpu.ds_permute_b32'"
  %permuted = low.op<amdgpu.ds_permute_b32>(%addr, %swizzled) {offset = 4} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  // REMARK@+1: BACKEND/018 "selected lds-crosslane low packet 'amdgpu.ds_bpermute_b32'"
  %bpermuted = low.op<amdgpu.ds_bpermute_b32>(%addr, %permuted) {offset = 8} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %bpermuted : reg<amdgpu.vgpr>
}
