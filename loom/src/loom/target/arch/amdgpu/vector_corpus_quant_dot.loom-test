// ====
// RUN: emit source-low @amdgpu_q4_0_byte_storage_gemv2_shape output=none
target.profile @gfx11_q4_0_byte_storage_gemv2_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q4_0_byte_storage_gemv2_shape_target) @amdgpu_q4_0_byte_storage_gemv2_shape(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %four = index.constant 4 : index
  %byte_base = index.mul %tid, %four : index
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<8xi8, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi8, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<2xi32, #dense>
  %lhs_bytes = vector.load %lhs_view[%byte_base] : view<8xi8, #dense> -> vector<4xi8>
  %lhs_offset_q4 = vector.bitcast %lhs_bytes : vector<4xi8> to vector<1xi32>
  %offset_binary_mask = vector.constant -2004318072 : vector<1xi32>
  %lhs_signed_q4 = vector.xori %lhs_offset_q4, %offset_binary_mask : vector<1xi32>
  %rhs_bytes = vector.load %rhs_view[0] : view<4xi8, #dense> -> vector<4xi8>
  %rhs_u4 = vector.bitcast %rhs_bytes : vector<4xi8> to vector<1xi32>
  %acc = vector.constant 0 : vector<1xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot8i4<s4u4> %lhs_signed_q4, %rhs_u4, %acc : vector<1xi32>
  vector.store %dot, %output_view[%tid] : vector<1xi32>, view<2xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q8_0_byte_storage_scaled_gemv2_shape output=none
target.profile @gfx11_q8_0_byte_storage_scaled_gemv2_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q8_0_byte_storage_scaled_gemv2_shape_target) @amdgpu_q8_0_byte_storage_scaled_gemv2_shape(%lhs_buffer: buffer, %rhs_buffer: buffer, %scale_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %four = index.constant 4 : index
  %byte_base = index.mul %tid, %four : index
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<8xi8, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi8, #dense>
  %scale_view = buffer.view %scale_buffer[%zero_offset] : buffer -> view<2xf32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<2xf32, #dense>
  %lhs = vector.load %lhs_view[%byte_base] : view<8xi8, #dense> -> vector<4xi8>
  %rhs = vector.load %rhs_view[0] : view<4xi8, #dense> -> vector<4xi8>
  %acc = vector.constant 0 : vector<1xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  %converted = vector.sitofp %dot : vector<1xi32> to vector<1xf32>
  %scale = vector.load %scale_view[%tid] : view<2xf32, #dense> -> vector<1xf32>
  %scaled = vector.mulf %converted, %scale : vector<1xf32>
  vector.store %scaled, %output_view[%tid] : vector<1xf32>, view<2xf32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_high2_chunk_dot2_shape output=none
target.profile @gfx11_q6_high2_chunk_dot2_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_high2_chunk_dot2_shape_target) @amdgpu_q6_high2_chunk_dot2_shape(%low_packed: vector<1xi32>, %high_word: vector<1xi32>, %rhs_packed: vector<2xi32>, %acc: vector<2xi32>) -> (vector<2xi32>) {
  %low4 = vector.bitunpacku<4> %low_packed : vector<1xi32> -> vector<8xi32>
  %high_bytes = vector.bitcast %high_word : vector<1xi32> to vector<4xi8>
  %high_packed = vector.slice %high_bytes[2] : vector<4xi8> -> vector<2xi8>
  %high2 = vector.bitunpacku<2> %high_packed : vector<2xi8> -> vector<8xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<8xi32>, vector<8xi32>
  %bias = vector.constant 32 : vector<8xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<8xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<8xi32> -> vector<8xi8>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<2xi32> -> vector<8xi32>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<8xi32> -> vector<8xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<8xi8>, vector<8xi8>, vector<2xi32>
  func.return %dot : vector<2xi32>
}

