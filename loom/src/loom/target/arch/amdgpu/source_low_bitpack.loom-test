// RUN: emit source-low @i32x4_to_i8x4_bitpack output=low
target.profile @gfx11_bitpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitpack_target) @i32x4_to_i8x4_bitpack(%codes: vector<4xi32>) -> (vector<4xi8>) {
  %packed = vector.bitpack<8> %codes : vector<4xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ----
low.func.def target(@gfx11_bitpack_target) abi(hal_kernel) @i32x4_to_i8x4_bitpack__low(%codes: reg<amdgpu.vgpr x4>) -> (reg<amdgpu.vgpr>) {
  %5 = low.const<amdgpu.v_mov_b32> {imm32 = 255} : reg<amdgpu.vgpr>
  %6 = low.slice %codes[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %7 = low.op<amdgpu.v_and_b32>(%6, %5) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %8 = low.slice %codes[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %9 = low.op<amdgpu.v_and_b32>(%8, %5) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %10 = low.const<amdgpu.v_mov_b32> {imm32 = 8} : reg<amdgpu.vgpr>
  %11 = low.op<amdgpu.v_lshlrev_b32>(%10, %9) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %12 = low.op<amdgpu.v_or_b32>(%7, %11) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %13 = low.slice %codes[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %14 = low.op<amdgpu.v_and_b32>(%13, %5) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %15 = low.const<amdgpu.v_mov_b32> {imm32 = 16} : reg<amdgpu.vgpr>
  %16 = low.op<amdgpu.v_lshlrev_b32>(%15, %14) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %17 = low.op<amdgpu.v_or_b32>(%12, %16) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %18 = low.slice %codes[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %19 = low.op<amdgpu.v_and_b32>(%18, %5) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %20 = low.const<amdgpu.v_mov_b32> {imm32 = 24} : reg<amdgpu.vgpr>
  %21 = low.op<amdgpu.v_lshlrev_b32>(%20, %19) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %packed = low.op<amdgpu.v_or_b32>(%17, %21) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.return %packed : reg<amdgpu.vgpr>
}

// ====
// RUN: emit source-low @bitpack_width_rejected output=low
target.profile @gfx11_bitpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitpack_target) @bitpack_width_rejected(%codes: vector<8xi32>) -> (vector<4xi8>) {
  // ERROR@+1: BACKEND/001 "AMDGPU vector.bitpack currently lowers byte packing width 8"
  %packed = vector.bitpack<4> %codes : vector<8xi32> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}

// ====
// RUN: emit source-low @bitpack_source_type_rejected output=low
target.profile @gfx11_bitpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitpack_target) @bitpack_source_type_rejected(%codes: vector<4xi8>) -> (vector<4xi8>) {
  // ERROR@+1: BACKEND/001 "static rank-1 i32 source vector"
  %packed = vector.bitpack<8> %codes : vector<4xi8> -> vector<4xi8>
  func.return %packed : vector<4xi8>
}
