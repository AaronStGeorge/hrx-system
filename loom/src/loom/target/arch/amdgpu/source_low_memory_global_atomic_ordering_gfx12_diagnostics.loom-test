// RUN: emit source-low target-preset=amdgpu-gfx12 diagnostics=memory output=low

func.def @global_atomic_release_gfx12_ordering_rejected(%input: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %global = buffer.assume.memory_space %input {memory_space = global} : buffer
  %view = buffer.view %global[%zero] : buffer -> view<64xi32, #dense>
  %one = scalar.constant 1 : i32
  // ERROR@+1: BACKEND/001 "GFX11 global acquire/release atomics"
  view.atomic.reduce<addi> %one, %view[%tid] {ordering = release, scope = device} : i32, view<64xi32, #dense>
  func.return
}
