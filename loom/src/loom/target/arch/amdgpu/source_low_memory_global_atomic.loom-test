  %48 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %old_maxui = low.op<amdgpu.buffer_atomic_max_u32_rtn>(%45, %view, %47, %48) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>) -> %45 as reg<amdgpu.vgpr>
  low.return
}
