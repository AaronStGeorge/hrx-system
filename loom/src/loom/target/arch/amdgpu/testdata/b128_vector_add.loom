target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<64x4xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}
