// RUN: emit source-low @amdgpu_packed_i8_dot_shape output=none
target.profile @gfx11_packed_i8_dot_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_packed_i8_dot_shape_target) @amdgpu_packed_i8_dot_shape(%lhs_packed: vector<1xi32>, %rhs_packed: vector<1xi32>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %lhs_i32 = vector.bitunpacks<8> %lhs_packed : vector<1xi32> -> vector<4xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<1xi32> -> vector<4xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<4xi32> -> vector<4xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}

// ====
// RUN: emit source-low @amdgpu_packed_i8_gemv4_shape output=none
target.profile @gfx11_packed_i8_gemv4_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_packed_i8_gemv4_shape_target) @amdgpu_packed_i8_gemv4_shape(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %lhs_packed = vector.load %lhs_view[%tid] : view<4xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %lhs_i32 = vector.bitunpacks<8> %lhs_packed : vector<1xi32> -> vector<4xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<1xi32> -> vector<4xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<4xi32> -> vector<4xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  %acc = vector.constant 0 : vector<1xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  vector.store %dot, %output_view[%tid] : vector<1xi32>, view<4xi32, #dense>
  func.return
}

