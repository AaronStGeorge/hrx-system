low.func.def target(@target) abi(hal_kernel) @async_gather_b128() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %source = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %bytes = low.const<amdgpu.s_mov_b32> {imm32 = 1024} : reg<amdgpu.sgpr>
  %dest = low.frame_index @async_gather_b128__lds7 {offset = 0} : reg<amdgpu.vgpr>
  %16 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %17 = low.op<amdgpu.v_lshlrev_b32>(%16, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %18 = low.slice %source[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  %19 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %20 = low.op<amdgpu.s_mov_b32_m0>(%19) : (reg<amdgpu.sgpr>) -> reg<amdgpu.m0>
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%17, %18, %20) {offset = 0} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.return
}

low.slot @async_gather_b128__lds7 {align = 16, function = @async_gather_b128, size = 1024, space = lds}
