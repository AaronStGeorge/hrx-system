// RUN: emit source-low @amdgpu_q4_decode_shape output=none
target.profile @gfx11_q4_decode_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q4_decode_shape_target) @amdgpu_q4_decode_shape(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %packed = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %shift = vector.constant 4 : vector<4xi32>
  %low_nibble = vector.bitfield.extractu %packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high_nibble = vector.bitfield.extractu %packed {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %low_shifted = vector.shli %low_nibble, %shift : vector<4xi32>
  %swapped = vector.ori %low_shifted, %high_nibble : vector<4xi32>
  vector.store %swapped, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_merge_shape output=none
target.profile @gfx11_q6_merge_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_merge_shape_target) @amdgpu_q6_merge_shape(%low_buffer: buffer, %high_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %low_packed = vector.load %low_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %high_packed = vector.load %high_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  vector.store %signed_q6, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_iq4_table_lookup_decode_shape output=none
target.profile @gfx11_iq4_table_lookup_decode_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_iq4_table_lookup_decode_shape_target) @amdgpu_iq4_table_lookup_decode_shape(%codes_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero_offset = index.constant 0 : offset
  %four = index.constant 4 : index
  %byte_base = index.mul %tid, %four : index
  %codes_view = buffer.view %codes_buffer[%zero_offset] : buffer -> view<8xi8, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<8xf32, #dense>
  %codes = vector.load %codes_view[%byte_base] : view<8xi8, #dense> -> vector<4xi8>
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant -0.5 : f32
  %g2 = scalar.constant 0.5 : f32
  %g3 = scalar.constant 1.5 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi8> -> vector<4xf32>
  vector.store %decoded, %output_view[%byte_base] : vector<4xf32>, view<8xf32, #dense>
  func.return
}
