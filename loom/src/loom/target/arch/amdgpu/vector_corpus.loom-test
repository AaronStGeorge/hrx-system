// ====
// RUN: emit source-low @amdgpu_lds_b96 output=none
target.profile @gfx11_lds_b96_target preset("amdgpu-gfx11")

func.def target(@gfx11_lds_b96_target) @amdgpu_lds_b96() {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %bytes = index.constant 768 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %scratch_view = buffer.view %scratch[%zero] : buffer -> view<64x3xi32, #dense>
  %value = vector.constant 7 : vector<3xi32>
  vector.store %value, %scratch_view[%tid, 0] : vector<3xi32>, view<64x3xi32, #dense>
  %loaded = vector.load %scratch_view[%tid, 0] : view<64x3xi32, #dense> -> vector<3xi32>
  %lane0 = vector.extract %loaded[0] : vector<3xi32> -> i32
  %lane1 = vector.extract %loaded[1] : vector<3xi32> -> i32
  %lane2 = vector.extract %loaded[2] : vector<3xi32> -> i32
  %result = vector.from_elements %lane0, %lane1, %lane2 : vector<3xi32>
  vector.store %result, %scratch_view[%tid, 0] : vector<3xi32>, view<64x3xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_f32_micro_tile output=none
target.profile @gfx11_f32_micro_tile_target preset("amdgpu-gfx11")

func.def target(@gfx11_f32_micro_tile_target) @amdgpu_f32_micro_tile(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xf32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xf32, #dense> -> vector<4xf32>
  %product = vector.mulf %lhs, %rhs : vector<4xf32>
  %bias = vector.constant 1.0 : vector<4xf32>
  %result = vector.fmaf %lhs, %rhs, %product : vector<4xf32>
  %biased = vector.addf %result, %bias : vector<4xf32>
  vector.store %biased, %output_view[%tid, 0] : vector<4xf32>, view<64x4xf32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q4_decode_shape output=none
target.profile @gfx11_q4_decode_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q4_decode_shape_target) @amdgpu_q4_decode_shape(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %packed = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %shift = vector.constant 4 : vector<4xi32>
  %low_nibble = vector.bitfield.extractu %packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high_nibble = vector.bitfield.extractu %packed {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %low_shifted = vector.shli %low_nibble, %shift : vector<4xi32>
  %swapped = vector.ori %low_shifted, %high_nibble : vector<4xi32>
  vector.store %swapped, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_merge_shape output=none
target.profile @gfx11_q6_merge_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_merge_shape_target) @amdgpu_q6_merge_shape(%low_buffer: buffer, %high_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %low_packed = vector.load %low_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %high_packed = vector.load %high_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  vector.store %signed_q6, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ====
// RUN: emit source-low @amdgpu_q6_pack_dot_shape output=none
target.profile @gfx11_q6_pack_dot_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_q6_pack_dot_shape_target) @amdgpu_q6_pack_dot_shape(%low_packed: vector<4xi32>, %high_packed: vector<4xi32>, %rhs: vector<4xi8>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  %lhs = vector.bitpack<8> %signed_q6 : vector<4xi32> -> vector<4xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}

// ====
// RUN: emit source-low @amdgpu_packed_i8_dot_shape output=none
target.profile @gfx11_packed_i8_dot_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_packed_i8_dot_shape_target) @amdgpu_packed_i8_dot_shape(%lhs_packed: vector<1xi32>, %rhs_packed: vector<1xi32>, %acc: vector<1xi32>) -> (vector<1xi32>) {
  %lhs_i32 = vector.bitunpacks<8> %lhs_packed : vector<1xi32> -> vector<4xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<1xi32> -> vector<4xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<4xi32> -> vector<4xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  func.return %dot : vector<1xi32>
}

// ====
// RUN: emit source-low @amdgpu_packed_i8_gemv4_shape output=none
target.profile @gfx11_packed_i8_gemv4_shape_target preset("amdgpu-gfx11")

func.def target(@gfx11_packed_i8_gemv4_shape_target) @amdgpu_packed_i8_gemv4_shape(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<1xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %lhs_packed = vector.load %lhs_view[%tid] : view<4xi32, #dense> -> vector<1xi32>
  %rhs_packed = vector.load %rhs_view[0] : view<1xi32, #dense> -> vector<1xi32>
  %lhs_i32 = vector.bitunpacks<8> %lhs_packed : vector<1xi32> -> vector<4xi32>
  %rhs_i32 = vector.bitunpacku<8> %rhs_packed : vector<1xi32> -> vector<4xi32>
  %lhs = vector.bitpack<8> %lhs_i32 : vector<4xi32> -> vector<4xi8>
  %rhs = vector.bitpack<8> %rhs_i32 : vector<4xi32> -> vector<4xi8>
  %acc = vector.constant 0 : vector<1xi32>
  // REMARK@+1: BACKEND/002 "selected AMDGPU packed dot descriptor"
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<4xi8>, vector<4xi8>, vector<1xi32>
  vector.store %dot, %output_view[%tid] : vector<1xi32>, view<4xi32, #dense>
  func.return
}

