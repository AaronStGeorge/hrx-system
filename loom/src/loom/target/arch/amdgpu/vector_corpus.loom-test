// RUN: emit source-low @amdgpu_i32_row_mix output=none
target.profile @gfx11_i32_row_mix_target preset("amdgpu-gfx11")

func.def target(@gfx11_i32_row_mix_target) @amdgpu_i32_row_mix(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %lhs = vector.load %lhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %rhs = vector.load %rhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs, %rhs : vector<4xi32>
  %product = vector.muli %sum, %rhs : vector<4xi32>
  %result = vector.subi %product, %lhs : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

