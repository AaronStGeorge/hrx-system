// RUN: emit source-low @f32_table_lookup_i8_codes output=low
target.profile @gfx11_table_target preset("amdgpu-gfx11")

func.def target(@gfx11_table_target) @f32_table_lookup_i8_codes(%codes_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %four = index.constant 4 : index
  %base = index.mul %tid, %four : index
  %codes_view = buffer.view %codes_buffer[%zero] : buffer -> view<8xi8, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<8xf32, #dense>
  %codes = vector.load %codes_view[%base] : view<8xi8, #dense> -> vector<4xi8>
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant -0.5 : f32
  %g2 = scalar.constant 0.5 : f32
  %g3 = scalar.constant 1.5 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi8> -> vector<4xf32>
  vector.store %decoded, %output_view[%base] : vector<4xf32>, view<8xf32, #dense>
  func.return
}

// ----
low.func.def target(@gfx11_table_target) abi(hal_kernel) @f32_table_lookup_i8_codes() asm<amdgpu.gfx11.core> {
  %tid = live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %codes_view = resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 8} : reg<amdgpu.sgpr x4>
  %output_view = resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 32} : reg<amdgpu.sgpr x4>
  %zero = s_mov_b32 0
  %four = s_mov_b32 4
  %20 = v_mov_b32 4
  %base = v_mul_lo_u32 %tid, %20
  %22 = s_mov_b32 0
  %codes = buffer_load_dword %codes_view, %base, %22 {offset = 0}
  %g0 = v_mov_b32 3212836864
  %g1 = v_mov_b32 3204448256
  %g2 = v_mov_b32 1056964608
  %g3 = v_mov_b32 1069547520
  %grid = concat(%g0, %g1, %g2, %g3) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %29 = slice %grid[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %30 = slice %grid[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %31 = v_mov_b32 1
  %32 = slice %grid[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %33 = v_mov_b32 2
  %34 = slice %grid[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %35 = v_mov_b32 3
  %36 = v_mov_b32 255
  %37 = v_and_b32 %codes, %36
  %38 = v_cmp_eq_i32 %37, %31
  %39 = v_cndmask_b32 %29, %30, %38
  %40 = v_cmp_eq_i32 %37, %33
  %41 = v_cndmask_b32 %39, %32, %40
  %42 = v_cmp_eq_i32 %37, %35
  %43 = v_cndmask_b32 %41, %34, %42
  %44 = v_mov_b32 8
  %45 = v_lshrrev_b32 %44, %codes
  %46 = v_mov_b32 255
  %47 = v_and_b32 %45, %46
  %48 = v_cmp_eq_i32 %47, %31
  %49 = v_cndmask_b32 %29, %30, %48
  %50 = v_cmp_eq_i32 %47, %33
  %51 = v_cndmask_b32 %49, %32, %50
  %52 = v_cmp_eq_i32 %47, %35
  %53 = v_cndmask_b32 %51, %34, %52
  %54 = v_mov_b32 16
  %55 = v_lshrrev_b32 %54, %codes
  %56 = v_mov_b32 255
  %57 = v_and_b32 %55, %56
  %58 = v_cmp_eq_i32 %57, %31
  %59 = v_cndmask_b32 %29, %30, %58
  %60 = v_cmp_eq_i32 %57, %33
  %61 = v_cndmask_b32 %59, %32, %60
  %62 = v_cmp_eq_i32 %57, %35
  %63 = v_cndmask_b32 %61, %34, %62
  %64 = v_mov_b32 24
  %65 = v_lshrrev_b32 %64, %codes
  %66 = v_mov_b32 255
  %67 = v_and_b32 %65, %66
  %68 = v_cmp_eq_i32 %67, %31
  %69 = v_cndmask_b32 %29, %30, %68
  %70 = v_cmp_eq_i32 %67, %33
  %71 = v_cndmask_b32 %69, %32, %70
  %72 = v_cmp_eq_i32 %67, %35
  %73 = v_cndmask_b32 %71, %34, %72
  %decoded = concat(%43, %53, %63, %73) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  %75 = v_mov_b32 2
  %76 = v_lshlrev_b32 %75, %base
  %77 = slice %output_view[0] : reg<amdgpu.sgpr x4> -> reg<amdgpu.sgpr x2>
  global_store_b128 %76, %decoded, %77 {offset = 0}
  return
}

// ====
// RUN: emit source-low @f32_table_lookup_i32_codes output=low
target.profile @gfx11_table_target preset("amdgpu-gfx11")

func.def target(@gfx11_table_target) @f32_table_lookup_i32_codes(%codes: vector<2xi32>) -> (vector<2xf32>) {
  %g0 = scalar.constant 2.0 : f32
  %g1 = scalar.constant -3.0 : f32
  %g2 = scalar.constant 5.0 : f32
  %grid = vector.from_elements %g0, %g1, %g2 : vector<3xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<3xf32>, vector<2xi32> -> vector<2xf32>
  func.return %decoded : vector<2xf32>
}

// ----
low.func.def target(@gfx11_table_target) abi(hal_kernel) @f32_table_lookup_i32_codes(%codes: reg<amdgpu.vgpr x2>) -> (reg<amdgpu.vgpr x2>) asm<amdgpu.gfx11.core> {
  %g0 = v_mov_b32 1073741824
  %g1 = v_mov_b32 3225419776
  %g2 = v_mov_b32 1084227584
  %grid = concat(%g0, %g1, %g2) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x3>
  %13 = slice %grid[0] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %14 = slice %grid[1] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %15 = v_mov_b32 1
  %16 = slice %grid[2] : reg<amdgpu.vgpr x3> -> reg<amdgpu.vgpr>
  %17 = v_mov_b32 2
  %18 = slice %codes[0] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %19 = v_cmp_eq_i32 %18, %15
  %20 = v_cndmask_b32 %13, %14, %19
  %21 = v_cmp_eq_i32 %18, %17
  %22 = v_cndmask_b32 %20, %16, %21
  %23 = slice %codes[1] : reg<amdgpu.vgpr x2> -> reg<amdgpu.vgpr>
  %24 = v_cmp_eq_i32 %23, %15
  %25 = v_cndmask_b32 %13, %14, %24
  %26 = v_cmp_eq_i32 %23, %17
  %27 = v_cndmask_b32 %25, %16, %26
  %decoded = concat(%22, %27) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  return %decoded
}

// ====
// RUN: emit source-low @i16_table_lookup_rejected output=none
target.profile @gfx11_table_target preset("amdgpu-gfx11")

func.def target(@gfx11_table_target) @i16_table_lookup_rejected(%codes: vector<4xi16>) -> (vector<4xf32>) {
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant 0.0 : f32
  %g2 = scalar.constant 1.0 : f32
  %g3 = scalar.constant 2.0 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  // ERROR@+1: BACKEND/001 "AMDGPU vector.table.lookup currently requires"
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi16> -> vector<4xf32>
  func.return %decoded : vector<4xf32>
}
