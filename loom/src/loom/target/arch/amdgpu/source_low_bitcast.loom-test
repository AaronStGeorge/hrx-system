// RUN: emit source-low @i32_to_i8x4_bitcast output=low
target.profile @gfx11_bitcast_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitcast_target) @i32_to_i8x4_bitcast(%word: vector<1xi32>) -> (vector<4xi8>) {
  %bytes = vector.bitcast %word : vector<1xi32> to vector<4xi8>
  func.return %bytes : vector<4xi8>
}

// ----
low.func.def target(@gfx11_bitcast_target) abi(hal_kernel) @i32_to_i8x4_bitcast__low(%bytes: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) {
  low.return %bytes : reg<amdgpu.vgpr>
}

