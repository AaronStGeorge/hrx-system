load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_generated_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_HAL_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/hal:__pkg__"]

_AMDGPU_NATIVE_VISIBILITY = ["//loom/src/loom/target/emit/native/amdgpu:__pkg__"]

_AMDGPU_ROOT_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu:__pkg__"]

_AMDGPU_TARGET_ID_VISIBILITY = ["//loom/src/loom/target/arch/amdgpu/target_id:__pkg__"]

_AMDGPU_TOOLING_VISIBILITY = ["//loom/src/loom/tooling/target/amdgpu:__pkg__"]

loom_generated_cc_library(
    name = "ops",
    srcs = [
        "registry.c",
        "target.c",
    ],
    hdrs = [
        "ops.h",
        "registry.h",
        "target.h",
    ],
    args = ["--dialect=amdgpu"],
    generated_src_flags = [
        "--builders",
        "--tables",
    ],
    generated_srcs = [
        "builders.c",
        "tables.c",
    ],
    generator = "//loom/py/loom/gen/ops:c_tables_generator",
    visibility = (
        _AMDGPU_HAL_VISIBILITY +
        _AMDGPU_NATIVE_VISIBILITY +
        _AMDGPU_ROOT_VISIBILITY +
        _AMDGPU_TARGET_ID_VISIBILITY +
        _AMDGPU_TOOLING_VISIBILITY
    ),
    deps = [
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/target",
        "//loom/src/loom/target:types",
        "//loom/src/loom/target/arch/amdgpu:error_defs",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//loom/src/loom/target/arch/amdgpu/records:target_records",
        "//runtime/src/iree/base",
    ],
)
