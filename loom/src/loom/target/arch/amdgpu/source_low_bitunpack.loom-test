// ----
low.func.def target(@gfx11_bitunpack_target) abi(hal_kernel) @i32_to_s8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.gfx11.core> {
  %5 = v_mov_b32 24
  %6 = v_lshlrev_b32 %5, %packed
  %7 = v_mov_b32 24
  %8 = v_ashrrev_i32 %7, %6
  %9 = v_mov_b32 16
  %10 = v_lshlrev_b32 %9, %packed
  %11 = v_mov_b32 24
  %12 = v_ashrrev_i32 %11, %10
  %13 = v_mov_b32 8
  %14 = v_lshlrev_b32 %13, %packed
  %15 = v_mov_b32 24
  %16 = v_ashrrev_i32 %15, %14
  %17 = v_mov_b32 24
  %18 = v_ashrrev_i32 %17, %packed
  %unpacked = concat(%8, %12, %16, %18) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

