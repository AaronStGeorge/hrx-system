// RUN: emit source-low output=low
target.profile @gfx11_bitunpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitunpack_target) @i32_to_u8x4_bitunpack(%packed: vector<1xi32>) -> (vector<4xi32>) {
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi32>
  func.return %unpacked : vector<4xi32>
}

// ----
low.func.def target(@gfx11_bitunpack_target) abi(hal_kernel) @i32_to_u8x4_bitunpack(%packed: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr x4>) asm<amdgpu.gfx11.core> {
  %5 = v_mov_b32 255
  %6 = v_and_b32 %packed, %5
  %7 = v_mov_b32 8
  %8 = v_lshrrev_b32 %7, %packed
  %9 = v_and_b32 %8, %5
  %10 = v_mov_b32 16
  %11 = v_lshrrev_b32 %10, %packed
  %12 = v_and_b32 %11, %5
  %13 = v_mov_b32 24
  %14 = v_lshrrev_b32 %13, %packed
  %15 = v_and_b32 %14, %5
  %unpacked = concat(%6, %9, %12, %15) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  return %unpacked
}

