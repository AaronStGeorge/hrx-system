// ====
// RUN: emit source-low output=low
target.profile @gfx11_bitunpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitunpack_target) @q3_width_rejected(%packed: vector<3xi8>) -> (vector<8xi32>) {
  // ERROR@+1: BACKEND/001 "width must evenly partition a 32-bit backing register"
  %unpacked = vector.bitunpacks<3> %packed : vector<3xi8> -> vector<8xi32>
  func.return %unpacked : vector<8xi32>
}

// ====
// RUN: emit source-low output=low
target.profile @gfx11_bitunpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitunpack_target) @bitunpack_lane_count_rejected(%packed: vector<16xi8>) -> (vector<32xi32>) {
  // ERROR@+1: BACKEND/001 "requires one to eight unpacked result lanes"
  %unpacked = vector.bitunpacku<4> %packed : vector<16xi8> -> vector<32xi32>
  func.return %unpacked : vector<32xi32>
}

// ====
// RUN: emit source-low output=low
target.profile @gfx11_bitunpack_target preset("amdgpu-gfx11")

func.def target(@gfx11_bitunpack_target) @bitunpack_result_type_rejected(%packed: vector<1xi32>) -> (vector<4xi8>) {
  // ERROR@+1: BACKEND/001 "requires a static rank-1 i32 result vector"
  %unpacked = vector.bitunpacku<8> %packed : vector<1xi32> -> vector<4xi8>
  func.return %unpacked : vector<4xi8>
}
