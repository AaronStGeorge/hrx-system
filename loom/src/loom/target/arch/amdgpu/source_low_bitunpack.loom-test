  %24 = v_and_b32 %23, %5
  %25 = v_mov_b32 28
  %26 = v_lshrrev_b32 %25, %packed
  %27 = v_and_b32 %26, %5
  %unpacked = concat(%6, %9, %12, %15, %18, %21, %24, %27) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
