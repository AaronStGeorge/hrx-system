// REQUIRES: amdgpu-hal, amdgpu-hal-b128

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&8xi32=1,2,3,4,5,6,7,8 --binding=&8xi32=10,10,10,10,10,10,10,10 --binding=&8xi32=0 --expected_binding=8xi32=1,2,3,4,5,6,7,8 --expected_binding=8xi32=10,10,10,10,10,10,10,10 --expected_binding=8xi32=0,0,0,0,15,16,17,18

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<1x8xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<1x8xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1x8xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[%tid, 4] : view<1x8xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[%tid, 4] : view<1x8xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %sum, %output_view[%tid, 4] : vector<4xi32>, view<1x8xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&256xi32=1 --binding=&256xi32=5 --binding=&256xi32=0 --expected_binding=256xi32=1 --expected_binding=256xi32=5 --expected_binding=256xi32=6

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<64x4xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&256xi32=1 --binding=&256xi32=0 --expected_binding=256xi32=1 --expected_binding=256xi32=6

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  %bias = vector.constant 5 : vector<4xi32>
  %sum = vector.addi %loaded, %bias : vector<4xi32>
  vector.store %sum, %output_view[%tid, 0] : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=100,100,100,100 --binding=&4xi32=0 --expected_binding=4xi32=100,100,100,100 --expected_binding=4xi32=100,101,102,103

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %zero_offset = index.constant 0 : offset
  %input_view = buffer.view %input[%zero_offset] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %zero = scalar.constant 0 : i32
  %one = scalar.constant 1 : i32
  %lanes = vector.iota %zero step %one : vector<4xi32>
  %sum = vector.addi %loaded, %lanes : vector<4xi32>
  vector.store %sum, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.
