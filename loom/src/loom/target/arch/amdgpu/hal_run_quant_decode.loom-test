// REQUIRES: amdgpu-hal, amdgpu-hal-b128

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=4660,22136,255,1 --binding=&4xi32=0 --expected_binding=4xi32=4660,22136,255,1 --expected_binding=4xi32=64,128,240,16

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] : view<1x4xi32, #dense> -> vector<4xi32>
  %shift = vector.constant 4 : vector<4xi32>
  %low_nibble = vector.bitfield.extractu %loaded {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high_nibble = vector.bitfield.extractu %loaded {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %low_shifted = vector.shli %low_nibble, %shift : vector<4xi32>
  %swapped = vector.ori %low_shifted, %high_nibble : vector<4xi32>
  %signed_high = vector.bitfield.extracts %loaded {offset = 4, width = 4} : vector<4xi32> -> vector<4xi32>
  %mask = vector.constant 15 : vector<4xi32>
  %signed_nibble = vector.andi %signed_high, %mask : vector<4xi32>
  %result = vector.xori %swapped, %signed_nibble : vector<4xi32>
  vector.store %result, %output_view[%tid, 0] : vector<4xi32>, view<1x4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=0,15,8,4 --binding=&4xi32=0,1,2,3 --binding=&4xi32=0 --expected_binding=4xi32=0,15,8,4 --expected_binding=4xi32=0,1,2,3 --expected_binding=4xi32=-32,-1,8,20

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%low_buffer: buffer, %high_buffer: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %low_view = buffer.view %low_buffer[%zero] : buffer -> view<4xi32, #dense>
  %high_view = buffer.view %high_buffer[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %low_packed = vector.load %low_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %high_packed = vector.load %high_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %low4 = vector.bitfield.extractu %low_packed {offset = 0, width = 4} : vector<4xi32> -> vector<4xi32>
  %high2 = vector.bitfield.extractu %high_packed {offset = 0, width = 2} : vector<4xi32> -> vector<4xi32>
  %q6 = vector.bitfield.insert %high2 into %low4 {offset = 4, width = 2} : vector<4xi32>, vector<4xi32>
  %bias = vector.constant 32 : vector<4xi32>
  %signed_q6 = vector.subi %q6, %bias : vector<4xi32>
  vector.store %signed_q6, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=2,1,1 --binding=&8xi8=0,1,2,3,3,2,1,0 --binding=&8xf32=0 --expected_binding=8xi8=0,1,2,3,3,2,1,0 --expected_binding=8xf32=-1,-0.5,0.5,1.5,1.5,0.5,-0.5,-1

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%codes_buffer: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %four = index.constant 4 : index
  %base = index.mul %tid, %four : index
  %codes_view = buffer.view %codes_buffer[%zero] : buffer -> view<8xi8, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<8xf32, #dense>
  %codes = vector.load %codes_view[%base] : view<8xi8, #dense> -> vector<4xi8>
  %g0 = scalar.constant -1.0 : f32
  %g1 = scalar.constant -0.5 : f32
  %g2 = scalar.constant 0.5 : f32
  %g3 = scalar.constant 1.5 : f32
  %grid = vector.from_elements %g0, %g1, %g2, %g3 : vector<4xf32>
  %decoded = vector.table.lookup %grid[%codes] : vector<4xf32>, vector<4xi8> -> vector<4xf32>
  vector.store %decoded, %output_view[%base] : vector<4xf32>, view<8xf32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.
