// RUN: emit source-low @gfx12_cache_policy output=low
target.profile @gfx12_cache_policy_target preset("amdgpu-gfx12")

func.def target(@gfx12_cache_policy_target) @gfx12_cache_policy(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] {cache_scope = system, cache_temporal = bypass} : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[%tid, 0] {cache_scope = device, cache_temporal = non_temporal_writeback} : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ----
low.func.def target(@gfx12_cache_policy_target) abi(hal_kernel) @gfx12_cache_policy__low() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = low.resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %11 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %12 = low.op<amdgpu.v_lshlrev_b32>(%11, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %loaded = low.op<amdgpu.buffer_load_b128>(%input_view, %12, %13) {offset = 0, scope = 3, th = 3} : (reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr x4>
  %15 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %16 = low.op<amdgpu.v_lshlrev_b32>(%15, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %17 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  low.op<amdgpu.buffer_store_b128>(%loaded, %output_view, %16, %17) {offset = 0, scope = 2, th = 7} : (reg<amdgpu.vgpr x4>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>)
  low.return
}

// ====
// RUN: emit source-low @gfx950_non_temporal output=low
target.profile @gfx950_non_temporal_target preset("amdgpu-gfx950")

func.def target(@gfx950_non_temporal_target) @gfx950_non_temporal(%input: buffer, %output: buffer) {
  %tid = kernel.workitem.id<x> : index
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<64x4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<64x4xi32, #dense>
  %loaded = vector.load %input_view[%tid, 0] {cache_scope = device, cache_temporal = non_temporal} : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[%tid, 0] {cache_scope = device, cache_temporal = non_temporal} : vector<4xi32>, view<64x4xi32, #dense>
  func.return
}

// ----
low.func.def target(@gfx950_non_temporal_target) abi(hal_kernel) @gfx950_non_temporal__low() {
  %tid = low.live_in<amdgpu.workitem_id.x> : reg<amdgpu.vgpr>
  %input_view = low.resource<hal_buffer_resource> {index = 0, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %output_view = low.resource<hal_buffer_resource> {index = 1, semantic_type = hal.buffer, valid_byte_count = 1024} : reg<amdgpu.sgpr x4>
  %zero = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %11 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %12 = low.op<amdgpu.v_lshlrev_b32>(%11, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %13 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  %loaded = low.op<amdgpu.buffer_load_dwordx4>(%input_view, %12, %13) {nt = 1, offset = 0} : (reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.vgpr x4>
  %15 = low.const<amdgpu.v_mov_b32> {imm32 = 4} : reg<amdgpu.vgpr>
  %16 = low.op<amdgpu.v_lshlrev_b32>(%15, %tid) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  %17 = low.const<amdgpu.s_mov_b32> {imm32 = 0} : reg<amdgpu.sgpr>
  low.op<amdgpu.buffer_store_dwordx4>(%loaded, %output_view, %16, %17) {nt = 1, offset = 0} : (reg<amdgpu.vgpr x4>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>)
  low.return
}
