load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_generated_textual_header",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_TARGET_RECORDS_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu/records:target_records"

_AMDGPU_TARGET_RECORDS_VISIBILITY = [
    "//loom/src/loom/target/arch/amdgpu:__pkg__",
    "//loom/src/loom/target/arch/amdgpu/ops:__pkg__",
    "//loom/src/loom/target/emit/native/amdgpu:__pkg__",
    "//loom/src/loom/tooling/target/amdgpu:__pkg__",
]

loom_generated_textual_header(
    name = "target_records_tables_gen",
    generator = _AMDGPU_TARGET_RECORDS_GENERATOR,
    output = "target_records_tables.inl",
    output_flag = "--tables",
    visibility = _AMDGPU_TARGET_RECORDS_VISIBILITY,
)

loom_cc_library(
    name = "target_records",
    srcs = ["target_records.c"],
    hdrs = ["target_records.h"],
    textual_hdrs = [":target_records_tables.inl"],
    visibility = _AMDGPU_TARGET_RECORDS_VISIBILITY,
    deps = [
        "//loom/src/loom/target:types",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//runtime/src/iree/base",
    ],
)
