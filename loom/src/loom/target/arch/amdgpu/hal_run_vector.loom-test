// REQUIRES: amdgpu-hal, amdgpu-hal-b128

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=5,6,7,8 --binding=&4xi32=0 --expected_binding=4xi32=5,6,7,8 --expected_binding=4xi32=5,6,7,8

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&8xi32=10,11,12,13,14,15,16,17 --binding=&4xi32=0 --expected_binding=8xi32=10,11,12,13,14,15,16,17 --expected_binding=4xi32=14,15,16,17

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %input_base = index.constant 16 : offset
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%input_base] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  vector.store %loaded, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=1,2,3,4 --binding=&4xi32=5,6,7,8 --binding=&4xi32=0 --expected_binding=4xi32=1,2,3,4 --expected_binding=4xi32=5,6,7,8 --expected_binding=4xi32=6,8,10,12

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %sum = vector.addi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %sum, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=1,2,3,4 --binding=&1xi32=0 --expected_binding=4xi32=1,2,3,4 --expected_binding=1xi32=10

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %init = scalar.constant 0 : i32
  %sum = vector.reduce<addi> %loaded, %init : vector<4xi32>, i32
  %stored = vector.from_elements %sum : vector<1xi32>
  vector.store %stored, %output_view[0] : vector<1xi32>, view<1xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=1,2,3,4 --binding=&4xi32=0 --expected_binding=4xi32=1,2,3,4 --expected_binding=4xi32=8,1,6,4

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %loaded = vector.load %input_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %lane0_input = vector.extract %loaded[0] : vector<4xi32> -> i32
  %lane1_input = vector.extract %loaded[1] : vector<4xi32> -> i32
  %lane2_input = vector.extract %loaded[2] : vector<4xi32> -> i32
  %lane3 = vector.extract %loaded[3] : vector<4xi32> -> i32
  %seven = scalar.constant 7 : i32
  %one = scalar.constant 1 : i32
  %two = scalar.constant 2 : i32
  %lane0 = scalar.addi %lane0_input, %seven : i32
  %lane1 = scalar.subi %lane1_input, %one : i32
  %lane2 = scalar.muli %lane2_input, %two : i32
  %result = vector.from_elements %lane0, %lane1, %lane2, %lane3 : vector<4xi32>
  vector.store %result, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=0,5,10,15 --binding=&4xi32=3,5,7,20 --binding=&4xi32=0 --expected_binding=4xi32=0,5,10,15 --expected_binding=4xi32=3,5,7,20 --expected_binding=4xi32=0,5,7,15

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %mask = vector.cmpi slt, %lhs_loaded, %rhs_loaded : vector<4xi32> -> vector<4xi1>
  %selected = vector.select %mask, %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %selected, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xf32=-1,0,2,5 --binding=&4xf32=0 --expected_binding=4xf32=-1,0,2,5 --expected_binding=4xf32=0,0,2,5

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%input: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xf32, #dense>
  %loaded = vector.load %input_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %zeroes = vector.constant 0.0 : vector<4xf32>
  %mask = vector.cmpf ogt, %loaded, %zeroes : vector<4xf32> -> vector<4xi1>
  %selected = vector.select %mask, %loaded, %zeroes : vector<4xf32>
  vector.store %selected, %output_view[0] : vector<4xf32>, view<4xf32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xf32=1,2,3,4 --binding=&4xf32=5,6,7,8 --binding=&4xf32=0 --expected_binding=4xf32=1,2,3,4 --expected_binding=4xf32=5,6,7,8 --expected_binding=4xf32=35,60,91,128

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<4xf32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xf32, #dense>
  %lhs_loaded = vector.load %lhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %rhs_loaded = vector.load %rhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %sum = vector.addf %lhs_loaded, %rhs_loaded : vector<4xf32>
  %product = vector.mulf %sum, %rhs_loaded : vector<4xf32>
  %fma = vector.fmaf %lhs_loaded, %rhs_loaded, %product : vector<4xf32>
  %bias = vector.constant 0.5 : vector<4xf32>
  %biased = vector.addf %fma, %bias : vector<4xf32>
  %adjusted = vector.subf %biased, %bias : vector<4xf32>
  vector.store %adjusted, %output_view[0] : vector<4xf32>, view<4xf32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xf32=1,2,3,4 --binding=&4xf32=5,6,7,8 --binding=&4xf32=0 --expected_binding=4xf32=1,2,3,4 --expected_binding=4xf32=5,6,7,8 --expected_binding=4xf32=6,12,-4,32.5

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<4xf32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<4xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xf32, #dense>
  %lhs_loaded = vector.load %lhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %rhs_loaded = vector.load %rhs_view[0] : view<4xf32, #dense> -> vector<4xf32>
  %lhs0 = vector.extract %lhs_loaded[0] : vector<4xf32> -> f32
  %rhs0 = vector.extract %rhs_loaded[0] : vector<4xf32> -> f32
  %lane0 = scalar.addf %lhs0, %rhs0 : f32
  %lhs1 = vector.extract %lhs_loaded[1] : vector<4xf32> -> f32
  %rhs1 = vector.extract %rhs_loaded[1] : vector<4xf32> -> f32
  %lane1 = scalar.mulf %lhs1, %rhs1 : f32
  %lhs2 = vector.extract %lhs_loaded[2] : vector<4xf32> -> f32
  %rhs2 = vector.extract %rhs_loaded[2] : vector<4xf32> -> f32
  %lane2 = scalar.subf %lhs2, %rhs2 : f32
  %lhs3 = vector.extract %lhs_loaded[3] : vector<4xf32> -> f32
  %rhs3 = vector.extract %rhs_loaded[3] : vector<4xf32> -> f32
  %bias = scalar.constant 0.5 : f32
  %lane3 = scalar.fmaf %lhs3, %rhs3, %bias : f32
  %result = vector.from_elements %lane0, %lane1, %lane2, %lane3 : vector<4xf32>
  vector.store %result, %output_view[0] : vector<4xf32>, view<4xf32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=1,1,1 --binding=&4xi32=20,21,22,23 --binding=&4xi32=3,4,5,6 --binding=&4xi32=0 --expected_binding=4xi32=20,21,22,23 --expected_binding=4xi32=3,4,5,6 --expected_binding=4xi32=17,17,17,17

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs: buffer, %rhs: buffer, %output: buffer) {
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs[%zero] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs[%zero] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<4xi32, #dense>
  %lhs_loaded = vector.load %lhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %rhs_loaded = vector.load %rhs_view[0] : view<4xi32, #dense> -> vector<4xi32>
  %diff = vector.subi %lhs_loaded, %rhs_loaded : vector<4xi32>
  vector.store %diff, %output_view[0] : vector<4xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=2,2,1 --binding=&4xi32=1,2,3,4 --binding=&4xi32=5,6,7,8 --binding=&4xi32=0 --expected_binding=4xi32=1,2,3,4 --expected_binding=4xi32=5,6,7,8 --expected_binding=4xi32=19,22,43,50

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs_buffer: buffer, %rhs_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero_offset = index.constant 0 : offset
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  %k = index.constant 2 : index
  %lhs_base = index.madd %y, %k, %zero : index
  %lhs_next = index.add %lhs_base, %one : index
  %rhs_base = index.add %x, %zero : index
  %rhs_next = index.add %x, %k : index
  %output_index = index.madd %y, %k, %x : index
  %lhs_view = buffer.view %lhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %rhs_view = buffer.view %rhs_buffer[%zero_offset] : buffer -> view<4xi32, #dense>
  %output_view = buffer.view %output[%zero_offset] : buffer -> view<4xi32, #dense>
  %lhs0 = vector.load %lhs_view[%lhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %rhs0 = vector.load %rhs_view[%rhs_base] : view<4xi32, #dense> -> vector<1xi32>
  %prod0 = vector.muli %lhs0, %rhs0 : vector<1xi32>
  %lhs1 = vector.load %lhs_view[%lhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %rhs1 = vector.load %rhs_view[%rhs_next] : view<4xi32, #dense> -> vector<1xi32>
  %prod1 = vector.muli %lhs1, %rhs1 : vector<1xi32>
  %sum = vector.addi %prod0, %prod1 : vector<1xi32>
  vector.store %sum, %output_view[%output_index] : vector<1xi32>, view<4xi32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.

// ====
// RUN: run --loom_backend=amdgpu-hal --workgroup_count=2,2,1 --binding=&4xf32=1,2,3,4 --binding=&4xf32=5,7,6,8 --binding=&4xf32=0 --expected_binding=4xf32=1,2,3,4 --expected_binding=4xf32=5,7,6,8 --expected_binding=4xf32=19,22,43,50

target.profile @gfx_target preset("amdgpu-current")

func.def target(@gfx_target) @loom_kernel(%lhs_buffer: buffer, %rhs_t_buffer: buffer, %output: buffer) {
  %x = kernel.workitem.id<x> : index
  %y = kernel.workitem.id<y> : index
  %zero = index.constant 0 : offset
  %lhs_view = buffer.view %lhs_buffer[%zero] : buffer -> view<2x2xf32, #dense>
  %rhs_t_view = buffer.view %rhs_t_buffer[%zero] : buffer -> view<2x2xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<2x2xf32, #dense>
  %lhs = vector.load %lhs_view[%y, 0] : view<2x2xf32, #dense> -> vector<2xf32>
  %rhs = vector.load %rhs_t_view[%x, 0] : view<2x2xf32, #dense> -> vector<2xf32>
  %acc = scalar.constant 0.0 : f32
  %dot = vector.dotf %lhs, %rhs, %acc : vector<2xf32>, vector<2xf32>, f32
  %stored = vector.from_elements %dot : vector<1xf32>
  vector.store %stored, %output_view[%y, %x] : vector<1xf32>, view<2x2xf32, #dense>
  func.return
}
// ----
[SUCCESS] all HAL bindings matched their expected values.
