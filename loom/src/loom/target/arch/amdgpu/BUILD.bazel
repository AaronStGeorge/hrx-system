#===------------------------------------------------------------------------===#
# AMDGPU low descriptors
#===------------------------------------------------------------------------===#

_AMDGPU_DESCRIPTOR_GENERATOR = "//loom/py/loom:amdgpu_descriptors"

_AMDGPU_DESCRIPTOR_GENERATOR_SCRIPT = "//loom/py/loom:gen/amdgpu_descriptors.py"

_AMDGPU_DESCRIPTOR_GENERATOR_DEPS = [
    "//loom/py/loom:gen/low_descriptors.py",
    "//loom/py/loom:target/arch/amdgpu/descriptor_overlay.py",
    "//loom/py/loom:target/arch/amdgpu/descriptors.py",
    "//loom/py/loom:target/arch/amdgpu/isa_xml.py",
    "//loom/py/loom:target/low_descriptors.py",
]

loom_low_descriptor_data_archive(
    name = "amdgpu_isa_xml",
    repo_name = AMDGPU_ISA_XML_ARCHIVE["repo_name"],
    sha256 = AMDGPU_ISA_XML_ARCHIVE["sha256"],
    urls = AMDGPU_ISA_XML_ARCHIVE["urls"],
)

loom_low_descriptor_cc_library(
    name = "gfx11_descriptors",
    args = [
        "--target=gfx11",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_rdna3.xml)",
    ],
    cmake_generator = _AMDGPU_DESCRIPTOR_GENERATOR_SCRIPT,
    cmake_generator_deps = _AMDGPU_DESCRIPTOR_GENERATOR_DEPS,
    exclude_from_cmake_all = True,
    generator = _AMDGPU_DESCRIPTOR_GENERATOR,
    header = "gfx11_descriptors.h",
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_rdna3.xml"],
    source = "gfx11_descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

