# AMDGPU low descriptors
#===------------------------------------------------------------------------===#

_AMDGPU_DESCRIPTOR_GENERATOR = "//loom/py/loom:amdgpu_descriptors"

iree_genrule(
    name = "gfx11_descriptors_gen",
    srcs = [
        "@amdgpu_isa_xml//:amdgpu_isa_rdna3.xml",
    ],
    outs = [
        "gfx11_descriptors.c",
        "gfx11_descriptors.h",
    ],
    cmd = " ".join([
        "$(location %s)" % _AMDGPU_DESCRIPTOR_GENERATOR,
        "--target=gfx11",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_rdna3.xml)",
        "--source=$(execpath gfx11_descriptors.c)",
        "--header=$(execpath gfx11_descriptors.h)",
    ]),
    tags = ["skip-bazel_to_cmake"],
    tools = [_AMDGPU_DESCRIPTOR_GENERATOR],
)

