load(
    "//loom/build_tools/amdgpu:descriptor_sets.bzl",
    "loom_amdgpu_descriptor_set_compatible_with",
    "loom_amdgpu_encoding_table_deps",
    "loom_amdgpu_selected_descriptor_set_defines",
)
load(
    "//loom/build_tools/amdgpu:target_config.bzl",
    "LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY",
)
load("//loom/build_tools/amdgpu/isa_xml:archive.bzl", "AMDGPU_ISA_XML_ARCHIVE")
load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
    "loom_generated_textual_header",
    "loom_low_descriptor_data_archive",
    "loom_target_table_cc_library",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_AMDGPU_ENCODING_TABLE_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu/encoding:encoding_tables"

_AMDGPU_CONFIG_TABLES_GENERATOR = "//loom/py/loom/gen/target/arch/amdgpu:config_tables"

_DESCRIPTOR_SET_CDNA3 = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.cdna3.core"]

_DESCRIPTOR_SET_CDNA4 = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.cdna4.core"]

_DESCRIPTOR_SET_RDNA3 = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.rdna3.core"]

_DESCRIPTOR_SET_RDNA4 = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.rdna4.core"]

_DESCRIPTOR_SET_RDNA4_GFX125X = LOOM_AMDGPU_DESCRIPTOR_SET_CAPABILITY_BY_KEY["amdgpu.rdna4.gfx125x.core"]

_AMDGPU_ENCODING_VISIBILITY = [
    "//loom/src/loom/target/arch/amdgpu/planning:__pkg__",
    "//loom/src/loom/target/emit/native/amdgpu:__pkg__",
]

loom_low_descriptor_data_archive(
    name = "amdgpu_isa_xml",
    repo_name = AMDGPU_ISA_XML_ARCHIVE["repo_name"],
    sha256 = AMDGPU_ISA_XML_ARCHIVE["sha256"],
    urls = AMDGPU_ISA_XML_ARCHIVE["urls"],
)

loom_generated_textual_header(
    name = "encoding_field_ids_gen",
    generator = _AMDGPU_CONFIG_TABLES_GENERATOR,
    output = "encoding_field_ids.h",
    output_flag = "--encoding-field-ids-header",
)

loom_cc_library(
    name = "encoding_defs",
    hdrs = [
        "encoding.h",
        ":encoding_field_ids.h",
    ],
    deps = ["//runtime/src/iree/base"],
)

loom_target_table_cc_library(
    name = "cdna3_encoding_tables",
    args = [
        "--target=cdna3",
        "--descriptor-set-key=amdgpu.cdna3.core",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_cdna3.xml)",
        "--public-header=loom/target/arch/amdgpu/encoding/cdna3_encoding_tables.h",
    ],
    exclude_from_cmake_all = True,
    generator = _AMDGPU_ENCODING_TABLE_GENERATOR,
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_cdna3.xml"],
    target_compatible_with = loom_amdgpu_descriptor_set_compatible_with(_DESCRIPTOR_SET_CDNA3),
    deps = [
        ":encoding_defs",
        "//runtime/src/iree/base",
    ],
)

loom_target_table_cc_library(
    name = "rdna3_encoding_tables",
    args = [
        "--target=rdna3",
        "--descriptor-set-key=amdgpu.rdna3.core",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_rdna3.xml)",
        "--public-header=loom/target/arch/amdgpu/encoding/rdna3_encoding_tables.h",
    ],
    exclude_from_cmake_all = True,
    generator = _AMDGPU_ENCODING_TABLE_GENERATOR,
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_rdna3.xml"],
    target_compatible_with = loom_amdgpu_descriptor_set_compatible_with(_DESCRIPTOR_SET_RDNA3),
    deps = [
        ":encoding_defs",
        "//runtime/src/iree/base",
    ],
)

loom_target_table_cc_library(
    name = "rdna4_encoding_tables",
    args = [
        "--target=rdna4",
        "--descriptor-set-key=amdgpu.rdna4.core",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_rdna4.xml)",
        "--public-header=loom/target/arch/amdgpu/encoding/rdna4_encoding_tables.h",
    ],
    exclude_from_cmake_all = True,
    generator = _AMDGPU_ENCODING_TABLE_GENERATOR,
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_rdna4.xml"],
    target_compatible_with = loom_amdgpu_descriptor_set_compatible_with(_DESCRIPTOR_SET_RDNA4),
    deps = [
        ":encoding_defs",
        "//runtime/src/iree/base",
    ],
)

loom_target_table_cc_library(
    name = "rdna4_gfx125x_encoding_tables",
    args = [
        "--target=rdna4_gfx125x",
        "--descriptor-set-key=amdgpu.rdna4.gfx125x.core",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_rdna4.xml)",
        "--public-header=loom/target/arch/amdgpu/encoding/rdna4_gfx125x_encoding_tables.h",
    ],
    exclude_from_cmake_all = True,
    generator = _AMDGPU_ENCODING_TABLE_GENERATOR,
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_rdna4.xml"],
    target_compatible_with = loom_amdgpu_descriptor_set_compatible_with(_DESCRIPTOR_SET_RDNA4_GFX125X),
    deps = [
        ":encoding_defs",
        "//runtime/src/iree/base",
    ],
)

loom_target_table_cc_library(
    name = "cdna4_encoding_tables",
    args = [
        "--target=cdna4",
        "--descriptor-set-key=amdgpu.cdna4.core",
        "--xml=$(rootpath @amdgpu_isa_xml//:amdgpu_isa_cdna4.xml)",
        "--public-header=loom/target/arch/amdgpu/encoding/cdna4_encoding_tables.h",
    ],
    exclude_from_cmake_all = True,
    generator = _AMDGPU_ENCODING_TABLE_GENERATOR,
    inputs = ["@amdgpu_isa_xml//:amdgpu_isa_cdna4.xml"],
    target_compatible_with = loom_amdgpu_descriptor_set_compatible_with(_DESCRIPTOR_SET_CDNA4),
    deps = [
        ":encoding_defs",
        "//runtime/src/iree/base",
    ],
)

loom_generated_textual_header(
    name = "encoding_tables_gen",
    generator = _AMDGPU_CONFIG_TABLES_GENERATOR,
    output = "encoding_tables.inl",
    output_flag = "--encoding-tables",
    visibility = _AMDGPU_ENCODING_VISIBILITY,
)

loom_cc_library(
    name = "encoding",
    srcs = ["encoding.c"],
    hdrs = ["encoding.h"],
    defines = loom_amdgpu_selected_descriptor_set_defines(),
    textual_hdrs = [":encoding_tables.inl"],
    visibility = _AMDGPU_ENCODING_VISIBILITY,
    deps = loom_amdgpu_encoding_table_deps() + [
        ":encoding_defs",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "encoding_test",
    srcs = ["encoding_test.cc"],
    deps = [
        ":encoding",
        "//loom/src/loom/target/arch/amdgpu:target_info",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
