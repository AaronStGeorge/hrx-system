// RUN: emit source-low @scalar_i32_uniform_sgpr output=low
target.profile @gfx11_scalar_i32_target preset("amdgpu-gfx11")

func.def target(@gfx11_scalar_i32_target) @scalar_i32_uniform_sgpr(%lhs: i32, %rhs: i32, %shift: i32) -> (i32) {
  %add = scalar.addi %lhs, %rhs : i32
  %sub = scalar.subi %add, %rhs : i32
  %and = scalar.andi %sub, %lhs : i32
  %or = scalar.ori %and, %rhs : i32
  %xor = scalar.xori %or, %lhs : i32
  %shl = scalar.shli %xor, %shift : i32
  %ashr = scalar.shrsi %shl, %shift : i32
  %lshr = scalar.shrui %ashr, %shift : i32
  func.return %lshr : i32
}

// ----
low.func.def target(@gfx11_scalar_i32_target) abi(hal_kernel) @scalar_i32_uniform_sgpr__low(%lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>, %shift: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.gfx11.core> {
  %add = s_add_u32 %lhs, %rhs
  %sub = s_sub_u32 %add, %rhs
  %and = s_and_b32 %sub, %lhs
  %or = s_or_b32 %and, %rhs
  %xor = s_xor_b32 %or, %lhs
  %shl = s_lshl_b32 %xor, %shift
  %ashr = s_ashr_i32 %shl, %shift
  %lshr = s_lshr_b32 %ashr, %shift
  return %lshr
}
