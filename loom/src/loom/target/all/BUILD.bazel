load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_assert_no_dependencies",
    "loom_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

#===------------------------------------------------------------------------===#
# Layering checks
#===------------------------------------------------------------------------===#

loom_assert_no_dependencies(
    name = "core_tools_no_all_low_registry_dep",
    dependencies = [":low_registry"],
    targets = [
        "//loom/src/loom/tools/iree-run-loom",
        "//loom/src/loom/tools/iree-run-loom:main",
        "//loom/src/loom/tools/loom-check",
        "//loom/src/loom/tools/loom-check:execute",
        "//loom/src/loom/tools/loom-check:main",
        "//loom/src/loom/tools/loom-check:provider",
    ],
)

#===------------------------------------------------------------------------===#
# All-target convenience registry
#===------------------------------------------------------------------------===#

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    deps = [
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:low_legality",
        "//loom/src/loom/target:types",
        "//loom/src/loom/target/arch/amdgpu:cdna4_descriptors",
        "//loom/src/loom/target/arch/amdgpu:low_registry",
        "//loom/src/loom/target/arch/amdgpu:lower",
        "//loom/src/loom/target/arch/amdgpu:rdna3_descriptors",
        "//loom/src/loom/target/arch/amdgpu:rdna4_descriptors",
        "//loom/src/loom/target/arch/amdgpu:rdna4_gfx125x_descriptors",
        "//loom/src/loom/target/arch/wasm:descriptors",
        "//loom/src/loom/target/arch/wasm:low_registry",
        "//loom/src/loom/target/arch/x86:avx512_descriptors",
        "//loom/src/loom/target/arch/x86:low_registry",
        "//loom/src/loom/target/arch/x86:lower",
        "//loom/src/loom/target/arch/x86:packed_dot_descriptors",
        "//loom/src/loom/target/emit/ireevm:descriptors",
        "//loom/src/loom/target/emit/ireevm:low_registry",
        "//loom/src/loom/target/emit/ireevm:lower",
        "//loom/src/loom/target/emit/wasm:lower",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/threading",
    ],
)
