load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "llvmir",
    srcs = [
        "builder.c",
        "intrinsics.c",
        "module.c",
        "text_writer.c",
        "types.h",
        "verify.c",
    ],
    hdrs = [
        "builder.h",
        "intrinsics.h",
        "llvmir.h",
        "module.h",
        "text_writer.h",
        "verify.h",
    ],
    deps = [
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "test_modules",
    testonly = True,
    srcs = ["test_modules.c"],
    hdrs = ["test_modules.h"],
    deps = [
        ":llvmir",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "text_writer_test",
    srcs = ["text_writer_test.cc"],
    deps = [
        ":llvmir",
        ":test_modules",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
