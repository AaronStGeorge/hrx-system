// RUN: emit x86-asm @x86_fragment
target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %lhs : reg<x86.zmm>, %rhs : reg<x86.zmm>) asm<x86.avx512.core> {
  %loaded = vmovdqu32.load %base {disp32 = 0}
  %sum = vpaddd %loaded, %lhs
  vmovdqu32.store %sum, %base {disp32 = 64}
  return
}
// ----
.Lbb0:
  vmovdqu32 zmm1, [rax]
  vpaddd zmm0, zmm1, zmm0
  vmovdqu32 [rax + 64], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%input : reg<x86.gpr64>, %output : reg<x86.gpr64>, %i : reg<x86.gpr64>, %j : reg<x86.gpr64>) asm<x86.avx512.core> {
  %index = lea %i, %j
  %loaded = vmovdqu32.load.indexed %input, %index {disp32 = 16, scale = 4}
  vmovdqu32.store.indexed %loaded, %output, %index {disp32 = 32, scale = 4}
  return
}

// ----
.Lbb0:
  lea rax, [rax + rcx]
  vmovdqu32 zmm0, [rdx + rax * 4 + 16]
  vmovdqu32 [rbx + rax * 4 + 32], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %value : reg<x86.gpr32>, %rhs : reg<x86.zmm>) asm<x86.avx512.core> {
  %splat = vpbroadcastd %value
  %sum = vpaddd %splat, %rhs
  vmovdqu32.store %sum, %base {disp32 = 128}
  return
}

// ----
.Lbb0:
  vpbroadcastd zmm1, eax
  vpaddd zmm0, zmm1, zmm0
  vmovdqu32 [rcx + 128], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %value : reg<x86.xmm>, %rhs : reg<x86.zmm>) asm<x86.avx512.core> {
  %splat = vbroadcastss %value
  %sum = vaddps %splat, %rhs
  vmovdqu32.store %sum, %base {disp32 = 192}
  return
}

// ----
.Lbb0:
  vbroadcastss zmm0, xmm0
  vaddps zmm0, zmm0, zmm1
  vmovdqu32 [rax + 192], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %lhs : reg<x86.zmm>, %rhs : reg<x86.zmm>) asm<x86.avx512.core> {
  %min_s = vpminsd %lhs, %rhs
  %max_s = vpmaxsd %lhs, %rhs
  %min_u = vpminud %lhs, %rhs
  %max_u = vpmaxud %lhs, %rhs
  %mask = vpandd %min_s, %max_s
  %mixed = vpxord %mask, %min_u
  %logic = vpord %mixed, %max_u
  %left = vpsllvd %logic, %rhs
  %signed = vpsravd %left, %rhs
  %result = vpsrlvd %signed, %rhs
  vmovdqu32.store %result, %base {disp32 = 128}
  return
}

// ----
.Lbb0:
  vpminsd zmm2, zmm0, zmm1
  vpmaxsd zmm3, zmm0, zmm1
  vpminud zmm4, zmm0, zmm1
  vpmaxud zmm0, zmm0, zmm1
  vpandd zmm2, zmm2, zmm3
  vpxord zmm2, zmm2, zmm4
  vpord zmm0, zmm2, zmm0
  vpsllvd zmm0, zmm0, zmm1
  vpsravd zmm0, zmm0, zmm1
  vpsrlvd zmm0, zmm0, zmm1
  vmovdqu32 [rax + 128], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %lhs : reg<x86.zmm>, %rhs : reg<x86.zmm>, %fallback : reg<x86.zmm>) asm<x86.avx512.core> {
  %signed = vpcmpd.sgt %lhs, %rhs
  %unsigned = vpcmpud.ugt %lhs, %rhs
  %ordered_lt = vcmpps.olt %lhs, %rhs
  %integer_selected = vpblendmd %signed, %lhs, %rhs
  %mixed_integer = vpblendmd %unsigned, %integer_selected, %fallback
  %float_selected = vblendmps %ordered_lt, %lhs, %mixed_integer
  vmovdqu32.store %float_selected, %base {disp32 = 192}
  return
}

// ----
.Lbb0:
  vpcmpd.sgt k0, zmm2, zmm0
  vpcmpud.ugt k1, zmm2, zmm0
  vcmpps.olt k2, zmm2, zmm0
  vpblendmd zmm0, k0, zmm2, zmm0
  vpblendmd zmm0, k1, zmm0, zmm1
  vblendmps zmm0, k2, zmm2, zmm0
  vmovdqu32 [rax + 192], zmm0
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %lhs : reg<x86.zmm>, %rhs : reg<x86.zmm>) {
  %greater = low.op<x86.avx512.vpcmpd.sgt.zmm>(%lhs, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.k>
  %less = low.op<x86.avx512.vpcmpd.slt.zmm>(%lhs, %rhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.k>
  %condition = low.op<x86.avx512.kandq>(%greater, %less) : (reg<x86.k>, reg<x86.k>) -> reg<x86.k>
  low.cond_br %condition, ^then, ^else : reg<x86.k>
^then:
  low.op<x86.avx512.vmovdqu32.store.zmm>(%lhs, %base) {disp32 = 0} : (reg<x86.zmm>, reg<x86.gpr64>)
  low.return
^else:
  low.op<x86.avx512.vmovdqu32.store.zmm>(%rhs, %base) {disp32 = 64} : (reg<x86.zmm>, reg<x86.gpr64>)
  low.return
}

// ----
.Lbb0:
  vpcmpd.sgt k0, zmm0, zmm1
  vpcmpd.slt k1, zmm0, zmm1
  kandq k0, k0, k1
  kortestq k0, k0
  jnz .Lbb1
  jmp .Lbb2
.Lbb1:
  vmovdqu32 [rax], zmm0
  ret
.Lbb2:
  vmovdqu32 [rax + 64], zmm1
  ret

// ====

target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%input : reg<x86.gpr64>, %output : reg<x86.gpr64>, %row : reg<x86.gpr64>, %stride : reg<x86.gpr64>, %col : reg<x86.gpr64>) asm<x86.avx512.core> {
  %bias = mov.imm64 256
  %row_copy = copy %row : reg<x86.gpr64> -> reg<x86.gpr64>
  %linear = imul %row_copy, %stride
  %index = lea %linear, %col
  %biased_index = lea %index, %bias
  %loaded = vmovdqu32.load.indexed %input, %biased_index {disp32 = 0, scale = 4}
  vmovdqu32.store.indexed %loaded, %output, %biased_index {disp32 = 64, scale = 4}
  return
}

// ----
.Lbb0:
  mov rbp, 256
  imul rax, rcx
  lea rax, [rax + rdx]
  lea rax, [rax + rbp]
  vmovdqu32 zmm0, [rbx + rax * 4]
  vmovdqu32 [rsp + rax * 4 + 64], zmm0
  ret
