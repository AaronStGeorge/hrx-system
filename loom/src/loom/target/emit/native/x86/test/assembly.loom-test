// RUN: emit x86-asm-mnemonics @x86_fragment
target.profile @x86_target preset("x86-avx512")

low.func.def target(@x86_target) @x86_fragment(%base : reg<x86.gpr64>, %lhs : reg<x86.zmm>, %rhs : reg<x86.zmm>) {
  %loaded = low.op<x86.avx512.vmovdqu32.load.zmm>(%base) {disp32 = 0} : (reg<x86.gpr64>) -> reg<x86.zmm>
  %sum = low.op<x86.avx512.vpaddd.zmm>(%loaded, %lhs) : (reg<x86.zmm>, reg<x86.zmm>) -> reg<x86.zmm>
  low.op<x86.avx512.vmovdqu32.store.zmm>(%sum, %base) {disp32 = 64} : (reg<x86.zmm>, reg<x86.gpr64>)
  low.return
}
// ----
vmovdqu32
vpaddd
vmovdqu32
ret
