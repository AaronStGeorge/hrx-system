  %a6 = global_load_b32_saddr %activation_address, %activation_view {offset = 24}
  %a7 = global_load_b32_saddr %activation_address, %activation_view {offset = 28}
  %activation = concat(%a0, %a1, %a2, %a3, %a4, %a5, %a6, %a7) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  %w0 = global_load_b32_saddr %activation_address, %weight_view {offset = 0}
  %w1 = global_load_b32_saddr %activation_address, %weight_view {offset = 4}
  %w2 = global_load_b32_saddr %activation_address, %weight_view {offset = 8}
  %w3 = global_load_b32_saddr %activation_address, %weight_view {offset = 12}
  %w4 = global_load_b32_saddr %activation_address, %weight_view {offset = 16}
  %w5 = global_load_b32_saddr %activation_address, %weight_view {offset = 20}
  %w6 = global_load_b32_saddr %activation_address, %weight_view {offset = 24}
  %w7 = global_load_b32_saddr %activation_address, %weight_view {offset = 28}
  %weight = concat(%w0, %w1, %w2, %w3, %w4, %w5, %w6, %w7) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  %b0 = global_load_b32_saddr %bias_address, %bias_view {offset = 0}
  %b1 = global_load_b32_saddr %bias_address, %bias_view {offset = 128}
  %b2 = global_load_b32_saddr %bias_address, %bias_view {offset = 256}
  %b3 = global_load_b32_saddr %bias_address, %bias_view {offset = 384}
  %b4 = global_load_b32_saddr %bias_address, %bias_view {offset = 512}
  %b5 = global_load_b32_saddr %bias_address, %bias_view {offset = 640}
  %b6 = global_load_b32_saddr %bias_address, %bias_view {offset = 768}
  %b7 = global_load_b32_saddr %bias_address, %bias_view {offset = 896}
  %bias = concat(%b0, %b1, %b2, %b3, %b4, %b5, %b6, %b7) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x8>
  %accumulator = v_wmma_f32_16x16x16_f16 %activation, %weight, %bias
  %out0 = slice %accumulator[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32_saddr %bias_address, %out0, %output_view {offset = 0}
