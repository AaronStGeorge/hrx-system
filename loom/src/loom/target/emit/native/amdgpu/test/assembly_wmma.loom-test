// RUN: emit amdgpu-assembly @gfx1250_wmma_supplemental waits=none
amdgpu.target<gfx1250> @gfx1250_target
low.func.def target(@gfx1250_target) @gfx1250_wmma_supplemental(%a8: reg<amdgpu.vgpr x8>, %a16: reg<amdgpu.vgpr x16>, %b8: reg<amdgpu.vgpr x8>, %b16: reg<amdgpu.vgpr x16>, %scale0: reg<amdgpu.vgpr>, %scale1: reg<amdgpu.vgpr>, %index: reg<amdgpu.vgpr>, %acc: reg<amdgpu.vgpr x8>, %addr: reg<amdgpu.vgpr>, %output_view: reg<amdgpu.sgpr x2>) asm<amdgpu.rdna4.gfx125x.core> {
  %wmma32 = v_wmma_f32_16x16x32_f16 %a8, %b8, %acc
  %scale = v_wmma_scale_f32_16x16x128_f8f6f4_f8_f8 %a16, %b16, %wmma32, %scale0, %scale1 {matrix_a_fmt = 1, matrix_b_fmt = 2, matrix_a_scale = 1, matrix_b_scale = 1, matrix_a_scale_fmt = 0, matrix_b_scale_fmt = 0, matrix_a_reuse = 0, matrix_b_reuse = 0}
  %swmmac = v_swmmac_f32_16x16x64_f16 %scale, %a8, %b16, %index {index_key_16bit = 1, matrix_a_reuse = 0, matrix_b_reuse = 1}
  %out0 = slice %swmmac[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr>
  global_store_b32_saddr %addr, %out0, %output_view {offset = 0}
  return
}

