// RUN: emit amdgpu-wait-counter-plan-json @gfx11_cross_block_wait strategy=source
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_cross_block_wait(%resource: reg<amdgpu.sgpr x4>, %vaddr: reg<amdgpu.vgpr>, %soffset: reg<amdgpu.sgpr>, %lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %loaded = buffer_load_dword %resource, %vaddr, %soffset
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^store, ^exit : reg<amdgpu.scc>
^store:
  buffer_store_dword %loaded, %resource, %vaddr, %soffset {offset = 4}
  return
^exit:
  return
}

