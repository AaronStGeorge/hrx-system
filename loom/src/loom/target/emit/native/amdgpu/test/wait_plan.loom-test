// RUN: emit amdgpu-wait-counter-plan-json @gfx11_same_block_partial_vmem_wait strategy=source
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_same_block_partial_vmem_wait(%resource: reg<amdgpu.sgpr x4>, %vaddr0: reg<amdgpu.vgpr>, %vaddr1: reg<amdgpu.vgpr>, %vaddr2: reg<amdgpu.vgpr>, %soffset: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %oldest = buffer_load_dword %resource, %vaddr0, %soffset
  %middle = buffer_load_dword %resource, %vaddr1, %soffset {offset = 4}
  %youngest = buffer_load_dword %resource, %vaddr2, %soffset {offset = 8}
  %oldest_sum = v_add_u32 %oldest, %vaddr0
  %middle_sum = v_add_u32 %middle, %oldest_sum
  %youngest_sum = v_add_u32 %youngest, %middle_sum
  buffer_store_dword %youngest_sum, %resource, %vaddr0, %soffset {offset = 12}
  return
}

