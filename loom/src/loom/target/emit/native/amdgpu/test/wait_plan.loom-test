// RUN: emit amdgpu-wait-counter-plan-json @gfx11_block_entry_wait_preserves_later_load strategy=source
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_block_entry_wait_preserves_later_load(%resource: reg<amdgpu.sgpr x4>, %vaddr0: reg<amdgpu.vgpr>, %vaddr1: reg<amdgpu.vgpr>, %soffset: reg<amdgpu.sgpr>, %lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %older = buffer_load_dword %resource, %vaddr0, %soffset
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^body, ^exit : reg<amdgpu.scc>
^body:
  %older_sum = v_add_u32 %older, %vaddr0
  %later = buffer_load_dword %resource, %vaddr1, %soffset {offset = 4}
  low.br ^join
^join:
  %later_sum = v_add_u32 %later, %older_sum
  buffer_store_dword %later_sum, %resource, %vaddr1, %soffset {offset = 8}
  return
^exit:
  return
}

