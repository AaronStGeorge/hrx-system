// RUN: emit amdgpu-wait-counter-plan-json @gfx11_smem_result_wait strategy=source
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_smem_result_wait(%kernarg: reg<amdgpu.sgpr x2>, %soffset: reg<amdgpu.sgpr>, %lhs: reg<amdgpu.sgpr>) -> (reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %loaded = s_load_dword %kernarg, %soffset
  %sum = s_add_u32 %loaded, %lhs
  return %sum
}

