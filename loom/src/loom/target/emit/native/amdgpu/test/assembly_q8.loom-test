// RUN: emit amdgpu-assembly @gfx11_q8_native strategy=source

amdgpu.target<gfx1100> @target
low.func.def target(@target) @gfx11_q8_native(%lane: reg<amdgpu.vgpr>, %weights_view: reg<amdgpu.sgpr x2>, %rhs_view: reg<amdgpu.sgpr x2>, %output_view: reg<amdgpu.sgpr x2>) asm<amdgpu.rdna3.core> {
  %scale_index = v_lshrrev_b32_lit %lane, 3
  %q_byte_offset = v_lshlrev_b32_src0_inline %lane, 2
  %packed = global_load_b32_saddr %q_byte_offset, %weights_view
  %scale_byte_offset = v_lshlrev_b32_src0_inline %scale_index, 1
  %scale = global_load_d16_b16_saddr %scale_byte_offset, %weights_view
  %rhs_byte_offset = v_lshlrev_b32_src0_inline %lane, 4
  %rhs = global_load_b128_saddr %rhs_byte_offset, %rhs_view
  %q0_i32 = v_bfe_i32_offset_width_inline %packed {offset = 0, width = 8}
  %q1_i32 = v_bfe_i32_offset_width_inline %packed {offset = 8, width = 8}
  %q2_i32 = v_bfe_i32_offset_width_inline %packed {offset = 16, width = 8}
  %q3_i32 = v_ashrrev_i32_src0_inline %packed, 24
  %q0_f32 = v_cvt_f32_i32 %q0_i32
  %q1_f32 = v_cvt_f32_i32 %q1_i32
  %q2_f32 = v_cvt_f32_i32 %q2_i32
  %q3_f32 = v_cvt_f32_i32 %q3_i32
  %scaled0 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %q0_f32, 0
  %scaled1 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %q1_f32, 0
  %scaled2 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %q2_f32, 0
  %scaled3 = v_fma_mix_f32_f16lo_f32_f32_src2_lit %scale, %q3_f32, 0
  %acc = v_mov_b32 0
  %rhs0 = slice %rhs[0] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot0 = v_fmac_f32 %acc, %scaled0, %rhs0
  %rhs1 = slice %rhs[1] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot1 = v_fmac_f32 %dot0, %scaled1, %rhs1
  %rhs2 = slice %rhs[2] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot2 = v_fmac_f32 %dot1, %scaled2, %rhs2
  %rhs3 = slice %rhs[3] : reg<amdgpu.vgpr x4> -> reg<amdgpu.vgpr>
  %dot = v_fmac_f32 %dot2, %scaled3, %rhs3
  global_store_b32_saddr %q_byte_offset, %dot, %output_view
  return
}

// ----
  v_lshrrev_b32 v1, 3, v0
  v_lshlrev_b32 v2, 2, v0
  global_load_b32 v3, v2, s[0:1] offset:0
  v_lshlrev_b32 v1, 1, v1
  global_load_d16_b16 v1, v1, s[0:1] offset:0
  v_lshlrev_b32 v0, 4, v0
  global_load_b128 v[4:7], v0, s[2:3] offset:0
  s_waitcnt vmcnt(2) lgkmcnt(63)
  v_bfe_i32 v0, v3, 0, 8
  v_bfe_i32 v8, v3, 8, 8
  v_bfe_i32 v9, v3, 16, 8
  v_ashrrev_i32 v10, 24, v3
  v_cvt_f32_i32 v0, v0
  v_cvt_f32_i32 v8, v8
  v_cvt_f32_i32 v9, v9
  v_cvt_f32_i32 v10, v10
  s_waitcnt vmcnt(1) lgkmcnt(63)
  v_fma_mix_f32 v0, v1, v0, 0 op_sel_hi:[1,0,0]
  v_fma_mix_f32 v8, v1, v8, 0 op_sel_hi:[1,0,0]
  v_fma_mix_f32 v9, v1, v9, 0 op_sel_hi:[1,0,0]
  v_fma_mix_f32 v10, v1, v10, 0 op_sel_hi:[1,0,0]
  v_mov_b32 v11, 0
  s_waitcnt vmcnt(0) lgkmcnt(63)
  s_delay_alu instid0(VALU_DEP_1)
  v_fmac_f32 v11, v0, v4
  s_delay_alu instid0(VALU_DEP_1)
  v_fmac_f32 v11, v8, v5
  s_delay_alu instid0(VALU_DEP_1)
  v_fmac_f32 v11, v9, v6
  s_delay_alu instid0(VALU_DEP_1)
  v_fmac_f32 v11, v10, v7
  global_store_b32 v2, v11, s[4:5] offset:0
  s_endpgm
