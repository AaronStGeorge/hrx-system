// RUN: emit amdgpu-packet-json @gfx11_packet_json

amdgpu.target<gfx1100> @gfx11_target

low.func.def target(@gfx11_target) @gfx11_packet_json(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>, %out: reg<amdgpu.sgpr x2>) asm<amdgpu.rdna3.core> {
  %sum = v_add_u32 %lhs, %rhs
  global_store_b32_saddr %lhs, %sum, %out {offset = 0}
  return
}

