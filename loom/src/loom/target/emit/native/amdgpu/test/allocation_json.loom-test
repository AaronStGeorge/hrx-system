// RUN: emit amdgpu-allocation-json @gfx11_allocation_json_lds_wait strategy=source
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_allocation_json_lds_wait(%addr0: reg<amdgpu.vgpr>, %addr1: reg<amdgpu.vgpr>) -> (reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %loaded0 = ds_read_b32 %addr0
  %loaded1 = ds_read_b32 %addr1 {offset = 4}
  %sum = v_add_u32 %loaded0, %loaded1
  return %sum
}

