// RUN: emit amdgpu-assembly @gfx11_scheduled_liveness_resource
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_scheduled_liveness_resource(%kernarg: reg<amdgpu.sgpr x2>, %soffset: reg<amdgpu.sgpr>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %ptr = s_load_dwordx2 %kernarg, %soffset
  %ptr_lo = slice %ptr[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %ptr_hi = slice %ptr[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %mask = s_mov_b32 65535
  %masked_hi = s_and_b32 %ptr_hi, %mask
  %base = concat(%ptr_lo, %masked_hi) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %range = s_mov_b32 256
  %flags = s_mov_b32 822243328
  %resource = concat(%base, %range, %flags) : (reg<amdgpu.sgpr x2>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x4>
  %value = v_mov_b32 1
  buffer_store_dword %value, %resource, %vaddr, %soffset
  return
}

// ----
  s_load_dwordx2 s[0:1], s[0:1], s2 offset:0
  s_mov_b32 s3, 65535
  s_mov_b32 s6, 256
  s_mov_b32 s7, 822243328
  v_mov_b32 v1, 1
  s_waitcnt vmcnt(63) lgkmcnt(0)
  s_and_b32 s1, s1, s3
  s_mov_b32 s4, s0
  s_mov_b32 s5, s1
  buffer_store_dword v1, v0, s[4:7], s2 offen offset:0
  s_endpgm

