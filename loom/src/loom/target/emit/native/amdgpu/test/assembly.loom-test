.Lbb0:
  buffer_load_dword v1, v0, s[0:3], s4 offen offset:0
  s_wait_loadcnt loadcnt(0)
  buffer_store_dword v1, v0, s[0:3], s4 offen offset:4
  s_wait_storecnt storecnt(0)
  s_endpgm

