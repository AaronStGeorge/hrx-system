// RUN: emit amdgpu-assembly @gfx11_constants waits=none
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_constants(%resource: reg<amdgpu.sgpr x4>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %s_c0 = s_mov_b32 7
  %v_c0 = v_mov_b32 9
  %v_sum = v_add_u32_lit %v_c0, 123
  buffer_store_dword %v_sum, %resource, %vaddr, %s_c0 {offset = 12}
  return
}

// ----
  s_mov_b32 s4, 7
  v_mov_b32 v1, 9
  v_add_u32 v1, 123, v1
  buffer_store_dword v1, v0, s[0:3], s4 offen offset:12
  s_endpgm

// ====

