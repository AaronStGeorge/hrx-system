// RUN: emit amdgpu-assembly @gfx11_concat waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_concat(%r0: reg<amdgpu.sgpr>, %r1: reg<amdgpu.sgpr>, %r2: reg<amdgpu.sgpr>, %r3: reg<amdgpu.sgpr>, %value: reg<amdgpu.vgpr>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %resource = concat(%r0, %r1, %r2, %r3) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x4>
  %sum0 = s_add_u32 %r0, %r1
  %sum1 = s_add_u32 %r2, %r3
  %soffset = s_add_u32 %sum0, %sum1
  buffer_store_dword %value, %resource, %vaddr, %soffset {offset = 0}
  return
}

// ----
.Lbb0:
  s_add_u32 s4, s0, s1
  s_add_u32 s5, s2, s3
  s_add_u32 s4, s4, s5
  buffer_store_dword v0, v1, s[0:3], s4 offen offset:0
  s_endpgm
