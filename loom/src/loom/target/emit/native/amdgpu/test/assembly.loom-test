// RUN: emit amdgpu-assembly @gfx11_branch waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_branch() {
  low.br ^body
^body:
  low.op<amdgpu.s_wait_idle>() : ()
  low.br ^exit
^exit:
  low.return
}

