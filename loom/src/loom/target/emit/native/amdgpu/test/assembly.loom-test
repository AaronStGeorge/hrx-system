low.func.def target(@gfx11_target) @gfx11_stress_fragment(%s0: reg<amdgpu.sgpr>, %s1: reg<amdgpu.sgpr>, %v0: reg<amdgpu.vgpr>, %v1: reg<amdgpu.vgpr>, %a: reg<amdgpu.vgpr x8>, %b: reg<amdgpu.vgpr x8>, %acc: reg<amdgpu.vgpr x8>, %kernarg: reg<amdgpu.sgpr x2>, %resource: reg<amdgpu.sgpr x4>, %soffset: reg<amdgpu.sgpr>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %s_sum = s_add_u32 %s0, %s1
  %v_sum = v_add_u32 %v0, %v1
  %smem = s_buffer_load_dword %resource, %soffset
  %binding_ptr = s_load_dwordx2 %kernarg, %soffset {offset = 16}
  %vmem = buffer_load_dword %resource, %vaddr, %soffset {offset = 4}
  %vmem_b128 = buffer_load_b128 %resource, %vaddr, %soffset {offset = 16}
  %s_mix = s_add_u32 %s_sum, %smem
  %v_mix = v_add_u32 %v_sum, %vmem
  %matrix0 = v_wmma_f32_16x16x16_f16 %a, %b, %acc
  %matrix1 = v_wmma_f32_16x16x16_f16 %a, %b, %matrix0
  %binding_offset = slice %binding_ptr[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %matrix_low = slice %matrix1[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr x4>
  buffer_store_dword %v_mix, %resource, %vaddr, %s_mix {offset = 8}
  buffer_store_b128 %vmem_b128, %resource, %vaddr, %binding_offset {offset = 32}
  buffer_store_b128 %matrix_low, %resource, %vaddr, %soffset {offset = 48}
  s_waitcnt {vmcnt = 0, lgkmcnt = 0}
  s_waitcnt_depctr {depctr = 0}
  s_wait_idle
  return
}

