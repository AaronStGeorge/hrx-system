// RUN: emit amdgpu-assembly @gfx11_concat_source_existing_span waits=none
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_concat_source_existing_span(%row: reg<amdgpu.sgpr>, %row_limit: reg<amdgpu.sgpr>, %output: reg<amdgpu.sgpr x2>, %metadata: reg<amdgpu.sgpr x2>, %input: reg<amdgpu.sgpr x2>, %lookup: reg<amdgpu.sgpr x2>, %thread: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %zero_v = v_mov_b32 0
  %output_lo = slice %output[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %metadata_lo = slice %metadata[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %input_lo = slice %input[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %prefix = s_add_u32 %output_lo, %metadata_lo
  %prefix_with_input = s_add_u32 %prefix, %input_lo
  %zero_s = s_mov_b32 0
  %row_i64 = concat(%row, %zero_s) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %scale = s_mov_b32 2
  %row_bytes = s_lshl_b64 %row_i64, %scale
  %lookup_lo = slice %lookup[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %lookup_hi = slice %lookup[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %row_bytes_lo = slice %row_bytes[0] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %row_bytes_hi = slice %row_bytes[1] : reg<amdgpu.sgpr x2> -> reg<amdgpu.sgpr>
  %address_lo = s_add_u32 %lookup_lo, %row_bytes_lo
  %address_hi = s_addc_u32 %lookup_hi, %row_bytes_hi
  %address = concat(%address_lo, %address_hi) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x2>
  %loaded = global_load_b32_saddr %zero_v, %address
  %cmp = v_cmp_lt_i32 %loaded, %thread
  %prefix_cmp = s_cmp_lt_i32 %prefix_with_input, %row_limit
  return
}

// ----
  v_mov_b32 v1, 0
  s_mov_b32 s9, 0
  s_mov_b32 s3, 2
  s_add_u32 s0, s0, s2
  s_add_u32 s0, s0, s4
  s_lshl_b64 s[2:3], s[8:9], s3
  s_add_u32 s2, s6, s2
  s_addc_u32 s3, s7, s3
  s_cmp_lt_i32 s0, s1
  global_load_b32 v1, v1, s[2:3] offset:0
  v_cmp_lt_i32 s[0:1], v1, v0
  s_endpgm

