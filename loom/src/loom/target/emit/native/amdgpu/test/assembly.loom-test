// RUN: emit amdgpu-assembly @gfx11_constants waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_constants(%resource : reg<amdgpu.sgpr x4>, %vaddr : reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %s_c0 = s_mov_b32 7
  %v_c0 = v_mov_b32 9
  %v_sum = v_add_u32 %v_c0, %v_c0
  buffer_store_dword %v_sum, %resource, %vaddr, %s_c0 {offset = 12}
  return
}

// ----
.Lbb0:
  s_mov_b32 s4, 7
  v_mov_b32 v1, 9
  v_add_u32 v1, v1, v1
  buffer_store_dword v1, v0, s[0:3], s4 offen offset:12
  s_endpgm

// ====
// RUN: emit amdgpu-assembly @gfx11_buffer_off_zero waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_buffer_off_zero(%resource : reg<amdgpu.sgpr x4>) {
  %loaded = low.op<amdgpu.buffer_load_dword_off_zero>(%resource) {offset = 12} : (reg<amdgpu.sgpr x4>) -> reg<amdgpu.vgpr>
  low.op<amdgpu.buffer_store_dword_off_zero>(%loaded, %resource) {offset = 16} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>)
  low.return
}

// ----
.Lbb0:
  buffer_load_dword v0, off, s[0:3], 0 offset:12
  buffer_store_dword v0, off, s[0:3], 0 offset:16
  s_endpgm

// ====
// RUN: emit amdgpu-assembly @gfx11_mask_select waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_mask_select(%lhs : reg<amdgpu.vgpr>, %rhs : reg<amdgpu.vgpr>, %true_value : reg<amdgpu.vgpr>, %false_value : reg<amdgpu.vgpr>, %resource : reg<amdgpu.sgpr x4>, %vaddr : reg<amdgpu.vgpr>, %soffset : reg<amdgpu.sgpr>) asm<amdgpu.gfx11.core> {
  %mask = v_cmp_lt_i32 %lhs, %rhs
  %selected = v_cndmask_b32 %false_value, %true_value, %mask
  buffer_store_dword %selected, %resource, %vaddr, %soffset {offset = 0}
  return
}

// ----
.Lbb0:
  v_cmp_lt_i32 s[6:7], v0, v1
  v_cndmask_b32 v0, v3, v2, s[6:7]
  buffer_store_dword v0, v4, s[0:3], s4 offen offset:0
  s_endpgm

// ====
// RUN: emit amdgpu-assembly @gfx11_global_pointer waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_global_pointer(%addr : reg<amdgpu.vgpr x2>) {
  %loaded = low.op<amdgpu.global_load_b128>(%addr) {offset = -16} : (reg<amdgpu.vgpr x2>) -> reg<amdgpu.vgpr x4>
  low.op<amdgpu.global_store_b128>(%addr, %loaded) {offset = 32} : (reg<amdgpu.vgpr x2>, reg<amdgpu.vgpr x4>)
  low.return
}

// ----
.Lbb0:
  global_load_b128 v[4:7], v[0:1], off offset:-16
  global_store_b128 v[0:1], v[4:7], off offset:32
  s_endpgm

// ====
// RUN: emit amdgpu-assembly @gfx11_global_saddr waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_global_saddr(%addr : reg<amdgpu.vgpr>, %saddr : reg<amdgpu.sgpr x2>) {
  %loaded = low.op<amdgpu.global_load_b128_saddr>(%addr, %saddr) {offset = 4} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>) -> reg<amdgpu.vgpr x4>
  low.op<amdgpu.global_store_b128_saddr>(%addr, %loaded, %saddr) {offset = 8} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr x4>, reg<amdgpu.sgpr x2>)
  low.return
}

// ----
.Lbb0:
  global_load_b128 v[4:7], v0, s[0:1] offset:4
  global_store_b128 v0, v[4:7], s[0:1] offset:8
  s_endpgm

// ====
// RUN: emit amdgpu-assembly @gfx950_global_load_lds waits=none
target.profile @gfx950_target preset("amdgpu-gfx950")

low.func.def target(@gfx950_target) @gfx950_global_load_lds(%addr64 : reg<amdgpu.vgpr x2>, %addr32 : reg<amdgpu.vgpr>, %saddr : reg<amdgpu.sgpr x2>, %m0 : reg<amdgpu.m0>) {
  low.op<amdgpu.global_load_lds_dword>(%addr64, %m0) {offset = 4} : (reg<amdgpu.vgpr x2>, reg<amdgpu.m0>)
  low.op<amdgpu.global_load_lds_dwordx4_saddr>(%addr32, %saddr, %m0) {offset = 16} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x2>, reg<amdgpu.m0>)
  low.return
}

// ----
.Lbb0:
  global_load_lds_dword v[0:1], off offset:4
  global_load_lds_dwordx4 v2, s[0:1] offset:16
  s_endpgm
