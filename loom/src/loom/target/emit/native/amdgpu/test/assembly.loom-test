amdgpu.target<gfx950> @gfx950_target
low.func.def target(@gfx950_target) @gfx950_smem_dwordx4_stores(%base: reg<amdgpu.sgpr x2>, %resource: reg<amdgpu.sgpr x4>, %soffset: reg<amdgpu.sgpr>, %value32: reg<amdgpu.sgpr>, %value64: reg<amdgpu.sgpr x2>, %value128: reg<amdgpu.sgpr x4>) asm<amdgpu.cdna4.core> {
