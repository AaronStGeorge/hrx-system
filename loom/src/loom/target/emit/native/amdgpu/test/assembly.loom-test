amdgpu.target<gfx1100> @gfx_target
low.func.def target(@gfx_target) @gfx11_smem_wait_drains_cross_block_peer(%kernarg: reg<amdgpu.sgpr x2>, %soffset: reg<amdgpu.sgpr>, %lhs: reg<amdgpu.sgpr>, %rhs: reg<amdgpu.sgpr>) asm<amdgpu.rdna3.core> {
  %first = s_load_dword %kernarg, %soffset
  %second = s_load_dword %kernarg, %soffset {offset = 4}
  %first_sum = s_add_u32 %first, %lhs
  %cond = s_cmp_lt_i32 %lhs, %rhs
  low.cond_br %cond, ^use_second, ^exit : reg<amdgpu.scc>
^use_second:
  %second_sum = s_add_u32 %second, %rhs
  %final = s_add_u32 %first_sum, %second_sum
  return
^exit:
  return
}

