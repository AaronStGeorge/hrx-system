// RUN: emit amdgpu-assembly @gfx11_coalesced_copy waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_coalesced_copy(%s0: reg<amdgpu.sgpr>, %s1: reg<amdgpu.sgpr>, %a: reg<amdgpu.vgpr x8>, %b: reg<amdgpu.vgpr x8>, %acc: reg<amdgpu.vgpr x8>, %resource: reg<amdgpu.sgpr x4>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.gfx11.core> {
  %s_copy = copy %s0 : reg<amdgpu.sgpr> -> reg<amdgpu.sgpr>
  %s_sum = s_add_u32 %s_copy, %s1
  %s_second = s_add_u32 %s0, %s_sum
  %v_copy = copy %a : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr x8>
  %matrix0 = v_wmma_f32_16x16x16_f16 %v_copy, %b, %acc
  %matrix1 = v_wmma_f32_16x16x16_f16 %a, %b, %matrix0
  %matrix_low = slice %matrix1[0] : reg<amdgpu.vgpr x8> -> reg<amdgpu.vgpr x4>
  buffer_store_b128 %matrix_low, %resource, %vaddr, %s_second {offset = 0}
  return
}

// ----
.Lbb0:
  s_add_u32 s0, s1, s0
  v_wmma_f32_16x16x16_f16 v[0:7], v[8:15], v[16:23], v[0:7]
  s_add_u32 s0, s1, s0
  v_wmma_f32_16x16x16_f16 v[0:7], v[8:15], v[16:23], v[0:7]
  buffer_store_b128 v[0:3], v24, s[4:7], s0 offen offset:0
  s_endpgm

