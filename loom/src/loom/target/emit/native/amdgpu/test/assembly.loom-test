  %next = v_fmac_f32 %acc, %lhs, %rhs
  buffer_store_dword %next, %resource, %vaddr, %soffset {offset = 0}
  return
}

// ----
  v_fmac_f32 v0, v1, v2
  buffer_store_dword v0, v3, s[0:3], s4 offen offset:0
  s_endpgm

