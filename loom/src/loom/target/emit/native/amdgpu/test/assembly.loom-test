// RUN: emit amdgpu-assembly-mnemonics @gfx950_lds_transpose waits=none
target.profile @gfx950_target preset("amdgpu-gfx950")

low.func.def target(@gfx950_target) @gfx950_lds_transpose(%addr : reg<amdgpu.vgpr>) {
  %loaded_b4 = low.op<amdgpu.ds_read_b64_tr_b4>(%addr) {offset = 0} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %loaded_b6 = low.op<amdgpu.ds_read_b96_tr_b6>(%addr) {offset = 16} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x3>
  %loaded_b8 = low.op<amdgpu.ds_read_b64_tr_b8>(%addr) {offset = 32} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  %loaded_b16 = low.op<amdgpu.ds_read_b64_tr_b16>(%addr) {offset = 48} : (reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x2>
  low.op<amdgpu.ds_write_b64>(%addr, %loaded_b4) {offset = 64} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr x2>)
  low.op<amdgpu.ds_write_b96>(%addr, %loaded_b6) {offset = 80} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr x3>)
  low.op<amdgpu.ds_write_b64>(%addr, %loaded_b8) {offset = 96} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr x2>)
  low.op<amdgpu.ds_write_b64>(%addr, %loaded_b16) {offset = 112} : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr x2>)
  low.return
}

