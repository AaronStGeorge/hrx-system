  %packed = concat(%a, %b, %c, %d) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr x4>
  buffer_store_b128 %packed, %resource, %vaddr, %soffset
  return
}

// ----
  v_mov_b32 v5, v1
  v_mov_b32 v1, v2
  v_mov_b32 v2, v3
  v_mov_b32 v3, v5
  buffer_store_b128 v[0:3], v4, s[0:3], s4 offen offset:0
  s_endpgm

// ====

// RUN: emit amdgpu-assembly @gfx11_convergent_exec_state_fence strategy=resource-stall
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_convergent_exec_state_fence(%lhs: reg<amdgpu.vgpr>, %rhs: reg<amdgpu.vgpr>, %addr: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %early = v_add_f32 %lhs, %rhs
  %also_early = v_add_f32 %early, %rhs
  %permuted = ds_bpermute_b32 %addr, %early
  %sum = v_add_f32 %permuted, %also_early
  return
}

// ----
  v_add_f32 v0, v0, v1
  v_add_f32 v1, v0, v1
  ds_bpermute_b32 v0, v2, v0 offset:0
  s_waitcnt vmcnt(63) lgkmcnt(0)
  v_add_f32 v1, v0, v1
  s_endpgm

// ====

// RUN: emit amdgpu-assembly @gfx11_concat waits=none
amdgpu.target<gfx1100> @gfx11_target
low.func.def target(@gfx11_target) @gfx11_concat(%r0: reg<amdgpu.sgpr>, %r1: reg<amdgpu.sgpr>, %r2: reg<amdgpu.sgpr>, %r3: reg<amdgpu.sgpr>, %value: reg<amdgpu.vgpr>, %vaddr: reg<amdgpu.vgpr>) asm<amdgpu.rdna3.core> {
  %resource = concat(%r0, %r1, %r2, %r3) : (reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>, reg<amdgpu.sgpr>) -> reg<amdgpu.sgpr x4>
  %sum0 = s_add_u32 %r0, %r1
  %sum1 = s_add_u32 %r2, %r3
  %soffset = s_add_u32 %sum0, %sum1
  buffer_store_dword %value, %resource, %vaddr, %soffset
  return
}

// ----
  s_add_u32 s4, s0, s1
  s_add_u32 s5, s2, s3
  s_add_u32 s4, s4, s5
  buffer_store_dword v0, v1, s[0:3], s4 offen offset:0
  s_endpgm
