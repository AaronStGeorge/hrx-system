// RUN: emit amdgpu-assembly @gfx11_constants waits=none
target.profile @gfx11_target preset("amdgpu-gfx11")

low.func.def target(@gfx11_target) @gfx11_constants(%resource : reg<amdgpu.sgpr x4>, %vaddr : reg<amdgpu.vgpr>) {
  %s_c0 = low.const<amdgpu.s_mov_b32> {imm32 = 7} : reg<amdgpu.sgpr>
  %v_c0 = low.const<amdgpu.v_mov_b32> {imm32 = 9} : reg<amdgpu.vgpr>
  %v_sum = low.op<amdgpu.v_add_u32>(%v_c0, %v_c0) : (reg<amdgpu.vgpr>, reg<amdgpu.vgpr>) -> reg<amdgpu.vgpr>
  low.op<amdgpu.buffer_store_dword>(%v_sum, %resource, %vaddr, %s_c0) {offset = 12} : (reg<amdgpu.vgpr>, reg<amdgpu.sgpr x4>, reg<amdgpu.vgpr>, reg<amdgpu.sgpr>)
  low.return
}

// ----
.Lbb0:
  s_mov_b32 s4, 7
  v_mov_b32 v1, 9
  v_add_u32 v1, v1, v1
  buffer_store_dword v1, v0, s[0:3], s4 offen offset:12
  s_endpgm

