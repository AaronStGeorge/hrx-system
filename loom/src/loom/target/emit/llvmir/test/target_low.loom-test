// RUN: emit llvmir-body

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

low.func.def target(@target) abi(object_function) @first(%lhs: reg<llvmir.i32>, %rhs: reg<llvmir.i32>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %sum = add.i32 %lhs, %rhs
  return %sum
}

low.func.def target(@target) abi(object_function) @second(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %bounded_i: reg<llvmir.i64>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %loaded = load.indexed.i32 %input_view, %bounded_i, 16, 4
  store.indexed.i32 %loaded, %output_view, %bounded_i, 32, 4
  return %loaded
}

low.func.def target(@target) abi(object_function) @memory_widths(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %bounded_i: reg<llvmir.i64>) -> (reg<llvmir.f32 x16>) asm<llvmir.generic.core> {
  %byte = load.i8 %input_view, 1
  %halves = load.v4f16 %input_view, 8
  %brain = load.v2bf16 %input_view, 32
  %wide = load.indexed.v16f32 %input_view, %bounded_i, 64, 64
  store.i8 %byte, %output_view, 1
  store.v4f16 %halves, %output_view, 8
  store.v2bf16 %brain, %output_view, 32
  store.indexed.v16f32 %wide, %output_view, %bounded_i, 64, 64
  return %wide
}

low.func.def target(@target) abi(object_function) @i8_identity(%value: reg<llvmir.i8>) -> (reg<llvmir.i8>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @i16_identity(%value: reg<llvmir.i16>) -> (reg<llvmir.i16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @f16_identity(%value: reg<llvmir.f16>) -> (reg<llvmir.f16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @bf16_identity(%value: reg<llvmir.bf16>) -> (reg<llvmir.bf16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v32i8_identity(%value: reg<llvmir.i8 x32>) -> (reg<llvmir.i8 x32>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v8f16_identity(%value: reg<llvmir.f16 x8>) -> (reg<llvmir.f16 x8>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v16bf16_identity(%value: reg<llvmir.bf16 x16>) -> (reg<llvmir.bf16 x16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @f64_unordered_select(%lhs: reg<llvmir.f64>, %rhs: reg<llvmir.f64>, %true_value: reg<llvmir.f64>, %false_value: reg<llvmir.f64>) -> (reg<llvmir.f64>) asm<llvmir.generic.core> {
  %mask = cmp.uno.f64 %lhs, %rhs
  %selected = select.f64 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @i32x16_vector_ops(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>, %fallback: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %sum = add.v16i32 %lhs, %rhs
  %shifted = shl.v16i32 %sum, %rhs
  %mask = cmp.ugt.v16i32 %shifted, %lhs
  %selected = select.v16i32 %mask, %shifted, %fallback
  return %selected
}

low.func.def target(@target) abi(object_function) @f32x16_unordered_select(%lhs: reg<llvmir.f32 x16>, %rhs: reg<llvmir.f32 x16>, %fallback: reg<llvmir.f32 x16>) -> (reg<llvmir.f32 x16>) asm<llvmir.generic.core> {
  %mask = cmp.une.v16f32 %lhs, %rhs
  %selected = select.v16f32 %mask, %lhs, %fallback
  return %selected
}

low.func.def target(@target) abi(object_function) @v4i8_select(%mask: reg<llvmir.i1 x4>, %true_value: reg<llvmir.i8 x4>, %false_value: reg<llvmir.i8 x4>) -> (reg<llvmir.i8 x4>) asm<llvmir.generic.core> {
  %selected = select.v4i8 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @v2i16_select(%mask: reg<llvmir.i1 x2>, %true_value: reg<llvmir.i16 x2>, %false_value: reg<llvmir.i16 x2>) -> (reg<llvmir.i16 x2>) asm<llvmir.generic.core> {
  %selected = select.v2i16 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @v16bf16_select(%mask: reg<llvmir.i1 x16>, %true_value: reg<llvmir.bf16 x16>, %false_value: reg<llvmir.bf16 x16>) -> (reg<llvmir.bf16 x16>) asm<llvmir.generic.core> {
  %selected = select.v16bf16 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @structural_i32_vector(%value: reg<llvmir.i32>, %source: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x4>) asm<llvmir.generic.core> {
  %splat = splat.v4i32 %value
  %lane = extract.v4i32 %source, 2
  %from = from_elements.v4i32 %value, %lane, %value, %lane
  %updated = insert.v4i32 %splat, %lane, 3
  %shuffled = shuffle.v4i32 %from, 3, 2, 1, 0
  return %shuffled
}

low.func.def target(@target) abi(object_function) @structural_slice(%source: reg<llvmir.i32 x4>) -> (reg<llvmir.i32 x2>) asm<llvmir.generic.core> {
  %slice = slice.v4i32.v2i32 %source, 1
  return %slice
}

low.func.def target(@target) abi(object_function) @structural_f32_splat(%float_value: reg<llvmir.f32>) -> (reg<llvmir.f32 x4>) asm<llvmir.generic.core> {
  %float_splat = splat.v4f32 %float_value
  return %float_splat
}

low.func.def target(@target) abi(object_function) @structural_f16_insert(%source: reg<llvmir.f16 x4>, %value: reg<llvmir.f16>) -> (reg<llvmir.f16 x4>) asm<llvmir.generic.core> {
  %updated = insert.v4f16 %source, %value, 1
  return %updated
}

low.func.def target(@target) abi(object_function) @structural_bf16_slice(%source: reg<llvmir.bf16 x4>) -> (reg<llvmir.bf16 x2>) asm<llvmir.generic.core> {
  %slice = slice.v4bf16.v2bf16 %source, 2
  return %slice
}

low.func.def target(@target) abi(object_function) @integer_vector_constant() -> (reg<llvmir.i32 x2>) asm<llvmir.generic.core> {
  %int = const.v2i32 7
  return %int
}

low.func.def target(@target) abi(object_function) @float_vector_constant() -> (reg<llvmir.f32 x2>) asm<llvmir.generic.core> {
  %float = const.v2f32 1073741824
  return %float
}

low.func.def target(@target) abi(object_function) @scalar_casts(%i8_value: reg<llvmir.i8>, %i32_value: reg<llvmir.i32>, %f16_value: reg<llvmir.f16>, %bf16_value: reg<llvmir.bf16>, %f32_value: reg<llvmir.f32>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %truncated = trunc.i32.i8 %i32_value
  %sext = sext.i8.i32 %i8_value
  %zext = zext.i8.i32 %i8_value
  %signed_fp = sitofp.i32.f32 %i32_value
  %unsigned_fp = uitofp.i32.f32 %i32_value
  %fp_to_signed = fptosi.f32.i32 %f32_value
  %fp_to_unsigned = fptoui.f32.i32 %f32_value
  %fp_truncated = fptrunc.f32.f16 %f32_value
  %fp_extended = fpext.f16.f32 %f16_value
  %bf16_extended = fpext.bf16.f32 %bf16_value
  %bits = bitcast.f32.i32 %f32_value
  return %bits
}

low.func.def target(@target) abi(object_function) @vector_casts(%i32_values: reg<llvmir.i32 x2>, %f32_values: reg<llvmir.f32 x2>) -> (reg<llvmir.f32 x2>) asm<llvmir.generic.core> {
  %signed_fp = sitofp.v2i32.v2f32 %i32_values
  %unsigned_fp = uitofp.v2i32.v2f32 %i32_values
  %bits = bitcast.v2i32.v2f32 %i32_values
  return %signed_fp
}

