// RUN: emit llvmir-body

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

low.func.def target(@target) abi(object_function) @first(%lhs: reg<llvmir.i32>, %rhs: reg<llvmir.i32>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %sum = add.i32 %lhs, %rhs
  return %sum
}

low.func.def target(@target) abi(object_function) @second(%input_view: reg<llvmir.ptr>, %output_view: reg<llvmir.ptr>, %bounded_i: reg<llvmir.i64>) -> (reg<llvmir.i32>) asm<llvmir.generic.core> {
  %loaded = load.indexed.i32 %input_view, %bounded_i, 16, 4
  store.indexed.i32 %loaded, %output_view, %bounded_i, 32, 4
  return %loaded
}

low.func.def target(@target) abi(object_function) @i8_identity(%value: reg<llvmir.i8>) -> (reg<llvmir.i8>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @i16_identity(%value: reg<llvmir.i16>) -> (reg<llvmir.i16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @f16_identity(%value: reg<llvmir.f16>) -> (reg<llvmir.f16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @bf16_identity(%value: reg<llvmir.bf16>) -> (reg<llvmir.bf16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v32i8_identity(%value: reg<llvmir.i8 x32>) -> (reg<llvmir.i8 x32>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v8f16_identity(%value: reg<llvmir.f16 x8>) -> (reg<llvmir.f16 x8>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @v16bf16_identity(%value: reg<llvmir.bf16 x16>) -> (reg<llvmir.bf16 x16>) asm<llvmir.generic.core> {
  return %value
}

low.func.def target(@target) abi(object_function) @f64_unordered_select(%lhs: reg<llvmir.f64>, %rhs: reg<llvmir.f64>, %true_value: reg<llvmir.f64>, %false_value: reg<llvmir.f64>) -> (reg<llvmir.f64>) asm<llvmir.generic.core> {
  %mask = cmp.uno.f64 %lhs, %rhs
  %selected = select.f64 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @i32x16_vector_ops(%lhs: reg<llvmir.i32 x16>, %rhs: reg<llvmir.i32 x16>, %fallback: reg<llvmir.i32 x16>) -> (reg<llvmir.i32 x16>) asm<llvmir.generic.core> {
  %sum = add.v16i32 %lhs, %rhs
  %shifted = shl.v16i32 %sum, %rhs
  %mask = cmp.ugt.v16i32 %shifted, %lhs
  %selected = select.v16i32 %mask, %shifted, %fallback
  return %selected
}

low.func.def target(@target) abi(object_function) @f32x16_unordered_select(%lhs: reg<llvmir.f32 x16>, %rhs: reg<llvmir.f32 x16>, %fallback: reg<llvmir.f32 x16>) -> (reg<llvmir.f32 x16>) asm<llvmir.generic.core> {
  %mask = cmp.une.v16f32 %lhs, %rhs
  %selected = select.v16f32 %mask, %lhs, %fallback
  return %selected
}

low.func.def target(@target) abi(object_function) @v4i8_select(%mask: reg<llvmir.i1 x4>, %true_value: reg<llvmir.i8 x4>, %false_value: reg<llvmir.i8 x4>) -> (reg<llvmir.i8 x4>) asm<llvmir.generic.core> {
  %selected = select.v4i8 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @v2i16_select(%mask: reg<llvmir.i1 x2>, %true_value: reg<llvmir.i16 x2>, %false_value: reg<llvmir.i16 x2>) -> (reg<llvmir.i16 x2>) asm<llvmir.generic.core> {
  %selected = select.v2i16 %mask, %true_value, %false_value
  return %selected
}

low.func.def target(@target) abi(object_function) @v16bf16_select(%mask: reg<llvmir.i1 x16>, %true_value: reg<llvmir.bf16 x16>, %false_value: reg<llvmir.bf16 x16>) -> (reg<llvmir.bf16 x16>) asm<llvmir.generic.core> {
  %selected = select.v16bf16 %mask, %true_value, %false_value
  return %selected
}

// ----
define dso_local i32 @first(i32 %lhs, i32 %rhs) {
entry:
  %sum = add i32 %lhs, %rhs
  ret i32 %sum
}

define dso_local i32 @second(ptr %input_view, ptr %output_view, i64 %bounded_i) {
entry:
  %v7 = mul i64 %bounded_i, 4
  %v9 = add i64 %v7, 16
  %v10 = getelementptr i8, ptr %input_view, i64 %v9
  %loaded = load i32, ptr %v10
  %v13 = mul i64 %bounded_i, 4
  %v15 = add i64 %v13, 32
  %v16 = getelementptr i8, ptr %output_view, i64 %v15
  store i32 %loaded, ptr %v16
  ret i32 %loaded
}

define dso_local i8 @i8_identity(i8 %value) {
entry:
  ret i8 %value
}

define dso_local i16 @i16_identity(i16 %value) {
entry:
  ret i16 %value
}

define dso_local half @f16_identity(half %value) {
entry:
  ret half %value
}

define dso_local bfloat @bf16_identity(bfloat %value) {
entry:
  ret bfloat %value
}

define dso_local <32 x i8> @v32i8_identity(<32 x i8> %value) {
entry:
  ret <32 x i8> %value
}

define dso_local <8 x half> @v8f16_identity(<8 x half> %value) {
entry:
  ret <8 x half> %value
}

define dso_local <16 x bfloat> @v16bf16_identity(<16 x bfloat> %value) {
entry:
  ret <16 x bfloat> %value
}

define dso_local double @f64_unordered_select(double %lhs, double %rhs, double %true_value, double %false_value) {
entry:
  %mask = fcmp uno double %lhs, %rhs
  %selected = select i1 %mask, double %true_value, double %false_value
  ret double %selected
}

define dso_local <16 x i32> @i32x16_vector_ops(<16 x i32> %lhs, <16 x i32> %rhs, <16 x i32> %fallback) {
entry:
  %sum = add <16 x i32> %lhs, %rhs
  %shifted = shl <16 x i32> %sum, %rhs
  %mask = icmp ugt <16 x i32> %shifted, %lhs
  %selected = select <16 x i1> %mask, <16 x i32> %shifted, <16 x i32> %fallback
  ret <16 x i32> %selected
}

define dso_local <16 x float> @f32x16_unordered_select(<16 x float> %lhs, <16 x float> %rhs, <16 x float> %fallback) {
entry:
  %mask = fcmp une <16 x float> %lhs, %rhs
  %selected = select <16 x i1> %mask, <16 x float> %lhs, <16 x float> %fallback
  ret <16 x float> %selected
}

define dso_local <4 x i8> @v4i8_select(<4 x i1> %mask, <4 x i8> %true_value, <4 x i8> %false_value) {
entry:
  %selected = select <4 x i1> %mask, <4 x i8> %true_value, <4 x i8> %false_value
  ret <4 x i8> %selected
}

define dso_local <2 x i16> @v2i16_select(<2 x i1> %mask, <2 x i16> %true_value, <2 x i16> %false_value) {
entry:
  %selected = select <2 x i1> %mask, <2 x i16> %true_value, <2 x i16> %false_value
  ret <2 x i16> %selected
}

define dso_local <16 x bfloat> @v16bf16_select(<16 x i1> %mask, <16 x bfloat> %true_value, <16 x bfloat> %false_value) {
entry:
  %selected = select <16 x i1> %mask, <16 x bfloat> %true_value, <16 x bfloat> %false_value
  ret <16 x bfloat> %selected
}

// ====

llvmir.target<object> @target {
  triple = "amdgcn-amd-amdhsa"
}

low.kernel.def target(@target) workgroup_size(64, 1, 1) @dispatch() asm<llvmir.generic.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<llvmir.ptr>
  %value = load.i32 %input, 4
  return
}

// ----
define amdgpu_kernel void @dispatch(ptr addrspace(1) inreg noundef %input) #0 !reqd_work_group_size !0 {
entry:
  %v5 = getelementptr i8, ptr addrspace(1) %input, i64 4
  %value = load i32, ptr addrspace(1) %v5
  ret void
}

attributes #0 = { alwaysinline "amdgpu-flat-work-group-size"="1,1024" "uniform-work-group-size" }

!0 = !{i32 64, i32 1, i32 1}
