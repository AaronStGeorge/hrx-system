// RUN: emit llvmir-bitcode
// REQUIRES: llvm-dis

llvmir.target<object> @target {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128"
}

func.def target(@target) @bitcode_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
target datalayout = "e-p:64:64-i64:64-n8:16:32:64-S128"
target triple = "loom-direct64-unknown-none"

define dso_local i32 @bitcode_add(i32 %lhs, i32 %rhs) {
entry:
  %sum = add i32 %lhs, %rhs
  ret i32 %sum
}

// ====

// RUN: emit llvmir-object x86_64-object
// REQUIRES: llc, llc-x86

llvmir.target<object> @target {
  triple = "x86_64-unknown-linux-gnu",
  data_layout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
}

func.def target(@target) @object_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi<nsw> %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
object emitted: x86_64-object
