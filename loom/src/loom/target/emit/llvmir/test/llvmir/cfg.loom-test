// RUN: emit llvmir-body

// CFG branch operands lower to LLVM phi incoming edges on the successor block.
func.def public @cfg_select_i32(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
define dso_local i32 @cfg_select_i32(i1 %cond, i32 %a, i32 %b) {
entry:
  br i1 %cond, label %then, label %else
then:
  br label %join
else:
  br label %join
join:
  %result = phi i32 [ %a, %then ], [ %b, %else ]
  ret i32 %result
}

// ====

// Loop-carried CFG block arguments lower to phis with entry and backedge values.
func.def @cfg_counted_accumulate(%n: index, %seed: i32, %x: i32) -> (i32) {
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  cfg.br ^loop(%zero, %seed : index, i32)
^loop(%i : index, %acc : i32):
  %keep_going = index.cmp slt, %i, %n : index
  cfg.cond_br %keep_going, ^body, ^exit : i1
^body:
  %next_acc = scalar.addi<nsw> %acc, %x : i32
  %next_i = index.add %i, %one : index
  cfg.br ^loop(%next_i, %next_acc : index, i32)
^exit:
  func.return %acc : i32
}

// ----
define internal i32 @cfg_counted_accumulate(i64 %n, i32 %seed, i32 %x) {
entry:
  br label %loop
loop:
  %i = phi i64 [ 0, %entry ], [ %next_i, %body ]
  %acc = phi i32 [ %seed, %entry ], [ %next_acc, %body ]
  %keep_going = icmp slt i64 %i, %n
  br i1 %keep_going, label %body, label %exit
body:
  %next_acc = add nsw i32 %acc, %x
  %next_i = add i64 %i, 1
  br label %loop
exit:
  ret i32 %acc
}
