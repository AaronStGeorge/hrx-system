// RUN: emit llvmir-body

// Dense 2-D view load/store lowers to explicit row-major address arithmetic.
func.def public @dense_memory(%buffer: buffer, %offset: offset, %row: index, %col: index, %value: f32) -> (f32) {
  %view = buffer.view %buffer[%offset] : buffer -> view<4x8xf32, #dense>
  %loaded = view.load %view[%row, %col] : view<4x8xf32, #dense> -> f32
  view.store %value, %view[0, %col] : f32, view<4x8xf32, #dense>
  func.return %loaded : f32
}

// ----
define dso_local float @dense_memory(ptr %buffer, i64 %offset, i64 %row, i64 %col, float %value) {
entry:
  %view = getelementptr i8, ptr %buffer, i64 %offset
  %v7 = mul i64 %row, 8
  %v8 = add i64 %v7, %col
  %v9 = getelementptr float, ptr %view, i64 %v8
  %loaded = load float, ptr %v9
  %v13 = mul i64 0, 8
  %v14 = add i64 %v13, %col
  %v15 = getelementptr float, ptr %view, i64 %v14
  store float %value, ptr %v15
  ret float %loaded
}

// ====

// Cache policy attributes map to LLVM memory metadata.
func.def public @cache_policy(%buffer: buffer, %offset: offset, %i: index, %scalar_value: f32, %vector_value: vector<4xf32>) -> (f32) {
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, #dense>
  %scalar_loaded = view.load %view[%i] {cache_scope = device, cache_temporal = non_temporal} : view<16xf32, #dense> -> f32
  view.store %scalar_value, %view[%i] {cache_scope = device, cache_temporal = non_temporal} : f32, view<16xf32, #dense>
  %vector_loaded = vector.load %view[%i] {cache_scope = device, cache_temporal = non_temporal} : view<16xf32, #dense> -> vector<4xf32>
  vector.store %vector_value, %view[%i] {cache_scope = device, cache_temporal = non_temporal} : vector<4xf32>, view<16xf32, #dense>
  func.return %scalar_loaded : f32
}

// ----
define dso_local float @cache_policy(ptr %buffer, i64 %offset, i64 %i, float %scalar_value, <4 x float> %vector_value) {
entry:
  %view = getelementptr i8, ptr %buffer, i64 %offset
  %v6 = getelementptr float, ptr %view, i64 %i
  %scalar_loaded = load float, ptr %v6, !nontemporal !0
  %v9 = getelementptr float, ptr %view, i64 %i
  store float %scalar_value, ptr %v9, !nontemporal !0
  %v10 = getelementptr float, ptr %view, i64 %i
  %vector_loaded = load <4 x float>, ptr %v10, !nontemporal !0
  %v12 = getelementptr float, ptr %view, i64 %i
  store <4 x float> %vector_value, ptr %v12, !nontemporal !0
  ret float %scalar_loaded
}

!0 = !{i32 1}

// ====

// Private buffer.alloca lowers to an LLVM stack allocation with alignment.
func.def public @stack_memory(%bytes: offset, %value: f32) -> (f32) {
  %zero = index.constant 0 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = private} : buffer
  %view = buffer.view %scratch[%zero] : buffer -> view<1xf32, #dense>
  view.store %value, %view[0] : f32, view<1xf32, #dense>
  %loaded = view.load %view[0] : view<1xf32, #dense> -> f32
  func.return %loaded : f32
}

// ----
define dso_local float @stack_memory(i64 %bytes, float %value) {
entry:
  %scratch = alloca i8, i64 %bytes, align 16
  %view = getelementptr i8, ptr %scratch, i64 0
  %v6 = getelementptr float, ptr %view, i64 0
  store float %value, ptr %v6, align 4
  %v8 = getelementptr float, ptr %view, i64 0
  %loaded = load float, ptr %v8, align 4
  ret float %loaded
}

// ====

// Vector stack load/store preserves vector alignment when the view is aligned.
func.def public @stack_vector_memory(%bytes: offset, %value: vector<4xf32>) -> (vector<4xf32>) {
  %zero = index.constant 0 : offset
  %scratch = buffer.alloca %bytes {base_alignment = 16, memory_space = private} : buffer
  %view = buffer.view %scratch[%zero] : buffer -> view<4xf32, #dense>
  vector.store %value, %view[0] : vector<4xf32>, view<4xf32, #dense>
  %loaded = vector.load %view[0] : view<4xf32, #dense> -> vector<4xf32>
  func.return %loaded : vector<4xf32>
}

// ----
define dso_local <4 x float> @stack_vector_memory(i64 %bytes, <4 x float> %value) {
entry:
  %scratch = alloca i8, i64 %bytes, align 16
  %view = getelementptr i8, ptr %scratch, i64 0
  %v6 = getelementptr float, ptr %view, i64 0
  store <4 x float> %value, ptr %v6, align 16
  %v8 = getelementptr float, ptr %view, i64 0
  %loaded = load <4 x float>, ptr %v8, align 16
  ret <4 x float> %loaded
}

// ====

// Prefetch hints lower to llvm.prefetch with explicit read/write locality.
func.def public @prefetch_row(%buffer: buffer, %offset: offset, %index: index) {
  %view = buffer.view %buffer[%offset] : buffer -> view<16xf32, #dense>
  view.prefetch %view[%index] {intent = read, locality = l2} : view<16xf32, #dense>
  view.prefetch %view[%index] {intent = write, locality = l3} : view<16xf32, #dense>
  func.return
}

// ----
define dso_local void @prefetch_row(ptr %buffer, i64 %offset, i64 %index) {
entry:
  %view = getelementptr i8, ptr %buffer, i64 %offset
  %v4 = getelementptr float, ptr %view, i64 %index
  call void @llvm.prefetch.p0(ptr %v4, i32 0, i32 2, i32 1)
  %v12 = getelementptr float, ptr %view, i64 %index
  call void @llvm.prefetch.p0(ptr %v12, i32 1, i32 3, i32 1)
  ret void
}

declare void @llvm.prefetch.p0(ptr readonly nocapture, i32 immarg, i32 immarg, i32 immarg)

// ====

// A small x86 vector memory kernel preserves offset math and vector fadd.
func.def public @saxpy4_object(%x: buffer, %y: buffer, %out: buffer, %base: index) {
  %zero = index.constant 0 : offset
  %step = index.constant 4 : index
  %next = index.add %base, %step : index
  %x_view = buffer.view %x[%zero] : buffer -> view<1024xf32, #dense>
  %y_view = buffer.view %y[%zero] : buffer -> view<1024xf32, #dense>
  %out_view = buffer.view %out[%zero] : buffer -> view<1024xf32, #dense>
  %xv = vector.load %x_view[%base] : view<1024xf32, #dense> -> vector<4xf32>
  %yv = vector.load %y_view[%next] : view<1024xf32, #dense> -> vector<4xf32>
  %sum = vector.addf<nnan> %xv, %yv : vector<4xf32>
  vector.store %sum, %out_view[%next] : vector<4xf32>, view<1024xf32, #dense>
  func.return
}

// ----
define dso_local void @saxpy4_object(ptr %x, ptr %y, ptr %out, i64 %base) {
entry:
  %next = add i64 %base, 4
  %x_view = getelementptr i8, ptr %x, i64 0
  %y_view = getelementptr i8, ptr %y, i64 0
  %out_view = getelementptr i8, ptr %out, i64 0
  %v10 = getelementptr float, ptr %x_view, i64 %base
  %xv = load <4 x float>, ptr %v10
  %v12 = getelementptr float, ptr %y_view, i64 %next
  %yv = load <4 x float>, ptr %v12
  %sum = fadd nnan <4 x float> %xv, %yv
  %v15 = getelementptr float, ptr %out_view, i64 %next
  store <4 x float> %sum, ptr %v15
  ret void
}

// ====
// RUN: emit llvmir-body amdgpu-hal

// AMDGPU dense vector memory uses global address-space pointers.
func.def public device @vector_dispatch(%input: buffer, %output: buffer, %base: index) {
  %zero = index.constant 0 : offset
  %input_view = buffer.view %input[%zero] : buffer -> view<1024xf32, #dense>
  %output_view = buffer.view %output[%zero] : buffer -> view<1024xf32, #dense>
  %loaded = vector.load %input_view[%base] : view<1024xf32, #dense> -> vector<4xf32>
  vector.store %loaded, %output_view[%base] : vector<4xf32>, view<1024xf32, #dense>
  func.return
}

// ----
define amdgpu_kernel void @vector_dispatch(ptr addrspace(1) inreg noalias noundef nonnull align 16 %input, ptr addrspace(1) inreg noalias noundef nonnull align 16 %output, i32 %base) #0 !reqd_work_group_size !0 {
entry:
  %input_view = getelementptr i8, ptr addrspace(1) %input, i64 0
  %output_view = getelementptr i8, ptr addrspace(1) %output, i64 0
  %v9 = getelementptr float, ptr addrspace(1) %input_view, i32 %base
  %loaded = load <4 x float>, ptr addrspace(1) %v9, align 4
  %v11 = getelementptr float, ptr addrspace(1) %output_view, i32 %base
  store <4 x float> %loaded, ptr addrspace(1) %v11, align 4
  ret void
}

attributes #0 = { alwaysinline "amdgpu-flat-work-group-size"="64,64" "uniform-work-group-size" }

!0 = !{i32 64, i32 1, i32 1}
