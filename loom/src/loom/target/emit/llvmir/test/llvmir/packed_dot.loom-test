// RUN: emit llvmir-body x86_64-packed-dot-object

// BF16 dot2f lowers to the AVX512 BF16 two-lane dot intrinsic.
func.def @dot2_bf16(%lhs: vector<16xbf16>, %rhs: vector<16xbf16>, %acc: vector<8xf32>) -> (vector<8xf32>) {
  %dot = vector.dot2f %lhs, %rhs, %acc : vector<16xbf16>, vector<16xbf16>, vector<8xf32>
  func.return %dot : vector<8xf32>
}

// ----
define internal <8 x float> @dot2_bf16(<16 x bfloat> %lhs, <16 x bfloat> %rhs, <8 x float> %acc) {
entry:
  %dot = call <8 x float> @llvm.x86.avx512bf16.dpbf16ps.256(<8 x float> %acc, <16 x bfloat> %lhs, <16 x bfloat> %rhs)
  ret <8 x float> %dot
}

declare <8 x float> @llvm.x86.avx512bf16.dpbf16ps.256(<8 x float>, <16 x bfloat>, <16 x bfloat>)

// ====

// Signed i8 dot4i lowers through the signed AVX VNNI INT8 intrinsic ABI.
func.def @dot4_s8s8(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<s8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
define internal <8 x i32> @dot4_s8s8(<32 x i8> %lhs, <32 x i8> %rhs, <8 x i32> %acc) {
entry:
  %v3 = bitcast <32 x i8> %lhs to <8 x i32>
  %v4 = bitcast <32 x i8> %rhs to <8 x i32>
  %dot = call <8 x i32> @llvm.x86.avx2.vpdpbssd.256(<8 x i32> %acc, <8 x i32> %v3, <8 x i32> %v4)
  ret <8 x i32> %dot
}

declare <8 x i32> @llvm.x86.avx2.vpdpbssd.256(<8 x i32>, <8 x i32>, <8 x i32>)

// ====

// Unsigned-by-signed i8 dot4i lowers through the AVX VNNI u8*s8 intrinsic ABI.
func.def @dot4_u8s8(%lhs: vector<32xi8>, %rhs: vector<32xi8>, %acc: vector<8xi32>) -> (vector<8xi32>) {
  %dot = vector.dot4i<u8s8> %lhs, %rhs, %acc : vector<32xi8>, vector<32xi8>, vector<8xi32>
  func.return %dot : vector<8xi32>
}

// ----
define internal <8 x i32> @dot4_u8s8(<32 x i8> %lhs, <32 x i8> %rhs, <8 x i32> %acc) {
entry:
  %v3 = bitcast <32 x i8> %lhs to <8 x i32>
  %v4 = bitcast <32 x i8> %rhs to <8 x i32>
  %dot = call <8 x i32> @llvm.x86.avx512.vpdpbusd.256(<8 x i32> %acc, <8 x i32> %v3, <8 x i32> %v4)
  ret <8 x i32> %dot
}

declare <8 x i32> @llvm.x86.avx512.vpdpbusd.256(<8 x i32>, <8 x i32>, <8 x i32>)
