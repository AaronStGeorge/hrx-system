// RUN: emit llvmir @direct_llvm_projection

llvmir.target<object> @direct_llvm_projection {
  triple = "loom-direct64-unknown-none",
  data_layout = "e-p:64:64-i64:64-n8:16:32:64-S128",
  cpu = "direct-cpu",
  features = "+direct-feature"
}

func.def @projection_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
source_filename = "loom/src/loom/target/emit/llvmir/test/llvmir/target_projection.loom-test"
target datalayout = "e-p:64:64-i64:64-n8:16:32:64-S128"
target triple = "loom-direct64-unknown-none"

define internal i32 @projection_add(i32 %lhs, i32 %rhs) {
entry:
  %sum = add i32 %lhs, %rhs
  ret i32 %sum
}
