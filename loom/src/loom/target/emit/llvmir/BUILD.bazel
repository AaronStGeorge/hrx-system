loom_cc_test(
    name = "text_writer_test",
    srcs = ["text_writer_test.cc"],
    deps = [
        ":core",
        ":test_modules_core",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "text_writer_target_test",
    srcs = ["text_writer_test.cc"],
    defines = ["LOOM_LLVMIR_TEXT_WRITER_TEST_TARGET_SCENARIOS=1"],
    deps = [
        ":core",
        ":test_modules",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "module_emitter_test",
    srcs = ["module_emitter_test.cc"],
    deps = [
        ":core",
        ":module_emitter",
        "//loom/src/loom/codegen/low:text_asm",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_registry",
        "//loom/src/loom/target/arch/llvmir/descriptors:low_registry",
        "//loom/src/loom/testing:diagnostic_matchers",
        "//loom/src/loom/testing:module_ptr",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "target_env_test",
    srcs = ["target_env_test.cc"],
    deps = [
        ":core",
        ":target_env",
        ":target_presets",
        "//loom/src/loom/target/emit/llvmir/amdgpu:target_env",
        "//loom/src/loom/target/emit/llvmir/x86:target_env",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "tool_test",
    srcs = ["tool_test.cc"],
    tags = ["requires-filesystem"],
    deps = [
        ":core",
        ":test_modules",
        "//loom/src/loom/target/tool:llvm",
        "//loom/src/loom/util:stream",
        "//runtime/src/iree/io:file_handle",
        "//runtime/src/iree/io:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "verify_test",
    srcs = ["verify_test.cc"],
    deps = [
        ":core",
        "//runtime/src/iree/testing:gtest",
