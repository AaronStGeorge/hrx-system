loom_cc_test(
    name = "bitcode_writer_target_test",
    srcs = ["bitcode_writer_test.cc"],
    defines = ["LOOM_LLVMIR_BITCODE_WRITER_TEST_TARGET_SCENARIOS=1"],
    deps = [
        ":core",
        ":target_env",
        ":test_modules",
        "//runtime/src/iree/io:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
