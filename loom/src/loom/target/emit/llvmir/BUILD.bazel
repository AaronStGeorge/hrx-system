        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "bitstream_writer_test",
    srcs = ["bitstream_writer_test.cc"],
    deps = [
        ":core",
        "//runtime/src/iree/io:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "bitcode_writer_test",
    srcs = ["bitcode_writer_test.cc"],
    deps = [
        ":core",
        ":target_env",
        ":test_modules_core",
        "//runtime/src/iree/io:stream",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
