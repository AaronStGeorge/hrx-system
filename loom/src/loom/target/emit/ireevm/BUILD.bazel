#===------------------------------------------------------------------------===#
# IREE VM low descriptors
#===------------------------------------------------------------------------===#

loom_low_descriptor_cc_library(
    name = "descriptors",
    args = ["--descriptor-set=ireevm_core"],
    cmake_generator = "//loom/py/loom:gen/low_descriptor_shard.py",
    cmake_generator_deps = [
        "//loom/py/loom:gen/low_descriptors.py",
        "//loom/py/loom:target/descriptor_sets.py",
        "//loom/py/loom:target/emit/ireevm/descriptors.py",
        "//loom/py/loom:target/low_descriptors.py",
    ],
    generator = "//loom/py/loom:ireevm_low_descriptor_shard",
    header = "descriptors.h",
    source = "descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "function_bytecode",
    srcs = ["function_bytecode.c"],
    hdrs = ["function_bytecode.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:allocation",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:packet",
        "//loom/src/loom/codegen/low:schedule",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/low",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "module_archive",
    srcs = ["module_archive.c"],
    hdrs = ["module_archive.h"],
    deps = [
        ":function_bytecode",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal/flatcc:building",
        "//runtime/src/iree/schemas:bytecode_module_def_c_fbs",
        "//runtime/src/iree/vm/bytecode/utils",
    ],
)

loom_cc_library(
    name = "module_compiler",
    srcs = ["module_compiler.c"],
    hdrs = ["module_compiler.h"],
    deps = [
        ":function_bytecode",
        ":low_registry",
        ":lower",
        ":module_archive",
        "//loom/src/loom/codegen/low:packetization",
        "//loom/src/loom/codegen/low:verify",
        "//loom/src/loom/error:diagnostic",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/func",
        "//loom/src/loom/ops/target",
        "//loom/src/loom/target:ir_records",
        "//loom/src/loom/target:module_compiler",
        "//loom/src/loom/target:presets",
        "//loom/src/loom/verify",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "lower",
    srcs = ["lower.c"],
    hdrs = ["lower.h"],
    deps = [
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/scalar",
