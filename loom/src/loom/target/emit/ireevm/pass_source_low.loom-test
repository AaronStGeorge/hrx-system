// RUN: pass source-to-low{target=@vm_target}
target.preset @vm_target {key = "iree-vm", source = @vm_add}

func.def @vm_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
target.snapshot @vm_target__snapshot {artifact_format = vm_bytecode, codegen_format = vm, data_layout = "", default_pointer_bitwidth = 64, index_bitwidth = 64, memory_space_constant = 0, memory_space_descriptor = 4294967295, memory_space_generic = 0, memory_space_global = 0, memory_space_host = 0, memory_space_private = 0, memory_space_workgroup = 4294967295, offset_bitwidth = 64, target_cpu = "iree-vm", target_features = "", target_triple = "iree-vm"}

target.export @vm_target__export {abi = vm_module_function, export_symbol = "vm_add", hal_binding_alignment = 0, hal_buffer_resource_flags = 0, hal_flat_workgroup_size_max = 0, hal_flat_workgroup_size_min = 0, hal_workgroup_size_x = 0, hal_workgroup_size_y = 0, hal_workgroup_size_z = 0, linkage = default, source = @vm_add}

target.config @vm_target__config {contract_feature_bits = 0, contract_set_key = "iree.vm.core"}

target.bundle @vm_target {config = @vm_target__config, export_plan = @vm_target__export, snapshot = @vm_target__snapshot}

func.def @vm_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

low.func.def target(@vm_target) @vm_add__low(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>) {
  %sum = low.op<iree.vm.add.i32>(%lhs, %rhs) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %sum : reg<vm.i32>
}
