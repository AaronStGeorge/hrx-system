// RUN: emit source-low output=low
target.generic<reference> @vm_target {contract_set_key = "iree.vm.core"}

func.def target(@vm_target) @vm_add(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}
// ----
low.func.def target(@vm_target) abi(vm_module_function) @vm_add(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>) asm<iree.vm.core> {
  %sum = vm.add.i32 %lhs, %rhs
  return %sum
}
