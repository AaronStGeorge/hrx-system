        # 2 functions in section.

<double>:

  local.get  0
  local.get  0
  i32x4.add
  local.set  0
  local.get  0
  return
  end

<entry>:

  local.get  0
  call  0
  local.set  0
  local.get  0
  call  0
  local.set  0
  local.get  0
  return
  end
