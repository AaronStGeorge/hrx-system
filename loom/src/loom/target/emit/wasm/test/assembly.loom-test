// RUN: emit wasm-dis
// REQUIRES: wasm-objdump

wasm.target<simd128> @target

low.func.def target(@target) abi(wasm_function) @for_without_iter_args(%lo: reg<wasm.i32>, %hi: reg<wasm.i32>, %step: reg<wasm.i32>, %lhs: reg<wasm.v128>, %rhs: reg<wasm.v128>) {
  low.scf.for [%lo to %hi step %step] do(%iv: reg<wasm.i32>) {
    %sum = low.op<wasm.i32x4.add>(%lhs, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  }
  low.return
}

low.func.def public target(@target) abi(wasm_function) @for_with_iter_args(%lo: reg<wasm.i32>, %hi: reg<wasm.i32>, %step: reg<wasm.i32>, %seed: reg<wasm.v128>, %bias: reg<wasm.v128>) -> (reg<wasm.v128>) {
  %result = low.scf.for [%lo to %hi step %step] iter_args(%seed: reg<wasm.v128>) -> (reg<wasm.v128>) do(%iv: reg<wasm.i32>, %acc: reg<wasm.v128>) {
    %next = low.op<wasm.i32x4.add>(%acc, %bias) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
    low.scf.yield %next : reg<wasm.v128>
  }
  %combined = low.op<wasm.i32x4.add>(%result, %seed) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  low.return %combined : reg<wasm.v128>
}

