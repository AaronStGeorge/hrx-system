// RUN: emit wasm-dis
// REQUIRES: wasm-objdump

wasm.target<simd128> @target

low.func.def target(@target) abi(wasm_function) @blend_i32x4(%control: reg<wasm.i32>, %lhs: reg<wasm.v128>, %rhs: reg<wasm.v128>, %bias: reg<wasm.v128>) -> (reg<wasm.v128>) asm<wasm.core.simd128> {
  %mask = i32x4.lt_s %lhs, %rhs
  %sum = i32x4.add %lhs, %bias
  %diff = i32x4.sub %rhs, %bias
  %selected = low.scf.if %control -> (reg<wasm.v128>) {
    %then = v128.bitselect %sum, %diff, %mask
    low.scf.yield %then : reg<wasm.v128>
  } else {
    %else = i32x4.mul %sum, %diff
    low.scf.yield %else : reg<wasm.v128>
  }
  return %selected
}

low.func.def public target(@target) abi(wasm_function) @simd_memory_pipeline(%lo: reg<wasm.i32>, %hi: reg<wasm.i32>, %step: reg<wasm.i32>, %input_base: reg<wasm.i32>, %bias_base: reg<wasm.i32>, %output_base: reg<wasm.i32>, %control: reg<wasm.i32>) {
  low.scf.for [%lo to %hi step %step] do(%offset: reg<wasm.i32>) {
    %input_address = low.op<wasm.i32.add>(%input_base, %offset) : (reg<wasm.i32>, reg<wasm.i32>) -> reg<wasm.i32>
    %bias_address = low.op<wasm.i32.add>(%bias_base, %offset) : (reg<wasm.i32>, reg<wasm.i32>) -> reg<wasm.i32>
    %output_address = low.op<wasm.i32.add>(%output_base, %offset) : (reg<wasm.i32>, reg<wasm.i32>) -> reg<wasm.i32>
    %input = low.op<wasm.v128.load>(%input_address) : (reg<wasm.i32>) -> reg<wasm.v128>
    %bias = low.op<wasm.v128.load>(%bias_address) : (reg<wasm.i32>) -> reg<wasm.v128>
    %result = low.func.call @blend_i32x4(%control, %input, %bias, %bias) : (reg<wasm.i32>, reg<wasm.v128>, reg<wasm.v128>, reg<wasm.v128>) -> (reg<wasm.v128>)
    low.op<wasm.v128.store>(%output_address, %result) : (reg<wasm.i32>, reg<wasm.v128>)
  }
  low.return
}

