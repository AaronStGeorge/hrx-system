// RUN: emit wasm-dis
// REQUIRES: wasm-objdump

wasm.target<simd128> @target

low.func.def target(@target) abi(wasm_function) @fold_i32x4(%value: reg<wasm.v128>, %init: reg<wasm.i32>, %limit: reg<wasm.i32>) -> (reg<wasm.i32>) asm<wasm.core.simd128> {
  %reversed = i8x16.shuffle %value, %value, 12, 13, 14, 15, 8, 9, 10, 11, 4, 5, 6, 7, 0, 1, 2, 3
  %lane0 = i32x4.extract_lane %reversed, 0
  %sum0 = i32.add %init, %lane0
  %lane1 = i32x4.extract_lane %reversed, 1
  %sum1 = i32.add %sum0, %lane1
  %lane2 = i32x4.extract_lane %reversed, 2
  %sum2 = i32.add %sum1, %lane2
  %lane3 = i32x4.extract_lane %reversed, 3
  %sum = i32.add %sum2, %lane3
  %cond = i32.lt_u %sum, %limit
  %result = low.scf.if %cond -> (reg<wasm.i32>) {
    %raised = i32.add %sum, %limit
    low.scf.yield %raised : reg<wasm.i32>
  } else {
    low.scf.yield %sum : reg<wasm.i32>
  }
  return %result
}

low.func.def target(@target) abi(wasm_function) @float_lane_mix(%value: reg<wasm.v128>, %bias: reg<wasm.v128>, %scalar: reg<wasm.f32>) -> (reg<wasm.v128>) asm<wasm.core.simd128> {
  %sum = f32x4.add %value, %bias
  %product = f32x4.mul %sum, %bias
  %lane = f32x4.extract_lane %product, 1
  %bumped = f32.add %lane, %scalar
  %updated = f32x4.replace_lane %product, %bumped, 2
  return %updated
}

low.func.def public target(@target) abi(wasm_function) @simd_lane_kernel(%lane_value: reg<wasm.i32>, %value: reg<wasm.v128>, %init: reg<wasm.i32>, %limit: reg<wasm.i32>, %float_value: reg<wasm.v128>, %float_bias: reg<wasm.v128>, %scalar: reg<wasm.f32>) -> (reg<wasm.i32>, reg<wasm.v128>) {
  %splat = low.op<wasm.i32x4.splat>(%lane_value) : (reg<wasm.i32>) -> reg<wasm.v128>
  %edited = low.op<wasm.i32x4.replace_lane>(%splat, %lane_value) {lane = 2} : (reg<wasm.v128>, reg<wasm.i32>) -> reg<wasm.v128>
  %combined = low.op<wasm.i32x4.add>(%edited, %value) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  %total = low.func.call @fold_i32x4(%combined, %init, %limit) : (reg<wasm.v128>, reg<wasm.i32>, reg<wasm.i32>) -> (reg<wasm.i32>)
  %mixed = low.func.call @float_lane_mix(%float_value, %float_bias, %scalar) : (reg<wasm.v128>, reg<wasm.v128>, reg<wasm.f32>) -> (reg<wasm.v128>)
  low.return %total, %mixed : reg<wasm.i32>, reg<wasm.v128>
}

