wasm module validated: wasm_f32_arithmetic

// ====
// RUN: emit wasm-module-validate @wasm_splat export=wasm_splat
// REQUIRES: wasm-validate
target.preset @wasm_splat_target {key = "wasm-simd128", source = @wasm_splat}

low.func.def target(@wasm_splat_target) @wasm_splat(%value: reg<wasm.i32>, %rhs: reg<wasm.v128>) -> (reg<wasm.v128>) {
  %splat = low.op<wasm.i32x4.splat>(%value) : (reg<wasm.i32>) -> reg<wasm.v128>
  %sum = low.op<wasm.i32x4.add>(%splat, %rhs) : (reg<wasm.v128>, reg<wasm.v128>) -> reg<wasm.v128>
  low.return %sum : reg<wasm.v128>
}

// ----
wasm module validated: wasm_splat
