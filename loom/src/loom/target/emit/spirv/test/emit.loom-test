// RUN: emit spirv-dis @empty_entry validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi(shader_entry_point) @empty_entry() asm<spirv.logical.core> {
  return
}

// ----
               OpCapability Shader
               OpCapability VulkanMemoryModel
               OpCapability PhysicalStorageBufferAddresses
               OpCapability Int64
               OpExtension "SPV_KHR_vulkan_memory_model"
               OpExtension "SPV_KHR_physical_storage_buffer"
               OpMemoryModel PhysicalStorageBuffer64 Vulkan
               OpEntryPoint GLCompute %empty_entry "empty_entry"
               OpExecutionMode %empty_entry LocalSize 1 1 1
               OpName %empty_entry "empty_entry"
       %void = OpTypeVoid
          %3 = OpTypeFunction %void
%empty_entry = OpFunction %void None %3
          %4 = OpLabel
               OpReturn
               OpFunctionEnd

// ====

// RUN: emit spirv-dis @spirv_i32_arithmetic validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi(shader_entry_point) @spirv_i32_arithmetic(%lhs: reg<spirv.id>, %rhs: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %bias = OpConstant.i32 7
  %sum = OpIAdd %lhs, %rhs
  %result = OpIAdd %sum, %bias
  return %result
}

// ----
               OpCapability Shader
               OpCapability VulkanMemoryModel
               OpCapability PhysicalStorageBufferAddresses
               OpCapability Int64
               OpExtension "SPV_KHR_vulkan_memory_model"
               OpExtension "SPV_KHR_physical_storage_buffer"
               OpMemoryModel PhysicalStorageBuffer64 Vulkan
               OpEntryPoint GLCompute %spirv_i32_arithmetic "spirv_i32_arithmetic"
               OpExecutionMode %spirv_i32_arithmetic LocalSize 1 1 1
               OpName %spirv_i32_arithmetic "spirv_i32_arithmetic"
               OpName %lhs "lhs"
               OpName %rhs "rhs"
               OpName %bias "bias"
               OpName %sum "sum"
               OpName %result "result"
               OpMemberDecorate %_struct_5 0 Offset 0
               OpDecorate %_struct_5 Block
               OpDecorate %4 DescriptorSet 0
               OpDecorate %4 Binding 0
               OpDecorate %8 DescriptorSet 0
               OpDecorate %8 Binding 1
               OpDecorate %9 DescriptorSet 0
               OpDecorate %9 Binding 2
        %int = OpTypeInt 32 1
      %int_0 = OpConstant %int 0
  %_struct_5 = OpTypeStruct %int
%_ptr_StorageBuffer__struct_5 = OpTypePointer StorageBuffer %_struct_5
%_ptr_StorageBuffer_int = OpTypePointer StorageBuffer %int
          %4 = OpVariable %_ptr_StorageBuffer__struct_5 StorageBuffer
          %8 = OpVariable %_ptr_StorageBuffer__struct_5 StorageBuffer
          %9 = OpVariable %_ptr_StorageBuffer__struct_5 StorageBuffer
       %void = OpTypeVoid
         %11 = OpTypeFunction %void
       %bias = OpConstant %int 7
%spirv_i32_arithmetic = OpFunction %void None %11
         %12 = OpLabel
         %13 = OpAccessChain %_ptr_StorageBuffer_int %4 %int_0
        %lhs = OpLoad %int %13 Aligned 4
         %15 = OpAccessChain %_ptr_StorageBuffer_int %8 %int_0
        %rhs = OpLoad %int %15 Aligned 4
        %sum = OpIAdd %int %lhs %rhs
     %result = OpIAdd %int %sum %bias
         %20 = OpAccessChain %_ptr_StorageBuffer_int %9 %int_0
               OpStore %20 %result Aligned 4
               OpReturn
               OpFunctionEnd

