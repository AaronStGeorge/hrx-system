// RUN: emit spirv-dis @spirv_raw_bda_storage_buffer_f32_copy validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_raw_bda_storage_buffer_f32_copy(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %input_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.f32 %input_view
  %sum = OpFAdd.f32 %loaded, %loaded
  %product = OpFMul.f32 %sum, %loaded
  %quotient = OpFDiv.f32 %product, %loaded
  %remainder = OpFRem.f32 %quotient, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %output, %byte_offset
  OpStore.storage_buffer.f32 %output_view, %remainder
  return
}

