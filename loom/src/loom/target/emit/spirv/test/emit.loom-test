spirv.target<vulkan1_3> @hal_target {abi = hal_kernel, contract_feature_bits = 33278}

low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_raw_bda_scalar_conversions(%byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
