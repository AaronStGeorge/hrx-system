// RUN: emit spirv-dis @spirv_storage_buffer_i32_roundtrip validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi(shader_entry_point) @spirv_storage_buffer_i32_roundtrip(%input: reg<spirv.ptr.storage_buffer>, %output: reg<spirv.ptr.storage_buffer>, %byte_offset: reg<spirv.offset64>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %input_view = OpPtrAccessChain.storage_buffer.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %incremented = OpIAdd %loaded, %loaded
  %output_view = OpPtrAccessChain.storage_buffer.byte_offset %output, %byte_offset
  OpStore.storage_buffer.i32 %output_view, %incremented
  return %loaded
}

// ----
               OpCapability Shader
               OpCapability VulkanMemoryModel
               OpCapability PhysicalStorageBufferAddresses
               OpCapability Int64
               OpExtension "SPV_KHR_vulkan_memory_model"
               OpExtension "SPV_KHR_physical_storage_buffer"
               OpMemoryModel PhysicalStorageBuffer64 Vulkan
               OpEntryPoint GLCompute %spirv_storage_buffer_i32_roundtrip "spirv_storage_buffer_i32_roundtrip"
               OpExecutionMode %spirv_storage_buffer_i32_roundtrip LocalSize 1 1 1
               OpName %spirv_storage_buffer_i32_roundtrip "spirv_storage_buffer_i32_roundtrip"
               OpName %input "input"
               OpName %output "output"
               OpName %byte_offset "byte_offset"
               OpName %input_view "input_view"
               OpName %loaded "loaded"
               OpName %incremented "incremented"
               OpName %output_view "output_view"
               OpDecorate %_ptr_PhysicalStorageBuffer_int ArrayStride 1
               OpMemberDecorate %_struct_7 0 Offset 0
               OpDecorate %_struct_7 Block
               OpDecorate %4 DescriptorSet 0
               OpDecorate %4 Binding 0
               OpDecorate %10 DescriptorSet 0
               OpDecorate %10 Binding 1
               OpDecorate %11 DescriptorSet 0
               OpDecorate %11 Binding 2
               OpMemberDecorate %_struct_13 0 Offset 0
               OpDecorate %_struct_13 Block
               OpDecorate %12 DescriptorSet 0
               OpDecorate %12 Binding 3
        %int = OpTypeInt 32 1
      %int_0 = OpConstant %int 0
%_ptr_PhysicalStorageBuffer_int = OpTypePointer PhysicalStorageBuffer %int
      %ulong = OpTypeInt 64 0
  %_struct_7 = OpTypeStruct %ulong
%_ptr_StorageBuffer__struct_7 = OpTypePointer StorageBuffer %_struct_7
%_ptr_StorageBuffer_ulong = OpTypePointer StorageBuffer %ulong
          %4 = OpVariable %_ptr_StorageBuffer__struct_7 StorageBuffer
         %10 = OpVariable %_ptr_StorageBuffer__struct_7 StorageBuffer
         %11 = OpVariable %_ptr_StorageBuffer__struct_7 StorageBuffer
 %_struct_13 = OpTypeStruct %int
%_ptr_StorageBuffer__struct_13 = OpTypePointer StorageBuffer %_struct_13
%_ptr_StorageBuffer_int = OpTypePointer StorageBuffer %int
         %12 = OpVariable %_ptr_StorageBuffer__struct_13 StorageBuffer
       %void = OpTypeVoid
         %17 = OpTypeFunction %void
%spirv_storage_buffer_i32_roundtrip = OpFunction %void None %17
         %18 = OpLabel
         %19 = OpAccessChain %_ptr_StorageBuffer_ulong %4 %int_0
         %20 = OpLoad %ulong %19 Aligned 8
      %input = OpConvertUToPtr %_ptr_PhysicalStorageBuffer_int %20
         %22 = OpAccessChain %_ptr_StorageBuffer_ulong %10 %int_0
         %23 = OpLoad %ulong %22 Aligned 8
     %output = OpConvertUToPtr %_ptr_PhysicalStorageBuffer_int %23
         %25 = OpAccessChain %_ptr_StorageBuffer_ulong %11 %int_0
%byte_offset = OpLoad %ulong %25 Aligned 8
 %input_view = OpPtrAccessChain %_ptr_PhysicalStorageBuffer_int %input %byte_offset
     %loaded = OpLoad %int %input_view Aligned 4
%incremented = OpIAdd %int %loaded %loaded
%output_view = OpPtrAccessChain %_ptr_PhysicalStorageBuffer_int %output %byte_offset
               OpStore %output_view %incremented Aligned 4
         %31 = OpAccessChain %_ptr_StorageBuffer_int %12 %int_0
               OpStore %31 %loaded Aligned 4
               OpReturn
               OpFunctionEnd
