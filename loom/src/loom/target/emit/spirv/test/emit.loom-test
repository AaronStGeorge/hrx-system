// RUN: emit spirv-dis @spirv_i32_arithmetic validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi(shader_entry_point) @spirv_i32_arithmetic(%lhs: reg<spirv.id>, %rhs: reg<spirv.id>) -> (reg<spirv.id>) asm<spirv.logical.core> {
  %bias = OpConstant.i32 7
  %sum = OpIAdd %lhs, %rhs
  %difference = OpISub %sum, %bias
  %product = OpIMul %difference, %rhs
  %scaled = OpIMulAdd %product, %rhs, %bias
  %result = OpIAdd %scaled, %bias
  return %result
}

