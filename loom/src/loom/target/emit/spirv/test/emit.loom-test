low.kernel.def target(@hal_target_scalar_payloads) abi_layout({spirv_arg_value_types = [1, 21, 22, 17, 20, 18, 19, 24, 0]}) workgroup_size(1, 1, 1) @spirv_raw_bda_direct_scalar_payloads(%flag: reg<spirv.id>, %i8: reg<spirv.id>, %i16: reg<spirv.id>, %f16: reg<spirv.id>, %bf16: reg<spirv.id>, %f32: reg<spirv.id>, %f64: reg<spirv.id>, %i64: reg<spirv.id>, %byte_offset: reg<spirv.offset64>) asm<spirv.logical.core> {
  %output_flag = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_i8 = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_i16 = resource<hal_binding> {index = 2, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_f16 = resource<hal_binding> {index = 3, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_bf16 = resource<hal_binding> {index = 4, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_f32 = resource<hal_binding> {index = 5, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_f64 = resource<hal_binding> {index = 6, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output_i64 = resource<hal_binding> {index = 7, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %zero = OpConstant.i32 0
  %one = OpConstant.i32 1
  %flag_i32 = OpSelect %flag, %one, %zero
  %flag_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output_flag, %byte_offset
  OpStore.storage_buffer.i32 %flag_view, %flag_i32
  %i8_view = OpPtrAccessChain.storage_buffer.i8.byte_offset %output_i8, %byte_offset
  OpStore.storage_buffer.i8 %i8_view, %i8
  %i16_view = OpPtrAccessChain.storage_buffer.i16.byte_offset %output_i16, %byte_offset
  OpStore.storage_buffer.i16 %i16_view, %i16
  %f16_view = OpPtrAccessChain.storage_buffer.f16.byte_offset %output_f16, %byte_offset
  OpStore.storage_buffer.f16 %f16_view, %f16
  %bf16_view = OpPtrAccessChain.storage_buffer.bf16.byte_offset %output_bf16, %byte_offset
  OpStore.storage_buffer.bf16 %bf16_view, %bf16
  %f32_sum = OpFAdd.f32 %f32, %f32
  %f32_view = OpPtrAccessChain.storage_buffer.f32.byte_offset %output_f32, %byte_offset
  OpStore.storage_buffer.f32 %f32_view, %f32_sum
  %f64_sum = OpFAdd.f64 %f64, %f64
  %f64_view = OpPtrAccessChain.storage_buffer.f64.byte_offset %output_f64, %byte_offset
  OpStore.storage_buffer.f64 %f64_view, %f64_sum
