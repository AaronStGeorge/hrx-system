%_ptr_PushConstant_uint = OpTypePointer PushConstant %uint
        %int = OpTypeInt 32 1
      %int_6 = OpConstant %int 6
      %int_0 = OpConstant %int 0
      %int_1 = OpConstant %int 1
   %ulong_32 = OpConstant %ulong 32
%_ptr_PushConstant_ulong = OpTypePointer PushConstant %ulong
%_runtimearr_ulong = OpTypeRuntimeArray %ulong
 %_struct_28 = OpTypeStruct %_runtimearr_ulong
%_ptr_PhysicalStorageBuffer__struct_28 = OpTypePointer PhysicalStorageBuffer %_struct_28
      %int_2 = OpConstant %int 2
%_ptr_PhysicalStorageBuffer_ulong = OpTypePointer PhysicalStorageBuffer %ulong
