// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

low.kernel.def target(@hal_target) workgroup_size(1, 2, 1) @spirv_raw_bda_builtin_storage_buffer_i32() asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %workgroup_x = OpLoadBuiltin.workgroup_id.x
  %local_y = OpLoadBuiltin.local_invocation_id.y
  %global_z = OpLoadBuiltin.global_invocation_id.z
  %sum = OpIAdd %workgroup_x, %local_y
  %linear = OpIAdd %sum, %global_z
  %shift = OpConstant.i32 2
  %byte_index = OpShiftLeftLogical %linear, %shift
  %byte_offset = OpUConvert.i32.offset64 %byte_index
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input, %byte_offset
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output, %byte_offset
  OpStore.storage_buffer.i32 %output_view, %loaded
  return
}

