  %output_trunc_i32_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output_trunc_i32, %byte_offset
  OpStore.storage_buffer.i32 %output_trunc_i32_view, %truncated_i32
  %input_f16_view = OpPtrAccessChain.storage_buffer.f16.byte_offset %input_f16, %byte_offset
  %loaded_f16 = OpLoad.storage_buffer.f16 %input_f16_view
  %extended_f32 = OpFConvert.f16.f32 %loaded_f16
