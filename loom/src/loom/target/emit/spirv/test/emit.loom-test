// RUN: emit spirv-dis @spirv_raw_bda_storage_buffer_i32_select validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @hal_target {abi = hal_kernel}

low.kernel.def target(@hal_target) workgroup_size(1, 1, 1) @spirv_raw_bda_storage_buffer_i32_select(%byte_offset: reg<spirv.offset64>, %limit: reg<spirv.offset64>) asm<spirv.logical.core> {
  %input = resource<hal_binding> {index = 0, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %output = resource<hal_binding> {index = 1, source_type = hal.buffer} : reg<spirv.ptr.storage_buffer>
  %zero_offset = OpConstant.offset64 0
  %inside = OpULessThanEqual.offset64 %byte_offset, %limit
  %selected_offset = OpSelect.offset64 %inside, %byte_offset, %zero_offset
  %input_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %input, %selected_offset
  %loaded = OpLoad.storage_buffer.i32 %input_view
  %zero = OpConstant.i32 0
  %one = OpConstant.i32 1
  %positive = OpSGreaterThan %loaded, %zero
  %selected = OpSelect %positive, %loaded, %zero
  %quotient = OpSDiv %selected, %one
  %remainder = OpSRem %quotient, %one
  %output_view = OpPtrAccessChain.storage_buffer.i32.byte_offset %output, %selected_offset
  OpStore.storage_buffer.i32 %output_view, %remainder
  return
}

