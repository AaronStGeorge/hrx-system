%spirv_raw_bda_storage_buffer_i32_roundtrip = OpFunction %void None %10
         %11 = OpLabel
         %16 = OpAccessChain %_ptr_PushConstant_uint %8 %int_6 %int_0
         %17 = OpLoad %uint %16 Aligned 4
         %19 = OpAccessChain %_ptr_PushConstant_uint %8 %int_6 %int_1
         %20 = OpLoad %uint %19 Aligned 4
         %21 = OpUConvert %ulong %17
         %22 = OpUConvert %ulong %20
         %24 = OpShiftLeftLogical %ulong %22 %ulong_32
%byte_offset = OpBitwiseOr %ulong %24 %21
         %31 = OpAccessChain %_ptr_PushConstant_ulong %8 %int_0
         %32 = OpLoad %ulong %31 Aligned 8
         %33 = OpConvertUToPtr %_ptr_PhysicalStorageBuffer__struct_28 %32
         %34 = OpAccessChain %_ptr_PushConstant_uint %8 %int_2
         %35 = OpLoad %uint %34 Aligned 4
         %37 = OpAccessChain %_ptr_PhysicalStorageBuffer_ulong %33 %int_0 %35
         %38 = OpLoad %ulong %37 Aligned 8
      %input = OpConvertUToPtr %_ptr_PhysicalStorageBuffer_int %38
         %42 = OpIAdd %uint %35 %uint_1
         %43 = OpAccessChain %_ptr_PhysicalStorageBuffer_ulong %33 %int_0 %42
         %44 = OpLoad %ulong %43 Aligned 8
     %output = OpConvertUToPtr %_ptr_PhysicalStorageBuffer_int %44
 %input_view = OpPtrAccessChain %_ptr_PhysicalStorageBuffer_int %input %byte_offset
     %loaded = OpLoad %int %input_view Aligned 4
%incremented = OpIAdd %int %loaded %loaded
%output_view = OpPtrAccessChain %_ptr_PhysicalStorageBuffer_int %output %byte_offset
               OpStore %output_view %incremented Aligned 4
               OpReturn
               OpFunctionEnd

