// RUN: emit spirv-dis @spirv_unsigned_integer_views validate
// REQUIRES: spirv-dis, spirv-val

spirv.target<vulkan1_3> @target

low.func.def target(@target) abi(shader_entry_point) @spirv_unsigned_integer_views() asm<spirv.logical.core> {
  %loaded = OpConstant.i32 42
  %one = OpConstant.i32 1
  %u_loaded = OpBitcast.i32.u32 %loaded
  %u_one = OpBitcast.i32.u32 %one
  %quotient = OpUDiv.u32 %u_loaded, %u_one
  %remainder = OpUMod.u32 %quotient, %u_one
  %less = OpULessThan.u32 %remainder, %u_loaded
  %as_float = OpConvertUToF.u32.f32 %remainder
  %roundtrip = OpConvertFToU.f32.u32 %as_float
  %result = OpBitcast.u32.i32 %roundtrip
  return
}

