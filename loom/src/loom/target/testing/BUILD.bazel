load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "low_descriptor_registry_verify",
    testonly = True,
    srcs = ["low_descriptor_registry_verify.c"],
    hdrs = ["low_descriptor_registry_verify.h"],
    deps = [
        "//loom/src/loom/codegen/low:requirements",
        "//loom/src/loom/target:low_descriptor_registry",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "low_provider_verify",
    testonly = True,
    srcs = ["low_provider_verify.c"],
    hdrs = ["low_provider_verify.h"],
    deps = [
        "//loom/src/loom/ir",
        "//loom/src/loom/target:low_legality",
        "//loom/src/loom/target:low_packet_diagnostics",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "low_descriptor_registry_verify_test",
    srcs = ["low_descriptor_registry_verify_test.cc"],
    deps = [
        ":low_descriptor_registry_verify",
        "//loom/src/loom/codegen/low:requirements",
        "//loom/src/loom/target:low_descriptor_registry_core_test",
        "//loom/src/loom/target:low_descriptor_registry_manifest",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "low_provider_verify_test",
    srcs = ["low_provider_verify_test.cc"],
    deps = [
        ":low_provider_verify",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
