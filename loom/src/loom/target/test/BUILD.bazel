load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_assert_no_dependencies",
    "loom_cc_library",
    "loom_low_descriptor_cc_library",
    "loom_target_table_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

#===------------------------------------------------------------------------===#
# Layering checks
#===------------------------------------------------------------------------===#

loom_assert_no_dependencies(
    name = "test_target_no_optional_target_deps",
    dependencies = [
        "//loom/src/loom/target/arch/amdgpu:matrix_contract",
        "//loom/src/loom/target/arch/wasm:descriptors",
        "//loom/src/loom/target/arch/x86:packed_dot_contract",
        "//loom/src/loom/target/emit/ireevm:descriptors",
        "//loom/src/loom/target/emit/llvmir:llvmir",
    ],
    targets = [
        ":alt_descriptors",
        ":contract_table",
        ":descriptors",
        ":lower_rules",
        ":lower",
        ":low_registry",
    ],
)

loom_assert_no_dependencies(
    name = "core_target_registry_no_test_target_dep",
    dependencies = [":low_registry"],
    targets = [
        "//loom/src/loom/target/all:low_registry",
        "//loom/src/loom/target:low_descriptor_registry",
    ],
)

#===------------------------------------------------------------------------===#
# Backend-independent low test descriptors
#===------------------------------------------------------------------------===#

loom_low_descriptor_cc_library(
    name = "descriptors",
    args = ["--descriptor-set=test_low_core"],
    generator = "//loom/py/loom/gen:test_low_descriptor_shard",
    header = "descriptors.h",
    source = "descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_low_descriptor_cc_library(
    name = "alt_descriptors",
    args = ["--descriptor-set=test_low_alt"],
    generator = "//loom/py/loom/gen:test_low_descriptor_shard",
    header = "alt_descriptors.h",
    source = "alt_descriptors.c",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_target_table_cc_library(
    name = "contract_table",
    args = ["--contract-table=test_low_core"],
    generator = "//loom/py/loom/gen:test_low_contract_shard",
    header = "contract_table.h",
    source = "contract_table.c",
    deps = ["//loom/src/loom/target:contract"],
)

loom_target_table_cc_library(
    name = "lower_rules",
    args = ["--contract-table=test_low_core"],
    generator = "//loom/py/loom/gen:test_low_lower_rule_shard",
    header = "lower_rules.h",
    source = "lower_rules.c",
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/vector",
    ],
)

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "lower",
    srcs = ["lower/registry.c"],
    hdrs = ["lower.h"],
    deps = [
        ":contract_table",
        ":descriptors",
        ":lower_rules",
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/codegen/low:source_memory_plan",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:combining",
        "//loom/src/loom/ops/buffer",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/vector",
        "//loom/src/loom/util:fact_table",
        "//runtime/src/iree/base",
    ],
)
