load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "loom_assert_no_dependencies",
    "loom_cc_library",
    "loom_low_descriptor_cc_library",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

#===------------------------------------------------------------------------===#
# Layering checks
#===------------------------------------------------------------------------===#

loom_assert_no_dependencies(
    name = "test_target_no_optional_target_deps",
    dependencies = [
        "//loom/src/loom/target/arch/amdgpu:matrix_contract",
        "//loom/src/loom/target/arch/wasm:descriptors",
        "//loom/src/loom/target/arch/x86:packed_dot_contract",
        "//loom/src/loom/target/arch/ireevm:descriptors",
        "//loom/src/loom/target/emit/llvmir:llvmir",
    ],
    targets = [
        ":alt_descriptors",
        ":descriptors",
        ":lower",
        ":low_registry",
        "//loom/src/loom/target/test/contracts:core",
        "//loom/src/loom/target/test/contracts:core_lower_rules",
    ],
)

loom_assert_no_dependencies(
    name = "core_target_registry_no_test_target_dep",
    dependencies = [":low_registry"],
    targets = [
        "//loom/src/loom/target/all:low_registry",
        "//loom/src/loom/target:low_descriptor_registry",
    ],
)

#===------------------------------------------------------------------------===#
# Backend-independent low test descriptors
#===------------------------------------------------------------------------===#

loom_low_descriptor_cc_library(
    name = "descriptors",
    args = ["--descriptor-set=test_low_core"],
    generator = "//loom/py/loom/gen:test_low_descriptor_shard",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_low_descriptor_cc_library(
    name = "alt_descriptors",
    args = ["--descriptor-set=test_low_alt"],
    generator = "//loom/py/loom/gen:test_low_descriptor_shard",
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_library(
    name = "target_record_table",
    srcs = ["target_records.c"],
    hdrs = ["target_records.h"],
    deps = [
        "//loom/src/loom/target:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "lower",
    srcs = ["lower/registry.c"],
    hdrs = ["lower.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:lower",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/target/test/contracts:core",
        "//loom/src/loom/target/test/contracts:core_lower_rules",
        "//runtime/src/iree/base",
    ],
)
