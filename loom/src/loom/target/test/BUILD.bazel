#===------------------------------------------------------------------------===#
# Backend-independent low test descriptors
#===------------------------------------------------------------------------===#

loom_cc_library(
    name = "descriptors",
    srcs = ["descriptors.c"],
    hdrs = ["descriptors.h"],
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_library(
    name = "alt_descriptors",
    srcs = ["alt_descriptors.c"],
    hdrs = ["alt_descriptors.h"],
    deps = ["//loom/src/loom/codegen/low:descriptors"],
)

loom_cc_library(
    name = "low_registry",
    srcs = ["low_registry.c"],
    hdrs = ["low_registry.h"],
    deps = [
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/target:low_descriptor_registry_base",
        "//loom/src/loom/target:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "descriptors_test",
    srcs = ["descriptors_test.cc"],
    deps = [
        ":alt_descriptors",
        ":descriptors",
        "//loom/src/loom/codegen/low:descriptors",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
