    hdrs = ["callable.h"],
    deps = [
        ":materialize",
        ":remap",
        ":rewriter",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/func",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "callable_test",
    srcs = ["callable_test.cc"],
    deps = [
        ":callable",
        ":rewriter",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/func",
        "//loom/src/loom/ops/test",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_library(
    name = "type_propagation",
    srcs = ["type_propagation.c"],
    hdrs = ["type_propagation.h"],
    deps = [
        ":rewriter",
        "//loom/src/loom/analysis:type_refinement",
