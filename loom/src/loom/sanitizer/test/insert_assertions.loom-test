// ====

// RUN: pass vector-memory-to-scalar,sanitizer-insert-assertions{checks=access},canonicalize,cse
func.def @access_after_memory_scalarization_checks_masked_vector_memory(%input: view<16xf32, #dense>, %output: view<16xf32, #dense>, %origin: index, %mask: vector<2xi1>, %old: vector<2xf32>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %loaded = vector.load.mask %input[%origin], %mask, %old : view<16xf32, #dense>, vector<2xi1>, vector<2xf32>
  vector.store.mask %value, %output[%origin], %mask : vector<2xf32>, view<16xf32, #dense>, vector<2xi1>
  func.return %loaded : vector<2xf32>
}

// ----
func.def @access_after_memory_scalarization_checks_masked_vector_memory(%input: view<16xf32, #dense>, %output: view<16xf32, #dense>, %origin: index, %mask: vector<2xi1>, %old: vector<2xf32>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %14 = vector.extract %mask[0] : vector<2xi1> -> i1
  %15 = scf.if %14 -> (f32) {
    sanitizer.assert.access<read> %input[%origin] : view<16xf32, #dense>
    %16 = view.load %input[%origin] : view<16xf32, #dense> -> f32
    scf.yield %16 : f32
  } else {
    %17 = vector.extract %old[0] : vector<2xf32> -> f32
    scf.yield %17 : f32
  }
  %18 = vector.extract %mask[1] : vector<2xi1> -> i1
  %19 = scf.if %18 -> (f32) {
    %20 = index.constant 1 : index
    %21 = index.add %origin, %20 : index
    sanitizer.assert.access<read> %input[%21] : view<16xf32, #dense>
    %22 = view.load %input[%21] : view<16xf32, #dense> -> f32
    scf.yield %22 : f32
  } else {
    %23 = vector.extract %old[1] : vector<2xf32> -> f32
    scf.yield %23 : f32
  }
  %loaded = vector.from_elements %15, %19 : vector<2xf32>
  scf.if %14 {
    %9 = vector.extract %value[0] : vector<2xf32> -> f32
    sanitizer.assert.access<write> %output[%origin] : view<16xf32, #dense>
    view.store %9, %output[%origin] : f32, view<16xf32, #dense>
  } else {
  }
  scf.if %18 {
    %11 = vector.extract %value[1] : vector<2xf32> -> f32
    %12 = index.constant 1 : index
    %13 = index.add %origin, %12 : index
    sanitizer.assert.access<write> %output[%13] : view<16xf32, #dense>
    view.store %11, %output[%13] : f32, view<16xf32, #dense>
  } else {
  }
  func.return %loaded : vector<2xf32>
}

