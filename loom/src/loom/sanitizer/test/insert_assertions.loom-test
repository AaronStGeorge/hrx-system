func.def @access_after_memory_scalarization_checks_per_lane_vector_memory(%input: view<16xf32, #dense>, %output: view<16xf32, #dense>, %origin: index, %offsets: vector<2xindex>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %loaded = vector.gather %input[%origin][%offsets] : view<16xf32, #dense>, vector<2xindex> -> vector<2xf32>
  vector.scatter %value, %output[%origin][%offsets] : vector<2xf32>, view<16xf32, #dense>, vector<2xindex>
  func.return %loaded : vector<2xf32>
}

// ----
func.def @access_after_memory_scalarization_checks_per_lane_vector_memory(%input: view<16xf32, #dense>, %output: view<16xf32, #dense>, %origin: index, %offsets: vector<2xindex>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %13 = vector.extract %offsets[0] : vector<2xindex> -> index
  %14 = index.add %origin, %13 : index
  sanitizer.assert.access<read> %input[%14] : view<16xf32, #dense>
  %15 = view.load %input[%14] : view<16xf32, #dense> -> f32
  %16 = vector.extract %offsets[1] : vector<2xindex> -> index
  %17 = index.add %origin, %16 : index
  sanitizer.assert.access<read> %input[%17] : view<16xf32, #dense>
  %18 = view.load %input[%17] : view<16xf32, #dense> -> f32
  %loaded = vector.from_elements %15, %18 : vector<2xf32>
  %7 = vector.extract %value[0] : vector<2xf32> -> f32
  sanitizer.assert.access<write> %output[%14] : view<16xf32, #dense>
  view.store %7, %output[%14] : f32, view<16xf32, #dense>
  %10 = vector.extract %value[1] : vector<2xf32> -> f32
  sanitizer.assert.access<write> %output[%17] : view<16xf32, #dense>
  view.store %10, %output[%17] : f32, view<16xf32, #dense>
  func.return %loaded : vector<2xf32>
}

