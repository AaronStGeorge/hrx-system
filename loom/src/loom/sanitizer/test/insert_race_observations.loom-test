  %view = buffer.view %scratch[%zero] : buffer -> view<64x4xi32, #dense>
  %value = vector.load %view[%lane, 0] : view<64x4xi32, #dense> -> vector<4xi32>
  vector.store %value, %view[%lane, 0] : vector<4xi32>, view<64x4xi32, #dense>
