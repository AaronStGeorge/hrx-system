load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "options",
    hdrs = ["options.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "pipeline_passes",
    srcs = ["pipeline_passes.c"],
    hdrs = ["pipeline_passes.h"],
    deps = [
        ":options",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/sanitizer",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/pass:pipeline",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/rewrite:rewriter",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "site_collection",
    srcs = ["site_collection.c"],
    hdrs = ["site_collection.h"],
    deps = [
        ":site_payload",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/sanitizer",
        "//loom/src/loom/util:walk",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "site_payload",
    srcs = ["site_payload.c"],
    hdrs = ["site_payload.h"],
    deps = [
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
    name = "site_collection_test",
    srcs = ["site_collection_test.cc"],
    deps = [
        ":site_collection",
        ":site_payload",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/sanitizer",
        "//loom/src/loom/ops/test",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "site_payload_test",
    srcs = ["site_payload_test.cc"],
    deps = [
        ":site_payload",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
