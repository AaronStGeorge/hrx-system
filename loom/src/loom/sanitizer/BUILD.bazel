    deps = [
        ":options_cli",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

loom_cc_test(
    name = "site_payload_test",
    srcs = ["site_payload_test.cc"],
    deps = [
        ":site_payload",
        "//runtime/src/iree/testing:gtest",
