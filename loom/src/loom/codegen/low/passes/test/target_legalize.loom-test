// RUN: pass target-legalize{mode=final},dce,canonicalize

test.target<low_core> @test_target

func.def target(@test_target) @leaves_legal_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

func.def target(@test_target) @scalarizes_reduce_axes_for_target(%v: vector<4xi32>, %init: i32) -> (i32) {
  %r = vector.reduce.axes<addi> %v, %init axes [0] : vector<4xi32>, i32
  func.return %r : i32
}

func.def target(@test_target) @scalarizes_dense_full_logical_mma(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xi32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xi32>, vector<4xi32>, vector<4xi32>
  func.return %result : vector<4xi32>
}

// ----
test.target<low_core> @test_target

func.def target(@test_target) @leaves_legal_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

func.def target(@test_target) @scalarizes_reduce_axes_for_target(%v: vector<4xi32>, %init: i32) -> (i32) {
  %19 = vector.extract %v[0] : vector<4xi32> -> i32
  %20 = scalar.addi %init, %19 : i32
  %21 = vector.extract %v[1] : vector<4xi32> -> i32
  %22 = scalar.addi %20, %21 : i32
  %23 = vector.extract %v[2] : vector<4xi32> -> i32
  %24 = scalar.addi %22, %23 : i32
  %25 = vector.extract %v[3] : vector<4xi32> -> i32
  %r = scalar.addi %24, %25 : i32
  func.return %r : i32
}

func.def target(@test_target) @scalarizes_dense_full_logical_mma(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %27 = vector.extract %init_data[0] : vector<4xi32> -> i32
  %28 = vector.extract %lhs_data[0] : vector<4xi32> -> i32
  %29 = vector.extract %rhs_data[0] : vector<4xi32> -> i32
  %30 = scalar.muli %28, %29 : i32
  %31 = scalar.addi %27, %30 : i32
  %32 = vector.extract %lhs_data[1] : vector<4xi32> -> i32
  %33 = vector.extract %rhs_data[2] : vector<4xi32> -> i32
  %34 = scalar.muli %32, %33 : i32
  %35 = scalar.addi %31, %34 : i32
  %36 = vector.extract %init_data[1] : vector<4xi32> -> i32
  %37 = vector.extract %lhs_data[0] : vector<4xi32> -> i32
  %38 = vector.extract %rhs_data[1] : vector<4xi32> -> i32
  %39 = scalar.muli %37, %38 : i32
  %40 = scalar.addi %36, %39 : i32
  %41 = vector.extract %lhs_data[1] : vector<4xi32> -> i32
  %42 = vector.extract %rhs_data[3] : vector<4xi32> -> i32
  %43 = scalar.muli %41, %42 : i32
  %44 = scalar.addi %40, %43 : i32
  %45 = vector.extract %init_data[2] : vector<4xi32> -> i32
  %46 = vector.extract %lhs_data[2] : vector<4xi32> -> i32
  %47 = vector.extract %rhs_data[0] : vector<4xi32> -> i32
  %48 = scalar.muli %46, %47 : i32
  %49 = scalar.addi %45, %48 : i32
  %50 = vector.extract %lhs_data[3] : vector<4xi32> -> i32
  %51 = vector.extract %rhs_data[2] : vector<4xi32> -> i32
  %52 = scalar.muli %50, %51 : i32
  %53 = scalar.addi %49, %52 : i32
  %54 = vector.extract %init_data[3] : vector<4xi32> -> i32
  %55 = vector.extract %lhs_data[2] : vector<4xi32> -> i32
  %56 = vector.extract %rhs_data[1] : vector<4xi32> -> i32
  %57 = scalar.muli %55, %56 : i32
  %58 = scalar.addi %54, %57 : i32
  %59 = vector.extract %lhs_data[3] : vector<4xi32> -> i32
  %60 = vector.extract %rhs_data[3] : vector<4xi32> -> i32
  %61 = scalar.muli %59, %60 : i32
  %62 = scalar.addi %58, %61 : i32
  %63 = vector.from_elements %35, %44, %53, %62 : vector<4xi32>
  %result = vector.fragment<result> %63 shape [%m, %n] : vector<4xi32>
  func.return %result : vector<4xi32>
}

// ====
// RUN: pass target-legalize{mode=final},dce,canonicalize,source-to-low

test.target<low_core> @test_target

func.def target(@test_target) @lowers_scalarized_dense_full_logical_mma_to_low(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xi32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xi32>, vector<4xi32>, vector<4xi32>
  func.return %result : vector<4xi32>
}

// ----
test.target<low_core> @test_target

low.func.def target(@test_target) abi(object_function) @lowers_scalarized_dense_full_logical_mma_to_low(%lhs_data: reg<test.i32 x4>, %rhs_data: reg<test.i32 x4>, %init_data: reg<test.i32 x4>) -> (reg<test.i32 x4>) {
  %53 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %54 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %55 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %56 = low.op<test.mul.i32>(%54, %55) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %57 = low.op<test.add.i32>(%53, %56) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %58 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %59 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %60 = low.op<test.mul.i32>(%58, %59) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %61 = low.op<test.add.i32>(%57, %60) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %62 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %63 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %64 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %65 = low.op<test.mul.i32>(%63, %64) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %66 = low.op<test.add.i32>(%62, %65) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %67 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %68 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %69 = low.op<test.mul.i32>(%67, %68) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %70 = low.op<test.add.i32>(%66, %69) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %71 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %72 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %73 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %74 = low.op<test.mul.i32>(%72, %73) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %75 = low.op<test.add.i32>(%71, %74) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %76 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %77 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %78 = low.op<test.mul.i32>(%76, %77) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %79 = low.op<test.add.i32>(%75, %78) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %80 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %81 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %82 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %83 = low.op<test.mul.i32>(%81, %82) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %84 = low.op<test.add.i32>(%80, %83) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %85 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %86 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %87 = low.op<test.mul.i32>(%85, %86) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %88 = low.op<test.add.i32>(%84, %87) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %result = low.op<test.from_elements.v4i32>(%61, %70, %79, %88) : (reg<test.i32>, reg<test.i32>, reg<test.i32>, reg<test.i32>) -> reg<test.i32 x4>
  low.return %result : reg<test.i32 x4>
}
