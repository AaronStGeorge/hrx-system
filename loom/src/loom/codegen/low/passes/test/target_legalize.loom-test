  %56 = low.op<test.mul.i32>(%54, %55) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %57 = low.op<test.add.i32>(%53, %56) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %58 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %59 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
