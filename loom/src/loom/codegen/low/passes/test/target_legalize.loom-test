test.target<low_core> @test_target

low.func.def target(@test_target) abi(object_function) @lowers_scalarized_dense_full_logical_mma_to_low(%lhs_data: reg<test.i32 x4>, %rhs_data: reg<test.i32 x4>, %init_data: reg<test.i32 x4>) -> (reg<test.i32 x4>) {
  %53 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %54 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %55 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %56 = low.op<test.mul.i32>(%54, %55) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %57 = low.op<test.add.i32>(%53, %56) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %58 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %59 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %60 = low.op<test.mul.i32>(%58, %59) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %61 = low.op<test.add.i32>(%57, %60) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %62 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %63 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %64 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %65 = low.op<test.mul.i32>(%63, %64) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %66 = low.op<test.add.i32>(%62, %65) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %67 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %68 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %69 = low.op<test.mul.i32>(%67, %68) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %70 = low.op<test.add.i32>(%66, %69) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %71 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %72 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %73 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %74 = low.op<test.mul.i32>(%72, %73) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %75 = low.op<test.add.i32>(%71, %74) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %76 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %77 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %78 = low.op<test.mul.i32>(%76, %77) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %79 = low.op<test.add.i32>(%75, %78) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %80 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %81 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %82 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %83 = low.op<test.mul.i32>(%81, %82) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %84 = low.op<test.add.i32>(%80, %83) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %85 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %86 = low.const<test.const.i32> {i32_value = 3} : reg<test.i32>
  %87 = low.op<test.mul.i32>(%85, %86) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %88 = low.op<test.add.i32>(%84, %87) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %result = low.op<test.from_elements.v4i32>(%61, %70, %79, %88) : (reg<test.i32>, reg<test.i32>, reg<test.i32>, reg<test.i32>) -> reg<test.i32 x4>
  low.return %result : reg<test.i32 x4>
}
