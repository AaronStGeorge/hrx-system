  %151 = index.constant 1 : index
  cfg.br ^_bb5(%150: index, %149: f32)
^_bb5(%165: index, %166: f32):
  %167 = index.cmp slt, %165, %k : index
  cfg.cond_br %167, ^_bb6, ^_bb7
^_bb6:
  %155 = view.load %lhs_view[%158, %165] : view<[%m]x[%k]xf32, %layout> -> f32
  %156 = view.load %rhs_view[%165, %161] : view<[%k]x[%n]xf32, %layout> -> f32
  %157 = scalar.fmaf %155, %156, %166 : f32
  %168 = index.add %165, %151 : index
  cfg.br ^_bb5(%168: index, %157: f32)
^_bb7:
  cfg.br ^_bb8(%166: f32)
^_bb8(%164: f32):
  view.store %164, %out_view[%158, %161] : f32, view<[%m]x[%n]xf32, %layout>
  %163 = index.add %161, %147 : index
  cfg.br ^_bb3(%163: index)
^_bb9:
  %160 = index.add %158, %144 : index
  cfg.br ^_bb1(%160: index)
^_bb10:
  func.return
}

