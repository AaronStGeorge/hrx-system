// ----
test.target<low_core> @test_target

low.func.def target(@test_target) @phys(%lhs: reg<test.phys>, %rhs: reg<test.phys>) -> (reg<test.phys>) {
  %phys_spill_storage_0 = low.storage.reserve {byte_alignment = 64, byte_length = 64} : low.storage<stack>
  low.spill %rhs, %phys_spill_storage_0 : reg<test.phys>, low.storage<stack>
  %5 = low.reload %phys_spill_storage_0 : low.storage<stack> -> reg<test.phys>
  %sum = low.op<test.add.phys>(%lhs, %5) : (reg<test.phys>, reg<test.phys>) -> reg<test.phys>
  low.return %sum : reg<test.phys>
}

