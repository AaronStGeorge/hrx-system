// RUN: emit low-schedule-json @tied_storage_overlapping_low_read_low_write

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_overlapping_low_read_low_write(%state: reg<test.i32>, %ptr: reg<test.ptr>) -> (reg<test.i32>, reg<test.i32>) {
  %low_read = low.op<test.read.low16.i32>(%state) : (reg<test.i32>) -> reg<test.i32>
  %next = low.op<test.write.low16.tied.i32>(%state, %ptr) : (reg<test.i32>, reg<test.ptr>) -> %state as reg<test.i32>
  low.return %low_read, %next : reg<test.i32>, reg<test.i32>
}

