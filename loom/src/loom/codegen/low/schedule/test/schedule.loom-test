// RUN: emit low-schedule-json @tied_storage_full_read_overlaps_subregister_write

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_full_read_overlaps_subregister_write(%state: reg<test.i32>, %rhs: reg<test.i32>, %ptr: reg<test.ptr>) -> (reg<test.i32>, reg<test.i32>) {
  %sum = low.op<test.add.i32>(%state, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %next = low.op<test.write.high16.i32>(%state, %ptr) : (reg<test.i32>, reg<test.ptr>) -> %state as reg<test.i32>
  low.return %sum, %next : reg<test.i32>, reg<test.i32>
}

