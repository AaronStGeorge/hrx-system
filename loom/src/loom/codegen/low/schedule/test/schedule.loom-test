// RUN: emit low-schedule-json @tied_storage_disjoint_high_read_low_write

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_disjoint_high_read_low_write(%state: reg<test.i32>, %ptr: reg<test.ptr>) -> (reg<test.i32>, reg<test.i32>) {
  %high_read = low.op<test.read.high16.i32>(%state) : (reg<test.i32>) -> reg<test.i32>
  %next = low.op<test.write.low16.tied.i32>(%state, %ptr) : (reg<test.i32>, reg<test.ptr>) -> %state as reg<test.i32>
  low.return %high_read, %next : reg<test.i32>, reg<test.i32>
}

