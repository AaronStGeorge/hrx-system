// RUN: emit low-schedule-json @tied_storage_antidependency

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_antidependency(%state: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>, reg<test.i32>) {
  %sum = low.op<test.add.i32>(%state, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %next = low.op<test.tied.any>(%state) : (reg<test.i32>) -> %state as reg<test.i32>
  low.return %sum, %next : reg<test.i32>, reg<test.i32>
}

