    %lhs0: reg<test.i32>, %rhs0: reg<test.i32>,
    %lhs1: reg<test.i32>, %rhs1: reg<test.i32>) -> (reg<test.i32>, reg<test.i32>) asm<test.low.core> {
  // REMARK@+1: BACKEND/015 {chosen_data_ready_stall_cycles="0", chosen_resource_stall_cycles="0", chosen_hazard_stall_cycles="0", chosen_effective_stall_cycles="0", rejected_data_ready_stall_cycles="0", rejected_resource_stall_cycles="0", rejected_hazard_stall_cycles="0", rejected_effective_stall_cycles="0"}
  %sum0 = test.add.i32 %lhs0, %rhs0
  %sum1 = test.mul.i32 %lhs1, %rhs1
  return %sum0, %sum1
}

