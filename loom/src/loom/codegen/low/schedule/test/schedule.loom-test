// RUN: emit low-schedule-json @tied_storage_subregister_read_overlaps_full_write

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_subregister_read_overlaps_full_write(%state: reg<test.i32>) -> (reg<test.i32>, reg<test.i32>) {
  %low_read = low.op<test.read.low16.i32>(%state) : (reg<test.i32>) -> reg<test.i32>
  %next = low.op<test.tied.any>(%state) : (reg<test.i32>) -> %state as reg<test.i32>
  low.return %low_read, %next : reg<test.i32>, reg<test.i32>
}

