// RUN: emit low-schedule-json @tied_storage_retains_disjoint_read_for_later_write

test.target<low_core> @test_target

low.func.def target(@test_target) @tied_storage_retains_disjoint_read_for_later_write(%state: reg<test.i32>, %ptr: reg<test.ptr>) -> (reg<test.i32>, reg<test.i32>) {
  %low_read = low.op<test.read.low16.i32>(%state) : (reg<test.i32>) -> reg<test.i32>
  %high_next = low.op<test.write.high16.i32>(%state, %ptr) : (reg<test.i32>, reg<test.ptr>) -> %state as reg<test.i32>
  %full_next = low.op<test.tied.any>(%high_next) : (reg<test.i32>) -> %high_next as reg<test.i32>
  low.return %low_read, %full_next : reg<test.i32>, reg<test.i32>
}

