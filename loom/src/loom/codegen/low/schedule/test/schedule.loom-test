  // REMARK@+1: BACKEND/015 {scheduled_ordinal="1", chosen_packet="test.add.i32", rejected_packet="test.add.v4i32", chosen_data_ready_stall_cycles="0", rejected_data_ready_stall_cycles="3", rejected_effective_stall_cycles="3", rejected_dependency_latency_cycles="4"}
  %independent = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %independent, %use : reg<test.i32>, reg<test.i32 x4>
}

