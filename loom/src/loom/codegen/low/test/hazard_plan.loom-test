// RUN: emit synthetic-hazard-plan-json @physical_overlap_action case=action fixed=%producer:physical_register:0:1 fixed=%consumer:physical_register:0:1

test.target<low_core> @test_target

low.func.def target(@test_target) @physical_overlap_action(%lhs: reg<test.phys>, %rhs: reg<test.phys>, %other: reg<test.phys>) -> (reg<test.phys>) asm<test.low.core> {
  %producer = test.add.phys %lhs, %rhs
  %consumer = test.add.phys %producer, %other
  return %consumer
}

