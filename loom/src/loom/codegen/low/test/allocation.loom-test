// RUN: emit low-allocation-json @multi_victim_spill test.i32=4 diagnostics=predicted-spills output=none

test.target<low_core> @test_target

// WARNING@+2: BACKEND/008 {function_name="multi_victim_spill", value_name="row", value_class="test.i32", spill_cause="register-budget-conflict"}
// WARNING@+1: BACKEND/008 {function_name="multi_victim_spill", value_name="carry", value_class="test.i32", spill_cause="register-budget-conflict"}
low.func.def target(@test_target) @multi_victim_spill(%row: reg<test.i32>, %carry: reg<test.i32>, %extra: reg<test.i32>) -> (reg<test.i32>) asm<test.low.core> {
  low.br ^late
^join(%state: reg<test.i32 x2>):
  %state0 = slice %state[0] : reg<test.i32 x2> -> reg<test.i32>
  %sum = test.add.i32 %row, %state0
  %sum2 = test.add.i32 %sum, %carry
  %out = test.add.i32 %sum2, %extra
  return %out
^late:
  %late_state0 = test.const.i32 7
  %late_state1 = test.const.i32 9
  %late_state = concat(%late_state0, %late_state1) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32 x2>
  low.br ^join(%late_state: reg<test.i32 x2>)
}

