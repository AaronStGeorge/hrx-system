// RUN: emit low-allocation-json @branch_concat_destination_layout

test.target<low_core> @test_target

low.func.def target(@test_target) @branch_concat_destination_layout(%cond: reg<test.i32>, %lhs: reg<test.i32 x2>, %rhs: reg<test.i32 x2>) -> (reg<test.i32 x2>) asm<test.low.core> {
  low.cond_br %cond, ^then, ^else : reg<test.i32>
^then:
  %lhs0 = slice %lhs[0] : reg<test.i32 x2> -> reg<test.i32>
  %rhs0 = slice %rhs[0] : reg<test.i32 x2> -> reg<test.i32>
  %out0 = test.add.i32 %lhs0, %rhs0
  %lhs1 = slice %lhs[1] : reg<test.i32 x2> -> reg<test.i32>
  %rhs1 = slice %rhs[1] : reg<test.i32 x2> -> reg<test.i32>
  %out1 = test.add.i32 %lhs1, %rhs1
  %out = concat(%out0, %out1) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32 x2>
  low.br ^join(%out: reg<test.i32 x2>)
^else:
  low.br ^join(%rhs: reg<test.i32 x2>)
^join(%state: reg<test.i32 x2>):
  return %state
}

