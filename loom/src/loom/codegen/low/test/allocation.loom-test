// RUN: emit low-allocation @alloc

test.target<low_core> @test_target

low.func.def target(@test_target) @alloc(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) asm<test.low.core> {
  %sum = test.add.i32 %lhs, %rhs
  return %sum
}

