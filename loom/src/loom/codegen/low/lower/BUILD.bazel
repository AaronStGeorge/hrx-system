        "//loom/src/loom/ops/target",
        "//loom/src/loom/ops/vector",
        "//loom/src/loom/target:contract",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:low_legality",
        "//loom/src/loom/target:registers",
        "//loom/src/loom/target:types",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:math",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_library(
    name = "source_selection",
    srcs = ["source_selection.c"],
    hdrs = ["source_selection.h"],
    visibility = [
        "//loom/src/loom/codegen/low/testing:__pkg__",
        "//loom/src/loom/codegen/low/transforms/pipeline:__pkg__",
    ],
    deps = [
