    "//loom/src/loom/target/test:__subpackages__",
    "//loom/src/loom/tools/loom-check:__pkg__",
    "//loom/src/loom/tools/loom-check:__pkg__",
]

loom_cc_library(
    name = "lower",
    srcs = [
        "contract_query.c",
        "lower.c",
        "lower_context.c",
        "lower_policy.c",
