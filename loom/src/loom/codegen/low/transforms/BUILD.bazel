    deps = [
        "//loom/src/loom/analysis:consumption",
        "//loom/src/loom/codegen/low:builder",
        "//loom/src/loom/codegen/low:descriptor_traits",
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low:diagnostics",
