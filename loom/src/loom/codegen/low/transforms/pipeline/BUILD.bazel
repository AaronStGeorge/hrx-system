load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:private"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

_PIPELINE_VISIBILITY = [
    "//loom/src/loom/pass:__pkg__",
]

loom_cc_library(
    name = "source_to_low",
    srcs = ["source_to_low.c"],
    hdrs = ["source_to_low.h"],
    visibility = _PIPELINE_VISIBILITY,
    deps = [
        "//loom/src/loom/codegen/low:descriptors",
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/codegen/low/lower:source_selection",
        "//loom/src/loom/codegen/low/pipeline:pass_environment",
        "//loom/src/loom/ir",
        "//loom/src/loom/pass:pipeline",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/target:low_legality",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "target_legalize",
    srcs = ["target_legalize.c"],
    hdrs = ["target_legalize.h"],
    visibility = _PIPELINE_VISIBILITY,
    deps = [
        "//loom/src/loom/analysis:contract",
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/codegen/low/lower:source_selection",
        "//loom/src/loom/codegen/low/pipeline:pass_environment",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/pass:pipeline",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/rewrite:greedy",
        "//loom/src/loom/target:compile_report",
        "//loom/src/loom/target:legalization",
        "//loom/src/loom/target:low_descriptor_registry",
        "//loom/src/loom/target:low_legality",
        "//loom/src/loom/transforms/scalar:target_legalization",
        "//loom/src/loom/transforms/vector:target_legalization",
        "//loom/src/loom/util:walk",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
    ],
)

loom_cc_test(
    name = "source_to_low_test",
    srcs = ["source_to_low_test.cc"],
    deps = [
        ":source_to_low",
        "//loom/src/loom/codegen/low/lower",
        "//loom/src/loom/codegen/low/lower:source_selection",
        "//loom/src/loom/codegen/low/pipeline:pass_environment",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/func",
        "//loom/src/loom/ops/low",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/target",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/target/test:low_registry",
        "//loom/src/loom/target/test:lower",
        "//loom/src/loom/target/test:target_record_table",
        "//loom/src/loom/target/test/contracts:core_lower_rules",
        "//loom/src/loom/testing:module_ptr",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
