// RUN: pass target-legalize{mode=final},dce,canonicalize

test.target<low_core> @test_target

func.def target(@test_target) @matrix_descriptor_reference_fallback(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xi32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xi32>, vector<4xi32>, vector<4xi32>
  func.return %result : vector<4xi32>
}

// ----
test.target<low_core> @test_target

func.def target(@test_target) @matrix_descriptor_reference_fallback(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %11 = vector.extract %init_data[0] : vector<4xi32> -> i32
  %12 = vector.extract %lhs_data[0] : vector<4xi32> -> i32
  %13 = vector.extract %rhs_data[0] : vector<4xi32> -> i32
  %55 = scalar.muli %12, %13 : i32
  %56 = scalar.addi %11, %55 : i32
  %15 = vector.extract %lhs_data[1] : vector<4xi32> -> i32
  %16 = vector.extract %rhs_data[2] : vector<4xi32> -> i32
  %53 = scalar.muli %15, %16 : i32
  %54 = scalar.addi %56, %53 : i32
  %18 = vector.extract %init_data[1] : vector<4xi32> -> i32
  %19 = vector.extract %lhs_data[0] : vector<4xi32> -> i32
  %20 = vector.extract %rhs_data[1] : vector<4xi32> -> i32
  %51 = scalar.muli %19, %20 : i32
  %52 = scalar.addi %18, %51 : i32
  %22 = vector.extract %lhs_data[1] : vector<4xi32> -> i32
  %23 = vector.extract %rhs_data[3] : vector<4xi32> -> i32
  %49 = scalar.muli %22, %23 : i32
  %50 = scalar.addi %52, %49 : i32
  %25 = vector.extract %init_data[2] : vector<4xi32> -> i32
  %26 = vector.extract %lhs_data[2] : vector<4xi32> -> i32
  %27 = vector.extract %rhs_data[0] : vector<4xi32> -> i32
  %47 = scalar.muli %26, %27 : i32
  %48 = scalar.addi %25, %47 : i32
  %29 = vector.extract %lhs_data[3] : vector<4xi32> -> i32
  %30 = vector.extract %rhs_data[2] : vector<4xi32> -> i32
  %45 = scalar.muli %29, %30 : i32
  %46 = scalar.addi %48, %45 : i32
  %32 = vector.extract %init_data[3] : vector<4xi32> -> i32
  %33 = vector.extract %lhs_data[2] : vector<4xi32> -> i32
  %34 = vector.extract %rhs_data[1] : vector<4xi32> -> i32
  %43 = scalar.muli %33, %34 : i32
  %44 = scalar.addi %32, %43 : i32
  %36 = vector.extract %lhs_data[3] : vector<4xi32> -> i32
  %37 = vector.extract %rhs_data[3] : vector<4xi32> -> i32
  %41 = scalar.muli %36, %37 : i32
  %42 = scalar.addi %44, %41 : i32
  %39 = vector.from_elements %54, %50, %46, %42 : vector<4xi32>
  %result = vector.fragment<result> %39 shape [%m, %n] : vector<4xi32>
  func.return %result : vector<4xi32>
}

