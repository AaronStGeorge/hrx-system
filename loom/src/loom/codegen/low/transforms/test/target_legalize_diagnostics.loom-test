// RUN: pass source-to-low

test.target<low_core> @test_target

func.def target(@test_target) @rejects_reduce_axes_without_target_legalization(%v: vector<4xi32>, %init: i32) -> (i32) {
  // ERROR@+1: TARGET/001 {op_name="vector.reduce.axes"}
  %r = vector.reduce.axes<addi> %v, %init axes [0] : vector<4xi32>, i32
  func.return %r : i32
}

// ====
// RUN: pass source-to-low

test.target<low_core> @test_target

func.def target(@test_target) @rejects_mma_without_target_legalization(%lhs_data: vector<4xi32>, %rhs_data: vector<4xi32>, %init_data: vector<4xi32>) -> (vector<4xi32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xi32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xi32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xi32>
  // ERROR@+1: TARGET/001 {op_name="vector.mma"}
  %result = vector.mma %lhs, %rhs, %init : vector<4xi32>, vector<4xi32>, vector<4xi32>
  func.return %result : vector<4xi32>
}

