// ====
// RUN: pass target-legalize

test.target<low_core> @test_target

kernel.def target(@test_target) @allows_guarded_workitem_id_assume_excluding_static_workgroup() {
  %c1 = index.constant 1 : index
  %c32 = index.constant 32 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c32, %c1, %c1) : index
} launch() {
  %lane = kernel.workitem.id<x> : index
  %c16 = index.constant 16 : index
  %inside = index.cmp ult, %lane, %c16 : index
  scf.if %inside {
    %guarded_lane = index.assume %lane [range(%lane, 0, 15)] : index
    test.use %guarded_lane : index
  }
  kernel.return
}

// ====
// RUN: pass scf-to-cfg,target-legalize

test.target<low_core> @test_target

kernel.def target(@test_target) @allows_cfg_guarded_workitem_id_assume_excluding_static_workgroup() {
  %c1 = index.constant 1 : index
  %c32 = index.constant 32 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c32, %c1, %c1) : index
} launch() {
  %lane = kernel.workitem.id<x> : index
  %c16 = index.constant 16 : index
  %inside = index.cmp ult, %lane, %c16 : index
  scf.if %inside {
    test.use %lane : index
  }
  kernel.return
}

// ----
test.target<low_core> @test_target

kernel.def target(@test_target) @allows_cfg_guarded_workitem_id_assume_excluding_static_workgroup() {
  %c1 = index.constant 1 : index
  %c32 = index.constant 32 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c32, %c1, %c1) : index
} launch() {
  %lane = kernel.workitem.id<x> : index
  %c16 = index.constant 16 : index
  %inside = index.cmp ult, %lane, %c16 : index
  cfg.cond_br %inside, ^_bb1, ^_bb2
^_bb1:
  test.use %lane : index
  cfg.br ^_bb2
^_bb2:
  kernel.return
}
