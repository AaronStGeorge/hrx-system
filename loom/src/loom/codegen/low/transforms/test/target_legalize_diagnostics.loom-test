kernel.def target(@test_target) @rejects_workitem_id_assume_excluding_static_workgroup() {
  %c1 = index.constant 1 : index
  %c64 = index.constant 64 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%c64, %c1, %c1) : index
} launch() {
  %lane0 = kernel.workitem.id<x> : index
  // ERROR@+1: TARGET/058 {value_kind="workitem.id", axis="x", required_min="0", required_max="63", assumed_min="0", assumed_max="31"}
  %lane = index.assume %lane0 [range(%lane0, 0, 31)] : index
  test.use %lane : index
  kernel.return
}

