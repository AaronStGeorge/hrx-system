func.def target(@test_target) @scalarizes_dynamic_rank2_mma_store(%m: index, %n: index, %k: index, %lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %base = index.constant 0 : offset
  %layout = encoding.layout.dense : encoding<layout>
  %lhs_view = buffer.view %lhs_buffer[%base] : buffer -> view<[%m]x[%k]xf32, %layout>
  %rhs_view = buffer.view %rhs_buffer[%base] : buffer -> view<[%k]x[%n]xf32, %layout>
  %init_view = buffer.view %init_buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %94 = index.constant 0 : index
  %95 = index.constant 1 : index
  cfg.br ^_bb1(%94: index)
^_bb1(%170: index):
  %171 = index.cmp slt, %170, %m : index
  cfg.cond_br %171, ^_bb2, ^_bb10
^_bb2:
  %97 = index.constant 0 : index
  %98 = index.constant 1 : index
  cfg.br ^_bb3(%97: index)
^_bb3(%173: index):
  %174 = index.cmp slt, %173, %n : index
  cfg.cond_br %174, ^_bb4, ^_bb9
^_bb4:
  %100 = view.load %init_view[%170, %173] : view<[%m]x[%n]xf32, %layout> -> f32
  %101 = index.constant 0 : index
  %102 = index.constant 1 : index
  cfg.br ^_bb5(%101: index, %100: f32)
^_bb5(%177: index, %178: f32):
  %179 = index.cmp slt, %177, %k : index
  cfg.cond_br %179, ^_bb6, ^_bb7
^_bb6:
  %106 = view.load %lhs_view[%170, %177] : view<[%m]x[%k]xf32, %layout> -> f32
  %107 = view.load %rhs_view[%177, %173] : view<[%k]x[%n]xf32, %layout> -> f32
  %108 = scalar.fmaf %106, %107, %178 : f32
  %180 = index.add %177, %102 : index
  cfg.br ^_bb5(%180: index, %108: f32)
^_bb7:
  cfg.br ^_bb8(%178: f32)
^_bb8(%176: f32):
  view.store %176, %out_view[%170, %173] : f32, view<[%m]x[%n]xf32, %layout>
  %175 = index.add %173, %98 : index
  cfg.br ^_bb3(%175: index)
^_bb9:
  %172 = index.add %170, %95 : index
  cfg.br ^_bb1(%172: index)
^_bb10:
  func.return
}

