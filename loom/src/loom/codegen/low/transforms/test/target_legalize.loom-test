low.func.def target(@test_target) abi(object_function) @lowers_scalarized_dense_full_logical_mma_to_low(%lhs_data: reg<test.i32 x4>, %rhs_data: reg<test.i32 x4>, %init_data: reg<test.i32 x4>) -> (reg<test.i32 x4>) {
  %61 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %62 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %63 = low.const<test.const.i32> {i32_value = 0} : reg<test.i32>
  %64 = low.op<test.mul.i32>(%62, %63) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %65 = low.op<test.add.i32>(%61, %64) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %66 = low.const<test.const.i32> {i32_value = 1} : reg<test.i32>
  %67 = low.const<test.const.i32> {i32_value = 2} : reg<test.i32>
  %68 = low.op<test.mul.i32>(%66, %67) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  %69 = low.op<test.add.i32>(%65, %68) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
