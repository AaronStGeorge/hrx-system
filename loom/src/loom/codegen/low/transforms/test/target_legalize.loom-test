// RUN: pass target-legalize{mode=final},scf-to-cfg,dce,canonicalize

test.target<low_core> @test_target

func.def target(@test_target) @leaves_legal_source_op(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

func.def target(@test_target) @scalarizes_reduce_axes_for_target(%v: vector<4xi32>, %init: i32) -> (i32) {
  %r = vector.reduce.axes<addi> %v, %init axes [0] : vector<4xi32>, i32
  func.return %r : i32
}

func.def target(@test_target) @scalarizes_dynamic_rank2_mma_store(%m: index, %n: index, %k: index, %lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %base = index.constant 0 : offset
  %origin = index.constant 0 : index
  %layout = encoding.layout.dense : encoding<layout>
  %lhs_view = buffer.view %lhs_buffer[%base] : buffer -> view<[%m]x[%k]xf32, %layout>
  %rhs_view = buffer.view %rhs_buffer[%base] : buffer -> view<[%k]x[%n]xf32, %layout>
  %init_view = buffer.view %init_buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %lhs_data = vector.load %lhs_view[%origin, %origin] : view<[%m]x[%k]xf32, %layout> -> vector<[%m]x[%k]xf32>
  %rhs_data = vector.load %rhs_view[%origin, %origin] : view<[%k]x[%n]xf32, %layout> -> vector<[%k]x[%n]xf32>
  %init_data = vector.load %init_view[%origin, %origin] : view<[%m]x[%n]xf32, %layout> -> vector<[%m]x[%n]xf32>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<[%m]x[%k]xf32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<[%k]x[%n]xf32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<[%m]x[%n]xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<[%m]x[%k]xf32>, vector<[%k]x[%n]xf32>, vector<[%m]x[%n]xf32>
  vector.store %result, %out_view[%origin, %origin] : vector<[%m]x[%n]xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}

func.def target(@test_target) @scalarizes_dynamic_flat_mma_store(%m: index, %n: index, %k: index, %lhs0: f32, %rhs0: f32, %init0: f32, %out_buffer: buffer) {
  %base = index.constant 0 : offset
  %origin = index.constant 0 : index
  %layout = encoding.layout.dense : encoding<layout>
  %mk = index.mul %m, %k : index
  %kn = index.mul %k, %n : index
  %mn = index.mul %m, %n : index
  %lhs_data = vector.splat %lhs0 : vector<[%mk]xf32>
  %rhs_data = vector.splat %rhs0 : vector<[%kn]xf32>
  %init_data = vector.splat %init0 : vector<[%mn]xf32>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<[%mn]xf32, %layout>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<[%mk]xf32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<[%kn]xf32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<[%mn]xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<[%mk]xf32>, vector<[%kn]xf32>, vector<[%mn]xf32>
  vector.store %result, %out_view[%origin] : vector<[%mn]xf32>, view<[%mn]xf32, %layout>
  func.return
}

func.def target(@test_target) @scalarizes_dense_flat_mma_fragment_store(%lhs0: f32, %rhs0: f32, %init0: f32, %out_buffer: buffer) {
  %base = index.constant 0 : offset
  %origin = index.constant 0 : index
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %layout = encoding.layout.dense : encoding<layout>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<2x2xf32, %layout>
  %lhs_data = vector.splat %lhs0 : vector<4xf32>
  %rhs_data = vector.splat %rhs0 : vector<4xf32>
  %init_data = vector.splat %init0 : vector<4xf32>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xf32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xf32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xf32>, vector<4xf32>, vector<4xf32>
  vector.fragment.store<result> %result, %out_view[%origin, %origin] shape [%m, %n] : vector<4xf32>, view<2x2xf32, %layout>
  func.return
}

func.def target(@test_target) @scalarizes_target_shaped_fragment_mma_store(%lhs_buffer: buffer, %rhs_buffer: buffer, %init_buffer: buffer, %out_buffer: buffer) {
  %base = index.constant 0 : offset
  %origin = index.constant 0 : index
  %m = index.constant 16 : index
  %n = index.constant 16 : index
  %k = index.constant 16 : index
  %layout = encoding.layout.dense : encoding<layout>
  %lhs_view = buffer.view %lhs_buffer[%base] : buffer -> view<16x16xf16, %layout>
  %rhs_view = buffer.view %rhs_buffer[%base] : buffer -> view<16x16xf16, %layout>
  %init_view = buffer.view %init_buffer[%base] : buffer -> view<16x16xf32, %layout>
  %out_view = buffer.view %out_buffer[%base] : buffer -> view<16x16xf32, %layout>
  %lhs = vector.fragment.load<lhs> %lhs_view[%origin, %origin] shape [%m, %k] : view<16x16xf16, %layout> -> vector<16xf16>
  %rhs = vector.fragment.load<rhs> %rhs_view[%origin, %origin] shape [%k, %n] : view<16x16xf16, %layout> -> vector<16xf16>
  %init = vector.fragment.load<init> %init_view[%origin, %origin] shape [%m, %n] : view<16x16xf32, %layout> -> vector<8xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<16xf16>, vector<16xf16>, vector<8xf32>
  vector.fragment.store<result> %result, %out_view[%origin, %origin] shape [%m, %n] : vector<8xf32>, view<16x16xf32, %layout>
  func.return
}

