// RUN: pass source-to-low{control-flow=structured-low}

test.target<low_core> @test_target

func.def target(@test_target) @structured_control_option_smoke(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32
  func.return %sum : i32
}

// ----
test.target<low_core> @test_target

low.func.def target(@test_target) abi(object_function) @structured_control_option_smoke(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32>
  low.return %sum : reg<test.i32>
}

// ====

// RUN: with-locations pass source-to-low

test.target<low_core> @test_target loc("target.loom":1:1)

func.def target(@test_target) @preserves_sanitizer_site_location(%lhs: i32, %rhs: i32) -> (i32) {
  %sum = scalar.addi %lhs, %rhs : i32 loc(tagged<sanitizer_site, "0405", "source-low.loom":3:1>)
  func.return %sum : i32 loc("source-low.loom":4:1)
} loc("source-low.loom":1:1 to 5:1)

// ----
test.target<low_core> @test_target loc("target.loom":1:1)

low.func.def target(@test_target) abi(object_function) @preserves_sanitizer_site_location(%lhs: reg<test.i32>, %rhs: reg<test.i32>) -> (reg<test.i32>) {
  %sum = low.op<test.add.i32>(%lhs, %rhs) : (reg<test.i32>, reg<test.i32>) -> reg<test.i32> loc(tagged<sanitizer_site, "0405", "source-low.loom":3:1>)
  low.return %sum : reg<test.i32> loc("source-low.loom":4:1)
} loc("source-low.loom":1:1 to 5:1)
