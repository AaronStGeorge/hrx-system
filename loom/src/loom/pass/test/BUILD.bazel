load(
    "//loom/build_tools/bazel:build_defs.bzl",
    "iree_assert_no_dependency",
    "loom_cc_library",
    "loom_cc_test",
)

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

iree_assert_no_dependency(
    name = "registry_no_builtin_registry_dep",
    dependency = "//loom/src/loom/pass:builtin_registry",
    target = "//loom/src/loom/pass/test:registry",
)

iree_assert_no_dependency(
    name = "registry_no_concrete_pass_dep",
    dependency = "//loom/src/loom/passes:canonicalize",
    target = "//loom/src/loom/pass/test:registry",
)

loom_cc_library(
    name = "registry",
    testonly = True,
    srcs = ["registry.c"],
    hdrs = ["registry.h"],
    deps = [
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "harness",
    testonly = True,
    srcs = ["harness.cc"],
    hdrs = ["harness.h"],
    deps = [
        ":registry",
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/format/text:parser",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops/pass",
        "//loom/src/loom/ops/test",
        "//loom/src/loom/pass:interpreter",
        "//loom/src/loom/pass:program",
        "//loom/src/loom/pass:report",
        "//loom/src/loom/pass:tooling",
        "//loom/src/loom/pass:verify",
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
    ],
)

loom_cc_test(
    name = "registry_test",
    srcs = ["registry_test.cc"],
    deps = [
        ":harness",
        ":registry",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//runtime/src/iree/base/internal:arena",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
