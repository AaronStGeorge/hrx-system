load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "scf_to_cfg",
    srcs = ["scf_to_cfg.c"],
    hdrs = ["scf_to_cfg.h"],
    deps = [
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/cfg",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/scf",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/rewrite:materialize",
        "//loom/src/loom/rewrite:remap",
        "//loom/src/loom/rewrite:rewriter",
        "//runtime/src/iree/base",
    ],
)

loom_cc_library(
    name = "scf_unroll",
    srcs = ["scf_unroll.c"],
    hdrs = ["scf_unroll.h"],
    deps = [
        "//loom/src/loom/error:emitter",
        "//loom/src/loom/error:error_defs",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/scf",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/rewrite:materialize",
        "//loom/src/loom/rewrite:remap",
        "//loom/src/loom/rewrite:rewriter",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:walk",
        "//runtime/src/iree/base",
    ],
)
