  %view = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout>
  %view_1 = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout_1>
  %view_2 = buffer.view %buffer[%offset] : buffer -> view<4xf32, %layout_2>
