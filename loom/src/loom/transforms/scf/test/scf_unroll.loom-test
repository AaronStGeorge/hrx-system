// RUN: pass unroll-scf-for

func.def @unmarked_static_loop_stays_structured() {
  %start = index.constant 0 : index
  %end = index.constant 3 : index
  %step = index.constant 1 : index
  scf.for %i = [%start to %end step %step] {
    test.use %i : index
  }
  func.return
}

