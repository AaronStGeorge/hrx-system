kernel.def @forward_imported_branch_accumulator() {
  %unit = index.constant 1 : index
  kernel.launch.config workgroups(%unit, %unit, %unit) workgroup_size(%unit, %unit, %unit) : index
} launch(%input: buffer, %sum_output: buffer, %normalized_output: buffer, %limit: index) {
  %zero_bytes = index.constant 0 : offset
  %layout = encoding.layout.dense : encoding<layout>
  %input_view = buffer.view %input[%zero_bytes] : buffer -> view<[%limit]x2xf32, %layout>
  %sum_output_view = buffer.view %sum_output[%zero_bytes] : buffer -> view<[%limit]xf32, %layout>
  %normalized_output_view = buffer.view %normalized_output[%zero_bytes] : buffer -> view<[%limit]x2xf32, %layout>
  %slot_index = index.constant 0 : index
  %initial = scalar.constant 9.9999999999999995e-21 : f32
  %workgroup = kernel.workgroup.id<x> : index
  %workitem = kernel.workitem.id<x> : index
  %workgroup_size = index.constant 128 : index
  %row = index.madd %workgroup, %workgroup_size, %workitem : index
  %in_bounds = index.cmp slt, %row, %limit : index
  scf.if %in_bounds {
    %bounded_row = index.assume %row [lt(%row, %limit)] : index
    %lane = index.constant 1 : index
    %lhs = view.load %input_view[%bounded_row, %slot_index] : view<[%limit]x2xf32, %layout> -> f32
    %rhs = view.load %input_view[%bounded_row, %lane] : view<[%limit]x2xf32, %layout> -> f32
    %sum = scalar.addf %initial, %lhs : f32
    %result = scalar.addf %sum, %rhs : f32
    view.store %result, %sum_output_view[%bounded_row] : f32, view<[%limit]xf32, %layout>
    %lhs_normalized = scalar.divf %lhs, %result : f32
    view.store %lhs_normalized, %normalized_output_view[%bounded_row, %slot_index] : f32, view<[%limit]x2xf32, %layout>
    %rhs_normalized = scalar.divf %rhs, %result : f32
    view.store %rhs_normalized, %normalized_output_view[%bounded_row, %lane] : f32, view<[%limit]x2xf32, %layout>
  }
  kernel.return
}

