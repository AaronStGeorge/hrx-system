func.def @entry(%lhs: i32) -> (i32) {
  // ERROR@+2: SYMBOL/002 "missing_low"
  // ERROR@+1: SYMBOL/002 "missing_adapter"
  %sum = low.invoke @missing_low(%lhs) {adapter = @missing_adapter} : (i32) -> (i32)
  func.return %sum : i32
}
