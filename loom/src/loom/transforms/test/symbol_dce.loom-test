// RUN: pass cfg-simplify,dce,symbol-dce

target.snapshot @vm_snapshot {codegen_format = vm, target_triple = "iree-vm", data_layout = "", artifact_format = vm_bytecode, target_cpu = "", target_features = "", default_pointer_bitwidth = 64, index_bitwidth = 64, offset_bitwidth = 64, memory_space_generic = 0, memory_space_global = 0, memory_space_workgroup = 0, memory_space_constant = 0, memory_space_private = 0, memory_space_host = 0, memory_space_descriptor = 0}
target.export @entry_export {source = @entry, export_symbol = "entry", abi = vm_module_function, linkage = default, hal_binding_alignment = 0, hal_workgroup_size_x = 0, hal_workgroup_size_y = 0, hal_workgroup_size_z = 0, hal_flat_workgroup_size_min = 0, hal_flat_workgroup_size_max = 0, hal_buffer_resource_flags = 0}
target.config @vm_config {contract_set_key = "iree.vm.core", contract_feature_bits = 0}
target.bundle @vm_target {snapshot = @vm_snapshot, export_plan = @entry_export, config = @vm_config}

low.func.def target(@vm_target) @vm_add(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>) {
  %sum = low.op<iree.vm.add.i32>(%lhs, %rhs) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %sum : reg<vm.i32>
}
low.abi.adapter @vm_add_i32 {callee = @vm_add, conversion = mapped, operand_count = 2, result_count = 1}
low.abi.operand @vm_add_i32_lhs {adapter = @vm_add_i32, index = 0, conversion = scalar_to_register, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.operand @vm_add_i32_rhs {adapter = @vm_add_i32, index = 1, conversion = scalar_to_register, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.result @vm_add_i32_result {adapter = @vm_add_i32, index = 0, conversion = register_to_scalar, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.effect @vm_add_i32_call {adapter = @vm_add_i32, kind = call, resource = "vm.import"}
low.abi.clobber @vm_add_i32_state {adapter = @vm_add_i32, resource = "vm.state"}

low.func.def target(@vm_target) @fallback_add(%lhs: reg<vm.i32>, %rhs: reg<vm.i32>) -> (reg<vm.i32>) {
  %sum = low.op<iree.vm.add.i32>(%lhs, %rhs) : (reg<vm.i32>, reg<vm.i32>) -> reg<vm.i32>
  low.return %sum : reg<vm.i32>
}
low.abi.adapter @fallback_add_i32 {callee = @fallback_add, conversion = mapped, operand_count = 2, result_count = 1}
low.abi.operand @fallback_add_i32_lhs {adapter = @fallback_add_i32, index = 0, conversion = scalar_to_register, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.operand @fallback_add_i32_rhs {adapter = @fallback_add_i32, index = 1, conversion = scalar_to_register, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.result @fallback_add_i32_result {adapter = @fallback_add_i32, index = 0, conversion = register_to_scalar, semantic_type = i32, abi_type = reg<vm.i32>}
low.abi.effect @fallback_add_i32_call {adapter = @fallback_add_i32, kind = call, resource = "vm.import"}
low.abi.clobber @fallback_add_i32_state {adapter = @fallback_add_i32, resource = "vm.state"}

func.def public @entry(%lhs: i32, %rhs: i32) -> (i32) {
  %is_vm = scalar.constant 1 : i1
  cfg.cond_br %is_vm, ^vm, ^fallback : i1
^vm:
  %vm_sum = low.invoke @vm_add(%lhs, %rhs) {adapter = @vm_add_i32} : (i32, i32) -> (i32)
  cfg.br ^join(%vm_sum : i32)
^fallback:
  %fallback_sum = low.invoke @fallback_add(%lhs, %rhs) {adapter = @fallback_add_i32} : (i32, i32) -> (i32)
  cfg.br ^join(%fallback_sum : i32)
^join(%sum: i32):
  func.return %sum : i32
}
