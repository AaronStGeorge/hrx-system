low.abi.operand @vm_add_i32_lhs {abi_type = reg<vm.i32>, adapter = @vm_add_i32, conversion = scalar_to_register, index = 0, semantic_type = i32}

low.abi.operand @vm_add_i32_rhs {abi_type = reg<vm.i32>, adapter = @vm_add_i32, conversion = scalar_to_register, index = 1, semantic_type = i32}

low.abi.result @vm_add_i32_result {abi_type = reg<vm.i32>, adapter = @vm_add_i32, conversion = register_to_scalar, index = 0, semantic_type = i32}

low.abi.effect @vm_add_i32_call {adapter = @vm_add_i32, kind = call, resource = "vm.import"}

