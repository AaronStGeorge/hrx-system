// RUN: pass cfg-simplify

func.def @folds_constant_branch_and_removes_dead(%a: i32, %b: i32) -> (i32) {
  %cond = scalar.constant 1 : i1
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %sum = test.addi %a, %b : i32
  cfg.br ^join(%sum : i32)
^else:
  %dead = test.addi %b, %b : i32
  cfg.br ^join(%dead : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_constant_branch_and_removes_dead(%a: i32, %b: i32) -> (i32) {
  %cond = scalar.constant 1 : i1
  %sum = test.addi %a, %b : i32
  func.return %sum : i32
}

// ====

func.def @forwards_empty_block(%cond: i1) {
  cfg.cond_br %cond, ^forward, ^exit : i1
^forward:
  cfg.br ^exit
^exit:
  func.return
}

// ----
func.def @forwards_empty_block(%cond: i1) {
  func.return
}

// ====

func.def @forwards_block_args(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^left, ^right : i1
^left:
  cfg.br ^forward(%a, %b : i32, i32)
^right:
  cfg.br ^forward(%b, %a : i32, i32)
^forward(%x : i32, %y : i32):
  cfg.br ^join(%y, %x : i32, i32)
^join(%p : i32, %q : i32):
  %sum = test.addi %p, %q : i32
  func.return %sum : i32
}

// ----
func.def @forwards_block_args(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^left, ^right : i1
^left:
  cfg.br ^join(%b, %a : i32, i32)
^right:
  cfg.br ^join(%a, %b : i32, i32)
^join(%p : i32, %q : i32):
  %sum = test.addi %p, %q : i32
  func.return %sum : i32
}

// ====

func.def @deduplicates_block_args(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a, %a : i32, i32)
^else:
  cfg.br ^join(%b, %b : i32, i32)
^join(%x : i32, %y : i32):
  %sum = test.addi %x, %y : i32
  func.return %sum : i32
}

// ----
func.def @deduplicates_block_args(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%x : i32):
  %sum = test.addi %x, %x : i32
  func.return %sum : i32
}

// ====

func.def @merges_duplicate_return_blocks(%cond: i1, %value: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %value : i32
^else:
  func.return %value : i32
}

// ----
func.def @merges_duplicate_return_blocks(%cond: i1, %value: i32) -> (i32) {
  func.return %value : i32
}

// ====

func.def @preserves_distinct_return_blocks(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %a : i32
^else:
  func.return %b : i32
}

// ====

func.def @folds_dominated_true_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %sum = test.addi %a, %a : i32
  cfg.br ^inner
^inner:
  cfg.cond_br %cond, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%sum : i32)
^dead:
  cfg.br ^join(%b : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_true_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %sum = test.addi %a, %a : i32
  cfg.br ^join(%sum : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @folds_dominated_false_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  %sum = test.addi %b, %b : i32
  cfg.br ^inner
^inner:
  cfg.cond_br %cond, ^dead, ^taken : i1
^dead:
  cfg.br ^join(%a : i32)
^taken:
  cfg.br ^join(%sum : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_false_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  %sum = test.addi %b, %b : i32
  cfg.br ^join(%sum : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @preserves_reconverged_branch_condition(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %left = test.addi %a, %a : i32
  cfg.br ^join(%left : i32)
^else:
  %right = test.addi %b, %b : i32
  cfg.br ^join(%right : i32)
^join(%value : i32):
  cfg.cond_br %cond, ^same, ^different : i1
^same:
  func.return %value : i32
^different:
  func.return %b : i32
}

// ====

func.def @folds_dominated_compare_from_true_edge(%i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %again = index.cmp slt, %i, %n : index
  cfg.cond_br %again, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%a : i32)
^dead:
  cfg.br ^join(%b : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_compare_from_true_edge(%i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %again = index.cmp slt, %i, %n : index
  cfg.br ^join(%a : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @folds_dominated_compare_from_false_edge(%i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  %again = index.cmp sge, %i, %n : index
  cfg.cond_br %again, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%b : i32)
^dead:
  cfg.br ^join(%a : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_compare_from_false_edge(%i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  cfg.br ^join(%a : i32)
^else:
  %again = index.cmp sge, %i, %n : index
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @folds_compare_after_equivalent_incoming_edges(%guard: i1, %i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %guard, ^left, ^right : i1
^left:
  cfg.cond_br %cond, ^join, ^exit : i1
^right:
  cfg.cond_br %cond, ^join, ^exit : i1
^join:
  %again = index.cmp slt, %i, %n : index
  cfg.cond_br %again, ^taken, ^dead : i1
^taken:
  cfg.br ^ret(%a : i32)
^dead:
  cfg.br ^ret(%b : i32)
^exit:
  cfg.br ^ret(%b : i32)
^ret(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_compare_after_equivalent_incoming_edges(%guard: i1, %i: index, %n: index, %a: i32, %b: i32) -> (i32) {
  %cond = index.cmp slt, %i, %n : index
  cfg.cond_br %guard, ^left, ^right : i1
^left:
  cfg.cond_br %cond, ^join, ^exit : i1
^right:
  cfg.cond_br %cond, ^join, ^exit : i1
^join:
  %again = index.cmp slt, %i, %n : index
  cfg.br ^ret(%a : i32)
^exit:
  cfg.br ^ret(%b : i32)
^ret(%result : i32):
  func.return %result : i32
}

// ====

func.def @folds_dominated_boolean_and_relations(%i: index, %n: index, %j: index, %z: index, %a: i32, %b: i32) -> (i32) {
  %i_in_range = index.cmp slt, %i, %n : index
  %j_nonzero = index.cmp ne, %j, %z : index
  %cond = scalar.andi %i_in_range, %j_nonzero : i1
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %i_again = index.cmp slt, %i, %n : index
  %j_again = index.cmp ne, %j, %z : index
  %both = scalar.andi %i_again, %j_again : i1
  cfg.cond_br %both, ^taken, ^dead : i1
^taken:
  cfg.br ^join(%a : i32)
^dead:
  cfg.br ^join(%b : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ----
func.def @folds_dominated_boolean_and_relations(%i: index, %n: index, %j: index, %z: index, %a: i32, %b: i32) -> (i32) {
  %i_in_range = index.cmp slt, %i, %n : index
  %j_nonzero = index.cmp ne, %j, %z : index
  %cond = scalar.andi %i_in_range, %j_nonzero : i1
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  %i_again = index.cmp slt, %i, %n : index
  %j_again = index.cmp ne, %j, %z : index
  %both = scalar.andi %i_again, %j_again : i1
  cfg.br ^join(%a : i32)
^else:
  cfg.br ^join(%b : i32)
^join(%result : i32):
  func.return %result : i32
}

// ====

func.def @removes_dependent_block_args(%layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^join(%layout, %view : encoding<layout>, view<4xf32, %layout>)
^join(%arg_layout : encoding<layout>, %arg_view : view<4xf32, %arg_layout>):
  test.use %arg_view : view<4xf32, %arg_layout>
  func.return
}

// ----
func.def @removes_dependent_block_args(%layout: encoding<layout>, %view: view<4xf32, %layout>) {
  test.use %view : view<4xf32, %layout>
  func.return
}

// ====

func.def @fuses_single_predecessor_block_args(%a: i32) -> (i32) {
  cfg.br ^middle(%a : i32)
^middle(%x : i32):
  cfg.br ^exit(%x : i32)
^exit(%result : i32):
  func.return %result : i32
}

// ----
func.def @fuses_single_predecessor_block_args(%a: i32) -> (i32) {
  func.return %a : i32
}

// ====

func.def @fuses_block_with_cond_terminator(%cond: i1, %a: i32, %b: i32) -> (i32) {
  cfg.br ^dispatch(%a : i32)
^dispatch(%x : i32):
  %sum = test.addi %x, %b : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %sum : i32
^else:
  func.return %b : i32
}

// ----
func.def @fuses_block_with_cond_terminator(%cond: i1, %a: i32, %b: i32) -> (i32) {
  %sum = test.addi %a, %b : i32
  cfg.cond_br %cond, ^then, ^else : i1
^then:
  func.return %sum : i32
^else:
  func.return %b : i32
}

// ====

func.def @preserves_loop_carried_args(%n: index, %seed: i32, %x: i32) -> (i32) {
  %zero = index.constant 0 : index
  %one = index.constant 1 : index
  cfg.br ^loop(%zero, %seed : index, i32)
^loop(%i : index, %acc : i32):
  %keep_going = index.cmp slt, %i, %n : index
  cfg.cond_br %keep_going, ^body, ^exit : i1
^body:
  %next = test.addi %acc, %x : i32
  %next_i = index.add %i, %one : index
  cfg.br ^loop(%next_i, %next : index, i32)
^exit:
  func.return %acc : i32
}

// ====

func.def @removes_self_forwarded_loop_arg(%cond: i1, %seed: i32) -> (i32) {
  cfg.br ^loop(%seed : i32)
^loop(%carry : i32):
  cfg.cond_br %cond, ^body, ^exit : i1
^body:
  cfg.br ^loop(%carry : i32)
^exit:
  func.return %carry : i32
}

// ----
func.def @removes_self_forwarded_loop_arg(%cond: i1, %seed: i32) -> (i32) {
  cfg.br ^loop
^loop:
  cfg.cond_br %cond, ^loop, ^exit : i1
^exit:
  func.return %seed : i32
}

// ====

func.def @removes_self_forwarded_dependent_loop_args(%cond: i1, %layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^loop(%layout, %view : encoding<layout>, view<4xf32, %layout>)
^loop(%arg_layout : encoding<layout>, %arg_view : view<4xf32, %arg_layout>):
  cfg.cond_br %cond, ^body, ^exit : i1
^body:
  cfg.br ^loop(%arg_layout, %arg_view : encoding<layout>, view<4xf32, %arg_layout>)
^exit:
  test.use %arg_view : view<4xf32, %arg_layout>
  func.return
}

// ----
func.def @removes_self_forwarded_dependent_loop_args(%cond: i1, %layout: encoding<layout>, %view: view<4xf32, %layout>) {
  cfg.br ^loop
^loop:
  cfg.cond_br %cond, ^loop, ^exit : i1
^exit:
  test.use %view : view<4xf32, %layout>
  func.return
}

// ====

func.def @preserves_effectful_forward_block(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  cfg.cond_br %cond, ^effect, ^exit : i1
^effect:
  view.store %value, %view[0] : f32, view<1xf32, %layout>
  cfg.br ^exit
^exit:
  func.return
}
