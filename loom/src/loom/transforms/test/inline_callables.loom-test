func.def public @entry_a(%arg: i32) -> (i32) {
  %result = func.call @double(%arg) : (i32) -> (i32)
  func.return %result : i32
}

func.def public @entry_b(%arg: i32) -> (i32) {
  %result = func.call @double(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ----
func.def public @entry_a(%arg: i32) -> (i32) {
  %doubled = test.addi %arg, %arg : i32
  func.return %doubled : i32
}

func.def public @entry_b(%arg: i32) -> (i32) {
  %doubled = test.addi %arg, %arg : i32
  func.return %doubled : i32
}

// ====

// RUN: pass inline-callables

func.template<test.addi> hot inline @double_template(%value: i32) -> (i32) {
  %doubled = test.addi %value, %value : i32
  func.return %doubled : i32
}

func.def public @entry(%arg: i32) -> (i32) {
  %result = func.apply @double_template(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ----
func.def public @entry(%arg: i32) -> (i32) {
  %doubled = test.addi %arg, %arg : i32
  func.return %doubled : i32
}

// ====

// RUN: pass inline-callables

func.def inline @unpack_block(%packed: i32) -> (i32) {
  %unpacked = test.addi %packed, %packed : i32
  func.return %unpacked : i32
}

func.def inline @apply_scale(%value: i32, %scale: i32) -> (i32) {
  %scaled = test.addi %value, %scale : i32
  func.return %scaled : i32
}

func.def inline @decode_block(%packed: i32, %scale: i32) -> (i32) {
  %unpacked = func.call @unpack_block(%packed) : (i32) -> (i32)
  %decoded = func.call @apply_scale(%unpacked, %scale) : (i32, i32) -> (i32)
  func.return %decoded : i32
}

func.def public @block_quant_entry(%packed: i32, %scale: i32) -> (i32) {
  %result = func.call @decode_block(%packed, %scale) : (i32, i32) -> (i32)
  func.return %result : i32
}

// ----
func.def public @block_quant_entry(%packed: i32, %scale: i32) -> (i32) {
  %unpacked = test.addi %packed, %packed : i32
  %scaled = test.addi %unpacked, %scale : i32
  func.return %scaled : i32
}

// ====

// RUN: pass inline-callables

func.decl inline @extern_a(%value: i32) -> (i32)
func.decl inline @extern_b(%value: i32) -> (i32)

func.def public @entry(%arg: i32) -> (i32, i32) {
  // ERROR@+1: LOWERING/044 {op_name="func.call", phase_name="inline-callables", callee_name="extern_a", reason="callee has no inlineable body"}
  %a = func.call @extern_a(%arg) : (i32) -> (i32)
  // ERROR@+1: LOWERING/044 {op_name="func.call", phase_name="inline-callables", callee_name="extern_b", reason="callee has no inlineable body"}
  %b = func.call @extern_b(%arg) : (i32) -> (i32)
  func.return %a, %b : i32, i32
}

// ====

// RUN: pass inline-callables

func.def inline @cycle_a(%value: i32) -> (i32) {
  // ERROR@+1: LOWERING/044 {op_name="func.call", phase_name="inline-callables", callee_name="cycle_b", reason="required inline cycle in the call graph"}
  %result = func.call @cycle_b(%value) : (i32) -> (i32)
  func.return %result : i32
}

func.def inline @cycle_b(%value: i32) -> (i32) {
  // ERROR@+1: LOWERING/044 {op_name="func.call", phase_name="inline-callables", callee_name="cycle_a", reason="required inline cycle in the call graph"}
  %result = func.call @cycle_a(%value) : (i32) -> (i32)
  func.return %result : i32
}
