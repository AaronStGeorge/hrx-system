// RUN: pass inline-callables

func.def @double(%value: i32) -> (i32) {
  %doubled = test.addi %value, %value : i32
  func.return %doubled : i32
}

func.def public @entry(%arg: i32) -> (i32) {
  %result = func.call hot inline @double(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ----
func.def public @entry(%arg: i32) -> (i32) {
  %doubled = test.addi %arg, %arg : i32
  func.return %doubled : i32
}

// ====

// RUN: pass inline-callables

func.def cold noinline @serializer(%value: i32) -> (i32) {
  %doubled = test.addi %value, %value : i32
  func.return %doubled : i32
}

func.def public @entry(%arg: i32) -> (i32) {
  %result = func.call @serializer(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ====

// RUN: pass inline-callables

func.def noinline @double(%value: i32) -> (i32) {
  %doubled = test.addi %value, %value : i32
  func.return %doubled : i32
}

func.def public @entry(%arg: i32) -> (i32) {
  // ERROR@+1: LOWERING/044 {op_name="func.call", phase_name="inline-callables", callee_name="double", reason="inline and noinline policies conflict on this edge"}
  %result = func.call inline @double(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ====

// RUN: pass inline-callables

func.def inline @inner(%value: i32) -> (i32) {
  %doubled = test.addi %value, %value : i32
  func.return %doubled : i32
}

func.def inline @outer(%value: i32) -> (i32) {
  %inner = func.call @inner(%value) : (i32) -> (i32)
  %sum = test.addi %inner, %value : i32
  func.return %sum : i32
}

func.def public @entry(%arg: i32) -> (i32) {
  %result = func.call @outer(%arg) : (i32) -> (i32)
  func.return %result : i32
}

// ----
func.def public @entry(%arg: i32) -> (i32) {
  %doubled = test.addi %arg, %arg : i32
  %sum = test.addi %doubled, %arg : i32
  func.return %sum : i32
}

// ====

