// RUN: pass cse

// A write nested inside a region op is a barrier for memory reads in the
// enclosing scope. The second load must not be replaced with the first load.
func.def @nested_write_blocks_outer_load_cse(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %before = view.load %view[0] : view<1xf32, %layout> -> f32
  scf.if %cond {
    view.store %value, %view[0] : f32, view<1xf32, %layout>
    scf.yield
  } else {
    scf.yield
  }
  %after = view.load %view[0] : view<1xf32, %layout> -> f32
  func.return %after : f32
}

// ====

// scf.while contributes both before/after region effects to the parent op's
// summary, so a nested write still blocks CSE of surrounding loads.
func.def @nested_while_write_blocks_outer_load_cse(%cond: i1, %buffer: buffer, %offset: offset, %value: f32) -> (f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%offset] : buffer -> view<1xf32, %layout>
  %before = view.load %view[0] : view<1xf32, %layout> -> f32
  %result = scf.while(%loop_value = %value : f32) -> (f32) {
    scf.condition %cond, %loop_value : i1, f32
  } do(%body: f32) {
    view.store %body, %view[0] : f32, view<1xf32, %layout>
    scf.yield %body : f32
  }
  %after = view.load %view[0] : view<1xf32, %layout> -> f32
  func.return %after : f32
}
