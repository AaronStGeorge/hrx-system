load("//loom/build_tools/bazel:build_defs.bzl", "loom_cc_library", "loom_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

loom_cc_library(
    name = "canonicalize",
    srcs = ["canonicalize.c"],
    hdrs = ["canonicalize.h"],
    visibility = [
        "//loom/src/loom/pass:__pkg__",
        "//loom/src/loom/transforms/symbol:__pkg__",
    ],
    deps = [
        "//loom/src/loom/analysis:condition_facts",
        "//loom/src/loom/analysis:symbolic_expr",
        "//loom/src/loom/ir",
        "//loom/src/loom/ir:facts",
        "//loom/src/loom/ops:op_defs",
        "//loom/src/loom/ops:special_values",
        "//loom/src/loom/ops:type_registry",
        "//loom/src/loom/ops/index",
        "//loom/src/loom/ops/scalar",
        "//loom/src/loom/ops/scf",
        "//loom/src/loom/ops/vector",
        "//loom/src/loom/pass:pipeline",
        "//loom/src/loom/pass:registry",
        "//loom/src/loom/pass:types",
        "//loom/src/loom/pass:value_facts",
        "//loom/src/loom/rewrite:greedy",
        "//loom/src/loom/rewrite:rewriter",
        "//loom/src/loom/rewrite:type_propagation",
        "//loom/src/loom/util:fact_table",
        "//loom/src/loom/util:walk",
        "//runtime/src/iree/base",
    ],
)

loom_cc_test(
