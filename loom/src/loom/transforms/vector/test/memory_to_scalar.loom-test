// RUN: pass vector-memory-to-scalar,canonicalize,cse

func.def @dense_vector_memory_stays_vector(%input: buffer, %output: buffer, %origin: index, %value: vector<4xf32>) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load %input_view[%origin] : view<32xf32, #dense> -> vector<4xf32>
  vector.store %value, %output_view[%origin] : vector<4xf32>, view<32xf32, #dense>
  func.return %loaded : vector<4xf32>
}

// ====

func.def @masked_dense_memory_scalarizes(%input: buffer, %output: buffer, %origin: index, %mask: vector<2xi1>, %old: vector<2xf32>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %base = index.constant 0 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<32xf32, #dense>
  %loaded = vector.load.mask %input_view[%origin], %mask, %old : view<32xf32, #dense>, vector<2xi1>, vector<2xf32>
  vector.store.mask %value, %output_view[%origin], %mask : vector<2xf32>, view<32xf32, #dense>, vector<2xi1>
  func.return %loaded : vector<2xf32>
}

// ----
func.def @masked_dense_memory_scalarizes(%input: buffer, %output: buffer, %origin: index, %mask: vector<2xi1>, %old: vector<2xf32>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %base = index.constant 0 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<32xf32, #dense>
  %17 = vector.extract %mask[0] : vector<2xi1> -> i1
  %18 = scf.if %17 -> (f32) {
    %19 = view.load %input_view[%origin] : view<32xf32, #dense> -> f32
    scf.yield %19 : f32
  } else {
    %20 = vector.extract %old[0] : vector<2xf32> -> f32
    scf.yield %20 : f32
  }
  %21 = vector.extract %mask[1] : vector<2xi1> -> i1
  %22 = scf.if %21 -> (f32) {
    %23 = index.constant 1 : index
    %24 = index.add %origin, %23 : index
    %25 = view.load %input_view[%24] : view<32xf32, #dense> -> f32
    scf.yield %25 : f32
  } else {
    %26 = vector.extract %old[1] : vector<2xf32> -> f32
    scf.yield %26 : f32
  }
  %loaded = vector.from_elements %18, %22 : vector<2xf32>
  scf.if %17 {
    %12 = vector.extract %value[0] : vector<2xf32> -> f32
    view.store %12, %output_view[%origin] : f32, view<32xf32, #dense>
  } else {
  }
  scf.if %21 {
    %14 = vector.extract %value[1] : vector<2xf32> -> f32
    %15 = index.constant 1 : index
    %16 = index.add %origin, %15 : index
    view.store %14, %output_view[%16] : f32, view<32xf32, #dense>
  } else {
  }
  func.return %loaded : vector<2xf32>
}

// ====

func.def @per_lane_memory_scalarizes(%input: buffer, %output: buffer, %origin: index, %offsets: vector<2xindex>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %base = index.constant 0 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<32xf32, #dense>
  %loaded = vector.gather %input_view[%origin][%offsets] : view<32xf32, #dense>, vector<2xindex> -> vector<2xf32>
  vector.scatter %value, %output_view[%origin][%offsets] : vector<2xf32>, view<32xf32, #dense>, vector<2xindex>
  func.return %loaded : vector<2xf32>
}

// ----
func.def @per_lane_memory_scalarizes(%input: buffer, %output: buffer, %origin: index, %offsets: vector<2xindex>, %value: vector<2xf32>) -> (vector<2xf32>) {
  %base = index.constant 0 : offset
  %input_view = buffer.view %input[%base] : buffer -> view<32xf32, #dense>
  %output_view = buffer.view %output[%base] : buffer -> view<32xf32, #dense>
  %16 = vector.extract %offsets[0] : vector<2xindex> -> index
  %17 = index.add %origin, %16 : index
  %18 = view.load %input_view[%17] : view<32xf32, #dense> -> f32
  %19 = vector.extract %offsets[1] : vector<2xindex> -> index
  %20 = index.add %origin, %19 : index
  %21 = view.load %input_view[%20] : view<32xf32, #dense> -> f32
  %loaded = vector.from_elements %18, %21 : vector<2xf32>
  %10 = vector.extract %value[0] : vector<2xf32> -> f32
  view.store %10, %output_view[%17] : f32, view<32xf32, #dense>
  %13 = vector.extract %value[1] : vector<2xf32> -> f32
  view.store %13, %output_view[%20] : f32, view<32xf32, #dense>
  func.return %loaded : vector<2xf32>
}

// ====

func.def @per_lane_gather_preserves_vector_dot(%latent: vector<8xbf16>, %weights: buffer, %origin: index) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %start = index.constant 0 : index
  %stride = index.constant 7 : index
  %zero_acc = vector.constant 0.0 : vector<4xf32>
  %weights_view = buffer.view %weights[%base] : buffer -> view<4096xbf16, #dense>
  %offsets = vector.iota %start step %stride : vector<8xindex>
  %weight = vector.gather %weights_view[%origin][%offsets] : view<4096xbf16, #dense>, vector<8xindex> -> vector<8xbf16>
  %dot = vector.dot2f %latent, %weight, %zero_acc : vector<8xbf16>, vector<8xbf16>, vector<4xf32>
  func.return %dot : vector<4xf32>
}

// ----
func.def @per_lane_gather_preserves_vector_dot(%latent: vector<8xbf16>, %weights: buffer, %origin: index) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %zero_acc = vector.constant 0.0 : vector<4xf32>
  %weights_view = buffer.view %weights[%base] : buffer -> view<4096xbf16, #dense>
  %15 = view.load %weights_view[%origin] : view<4096xbf16, #dense> -> bf16
  %19 = index.constant 7 : index
  %20 = index.add %origin, %19 : index
  %21 = view.load %weights_view[%20] : view<4096xbf16, #dense> -> bf16
  %25 = index.constant 14 : index
  %26 = index.add %origin, %25 : index
  %27 = view.load %weights_view[%26] : view<4096xbf16, #dense> -> bf16
  %31 = index.constant 21 : index
  %32 = index.add %origin, %31 : index
  %33 = view.load %weights_view[%32] : view<4096xbf16, #dense> -> bf16
  %37 = index.constant 28 : index
  %38 = index.add %origin, %37 : index
  %39 = view.load %weights_view[%38] : view<4096xbf16, #dense> -> bf16
  %43 = index.constant 35 : index
  %44 = index.add %origin, %43 : index
  %45 = view.load %weights_view[%44] : view<4096xbf16, #dense> -> bf16
  %49 = index.constant 42 : index
  %50 = index.add %origin, %49 : index
  %51 = view.load %weights_view[%50] : view<4096xbf16, #dense> -> bf16
  %55 = index.constant 49 : index
  %56 = index.add %origin, %55 : index
  %57 = view.load %weights_view[%56] : view<4096xbf16, #dense> -> bf16
  %weight = vector.from_elements %15, %21, %27, %33, %39, %45, %51, %57 : vector<8xbf16>
  %dot = vector.dot2f %latent, %weight, %zero_acc : vector<8xbf16>, vector<8xbf16>, vector<4xf32>
  func.return %dot : vector<4xf32>
}

// ====

func.def @masked_per_lane_gather_uses_passthrough_lanes(%values: buffer, %mask: vector<4xi1>, %old: vector<4xf32>) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %start = index.constant 0 : index
  %step = index.constant 2 : index
  %view = buffer.view %values[%base] : buffer -> view<64xf32, #dense>
  %offsets = vector.iota %start step %step : vector<4xindex>
  %gathered = vector.gather.mask %view[4][%offsets], %mask, %old : view<64xf32, #dense>, vector<4xindex>, vector<4xi1>, vector<4xf32>
  func.return %gathered : vector<4xf32>
}

// ----
func.def @masked_per_lane_gather_uses_passthrough_lanes(%values: buffer, %mask: vector<4xi1>, %old: vector<4xf32>) -> (vector<4xf32>) {
  %base = index.constant 0 : offset
  %view = buffer.view %values[%base] : buffer -> view<64xf32, #dense>
  %10 = vector.extract %mask[0] : vector<4xi1> -> i1
  %11 = scf.if %10 -> (f32) {
    %15 = view.load %view[4] : view<64xf32, #dense> -> f32
    scf.yield %15 : f32
  } else {
    %16 = vector.extract %old[0] : vector<4xf32> -> f32
    scf.yield %16 : f32
  }
  %17 = vector.extract %mask[1] : vector<4xi1> -> i1
  %18 = scf.if %17 -> (f32) {
    %22 = view.load %view[6] : view<64xf32, #dense> -> f32
    scf.yield %22 : f32
  } else {
    %23 = vector.extract %old[1] : vector<4xf32> -> f32
    scf.yield %23 : f32
  }
  %24 = vector.extract %mask[2] : vector<4xi1> -> i1
  %25 = scf.if %24 -> (f32) {
    %29 = view.load %view[8] : view<64xf32, #dense> -> f32
    scf.yield %29 : f32
  } else {
    %30 = vector.extract %old[2] : vector<4xf32> -> f32
    scf.yield %30 : f32
  }
  %31 = vector.extract %mask[3] : vector<4xi1> -> i1
  %32 = scf.if %31 -> (f32) {
    %36 = view.load %view[10] : view<64xf32, #dense> -> f32
    scf.yield %36 : f32
  } else {
    %37 = vector.extract %old[3] : vector<4xf32> -> f32
    scf.yield %37 : f32
  }
  %gathered = vector.from_elements %11, %18, %25, %32 : vector<4xf32>
  func.return %gathered : vector<4xf32>
}

// ====

func.def @atomic_memory_stays_vector(%buffer: buffer, %origin: index, %offsets: vector<2xindex>, %value: vector<2xi32>) -> (vector<2xi32>) {
  %base = index.constant 0 : offset
  %view = buffer.view %buffer[%base] : buffer -> view<32xi32, #dense>
  %old = vector.atomic.rmw<addi> %value, %view[%origin][%offsets] {ordering = relaxed, scope = workgroup} : vector<2xi32>, view<32xi32, #dense>, vector<2xindex>
  func.return %old : vector<2xi32>
}
