// RUN: pass vector-to-scalar,canonicalize

// A specialized zero vector extent erases the scalarized load/store loops. This
// is the optional-feature shape we want to be boring: valid dynamic IR enters
// lowering and disappears when facts say there are no lanes.
func.def @zero_extent_vector_memory_erases(%features: index, %buffer: buffer, %byte_offset: offset, %origin: index) {
  %disabled = index.assume %features [range(%features, 0, 0)] : index
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%byte_offset] : buffer -> view<[%disabled]xf32, %layout>
  %loaded = vector.load %view[%origin] : view<[%disabled]xf32, %layout> -> vector<[%disabled]xf32>
  vector.store %loaded, %view[%origin] : vector<[%disabled]xf32>, view<[%disabled]xf32, %layout>
  func.return
}

// ----
func.def @zero_extent_vector_memory_erases(%features: index, %buffer: buffer, %byte_offset: offset, %origin: index) {
  func.return
}

// ====

func.def @scalarizes_fragment_store_splat_source(%buffer: buffer, %base: offset, %row: index, %column: index, %m: index, %n: index, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %fragment = vector.splat %value : vector<[%m]x[%n]xf32>
  vector.fragment.store<result> %fragment, %view[%row, %column] shape [%m, %n] : vector<[%m]x[%n]xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}

// ----
func.def @scalarizes_fragment_store_splat_source(%buffer: buffer, %base: offset, %row: index, %column: index, %m: index, %n: index, %value: f32) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %10 = index.constant 0 : index
  %11 = index.constant 1 : index
  scf.for %12 = [%10 to %m step %11] {
    %13 = index.constant 0 : index
    %14 = index.constant 1 : index
    scf.for %15 = [%13 to %n step %14] {
      %16 = index.add %row, %12 : index
      %17 = index.add %column, %15 : index
      view.store %value, %view[%16, %17] : f32, view<[%m]x[%n]xf32, %layout>
    }
  }
  func.return
}

// ====

func.def @scalarizes_fragment_store_loaded_source(%source_buffer: buffer, %target_buffer: buffer, %source_base: offset, %target_base: offset, %row: index, %column: index, %m: index, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %source = buffer.view %source_buffer[%source_base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %target = buffer.view %target_buffer[%target_base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %loaded = vector.fragment.load<result> %source[%row, %column] shape [%m, %n] : view<[%m]x[%n]xf32, %layout> -> vector<[%m]x[%n]xf32>
  vector.fragment.store<result> %loaded, %target[%row, %column] shape [%m, %n] : vector<[%m]x[%n]xf32>, view<[%m]x[%n]xf32, %layout>
  func.return
}

// ----
func.def @scalarizes_fragment_store_loaded_source(%source_buffer: buffer, %target_buffer: buffer, %source_base: offset, %target_base: offset, %row: index, %column: index, %m: index, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %source = buffer.view %source_buffer[%source_base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %target = buffer.view %target_buffer[%target_base] : buffer -> view<[%m]x[%n]xf32, %layout>
  %12 = index.constant 0 : index
  %13 = index.constant 1 : index
  scf.for %14 = [%12 to %m step %13] {
    %15 = index.constant 0 : index
    %16 = index.constant 1 : index
    scf.for %17 = [%15 to %n step %16] {
      %18 = index.add %row, %14 : index
      %19 = index.add %column, %17 : index
      %20 = view.load %source[%18, %19] : view<[%m]x[%n]xf32, %layout> -> f32
      %21 = index.add %row, %14 : index
      %22 = index.add %column, %17 : index
      view.store %20, %target[%21, %22] : f32, view<[%m]x[%n]xf32, %layout>
    }
  }
  func.return
}

// ====

func.def @scalarizes_dense_f16_f32_mma(%lhs_data: vector<4xf16>, %rhs_data: vector<4xf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<4xf16>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<4xf16>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xf16>, vector<4xf16>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
func.def @scalarizes_dense_f16_f32_mma(%lhs_data: vector<4xf16>, %rhs_data: vector<4xf16>, %init_data: vector<4xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %11 = vector.extract %init_data[0] : vector<4xf32> -> f32
  %12 = vector.extract %lhs_data[0] : vector<4xf16> -> f16
  %13 = vector.extract %rhs_data[0] : vector<4xf16> -> f16
  %14 = scalar.extf %12 : f16 to f32
  %15 = scalar.extf %13 : f16 to f32
  %16 = scalar.fmaf %14, %15, %11 : f32
  %17 = vector.extract %lhs_data[1] : vector<4xf16> -> f16
  %18 = vector.extract %rhs_data[2] : vector<4xf16> -> f16
  %19 = scalar.extf %17 : f16 to f32
  %20 = scalar.extf %18 : f16 to f32
  %21 = scalar.fmaf %19, %20, %16 : f32
  %22 = vector.extract %init_data[1] : vector<4xf32> -> f32
  %23 = vector.extract %lhs_data[0] : vector<4xf16> -> f16
  %24 = vector.extract %rhs_data[1] : vector<4xf16> -> f16
  %25 = scalar.extf %23 : f16 to f32
  %26 = scalar.extf %24 : f16 to f32
  %27 = scalar.fmaf %25, %26, %22 : f32
  %28 = vector.extract %lhs_data[1] : vector<4xf16> -> f16
  %29 = vector.extract %rhs_data[3] : vector<4xf16> -> f16
  %30 = scalar.extf %28 : f16 to f32
  %31 = scalar.extf %29 : f16 to f32
  %32 = scalar.fmaf %30, %31, %27 : f32
  %33 = vector.extract %init_data[2] : vector<4xf32> -> f32
  %34 = vector.extract %lhs_data[2] : vector<4xf16> -> f16
  %35 = vector.extract %rhs_data[0] : vector<4xf16> -> f16
  %36 = scalar.extf %34 : f16 to f32
  %37 = scalar.extf %35 : f16 to f32
  %38 = scalar.fmaf %36, %37, %33 : f32
  %39 = vector.extract %lhs_data[3] : vector<4xf16> -> f16
  %40 = vector.extract %rhs_data[2] : vector<4xf16> -> f16
  %41 = scalar.extf %39 : f16 to f32
  %42 = scalar.extf %40 : f16 to f32
  %43 = scalar.fmaf %41, %42, %38 : f32
  %44 = vector.extract %init_data[3] : vector<4xf32> -> f32
  %45 = vector.extract %lhs_data[2] : vector<4xf16> -> f16
  %46 = vector.extract %rhs_data[1] : vector<4xf16> -> f16
  %47 = scalar.extf %45 : f16 to f32
  %48 = scalar.extf %46 : f16 to f32
  %49 = scalar.fmaf %47, %48, %44 : f32
  %50 = vector.extract %lhs_data[3] : vector<4xf16> -> f16
  %51 = vector.extract %rhs_data[3] : vector<4xf16> -> f16
  %52 = scalar.extf %50 : f16 to f32
  %53 = scalar.extf %51 : f16 to f32
  %54 = scalar.fmaf %52, %53, %49 : f32
  %55 = vector.from_elements %21, %32, %43, %54 : vector<4xf32>
  %result = vector.fragment<result> %55 shape [%m, %n] : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====

func.def @scalarizes_block_scaled_f8_mma(%lhs_data: vector<4xf8E4M3>, %rhs_data: vector<4xf8E4M3>, %init_data: vector<4xf32>, %lhs_scale: vector<2xf32>, %rhs_scale: vector<2xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %schema = encoding.define #matrix_operand<element_format=f8e4m3, payload_packing=dense_lanes, payload_elements=4, payload_registers=0, scale_format=f32, scale_group_elements=2, scale_operands=1, scale_topology=block_1d, affine=scale_only> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {scale = %lhs_scale : vector<2xf32>, schema = %schema : encoding<schema>} : vector<4xf8E4M3>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {scale = %rhs_scale : vector<2xf32>, schema = %schema : encoding<schema>} : vector<4xf8E4M3>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xf8E4M3>, vector<4xf8E4M3>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
func.def @scalarizes_block_scaled_f8_mma(%lhs_data: vector<4xf8E4M3>, %rhs_data: vector<4xf8E4M3>, %init_data: vector<4xf32>, %lhs_scale: vector<2xf32>, %rhs_scale: vector<2xf32>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %14 = vector.extract %init_data[0] : vector<4xf32> -> f32
  %15 = vector.extract %lhs_data[0] : vector<4xf8E4M3> -> f8E4M3
  %16 = scalar.extf %15 : f8E4M3 to f32
  %17 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %18 = scalar.mulf %16, %17 : f32
  %19 = vector.extract %rhs_data[0] : vector<4xf8E4M3> -> f8E4M3
  %20 = scalar.extf %19 : f8E4M3 to f32
  %21 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %22 = scalar.mulf %20, %21 : f32
  %23 = scalar.fmaf %18, %22, %14 : f32
  %24 = vector.extract %lhs_data[1] : vector<4xf8E4M3> -> f8E4M3
  %25 = scalar.extf %24 : f8E4M3 to f32
  %26 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %27 = scalar.mulf %25, %26 : f32
  %28 = vector.extract %rhs_data[2] : vector<4xf8E4M3> -> f8E4M3
  %29 = scalar.extf %28 : f8E4M3 to f32
  %30 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %31 = scalar.mulf %29, %30 : f32
  %32 = scalar.fmaf %27, %31, %23 : f32
  %33 = vector.extract %init_data[1] : vector<4xf32> -> f32
  %34 = vector.extract %lhs_data[0] : vector<4xf8E4M3> -> f8E4M3
  %35 = scalar.extf %34 : f8E4M3 to f32
  %36 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %37 = scalar.mulf %35, %36 : f32
  %38 = vector.extract %rhs_data[1] : vector<4xf8E4M3> -> f8E4M3
  %39 = scalar.extf %38 : f8E4M3 to f32
  %40 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %41 = scalar.mulf %39, %40 : f32
  %42 = scalar.fmaf %37, %41, %33 : f32
  %43 = vector.extract %lhs_data[1] : vector<4xf8E4M3> -> f8E4M3
  %44 = scalar.extf %43 : f8E4M3 to f32
  %45 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %46 = scalar.mulf %44, %45 : f32
  %47 = vector.extract %rhs_data[3] : vector<4xf8E4M3> -> f8E4M3
  %48 = scalar.extf %47 : f8E4M3 to f32
  %49 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %50 = scalar.mulf %48, %49 : f32
  %51 = scalar.fmaf %46, %50, %42 : f32
  %52 = vector.extract %init_data[2] : vector<4xf32> -> f32
  %53 = vector.extract %lhs_data[2] : vector<4xf8E4M3> -> f8E4M3
  %54 = scalar.extf %53 : f8E4M3 to f32
  %55 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %56 = scalar.mulf %54, %55 : f32
  %57 = vector.extract %rhs_data[0] : vector<4xf8E4M3> -> f8E4M3
  %58 = scalar.extf %57 : f8E4M3 to f32
  %59 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %60 = scalar.mulf %58, %59 : f32
  %61 = scalar.fmaf %56, %60, %52 : f32
  %62 = vector.extract %lhs_data[3] : vector<4xf8E4M3> -> f8E4M3
  %63 = scalar.extf %62 : f8E4M3 to f32
  %64 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %65 = scalar.mulf %63, %64 : f32
  %66 = vector.extract %rhs_data[2] : vector<4xf8E4M3> -> f8E4M3
  %67 = scalar.extf %66 : f8E4M3 to f32
  %68 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %69 = scalar.mulf %67, %68 : f32
  %70 = scalar.fmaf %65, %69, %61 : f32
  %71 = vector.extract %init_data[3] : vector<4xf32> -> f32
  %72 = vector.extract %lhs_data[2] : vector<4xf8E4M3> -> f8E4M3
  %73 = scalar.extf %72 : f8E4M3 to f32
  %74 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %75 = scalar.mulf %73, %74 : f32
  %76 = vector.extract %rhs_data[1] : vector<4xf8E4M3> -> f8E4M3
  %77 = scalar.extf %76 : f8E4M3 to f32
  %78 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %79 = scalar.mulf %77, %78 : f32
  %80 = scalar.fmaf %75, %79, %71 : f32
  %81 = vector.extract %lhs_data[3] : vector<4xf8E4M3> -> f8E4M3
  %82 = scalar.extf %81 : f8E4M3 to f32
  %83 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %84 = scalar.mulf %82, %83 : f32
  %85 = vector.extract %rhs_data[3] : vector<4xf8E4M3> -> f8E4M3
  %86 = scalar.extf %85 : f8E4M3 to f32
  %87 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %88 = scalar.mulf %86, %87 : f32
  %89 = scalar.fmaf %84, %88, %80 : f32
  %90 = vector.from_elements %32, %51, %70, %89 : vector<4xf32>
  %result = vector.fragment<result> %90 shape [%m, %n] : vector<4xf32>
  func.return %result : vector<4xf32>
}

// ====

func.def @scalarizes_quant_i8_zero_point_mma(%lhs_data: vector<4xi8>, %rhs_data: vector<4xi8>, %init_data: vector<4xf32>, %lhs_scale: vector<2xf32>, %rhs_scale: vector<2xf32>, %lhs_zero_point: vector<2xi8>, %rhs_zero_point: vector<2xi8>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %k = index.constant 2 : index
  %schema = encoding.define #matrix_operand<element_format=quant_i8, payload_packing=dense_lanes, payload_elements=4, payload_registers=0, scale_format=f32, scale_group_elements=2, scale_operands=1, scale_topology=block_1d, affine=scale_plus_zero_point> : encoding<schema>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] using {scale = %lhs_scale : vector<2xf32>, zero_point = %lhs_zero_point : vector<2xi8>, schema = %schema : encoding<schema>} : vector<4xi8>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] using {scale = %rhs_scale : vector<2xf32>, zero_point = %rhs_zero_point : vector<2xi8>, schema = %schema : encoding<schema>} : vector<4xi8>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<4xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<4xi8>, vector<4xi8>, vector<4xf32>
  func.return %result : vector<4xf32>
}

// ----
func.def @scalarizes_quant_i8_zero_point_mma(%lhs_data: vector<4xi8>, %rhs_data: vector<4xi8>, %init_data: vector<4xf32>, %lhs_scale: vector<2xf32>, %rhs_scale: vector<2xf32>, %lhs_zero_point: vector<2xi8>, %rhs_zero_point: vector<2xi8>) -> (vector<4xf32>) {
  %m = index.constant 2 : index
  %n = index.constant 2 : index
  %16 = vector.extract %init_data[0] : vector<4xf32> -> f32
  %17 = vector.extract %lhs_data[0] : vector<4xi8> -> i8
  %18 = scalar.sitofp %17 : i8 to f32
  %19 = vector.extract %lhs_zero_point[0] : vector<2xi8> -> i8
  %20 = scalar.sitofp %19 : i8 to f32
  %21 = scalar.subf %18, %20 : f32
  %22 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %23 = scalar.mulf %21, %22 : f32
  %24 = vector.extract %rhs_data[0] : vector<4xi8> -> i8
  %25 = scalar.sitofp %24 : i8 to f32
  %26 = vector.extract %rhs_zero_point[0] : vector<2xi8> -> i8
  %27 = scalar.sitofp %26 : i8 to f32
  %28 = scalar.subf %25, %27 : f32
  %29 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %30 = scalar.mulf %28, %29 : f32
  %31 = scalar.fmaf %23, %30, %16 : f32
  %32 = vector.extract %lhs_data[1] : vector<4xi8> -> i8
  %33 = scalar.sitofp %32 : i8 to f32
  %34 = vector.extract %lhs_zero_point[0] : vector<2xi8> -> i8
  %35 = scalar.sitofp %34 : i8 to f32
  %36 = scalar.subf %33, %35 : f32
  %37 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %38 = scalar.mulf %36, %37 : f32
  %39 = vector.extract %rhs_data[2] : vector<4xi8> -> i8
  %40 = scalar.sitofp %39 : i8 to f32
  %41 = vector.extract %rhs_zero_point[1] : vector<2xi8> -> i8
  %42 = scalar.sitofp %41 : i8 to f32
  %43 = scalar.subf %40, %42 : f32
  %44 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %45 = scalar.mulf %43, %44 : f32
  %46 = scalar.fmaf %38, %45, %31 : f32
  %47 = vector.extract %init_data[1] : vector<4xf32> -> f32
  %48 = vector.extract %lhs_data[0] : vector<4xi8> -> i8
  %49 = scalar.sitofp %48 : i8 to f32
  %50 = vector.extract %lhs_zero_point[0] : vector<2xi8> -> i8
  %51 = scalar.sitofp %50 : i8 to f32
  %52 = scalar.subf %49, %51 : f32
  %53 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %54 = scalar.mulf %52, %53 : f32
  %55 = vector.extract %rhs_data[1] : vector<4xi8> -> i8
  %56 = scalar.sitofp %55 : i8 to f32
  %57 = vector.extract %rhs_zero_point[0] : vector<2xi8> -> i8
  %58 = scalar.sitofp %57 : i8 to f32
  %59 = scalar.subf %56, %58 : f32
  %60 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %61 = scalar.mulf %59, %60 : f32
  %62 = scalar.fmaf %54, %61, %47 : f32
  %63 = vector.extract %lhs_data[1] : vector<4xi8> -> i8
  %64 = scalar.sitofp %63 : i8 to f32
  %65 = vector.extract %lhs_zero_point[0] : vector<2xi8> -> i8
  %66 = scalar.sitofp %65 : i8 to f32
  %67 = scalar.subf %64, %66 : f32
  %68 = vector.extract %lhs_scale[0] : vector<2xf32> -> f32
  %69 = scalar.mulf %67, %68 : f32
  %70 = vector.extract %rhs_data[3] : vector<4xi8> -> i8
  %71 = scalar.sitofp %70 : i8 to f32
  %72 = vector.extract %rhs_zero_point[1] : vector<2xi8> -> i8
  %73 = scalar.sitofp %72 : i8 to f32
  %74 = scalar.subf %71, %73 : f32
  %75 = vector.extract %rhs_scale[1] : vector<2xf32> -> f32
  %76 = scalar.mulf %74, %75 : f32
  %77 = scalar.fmaf %69, %76, %62 : f32
  %78 = vector.extract %init_data[2] : vector<4xf32> -> f32
  %79 = vector.extract %lhs_data[2] : vector<4xi8> -> i8
  %80 = scalar.sitofp %79 : i8 to f32
  %81 = vector.extract %lhs_zero_point[1] : vector<2xi8> -> i8
  %82 = scalar.sitofp %81 : i8 to f32
  %83 = scalar.subf %80, %82 : f32
  %84 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %85 = scalar.mulf %83, %84 : f32
  %86 = vector.extract %rhs_data[0] : vector<4xi8> -> i8
  %87 = scalar.sitofp %86 : i8 to f32
  %88 = vector.extract %rhs_zero_point[0] : vector<2xi8> -> i8
  %89 = scalar.sitofp %88 : i8 to f32
  %90 = scalar.subf %87, %89 : f32
  %91 = vector.extract %rhs_scale[0] : vector<2xf32> -> f32
  %92 = scalar.mulf %90, %91 : f32
  %93 = scalar.fmaf %85, %92, %78 : f32
  %94 = vector.extract %lhs_data[3] : vector<4xi8> -> i8
  %95 = scalar.sitofp %94 : i8 to f32
  %96 = vector.extract %lhs_zero_point[1] : vector<2xi8> -> i8
  %97 = scalar.sitofp %96 : i8 to f32
  %98 = scalar.subf %95, %97 : f32
  %99 = vector.extract %lhs_scale[1] : vector<2xf32> -> f32
  %100 = scalar.mulf %98, %99 : f32
  %101 = vector.extract %rhs_data[2] : vector<4xi8> -> i8
  %102 = scalar.sitofp %101 : i8 to f32
  %103 = vector.extract %rhs_zero_point[1] : vector<2xi8> -> i8
  %104 = scalar.sitofp %103 : i8 to f32
  %105 = scalar.subf %102, %104 : f32
