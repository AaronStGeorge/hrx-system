func.def @scalarizes_dynamic_dense_rank2_f32_mma(%m: index, %n: index, %k: index, %lhs_data: vector<[%m]x[%k]xf32>, %rhs_data: vector<[%k]x[%n]xf32>, %init_data: vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
  %11 = index.constant 0 : index
  %12 = index.constant 1 : index
  %15 = scf.for %13 = [%11 to %m step %12](%14 = %init_data : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
    %16 = index.constant 0 : index
    %17 = index.constant 1 : index
    %20 = scf.for %18 = [%16 to %n step %17](%19 = %14 : vector<[%m]x[%n]xf32>) -> (vector<[%m]x[%n]xf32>) {
      %21 = vector.extract %init_data[%13, %18] : vector<[%m]x[%n]xf32> -> f32
      %22 = index.constant 0 : index
      %23 = index.constant 1 : index
      %26 = scf.for %24 = [%22 to %k step %23](%25 = %21 : f32) -> (f32) {
        %27 = vector.extract %lhs_data[%13, %24] : vector<[%m]x[%k]xf32> -> f32
        %28 = vector.extract %rhs_data[%24, %18] : vector<[%k]x[%n]xf32> -> f32
        %29 = scalar.fmaf %27, %28, %25 : f32
        scf.yield %29 : f32
      }
      %30 = vector.insert %26 into %19[%13, %18] : f32, vector<[%m]x[%n]xf32>
      scf.yield %30 : vector<[%m]x[%n]xf32>
    }
    scf.yield %20 : vector<[%m]x[%n]xf32>
  }
  %result = vector.fragment<result> %15 shape [%m, %n] : vector<[%m]x[%n]xf32>
  func.return %result : vector<[%m]x[%n]xf32>
}

