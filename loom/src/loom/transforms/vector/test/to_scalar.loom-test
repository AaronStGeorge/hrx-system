func.def @scalarizes_dynamic_flat_product_f32_mma(%m: index, %n: index, %k: index, %lhs0: f32, %rhs0: f32, %init0: f32) {
  %mk = index.mul %m, %k : index
  %kn = index.mul %k, %n : index
  %mn = index.mul %m, %n : index
  %lhs_data = vector.splat %lhs0 : vector<[%mk]xf32>
  %rhs_data = vector.splat %rhs0 : vector<[%kn]xf32>
  %init_data = vector.splat %init0 : vector<[%mn]xf32>
  %lhs = vector.fragment<lhs> %lhs_data shape [%m, %k] : vector<[%mk]xf32>
  %rhs = vector.fragment<rhs> %rhs_data shape [%k, %n] : vector<[%kn]xf32>
  %init = vector.fragment<init> %init_data shape [%m, %n] : vector<[%mn]xf32>
  %result = vector.mma %lhs, %rhs, %init : vector<[%mk]xf32>, vector<[%kn]xf32>, vector<[%mn]xf32>
  test.use %result : vector<[%mn]xf32>
  func.return
}

// ----
func.def @scalarizes_dynamic_flat_product_f32_mma(%m: index, %n: index, %k: index, %lhs0: f32, %rhs0: f32, %init0: f32) {
  %mn = index.mul %m, %n : index
  %42 = vector.constant 0.0 : vector<[%mn]xf32>
  %43 = index.constant 0 : index
  %44 = index.constant 1 : index
  %init_data = scf.for %45 = [%43 to %mn step %44](%46 = %42 : vector<[%mn]xf32>) -> (vector<[%mn]xf32>) {
    %48 = vector.insert %init0 into %46[%45] : f32, vector<[%mn]xf32>
    scf.yield %48 : vector<[%mn]xf32>
  }
  %16 = index.constant 0 : index
  %17 = index.constant 1 : index
  %20 = scf.for %18 = [%16 to %m step %17](%19 = %init_data : vector<[%mn]xf32>) -> (vector<[%mn]xf32>) {
    %21 = index.constant 0 : index
    %22 = index.constant 1 : index
    %25 = scf.for %23 = [%21 to %n step %22](%24 = %19 : vector<[%mn]xf32>) -> (vector<[%mn]xf32>) {
      %28 = index.constant 0 : index
      %29 = index.constant 1 : index
      %32 = scf.for %30 = [%28 to %k step %29](%31 = %init0 : f32) -> (f32) {
        %37 = scalar.fmaf %lhs0, %rhs0, %31 : f32
        scf.yield %37 : f32
      }
      %38 = index.mul %18, %n : index
      %39 = index.add %38, %23 : index
      %40 = vector.insert %32 into %24[%39] : f32, vector<[%mn]xf32>
      scf.yield %40 : vector<[%mn]xf32>
    }
    scf.yield %25 : vector<[%mn]xf32>
  }
  %result = vector.fragment<result> %20 shape [%m, %n] : vector<[%mn]xf32>
  test.use %result : vector<[%mn]xf32>
  func.return
}

