kernel.def @dynamic_unit_axis_proven_by_workgroup_id_launch_config(%rows: index) {
  %c1 = index.constant 1 : index
  %c128 = index.constant 128 : index
  kernel.launch.config workgroups(%rows, %c1, %c1) workgroup_size(%c128, %c1, %c1) : index
} launch(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %row = kernel.workgroup.id<x> : index
  %row_count = kernel.workgroup.count<x> : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%row_count]x2xf32, %layout>
  %loaded = vector.load %view[%row, 0] : view<[%row_count]x2xf32, %layout> -> vector<2xf32>
  kernel.return
}

// ====

kernel.def @dynamic_unit_axis_proven_by_workitem_id_launch_config(%columns: index) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%columns, %c1, %c1) : index
} launch(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %column = kernel.workitem.id<x> : index
  %column_count = kernel.workgroup.size<x> : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%column_count]xf32, %layout>
  %loaded = vector.load %view[%column] : view<[%column_count]xf32, %layout> -> vector<1xf32>
  kernel.return
}

// ====

kernel.def @dynamic_scaled_vector_origin_proven_by_workitem_id_launch_config(%columns: index) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%columns, %c1, %c1) : index
} launch(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %four = index.constant 4 : index
  %column = kernel.workitem.id<x> : index
  %column_count = kernel.workgroup.size<x> : index
  %element_count = index.mul %column_count, %four : index
  %origin = index.mul %column, %four : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%element_count]xf32, %layout>
  %loaded = vector.load %view[%origin] : view<[%element_count]xf32, %layout> -> vector<4xf32>
  kernel.return
}

// ====

kernel.def @dynamic_scaled_vector_origin_rejects_offset_workitem_id(%columns: index) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%c1, %c1, %c1) workgroup_size(%columns, %c1, %c1) : index
} launch(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %one = index.constant 1 : index
  %four = index.constant 4 : index
  %column = kernel.workitem.id<x> : index
  %column_count = kernel.workgroup.size<x> : index
  %element_count = index.mul %column_count, %four : index
  %next_column = index.add %column, %one : index
  %origin = index.mul %next_column, %four : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%element_count]xf32, %layout>
  // ERROR@+1: SUBRANGE/010 "full-vector footprint upper bound" "origin + vector_extent <= view_bound"
  %loaded = vector.load %view[%origin] : view<[%element_count]xf32, %layout> -> vector<4xf32>
  kernel.return
}

// ====

kernel.def @dynamic_unit_axis_rejects_offset_workgroup_id(%rows: index) {
  %c1 = index.constant 1 : index
  kernel.launch.config workgroups(%rows, %c1, %c1) workgroup_size(%c1, %c1, %c1) : index
} launch(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %one = index.constant 1 : index
  %row = kernel.workgroup.id<x> : index
  %next_row = index.add %row, %one : index
  %row_count = kernel.workgroup.count<x> : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%row_count]x2xf32, %layout>
  // ERROR@+1: SUBRANGE/011 "scalar-axis footprint upper bound" "origin + 1 <= view_bound"
  %loaded = vector.load %view[%next_row, 0] : view<[%row_count]x2xf32, %layout> -> vector<2xf32>
  kernel.return
}

// ====

func.def @mask_range_tail_uses_upper_bound(%buffer: buffer, %base: offset, %n: index, %iv: index, %old: vector<16xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %c1 = index.constant 1 : index
  %iv2 = index.assume %iv [range(%iv, 0, 4096)] : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]xf32, %layout>
  %mask = vector.mask.range [%iv2 to %n step %c1] : index -> vector<16xi1>
  %loaded = vector.load.mask %view[%iv2], %mask, %old : view<[%n]xf32, %layout>, vector<16xi1>, vector<16xf32>
  func.return
}

// ====

func.def @masked_store_tail_uses_upper_bound(%buffer: buffer, %base: offset, %n: index, %iv: index, %value: vector<16xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %c1 = index.constant 1 : index
  %iv2 = index.assume %iv [range(%iv, 0, 4096)] : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]xf32, %layout>
  %mask = vector.mask.range [%iv2 to %n step %c1] : index -> vector<16xi1>
  vector.store.mask %value, %view[%iv2], %mask : vector<16xf32>, view<[%n]xf32, %layout>, vector<16xi1>
  func.return
}

// ====

func.def @expand_compress_tail_uses_upper_bound(%buffer: buffer, %base: offset, %n: index, %iv: index, %old: vector<16xf32>, %value: vector<16xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %c1 = index.constant 1 : index
  %iv2 = index.assume %iv [range(%iv, 0, 4096)] : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]xf32, %layout>
  %mask = vector.mask.range [%iv2 to %n step %c1] : index -> vector<16xi1>
  %loaded = vector.load.expand %view[%iv2], %mask, %old : view<[%n]xf32, %layout>, vector<16xi1>, vector<16xf32>
  vector.store.compress %value, %view[%iv2], %mask : vector<16xf32>, view<[%n]xf32, %layout>, vector<16xi1>
  func.return
}

// ====

func.def @iota_gather_in_bounds(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %view = buffer.view %buffer[%base] : buffer -> view<4xf32, %layout>
  %offsets = vector.iota %c0 step %c1 : vector<4xindex>
  %loaded = vector.gather %view[%c0][%offsets] : view<4xf32, %layout>, vector<4xindex> -> vector<4xf32>
  func.return
}

