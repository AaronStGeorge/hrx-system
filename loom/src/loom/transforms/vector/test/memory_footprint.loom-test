// RUN: pass vector-memory-footprint

func.def @static_dense_load_in_bounds(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<8xf32, %layout>
  %loaded = vector.load %view[4] : view<8xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @static_dense_store_in_bounds(%buffer: buffer, %base: offset, %value: vector<4xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<8xf32, %layout>
  vector.store %value, %view[4] : vector<4xf32>, view<8xf32, %layout>
  func.return
}

// ====

func.def @static_dense_load_out_of_bounds(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<8xf32, %layout>
  // ERROR@+1: SUBRANGE/010 "vector.load" "full-vector footprint upper bound" "origin + vector_extent <= view_bound"
  %loaded = vector.load %view[5] : view<8xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @dynamic_full_vector_at_zero_is_proven(%buffer: buffer, %base: offset, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %c0 = index.constant 0 : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]xf32, %layout>
  %loaded = vector.load %view[%c0] : view<[%n]xf32, %layout> -> vector<[%n]xf32>
  func.return
}

// ====

func.def @dynamic_unproven_tail(%buffer: buffer, %base: offset, %n: index, %iv: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %iv2 = index.assume %iv [range(%iv, 0, 4096)] : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]xf32, %layout>
  // ERROR@+1: SUBRANGE/010 "full-vector footprint upper bound" "origin + vector_extent <= view_bound"
  %loaded = vector.load %view[%iv2] : view<[%n]xf32, %layout> -> vector<16xf32>
  func.return
}

// ====

func.def @counted_loop_iv_proves_pair_load_extent(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %start = index.constant 0 : index
  %limit = index.constant 3584 : index
  %step = index.constant 2 : index
  %view = buffer.view %buffer[%base] : buffer -> view<3584xbf16, %layout>
  scf.for %origin = [%start to %limit step %step] {
    %loaded = vector.load %view[%origin] : view<3584xbf16, %layout> -> vector<2xbf16>
  }
  func.return
}

// ====

func.def @dynamic_unit_axis_proven_by_assume_relation(%buffer: buffer, %base: offset, %row: index, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]x4xf32, %layout>
  %row_in_bounds, %n_assumed = index.assume %row, %n [ge(%row, 0), lt(%row, %n)] : index, index
  %loaded = vector.load %view[%row_in_bounds, 0] : view<[%n]x4xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @dynamic_scaled_vector_origin_proven_by_assume_relation(%buffer: buffer, %base: offset, %i: index, %n: index) {
  %layout = encoding.layout.dense : encoding<layout>
  %four = index.constant 4 : index
  %i_in_bounds, %n_assumed = index.assume %i, %n [ge(%i, 0), lt(%i, %n)] : index, index
  %element_count = index.mul %n_assumed, %four : index
  %origin = index.mul %i_in_bounds, %four : index
  %view = buffer.view %buffer[%base] : buffer -> view<[%element_count]xf32, %layout>
  %loaded = vector.load %view[%origin] : view<[%element_count]xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @dynamic_unit_axis_proven_by_assume_relation_through_cast(%buffer: buffer, %base: offset, %row: index, %n: i32) {
  %layout = encoding.layout.dense : encoding<layout>
  %n_idx = index.cast %n : i32 to index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n]x4xf32, %layout>
  %row_in_bounds, %n_idx_assumed = index.assume %row, %n_idx [ge(%row, 0), lt(%row, %n_idx)] : index, index
  %loaded = vector.load %view[%row_in_bounds, 0] : view<[%n]x4xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @dynamic_unit_axis_proven_by_scalar_assume_before_index_cast(%buffer: buffer, %base: offset, %row: i32, %n: i32) {
  %layout = encoding.layout.dense : encoding<layout>
  %n_idx = index.cast %n : i32 to index
  %view = buffer.view %buffer[%base] : buffer -> view<[%n_idx]x4xf32, %layout>
  %row_bounded, %n_bounded = scalar.assume %row, %n [lt(%row, %n)] : i32, i32
  %row_nonnegative = scalar.assume %row_bounded [ge(%row_bounded, 0)] : i32
  %row_idx = index.cast %row_nonnegative : i32 to index
  %loaded = vector.load %view[%row_idx, 0] : view<[%n_idx]x4xf32, %layout> -> vector<4xf32>
  func.return
}

