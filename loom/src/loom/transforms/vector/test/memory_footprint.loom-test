func.def @iota_gather_rank_two_linear_out_of_bounds(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %c0 = index.constant 0 : index
  %c1 = index.constant 1 : index
  %view = buffer.view %buffer[%base] : buffer -> view<2x4xf32, %layout>
  %offsets = vector.iota %c0 step %c1 : vector<2xindex>
  // ERROR@+1: SUBRANGE/016 "vector.gather" "linear footprint upper bound" "linearized_origin + max(offsets) + 1 <= view_storage_span"
  %loaded = vector.gather %view[1, 3][%offsets] : view<2x4xf32, %layout>, vector<2xindex> -> vector<2xf32>
  func.return
}

