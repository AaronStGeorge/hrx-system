// RUN: pass vector-memory-footprint

func.def @static_dense_load_in_bounds(%buffer: buffer, %base: offset) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<8xf32, %layout>
  %loaded = vector.load %view[4] : view<8xf32, %layout> -> vector<4xf32>
  func.return
}

// ====

func.def @static_dense_store_in_bounds(%buffer: buffer, %base: offset, %value: vector<4xf32>) {
  %layout = encoding.layout.dense : encoding<layout>
  %view = buffer.view %buffer[%base] : buffer -> view<8xf32, %layout>
  vector.store %value, %view[4] : vector<4xf32>, view<8xf32, %layout>
  func.return
}

