// RUN: pass canonicalize,vector-memory-footprint
func.def @guarded_loaded_i32_precast_index_proves_unit_axis(%ids: buffer, %payload: buffer, %base: offset, %row_count: i32) {
  %layout = encoding.layout.dense : encoding<layout>
  %id_view = buffer.view %ids[%base] : buffer -> view<1xi32, %layout>
  %id_vec = vector.load %id_view[0] : view<1xi32, %layout> -> vector<1xi32>
  %row = vector.extract %id_vec[0] : vector<1xi32> -> i32
  %row_idx = index.cast %row : i32 to index
  %row_count_idx = index.cast %row_count : i32 to index
  %zero = scalar.constant 0 : i32
  %nonnegative = scalar.cmpi sge, %row, %zero : i32
  %below = scalar.cmpi slt, %row, %row_count : i32
  %guard = scalar.andi %nonnegative, %below : i1
  scf.if %guard {
    %payload_view = buffer.view %payload[%base] : buffer -> view<[%row_count_idx]x4xf32, %layout>
    %loaded = vector.load %payload_view[%row_idx, 0] : view<[%row_count_idx]x4xf32, %layout> -> vector<4xf32>
    test.use %loaded : vector<4xf32>
    scf.yield
  } else {
    scf.yield
  }
  func.return
}

