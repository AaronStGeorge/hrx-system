# Public Bazel facade for source dependencies. Source declarations, locks, and
# CMake adapters live under build_tools/third_party/. See
# build_tools/third_party/README.md for dependency ownership and update policy.

package(default_visibility = ["//visibility:private"])

package_group(
    name = "build_tool_users",
    packages = ["//build_tools/..."],
)

package_group(
    name = "runtime_users",
    packages = ["//runtime/..."],
)

package_group(
    name = "libhrx_users",
    packages = ["//libhrx/..."],
)

package_group(
    name = "loom_users",
    packages = ["//loom/..."],
)

package_group(
    name = "benchmark_users",
    packages = [
        "//build_tools/...",
        "//libhrx/...",
        "//loom/...",
        "//runtime/...",
    ],
)

package_group(
    name = "test_framework_users",
    packages = [
        "//build_tools/...",
        "//libhrx/...",
        "//loom/...",
        "//runtime/...",
    ],
)

alias(
    name = "google_benchmark",
    actual = "@com_google_benchmark//:benchmark",
    visibility = [":benchmark_users"],
)

alias(
    name = "google_benchmark_main",
    actual = "@com_google_benchmark//:benchmark_main",
    visibility = [":benchmark_users"],
)

alias(
    name = "google_test",
    actual = "@com_google_googletest//:gtest",
    visibility = [":test_framework_users"],
)

alias(
    name = "google_test_main",
    actual = "@com_google_googletest//:gtest_main",
    visibility = [":test_framework_users"],
)

alias(
    name = "catch2",
    actual = "@catch2//:catch2",
    visibility = [":libhrx_users"],
)

alias(
    name = "flatcc",
    actual = "@flatcc//:flatcc",
    visibility = [":runtime_users"],
)

alias(
    name = "flatcc_compiler",
    actual = "@flatcc//:compiler",
    visibility = [":runtime_users"],
)

alias(
    name = "flatcc_parsing",
    actual = "@flatcc//:parsing",
    visibility = [":runtime_users"],
)

alias(
    name = "flatcc_runtime",
    actual = "@flatcc//:runtime",
    visibility = [":runtime_users"],
)

alias(
    name = "libbacktrace",
    actual = "//build_tools/third_party/libbacktrace",
    visibility = [":runtime_users"],
)

filegroup(
    name = "empty_aqlprofile_sdk_headers",
)

filegroup(
    name = "empty_hip_api_headers",
)

filegroup(
    name = "empty_hsa_runtime_headers",
)

filegroup(
    name = "empty_rccl_headers",
)

filegroup(
    name = "empty_vulkan_headers",
)

alias(
    name = "aqlprofile_sdk_headers",
    actual = select({
        "//runtime/config/hal:driver_amdgpu": "@hsa_runtime_headers//:aqlprofile_sdk_headers",
        "//conditions:default": ":empty_aqlprofile_sdk_headers",
    }),
    tags = ["manual"],
    visibility = [":runtime_users"],
)

alias(
    name = "hsa_runtime_headers",
    actual = select({
        "//runtime/config/hal:driver_amdgpu": "@hsa_runtime_headers//:hsa_runtime_headers",
        "//conditions:default": ":empty_hsa_runtime_headers",
    }),
    tags = ["manual"],
    visibility = [":runtime_users"],
)

alias(
    name = "hip_api_headers",
    actual = select({
        "//runtime/config/hal:driver_hip": "@hip_api_headers//:headers",
        "//conditions:default": ":empty_hip_api_headers",
    }),
    tags = ["manual"],
    visibility = [":runtime_users"],
)

alias(
    name = "rccl_headers",
    actual = select({
        "//runtime/src/iree/hal/drivers/hip:rccl_enabled": "@rccl//:headers",
        "//conditions:default": ":empty_rccl_headers",
    }),
    tags = ["manual"],
    visibility = [":runtime_users"],
)

alias(
    name = "vulkan_headers",
    actual = select({
        "//runtime/config/hal:driver_vulkan": "@vulkan_headers//:headers",
        "//conditions:default": ":empty_vulkan_headers",
    }),
    tags = ["manual"],
    visibility = [":runtime_users"],
)
