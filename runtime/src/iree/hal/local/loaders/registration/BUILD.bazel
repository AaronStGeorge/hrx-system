load("//build_tools/bazel:select.bzl", "iree_select")
load("//runtime/build_tools/bazel:cc.bzl", "iree_runtime_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

iree_runtime_cc_library(
    name = "registration",
    srcs = ["init.c"],
    hdrs = ["init.h"],
    deps = [
        "//runtime/src/iree/base",
        "//runtime/src/iree/hal",
        "//runtime/src/iree/hal/local",
    ] + iree_select({
        "//runtime/config/hal:executable_loader_embedded_elf": [
            "//runtime/src/iree/hal/local/loaders:embedded_elf_loader",
        ],
        "//conditions:default": [],
    }) + iree_select({
        "//runtime/config/hal:executable_loader_system_library": [
            "//runtime/src/iree/hal/local/loaders:system_library_loader",
        ],
        "//conditions:default": [],
    }) + iree_select({
        "//runtime/config/hal:executable_loader_vmvx_module": [
            "//runtime/src/iree/hal/local/loaders:vmvx_module_loader",
        ],
        "//conditions:default": [],
    }),
)
