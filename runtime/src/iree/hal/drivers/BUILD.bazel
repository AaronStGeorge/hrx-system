load("//build_tools/bazel:select.bzl", "iree_select")
load("//runtime/build_tools/bazel:cc.bzl", "iree_runtime_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

iree_runtime_cc_library(
    name = "drivers",
    srcs = ["init.c"],
    hdrs = ["init.h"],
    deps = (
        [
            "//runtime/src/iree/base",
            "//runtime/src/iree/hal",
        ] + iree_select({
            "//runtime/config/hal:driver_amdgpu": [
                "//runtime/src/iree/hal/drivers/amdgpu/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_cuda": [
                "//runtime/src/iree/hal/drivers/cuda/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_hip": [
                "//runtime/src/iree/hal/drivers/hip/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_local_sync": [
                "//runtime/src/iree/hal/drivers/local_sync/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_local_task": [
                "//runtime/src/iree/hal/drivers/local_task/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_null": [
                "//runtime/src/iree/hal/drivers/null/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_vulkan": [
                "//runtime/src/iree/hal/drivers/vulkan/registration",
            ],
            "//conditions:default": [],
        }) +
        iree_select({
            "//runtime/config/hal:driver_webgpu": [
                "//runtime/src/iree/hal/drivers/webgpu/registration",
            ],
            "//conditions:default": [],
        })
    ),
)
