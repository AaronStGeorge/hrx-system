load("//build_tools/amdgpu:binary.bzl", "iree_amdgpu_library_variants")
load("//runtime/build_tools/bazel:cc.bzl", "iree_runtime_cc_library")
load("//runtime/build_tools/bazel:cc_test.bzl", "iree_runtime_cc_test")
load(":device_bitcode_sources.bzl", "IREE_HAL_AMDGPU_DEVICE_BITCODE_SRCS")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

DEVICE_HDRS = [
    "blit.h",
    "dispatch.h",
    "kernel_tables.h",
    "kernels.h",
    "support/asan.h",
    "support/common.h",
    "support/feedback.h",
    "support/kernel.h",
    "support/queue.h",
    "support/signal.h",
    "timestamp.h",
]

filegroup(
    name = "bitcode_srcs",
    srcs = IREE_HAL_AMDGPU_DEVICE_BITCODE_SRCS,
)

exports_files(["device_bitcode_sources.bzl"])

filegroup(
    name = "bitcode_hdrs",
    srcs = DEVICE_HDRS,
)

# Replacement `asanrtl` bitcode archive for AMDGPU external-runtime ASAN.
iree_amdgpu_library_variants(
    name = "asanrtl",
    srcs = ["asanrtl.c"],
    internal_hdrs = [
        "//runtime/src/iree/hal/drivers/amdgpu/abi:amdgpu_abi_bitcode_hdrs",
        ":bitcode_hdrs",
    ],
    tags = ["manual"],
    target = "amdgcn-amd-amdhsa",
    target_selectors_flag = "//runtime/src/iree/hal/drivers/amdgpu:targets",
)

#===------------------------------------------------------------------------===#
# Exported Headers
#===------------------------------------------------------------------------===#

iree_runtime_cc_library(
    name = "headers",
    hdrs = DEVICE_HDRS,
    deps = [
        "//runtime/src/iree/base",
        "//runtime/src/iree/base/internal",
        "//runtime/src/iree/base/threading:thread",
        "//runtime/src/iree/hal/drivers/amdgpu/abi",
    ],
)

iree_runtime_cc_library(
    name = "blit",
    srcs = [
        "blit.c",
    ],
    deps = [
        ":headers",
    ],
)

iree_runtime_cc_library(
    name = "dispatch",
    srcs = [
        "dispatch.c",
    ],
    deps = [
        ":headers",
    ],
)

iree_runtime_cc_library(
    name = "timestamp",
    srcs = [
        "timestamp.c",
    ],
    deps = [
        ":dispatch",
        ":headers",
    ],
)

iree_runtime_cc_test(
    name = "blit_test",
    srcs = ["blit_test.cc"],
    deps = [
        ":blit",
        ":headers",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

iree_runtime_cc_test(
    name = "dispatch_test",
    srcs = ["dispatch_test.cc"],
    deps = [
        ":dispatch",
        ":headers",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

iree_runtime_cc_test(
    name = "timestamp_test",
    srcs = ["timestamp_test.cc"],
    deps = [
        ":headers",
        ":timestamp",
        "//runtime/src/iree/hal/drivers/amdgpu/abi",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)
