# Runtime-only CTS test binaries for the AMDGPU HAL driver.

load("//build_tools/amdgpu:cts.bzl", "iree_amdgpu_hal_cts_testdata")
load("//build_tools/bazel:cmake.bzl", "iree_cmake_extra_content")
load("//build_tools/bazel:iree_hal_cts_test_suite.bzl", "iree_hal_cts_test_suite")
load("//runtime/build_tools/bazel:cc.bzl", "iree_runtime_cc_library")
load("//runtime/build_tools/bazel:cc_test.bzl", "iree_runtime_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],
)

iree_cmake_extra_content(
    content = """
iree_amdgpu_expand_target_selectors(
  _IREE_HAL_AMDGPU_EXACT_TARGETS
  "${IREE_AMDGPU_TARGET_EXPANSION_EXACT}"
  ${IREE_HAL_AMDGPU_TARGETS}
)
if(NOT _IREE_HAL_AMDGPU_EXACT_TARGETS)
  return()
endif()
""",
)

iree_runtime_cc_library(
    name = "backends",
    testonly = True,
    srcs = ["backends.cc"],
    deps = [
        "//runtime/src/iree/hal",
        "//runtime/src/iree/hal/cts/util:registry",
        "//runtime/src/iree/hal/drivers/amdgpu/registration",
    ],
    alwayslink = True,
)

iree_amdgpu_hal_cts_testdata(
    name = "testdata_amdgpu",
    srcs = [
        "testdata/command_buffer_dispatch_constants_bindings_test.c",
        "testdata/command_buffer_dispatch_constants_test.c",
        "testdata/command_buffer_dispatch_indirect_parameters_test.c",
        "testdata/command_buffer_dispatch_multi_entrypoint_test.c",
        "testdata/command_buffer_dispatch_multi_workgroup_test.c",
        "testdata/command_buffer_dispatch_test.c",
        "testdata/executable_cache_test.c",
        "testdata/executable_test.c",
    ],
    format_name = "amdgpu",
    format_string = '"amdgcn-amd-amdhsa--{AMDGPU_TARGET}"',
    identifier = "iree_cts_testdata_amdgpu",
    internal_hdrs = [
        "//runtime/src/iree/hal/drivers/amdgpu/abi:amdgpu_abi_bitcode_hdrs",
        "//runtime/src/iree/hal/drivers/amdgpu/device:bitcode_hdrs",
    ],
    tags = ["manual"],
    target_selectors_flag = "//runtime/src/iree/hal/drivers/amdgpu:targets",
)

iree_amdgpu_hal_cts_testdata(
    name = "asan_testdata_amdgpu",
    srcs = [
        "testdata/asan_allocation_test.c",
        "testdata/manual_asan_noop_test.c",
        "testdata/manual_asan_test.c",
    ],
    format_name = "amdgpu_asan",
    format_string = '"amdgcn-amd-amdhsa--{AMDGPU_TARGET}"',
    identifier = "iree_cts_asan_testdata_amdgpu",
    internal_hdrs = [
        "//runtime/src/iree/hal/drivers/amdgpu/abi:amdgpu_abi_bitcode_hdrs",
        "//runtime/src/iree/hal/drivers/amdgpu/device:bitcode_hdrs",
    ],
    internalize = False,
    tags = ["manual"],
    target_selectors_flag = "//runtime/src/iree/hal/drivers/amdgpu:targets",
    deps = [
        "//runtime/src/iree/hal/drivers/amdgpu/device:asanrtl_{AMDGPU_CODE_OBJECT_TARGET_FRAGMENT}",
    ],
)

iree_runtime_cc_library(
    name = "asan_executable_test",
    testonly = True,
    srcs = ["asan_executable_test.cc"],
    deps = [
        "//runtime/src/iree/hal/cts/sanitizer:asan_test_util",
        "//runtime/src/iree/hal/drivers/amdgpu:headers",
        "//runtime/src/iree/hal/drivers/amdgpu/abi",
    ],
    alwayslink = True,
)

iree_runtime_cc_test(
    name = "asan_executable_tests",
    srcs = ["//runtime/src/iree/hal/cts/util:test_main.cc"],
    args = ["--amdgpu_asan=true"],
    deps = [
        ":asan_executable_test",
        ":backends",
        ":testdata_amdgpu",
        "//runtime/src/iree/base/tooling:flags",
        "//runtime/src/iree/hal/cts/util:registry",
        "//runtime/src/iree/hal/cts/util:test_base",
        "//runtime/src/iree/testing:gtest",
    ],
)

iree_runtime_cc_library(
    name = "manual_asan_executable_test",
    testonly = True,
    srcs = ["manual_asan_executable_test.cc"],
    deps = [
        "//runtime/src/iree/hal",
        "//runtime/src/iree/hal/cts/sanitizer:asan_test_util",
        "//runtime/src/iree/hal/cts/util:registry",
        "//runtime/src/iree/hal/cts/util:test_base",
        "//runtime/src/iree/hal/drivers/amdgpu:buffer",
    ],
    alwayslink = True,
)

iree_runtime_cc_test(
    name = "asan_allocation_tests",
    srcs = ["//runtime/src/iree/hal/cts/util:test_main.cc"],
    args = ["--amdgpu_asan=true"],
    deps = [
        ":asan_testdata_amdgpu",
        ":backends",
        "//runtime/src/iree/base/tooling:flags",
        "//runtime/src/iree/hal/cts/sanitizer:asan_allocation_test",
        "//runtime/src/iree/hal/cts/util:registry",
        "//runtime/src/iree/hal/cts/util:test_base",
        "//runtime/src/iree/testing:gtest",
    ],
)

iree_runtime_cc_test(
    name = "manual_asan_executable_tests",
    srcs = ["//runtime/src/iree/hal/cts/util:test_main.cc"],
    args = ["--amdgpu_asan=true"],
    deps = [
        ":asan_testdata_amdgpu",
        ":backends",
        ":manual_asan_executable_test",
        "//runtime/src/iree/base/tooling:flags",
        "//runtime/src/iree/hal/cts/util:registry",
        "//runtime/src/iree/hal/cts/util:test_base",
        "//runtime/src/iree/testing:gtest",
    ],
)

iree_hal_cts_test_suite(
    backends_lib = ":backends",
    testdata_libs = [":testdata_amdgpu"],
)
