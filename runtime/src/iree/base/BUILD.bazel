#===------------------------------------------------------------------------===#
# Core headers (platform detection, compiler compat, etc)
#===------------------------------------------------------------------------===#

# NOTE: this cannot contain any sources as it is used by header-only targets.
iree_runtime_cc_library(
    name = "core_headers",
    hdrs = [
        "alignment.h",
        "attributes.h",
        "config.h",
        "target_platform.h",
        "time.h",
        "tracing.h",
    ],
)

