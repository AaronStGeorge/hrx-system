# Common types and utilities used in the IREE codebase.

load("//build_tools/bazel:select.bzl", "iree_select")
load("//runtime/build_tools/bazel:cc.bzl", "iree_runtime_cc_library")
load("//runtime/build_tools/bazel:cc_benchmark.bzl", "iree_runtime_cc_benchmark")
load("//runtime/build_tools/bazel:cc_fuzz.bzl", "iree_runtime_cc_fuzz")
load("//runtime/build_tools/bazel:cc_test.bzl", "iree_runtime_cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],  # Apache 2.0
)

#===------------------------------------------------------------------------===#
# Public API
#===------------------------------------------------------------------------===#

iree_runtime_cc_library(
    name = "base",
    srcs = [
        "allocator.c",
        "bitfield.c",
        "bitmap.c",
        "printf.c",
        "status.c",
        "status_stack_trace.c",
        "string_builder.c",
        "string_view.c",
        "time.c",
        "wait_source.c",
    ] + iree_select({
        "//runtime/config/base:allocator_system_custom": [],
        "//conditions:default": ["allocator_libc.c"],
    }),
    hdrs = [
        "allocator.h",
        "api.h",
        "assert.h",
        "bitfield.h",
        "bitmap.h",
        "printf.h",
        "status.h",
        "status_cc.h",
        "status_payload.h",
        "string_builder.h",
        "string_view.h",
        "time.h",
        "wait_source.h",
    ],
    defines = iree_select({
        "//runtime/config/base:allocator_system_custom": [],
        "//conditions:default": [
            "IREE_ALLOCATOR_SYSTEM_CTL=iree_allocator_libc_ctl",
        ],
    }),
    deps = [
        ":core_headers",
        "//build_tools/third_party/libbacktrace",
        "//runtime/src/iree/base/internal",
        "//runtime/src/iree/base/internal:time",
        "//runtime/src/iree/base/tracing:provider",
    ],
)

iree_runtime_cc_benchmark(
    name = "allocator_benchmark",
    srcs = ["allocator_benchmark.cc"],
    deps = [
        ":base",
        "//runtime/src/iree/testing:benchmark",
        "//runtime/src/iree/testing:benchmark_main",
    ],
)

iree_runtime_cc_test(
    name = "allocator_test",
    srcs = ["allocator_test.cc"],
    deps = [
        ":base",
        "//runtime/src/iree/testing:gtest",
        "//runtime/src/iree/testing:gtest_main",
    ],
)

iree_runtime_cc_test(
