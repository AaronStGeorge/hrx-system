{
  "version": 1,
  "cases": [
    {
      "name": "prints replay capture guide",
      "run": {
        "tool": "iree-run-module",
        "args": ["--agents_md"]
      },
      "stdout": {
        "contains": ["# iree-run-module Replay Capture", "device_replay_output"]
      },
      "stderr": {
        "empty": true
      }
    },
    {
      "name": "runs bytecode module assembled from vmasm",
      "steps": [
        {
          "name": "write-source",
          "write": {
            "path": "{tmp}/module.vmasm",
            "text": "vm.module @iree_run_module_test version 0\nvm.export @add_i32\nvm.func @add_i32(%i0: i32, %i1: i32) -> (i32) {\n^bb0:\n  %i2 = vm.add.i32 %i0, %i1\n  vm.return %i2\n}\n"
          }
        },
        {
          "name": "assemble",
          "run": {
            "tool": "iree-as-module",
            "args": ["--output={tmp}/module.vmfb", "{tmp}/module.vmasm"]
          },
          "stdout": {
            "empty": true
          },
          "stderr": {
            "empty": true
          },
          "files": [
            {
              "path": "{tmp}/module.vmfb",
              "non_empty": true
            }
          ]
        },
        {
          "name": "run",
          "run": {
            "tool": "iree-run-module",
            "args": [
              "--module={tmp}/module.vmfb",
              "--function=add_i32",
              "--input=2",
              "--input=40"
            ]
          },
          "stdout": {
            "contains": ["EXEC @add_i32", "result[0]: i32=42"]
          },
          "stderr": {
            "empty": true
          }
        }
      ]
    }
  ]
}
