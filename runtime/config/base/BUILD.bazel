load("@bazel_skylib//rules:common_settings.bzl", "string_flag")

package(default_visibility = ["//visibility:public"])

string_flag(
    name = "allocator_system",
    build_setting_default = "libc",
    values = [
        "custom",
        "libc",
    ],
)

config_setting(
    name = "allocator_system_custom",
    flag_values = {
        ":allocator_system": "custom",
    },
)
