CLANG_TIDY_LLVM_ERROR = "Set --repo_env=IREE_CLANG_TIDY_LLVM=auto or --repo_env=IREE_CLANG_TIDY_LLVM_CONFIG=/path/to/llvm-config to enable clang-tidy plugin builds."
